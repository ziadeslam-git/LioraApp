        </div>
        <div class="border-t border-outline-variant dark:border-[#4a4541] flex divide-x divide-outline-variant dark:divide-[#4a4541]">
            <button class="flex-1 py-3 text-on-surface dark:text-[#e8e1db] font-bold hover:bg-surface-container-highest dark:hover:bg-[#3d3733] transition-colors flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-[18px]">edit</span>
                Edit
            </button>
            <button class="flex-1 py-3 text-error dark:text-[#ffdad6] font-bold hover:bg-error-container dark:hover:bg-[#93000a] hover:text-on-error-container dark:hover:text-[#ffdad6] transition-colors flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-[18px]">delete</span>
                Delete
            </button>
        </div>
    </div>
    <!-- Bundle Card 3 -->
    <div class="bg-surface dark:bg-[#2c2825] rounded-bundle ambient-shadow-1 hover:ambient-shadow-2 transition-ease-out overflow-hidden flex flex-col group relative border border-transparent dark:border-[#4a4541] hover:border-primary-container dark:hover:border-[#7f5446]">
        <div class="absolute top-4 right-4 z-10">
            <div class="relative inline-block w-10 mr-2 align-middle select-none transition duration-200 ease-in">
                <input checked="" class="toggle-checkbox absolute block w-5 h-5 rounded-full bg-white border-4 appearance-none cursor-pointer z-10 right-0 border-primary dark:border-[#c49080]" id="toggle3" name="toggle3" type="checkbox" />
                <label class="toggle-label block overflow-hidden h-5 rounded-full bg-primary dark:bg-[#c49080] cursor-pointer" for="toggle3"></label>
            </div>
        </div>
        <div class="h-48 relative overflow-hidden bg-surface-container dark:bg-[#3d3733]">
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent z-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <img alt="Spa Day Collection" class="w-full h-full object-cover group-hover:scale-105 transition-ease-out" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCzi1M1MYvdfnStnbO_HnBxxuW439NdJdFMF-SxbG5GzdSC8CbqOMUTySr2kmhBPkoCglgE7biGJ6JTbNuAZJdTPbRs6nRknp_DV_S88Zxr1WUR9p0X9SMbnG53SDupgpKoEvz5pzbTRY9pcTZQe2tp_QD7S6VprcDbKcJX2r-MuFOYIpAmV8Vrzx4DmSfUh9mqiQtpr8fKH799XBCJt9KD6c-yS59OaSUA5HayLQcY3X64fptLMNRO4x1fYcK8TS_CzIzr-wFnUGhZ" />
            <div class="absolute bottom-4 left-4 z-10">
                <span class="bg-primary/20 text-primary dark:text-[#f2baa8] font-label-caps text-label-caps px-3 py-1 rounded-full border border-primary/30 uppercase tracking-wider backdrop-blur-md">Seasonal</span>
            </div>
        </div>
        <div class="p-6 flex-1 flex flex-col">
            <h3 class="font-headline-md text-headline-md text-on-surface dark:text-[#fff8f3] mb-1">At-Home Spa Retreat</h3>
            <p class="font-body-md text-on-surface-variant dark:text-[#a299a7] mb-6 line-clamp-2">Transform any evening with our plush waffle robe, bath salts, and hydrating body oil.</p>
            <div class="mt-auto space-y-3">
                <div class="flex items-center justify-between text-sm">
                    <span class="text-on-surface-variant dark:text-[#a299a7]">Base Price</span>
                    <span class="font-bold text-on-surface dark:text-[#fff8f3]">$310.00</span>
                </div>
                <div class="bg-surface-container-low dark:bg-[#1e1b18] p-3 rounded-lg border border-outline-variant dark:border-[#4a4541]">
                    <p class="font-label-caps text-[10px] text-primary dark:text-[#c49080] mb-1 uppercase">Discount Tiers</p>
                    <div class="space-y-1">
                        <div class="flex justify-between text-sm">
                            <span class="text-on-surface dark:text-[#e8e1db]">3 Items</span>
                            <span class="font-bold text-tertiary dark:text-[#d1c0de]">15% OFF</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-on-surface dark:text-[#e8e1db]">4+ Items</span>
                            <span class="font-bold text-tertiary dark:text-[#d1c0de]">25% OFF</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="border-t border-outline-variant dark:border-[#4a4541] flex divide-x divide-outline-variant dark:divide-[#4a4541]">
            <button class="flex-1 py-3 text-on-surface dark:text-[#e8e1db] font-bold hover:bg-surface-container-highest dark:hover:bg-[#3d3733] transition-colors flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-[18px]">edit</span>
                Edit
            </button>
            <button class="flex-1 py-3 text-error dark:text-[#ffdad6] font-bold hover:bg-error-container dark:hover:bg-[#93000a] hover:text-on-error-container dark:hover:text-[#ffdad6] transition-colors flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-[18px]">delete</span>
                Delete
            </button>
        </div>
    </div>
    <!-- Add New Bundle Placeholder -->
    <div class="bg-surface-container-low dark:bg-[#1e1b18] rounded-bundle border-2 border-dashed border-outline-variant dark:border-[#4a4541] flex flex-col items-center justify-center p-8 text-center hover:bg-surface-container dark:hover:bg-[#2c2825] hover:border-primary dark:hover:border-[#c49080] transition-ease-out cursor-pointer group min-h-[450px]">
        <div class="w-16 h-16 rounded-full bg-surface-container dark:bg-[#3d3733] flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
            <span class="material-symbols-outlined text-[32px] text-primary dark:text-[#c49080]">add_box</span>
        </div>
        <h3 class="font-headline-md text-on-surface dark:text-[#fff8f3] mb-2">Create New Bundle</h3>
        <p class="text-on-surface-variant dark:text-[#a299a7] text-sm max-w-[200px]">Combine products to create custom gift experiences with tiered pricing.</p>
    </div>
</div>

@section Scripts {
<script>
    // Simple toggle functionality demonstration
    document.querySelectorAll('.toggle-checkbox').forEach(toggle => {
    toggle.addEventListener('change', function() {
    const card = this.closest('.rounded-bundle');
    const img = card.querySelector('img');
    const badge = card.querySelector('.backdrop-blur-sm');

    if(!this.checked) {
    if(img) {
    img.classList.add('grayscale', 'opacity-60');
    }
    if(!badge && card.querySelector('.absolute.inset-0.bg-black\\/20')) {
    // Already draft style
    } else if (!badge) {
    const imgContainer = card.querySelector('.relative.overflow-hidden');
    const overlay = document.createElement('div');
    overlay.className = 'absolute inset-0 bg-black/20 z-0 draft-overlay';
    const badgeContainer = document.createElement('div');
    badgeContainer.className = 'absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 z-10 draft-badge';
    badgeContainer.innerHTML = '<span class="bg-surface/90 dark:bg-[#1e1b18]/90 text-on-surface dark:text-[#fff8f3] font-label-caps text-label-caps px-4 py-2 rounded-full uppercase tracking-wider backdrop-blur-sm">Draft</span>';
    imgContainer.appendChild(overlay);
    imgContainer.appendChild(badgeContainer);

    const title = card.querySelector('h3');
    const desc = card.querySelector('p');
    title.classList.add('text-on-surface-variant', 'dark:text-[#a299a7]');
    title.classList.remove('text-on-surface', 'dark:text-[#fff8f3]');

    card.querySelector('.mt-auto').classList.add('opacity-60');
    }
    } else {
    if(img) {
    img.classList.remove('grayscale', 'opacity-60');
    }
    const draftOverlay = card.querySelector('.draft-overlay');
    const draftBadge = card.querySelector('.draft-badge');
    if(draftOverlay) draftOverlay.remove();
    if(draftBadge) draftBadge.remove();

    const title = card.querySelector('h3');
    title.classList.remove('text-on-surface-variant', 'dark:text-[#a299a7]');
    title.classList.add('text-on-surface', 'dark:text-[#fff8f3]');

    card.querySelector('.mt-auto').classList.remove('opacity-60');
    }
    });
    });
</script>
}