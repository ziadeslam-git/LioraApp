@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Liora - Gift Bundles";
}

@section Styles {
<style>
    .ambient-shadow-1 {
    box-shadow: 0px 10px 30px rgba(26, 16, 37, 0.05);
    }

    .dark .ambient-shadow-1 {
    box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.4);
    }

    .ambient-shadow-2 {
    box-shadow: 0px 20px 50px rgba(26, 16, 37, 0.08);
    }

    .dark .ambient-shadow-2 {
    box-shadow: 0px 20px 50px rgba(0, 0, 0, 0.6);
    }

    .transition-ease-out {
    transition-property: all;
    transition-timing-function: cubic-bezier(0, 0, 0.2, 1);
    transition-duration: 250ms;
    }

    /* Toggle switch styles */
    .toggle-checkbox:checked {
    right: 0;
    border-color: theme('colors.primary');
    }

    .toggle-checkbox:checked + .toggle-label {
    background-color: theme('colors.primary');
    }

    .dark .toggle-checkbox:checked + .toggle-label {
    background-color: theme('colors.primary');
    }

    /* Custom scrollbar for webkit */
    ::-webkit-scrollbar {
    width: 8px;
    }

    ::-webkit-scrollbar-track {
    background: transparent;
    }

    ::-webkit-scrollbar-thumb {
    background-color: theme('colors.surface-variant');
    border-radius: theme('borderRadius.full');
    }

    .dark ::-webkit-scrollbar-thumb {
    background-color: #33302c;
    }
</style>
}

<!-- Page Header -->
<div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-stack-lg">
    <div>
        <p class="font-label-caps text-label-caps text-primary dark:text-[#c49080] mb-2 uppercase tracking-widest">Catalog Management</p>
        <h2 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface dark:text-[#fff8f3]">Gift Bundles</h2>
    </div>
    <button class="bg-primary-container dark:bg-[#c49080] text-on-primary-container dark:text-[#311309] px-6 py-3 rounded-lg font-bold hover:opacity-90 active:scale-98 transition-ease-out flex items-center justify-center gap-2 self-start md:self-auto">
        <span class="material-symbols-outlined text-[20px]">add</span>
        Create Bundle
    </button>
</div>
<!-- Bundle Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-gutter pb-section-gap">
    <!-- Bundle Card 1 -->
    <div class="bg-surface dark:bg-[#2c2825] rounded-bundle ambient-shadow-1 hover:ambient-shadow-2 transition-ease-out overflow-hidden flex flex-col group relative border border-transparent dark:border-[#4a4541] hover:border-primary-container dark:hover:border-[#7f5446]">
        <div class="absolute top-4 right-4 z-10">
            <div class="relative inline-block w-10 mr-2 align-middle select-none transition duration-200 ease-in">
