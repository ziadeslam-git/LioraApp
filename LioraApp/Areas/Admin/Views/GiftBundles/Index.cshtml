                <label class="toggle-label block overflow-hidden h-5 rounded-full bg-primary dark:bg-[#c49080] cursor-pointer" for="toggle1"></label>
            </div>
        </div>
        <div class="h-48 relative overflow-hidden bg-surface-container dark:bg-[#3d3733]">
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent z-0"></div>
            <img alt="Silk Robe and Candle Set" class="w-full h-full object-cover group-hover:scale-105 transition-ease-out" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCgVPhEaJ8x3unflF41Y988pnRQ1wtIdPlMPSxdVOB5XMbWZKiw1Ut32X0OvnKbnWR8nKTq1DZCTD0G7N3ExH-mnH_SyrkiszPn6VO7QJ2YVDlvIk4LfuXyQ-YUeqpgkquZZ9lcRIgdQnHorwtYCdMNa0Pt-ahWWvejW9LBJIurpIpqlAl6_7AOSOzZ0Cx115i2oyY-1K2n9LPqq1STIXPgkP89lxOJR1d6p-7yEb6xx_iMJRyyCcjdYb6bev_dPafukne43pGhclUp" />
            <div class="absolute bottom-4 left-4 z-10">
                <span class="bg-surface dark:bg-[#1e1b18] text-on-surface dark:text-[#fff8f3] font-label-caps text-label-caps px-3 py-1 rounded-full uppercase tracking-wider">Best Seller</span>
            </div>
        </div>
        <div class="p-6 flex-1 flex flex-col">
            <h3 class="font-headline-md text-headline-md text-on-surface dark:text-[#fff8f3] mb-1">The Evening Unwind Set</h3>
            <p class="font-body-md text-on-surface-variant dark:text-[#a299a7] mb-6 line-clamp-2">A curated collection featuring our signature silk robe, sleep mask, and calming lavender candle.</p>
            <div class="mt-auto space-y-3">
                <div class="flex items-center justify-between text-sm">
                    <span class="text-on-surface-variant dark:text-[#a299a7]">Base Price</span>
                    <span class="font-bold text-on-surface dark:text-[#fff8f3]">$240.00</span>
                </div>
                <div class="bg-surface-container-low dark:bg-[#1e1b18] p-3 rounded-lg border border-outline-variant dark:border-[#4a4541]">
