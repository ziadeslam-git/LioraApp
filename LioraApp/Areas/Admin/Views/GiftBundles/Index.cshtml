            <div class="absolute inset-0 bg-black/20 z-0"></div>
            <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 z-10">
                <span class="bg-surface/90 dark:bg-[#1e1b18]/90 text-on-surface dark:text-[#fff8f3] font-label-caps text-label-caps px-4 py-2 rounded-full uppercase tracking-wider backdrop-blur-sm">Draft</span>
            </div>
        </div>
        <div class="p-6 flex-1 flex flex-col">
            <h3 class="font-headline-md text-headline-md text-on-surface dark:text-[#a299a7] mb-1">Lace Elegance Duo</h3>
            <p class="font-body-md text-on-surface-variant dark:text-[#6c5f79] mb-6 line-clamp-2">Matching camisole and shorts crafted from premium Egyptian cotton and French lace.</p>
            <div class="mt-auto space-y-3 opacity-60">
                <div class="flex items-center justify-between text-sm">
