@model PaymentVM
@{
    ViewData["Title"] = "Payment Details";
}

@section Styles {
    }

<div class="max-w-3xl mx-auto space-y-8 font-inter">
    <!-- Breadcrumb & Header -->
    <div class="flex items-center justify-between">
        <div class="flex items-center gap-4">
            <a asp-action="Index" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-slate-200 transition-colors text-slate-500 bg-slate-100 shadow-sm">
                <span class="material-symbols-outlined text-[20px]">arrow_back</span>
            </a>
            <div>
                <h2 class="text-2xl font-bold text-slate-800 tracking-tight">Payment #@Model.Id</h2>
                <p class="text-xs text-slate-500 font-medium">Read-only transaction record</p>
            </div>
        </div>
        <div>
            @if (Model.Status == "Paid")
            {
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-extrabold bg-emerald-100 text-emerald-700 border border-emerald-200 uppercase tracking-widest shadow-sm">
                    <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span> @Model.Status
                </span>
            }
            else if (Model.Status == "Pending")
            {
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-extrabold bg-amber-100 text-amber-700 border border-amber-200 uppercase tracking-widest shadow-sm">
                    <span class="w-1.5 h-1.5 bg-amber-500 rounded-full"></span> @Model.Status
                </span>
            }
            else
            {
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-extrabold bg-red-100 text-error border border-red-200 uppercase tracking-widest shadow-sm">
                    <span class="w-1.5 h-1.5 bg-red-500 rounded-full"></span> @Model.Status
                </span>
            }
        </div>
    </div>

    <!-- Quick Overview Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-surface-container-lowest p-6 rounded-2xl shadow-sm border border-slate-100 flex items-center gap-5 relative overflow-hidden">
            <div class="w-16 h-16 rounded-full bg-indigo-50 flex items-center justify-center border border-indigo-100/50 shadow-inner z-10">
                <span class="material-symbols-outlined text-3xl text-primary font-light">receipt_long</span>
            </div>
            <div class="z-10">
                <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-1">Associated Order</p>
                <p class="text-2xl font-black text-slate-800">#@Model.OrderId</p>
            </div>
            <!-- Decorative circle -->
            <div class="absolute -right-6 -bottom-6 w-32 h-32 bg-primary/5 rounded-full blur-2xl"></div>
        </div>
        
        <div class="bg-surface-container-lowest p-6 rounded-2xl shadow-sm border border-slate-100 flex items-center gap-5 relative overflow-hidden">
            <div class="w-16 h-16 rounded-full bg-emerald-50 flex items-center justify-center border border-emerald-100/50 shadow-inner z-10">
                <span class="material-symbols-outlined text-3xl text-emerald-600 font-light">attach_money</span>
            </div>
            <div class="z-10">
                <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-1">Total Amount</p>
                <p class="text-2xl font-black text-slate-800 font-mono">$@Model.Amount.ToString("N2")</p>
            </div>
            <!-- Decorative circle -->
            <div class="absolute -right-6 -bottom-6 w-32 h-32 bg-emerald-500/5 rounded-full blur-2xl"></div>
        </div>
    </div>

    <!-- Details Box -->
    <div class="bg-surface-container-lowest rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <!-- Header -->
        <div class="px-8 py-5 border-b border-slate-100 bg-surface-container-low flex items-center gap-3">
            <span class="material-symbols-outlined text-primary">data_info_alert</span>
            <h3 class="font-bold text-slate-800">Transaction Details</h3>
        </div>

        <!-- Body Grid -->
        <div class="p-8 grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
            <div>
                <span class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-1">Payment ID</span>
                <span class="font-mono text-sm font-semibold text-slate-700 bg-slate-50 px-2 py-1 rounded border border-slate-200">@Model.Id</span>
            </div>
            
            <div>
                <span class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-1">Transaction Ref / External ID</span>
                @if (string.IsNullOrEmpty(Model.TransactionId))
                {
                    <span class="text-sm italic text-slate-400">Not Available</span>
                }
                else
                {
                    <span class="font-mono text-[13px] text-slate-600 truncate max-w-[280px] block" title="@Model.TransactionId">@Model.TransactionId</span>
                }
            </div>

            <div class="md:col-span-2 border-t border-slate-100 pt-6 mt-2"></div>

            <div>
                <span class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-1">Customer Name</span>
                <span class="text-sm font-semibold text-slate-800">@Model.CustomerName</span>
            </div>

            <div>
                <span class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-1">Customer Email</span>
                <span class="text-sm font-medium text-primary">@Model.CustomerEmail</span>
            </div>

            <div class="md:col-span-2 border-t border-slate-100 pt-6 mt-2"></div>

            <div>
                <span class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-1">Payment Provider</span>
                <div class="inline-flex items-center gap-2 mt-1">
                    <span class="w-8 h-8 rounded bg-slate-100 border border-slate-200 flex items-center justify-center">
                        <span class="material-symbols-outlined text-[16px] text-slate-600">credit_card</span>
                    </span>
                    <span class="text-sm font-bold text-slate-700">@Model.Provider</span>
                </div>
            </div>

            <div>
                <span class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-1">Timestamp</span>
                <span class="text-sm text-slate-700 font-medium">@Model.CreatedAt.ToString("f")</span>
            </div>
        </div>
        
        <!-- Footer Note -->
        <div class="bg-slate-50 px-8 py-4 border-t border-slate-100 flex items-start gap-3">
            <span class="material-symbols-outlined text-amber-500 text-[20px] shrink-0 mt-0.5" style="font-variation-settings: 'FILL' 1;">lock</span>
            <p class="text-xs text-slate-500 leading-relaxed font-medium">
                This record is read-only and automatically managed via webhooks from @Model.Provider. Manual modifications to transaction schemas are restricted for compliance and security purposes.
            </p>
        </div>
    </div>
</div>

