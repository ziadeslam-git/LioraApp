@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Payment Details";
}

<!-- Header & Breadcrumbs -->
        <div class="mb-stack-lg">
            <div class="flex items-center gap-2 text-on-surface-variant font-label-caps text-label-caps mb-2 tracking-wider">
                <a class="hover:text-primary transition-colors" asp-controller="Dashboard" asp-action="Index">SALES</a>
                <span class="material-symbols-outlined text-[14px]">chevron_right</span>
                <a class="hover:text-primary transition-colors" asp-action="Index">PAYMENTS</a>
                <span class="material-symbols-outlined text-[14px]">chevron_right</span>
                <span class="text-primary">DETAILS</span>
            </div>
            <h1 class="font-headline-md text-headline-md text-on-surface">Payment Details</h1>
        </div>
        <!-- 65 / 35 Layout -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
            <!-- Left Column (65%) -->
            <div class="lg:col-span-8 flex flex-col gap-gutter">
                <!-- Transaction Info Card -->
                <div class="bg-surface-container-lowest rounded-2xl p-8 shadow-level-1 flex flex-col gap-6 relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-primary-container opacity-5 rounded-bl-full pointer-events-none"></div>
                    <h2 class="font-headline-md text-xl text-on-surface mb-2 border-b border-surface-variant pb-4">Transaction Information</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <div class="text-sm text-on-surface-variant mb-1">Payment ID</div>
                            <div class="font-mono text-lg text-on-surface tracking-tight">PAY-8924-XQ91</div>
                        </div>
                        <div>
                            <div class="text-sm text-on-surface-variant mb-1">Order Reference</div>
                            <a class="text-primary font-medium hover:underline flex items-center gap-1" asp-controller="Orders" asp-action="Index">
                                ORD-2023-1194
                                <span class="material-symbols-outlined text-[16px]">open_in_new</span>
                            </a>
                        </div>
                        <div>
                            <div class="text-sm text-on-surface-variant mb-1">Method</div>
                            <div class="flex items-center gap-2 text-on-surface">
                                <span class="material-symbols-outlined text-tertiary">account_balance</span>
                                <span>Bank Transfer (InstaPay)</span>
                            </div>
                        </div>
                        <div>
                            <div class="text-sm text-on-surface-variant mb-1">Date / Time</div>
                            <div class="text-on-surface">Oct 24, 2023 • 14:32 EET</div>
                        </div>
                    </div>
                </div>
                <!-- Proof of Payment Section -->
                <div class="bg-surface-container-lowest rounded-2xl p-8 shadow-level-1 flex flex-col gap-6">
                    <div class="flex items-center justify-between border-b border-surface-variant pb-4">
                        <h2 class="font-headline-md text-xl text-on-surface">Proof of Payment</h2>
                        <div class="flex gap-3">
                            <button class="btn-hover-scale px-4 py-2 rounded-full border border-outline text-on-surface text-sm font-medium hover:bg-surface-variant transition-colors flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px]">download</span>
                                Download
                            </button>
                            <button class="btn-hover-scale px-4 py-2 rounded-full border border-outline text-on-surface text-sm font-medium hover:bg-surface-variant transition-colors flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px]">fullscreen</span>
                                View Full Size
                            </button>
                        </div>
                    </div>
                    <div class="w-full bg-surface-container rounded-xl overflow-hidden flex items-center justify-center p-4 relative group cursor-pointer">
                        <div class="absolute inset-0 bg-inverse-surface opacity-0 group-hover:opacity-20 transition-opacity duration-300 pointer-events-none"></div>
                        <img alt="Receipt Preview" class="max-h-[400px] w-auto object-contain rounded-lg shadow-sm" data-alt="A stylized, high-quality photograph of a printed transaction receipt or bank transfer confirmation slip resting on a clean, light marble surface. The lighting is soft and natural, casting delicate shadows that emphasize the texture of the paper. The overall aesthetic is minimal, luxurious, and highly professional, fitting a high-end fashion brand's administrative context." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBMBPZh-s_8ojNCVxkpPFBNmkdREgF90SwmeYCK2z8gcK9j5INMwuNwLfnf-tW8e6amZT7x4K6V6_06L8zitwwGKB-X5YZ19OuON2HsRtwqtn0YFcDN1PmdG-Yz1L_NiF9U_t7tp8r5jnAhins9-0KMU3VAg8zrP75stejGE76gHcIw7ziwtX-pJouyKTWXOsx87TNYoF5yGTnHauaTn9rVxnuAbMJkbMZqa71m7IFvRmaAiAffebJUr942-Uh0Cq2qWEEh7untV4_N" />
                    </div>
                </div>
            </div>
            <!-- Right Column (35%) -->
            <div class="lg:col-span-4 flex flex-col gap-gutter">
                <!-- Status Card -->
                <div class="bg-surface-container-lowest rounded-2xl p-8 shadow-level-1 flex flex-col gap-6 text-center">
                    <div class="text-sm text-on-surface-variant font-label-caps mb-2 tracking-widest">CURRENT STATUS</div>
                    <div class="inline-flex items-center justify-center gap-2 bg-[#fff4e6] text-[#b06100] px-6 py-3 rounded-full font-bold text-lg mb-4 mx-auto self-center shadow-sm">
                        <span class="material-symbols-outlined fill">pending_actions</span>
                        Pending Review
                    </div>
                    <p class="text-on-surface-variant text-sm mb-4">Awaiting manual verification of the uploaded transfer receipt against bank records.</p>
                    <div class="flex flex-col gap-3 mt-2">
                        <button class="btn-hover-scale w-full py-3 rounded-full bg-primary-container text-on-primary-container font-bold text-sm shadow-sm hover:shadow-md transition-all flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-[18px]">check_circle</span>
                            Verify Payment
                        </button>
                        <button class="btn-hover-scale w-full py-3 rounded-full border border-error text-error font-medium text-sm hover:bg-error-container transition-colors flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-[18px]">cancel</span>
                            Reject
                        </button>
                    </div>
                </div>
                <!-- Customer Overview -->
                <div class="bg-surface-container-lowest rounded-2xl p-6 shadow-level-1">
                    <h3 class="font-label-caps text-label-caps text-on-surface-variant tracking-widest mb-4">CUSTOMER</h3>
                    <div class="flex items-center gap-4 mb-4">
                        <div class="w-12 h-12 rounded-full overflow-hidden bg-surface-variant shrink-0">
                            <img alt="Customer Avatar" class="w-full h-full object-cover" data-alt="A refined portrait of a stylish female customer against a neutral studio background. The aesthetic matches high-fashion editorial standards, with soft, diffused lighting and a modern, minimalist vibe. The color palette emphasizes sophisticated ivories, soft plums, and muted warm tones." src="https://lh3.googleusercontent.com/aida-public/AB6AXuD_xxZCXbeDX0nvORhyUmJyNsTLUuH-LHAwx91a-1oc91q6TQVaL6F-0dIz_NmuliUC4r-MHRCfegwkpd7ijgD3Xv7ZuCgvA1-43_MBX91z_qVr-p6yr_PH9gDJ2fnleRtQ1RVzPIf75F4zaXkvlcQl4bwIy57GaRRuSfet2XQw9-Gp6lrOwg_quSHhc0IIb_tguA-CeI6FsjYhwD-agBnZyeDIJbsAjIcWDgJAqhDZd6rXh5--D3MBM5yzyoLnOdbPGwf_Lh-IdEMX" />
                        </div>
                        <div>
                            <div class="font-medium text-on-surface">Amira Hassan</div>
                            <div class="text-sm text-on-surface-variant">amira.h@example.com</div>
                        </div>
                    </div>
                    <a class="text-sm text-primary font-medium hover:underline flex items-center gap-1" asp-controller="Users" asp-action="Index">
                        View Profile <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                    </a>
                </div>
                <!-- Amount Summary -->
                <div class="bg-surface-container-lowest rounded-2xl p-6 shadow-level-1">
                    <h3 class="font-label-caps text-label-caps text-on-surface-variant tracking-widest mb-4">AMOUNT</h3>
                    <div class="space-y-3 text-sm">
                        <div class="flex justify-between text-on-surface-variant">
                            <span>Subtotal (2 items)</span>
                            <span class="font-mono">EGP 12,450.00</span>
                        </div>
                        <div class="flex justify-between text-on-surface-variant">
                            <span>Shipping (Cairo)</span>
                            <span class="font-mono">EGP 150.00</span>
                        </div>
                        <div class="flex justify-between text-on-surface-variant">
                            <span>Taxes</span>
                            <span class="font-mono">EGP 0.00</span>
                        </div>
                        <div class="border-t border-surface-variant pt-3 mt-3 flex justify-between items-center">
                            <span class="font-medium text-on-surface">Total</span>
                            <span class="font-mono text-xl font-bold text-primary">EGP 12,600.00</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Timeline / Audit Log Bottom Section -->
        <div class="mt-gutter bg-surface-container-lowest rounded-2xl p-8 shadow-level-1 mb-section-gap">
            <h2 class="font-headline-md text-xl text-on-surface mb-6 border-b border-surface-variant pb-4">Activity Timeline</h2>
            <div class="relative pl-4 space-y-8 before:absolute before:inset-y-0 before:left-5 before:w-px before:bg-outline-variant">
                <!-- Event 1 -->
                <div class="relative flex gap-4">
                    <div class="absolute -left-6 bg-surface-container-lowest rounded-full p-1 z-10">
                        <div class="w-3 h-3 rounded-full bg-primary-container border-2 border-surface-container-lowest"></div>
                    </div>
                    <div>
                        <div class="text-sm font-medium text-on-surface mb-1">Payment Proof Uploaded</div>
                        <div class="text-xs text-on-surface-variant mb-2">Oct 24, 2023 • 14:35 EET</div>
                        <p class="text-sm text-on-surface-variant bg-surface-container-low p-3 rounded-lg border border-outline-variant">Customer uploaded receipt via checkout flow.</p>
                    </div>
                </div>
                <!-- Event 2 -->
                <div class="relative flex gap-4">
                    <div class="absolute -left-6 bg-surface-container-lowest rounded-full p-1 z-10">
                        <div class="w-3 h-3 rounded-full bg-surface-variant border-2 border-surface-container-lowest"></div>
                    </div>
                    <div>
                        <div class="text-sm font-medium text-on-surface mb-1">Order Created</div>
                        <div class="text-xs text-on-surface-variant">Oct 24, 2023 • 14:32 EET</div>
                    </div>
                </div>
            </div>
        </div>
