@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Payments";
}

<!-- Page Header -->
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-stack-lg gap-6">
            <div>
                <h2 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-background">Payments</h2>
                <p class="font-body-md text-body-md text-on-surface-variant mt-2 max-w-2xl">Manage and verify transaction proofs, track cash-on-delivery orders, and oversee financial inflows.</p>
            </div>
            <div class="flex gap-4">
                <button class="btn-press bg-surface border border-primary text-primary px-6 py-3 rounded-DEFAULT font-label-caps text-label-caps flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">download</span>
                    EXPORT
                </button>
                <button class="btn-press bg-primary-container text-on-primary-container px-6 py-3 rounded-DEFAULT font-label-caps text-label-caps flex items-center gap-2 shadow-level1">
                    <span class="material-symbols-outlined text-[18px]">add</span>
                    RECORD MANUAL
                </button>
            </div>
        </div>
        <!-- Filter Tabs -->
        <div class="flex gap-8 border-b border-outline-variant mb-stack-lg overflow-x-auto pb-[2px] hide-scrollbar">
            <button class="pb-3 font-label-caps text-label-caps text-primary tab-underline tab-active whitespace-nowrap px-1">ALL TRANSACTIONS</button>
            <button class="pb-3 font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors tab-underline whitespace-nowrap px-1">VERIFIED</button>
            <button class="pb-3 font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors tab-underline whitespace-nowrap px-1 flex items-center gap-2">
                PENDING REVIEW
                <span class="bg-error text-on-error rounded-full px-2 py-0.5 text-[10px]">3</span>
            </button>
            <button class="pb-3 font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors tab-underline whitespace-nowrap px-1">REJECTED</button>
            <button class="pb-3 font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors tab-underline whitespace-nowrap px-1">COD</button>
        </div>
        <!-- Bento Style Stats (Optional enhancement based on instructions) -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-stack-lg">
            <div class="bg-surface-container-lowest p-6 rounded-lg shadow-level1 flex flex-col justify-between relative overflow-hidden">
                <div class="absolute -right-4 -top-4 w-24 h-24 bg-primary-container/10 rounded-full blur-xl"></div>
                <p class="font-label-caps text-label-caps text-on-surface-variant mb-4">TOTAL VOLUME</p>
                <p class="font-headline-md text-headline-md text-on-background">EGP 145,200</p>
                <p class="font-body-md text-body-md text-tertiary text-sm mt-2 flex items-center gap-1">
                    <span class="material-symbols-outlined text-[16px]">trending_up</span> +12% this month
                </p>
            </div>
            <div class="bg-surface-container-lowest p-6 rounded-lg shadow-level1 flex flex-col justify-between relative overflow-hidden">
                <p class="font-label-caps text-label-caps text-on-surface-variant mb-4">PENDING VERIFICATION</p>
                <p class="font-headline-md text-headline-md text-on-background">3</p>
                <p class="font-body-md text-body-md text-tertiary text-sm mt-2">Requires manual review</p>
            </div>
        </div>
        <!-- Data Table / List -->
        <div class="bg-surface-container-lowest rounded-xl shadow-level1 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-outline-variant bg-surface-container-low/50">
                            <th class="p-4 font-label-caps text-label-caps text-on-surface-variant">PAYMENT ID</th>
                            <th class="p-4 font-label-caps text-label-caps text-on-surface-variant">ORDER #</th>
                            <th class="p-4 font-label-caps text-label-caps text-on-surface-variant">CUSTOMER</th>
                            <th class="p-4 font-label-caps text-label-caps text-on-surface-variant">METHOD</th>
                            <th class="p-4 font-label-caps text-label-caps text-on-surface-variant">AMOUNT</th>
                            <th class="p-4 font-label-caps text-label-caps text-on-surface-variant">PROOF</th>
                            <th class="p-4 font-label-caps text-label-caps text-on-surface-variant">STATUS</th>
                            <th class="p-4 font-label-caps text-label-caps text-on-surface-variant">DATE</th>
                            <th class="p-4 font-label-caps text-label-caps text-on-surface-variant text-right">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody class="font-body-md text-body-md">
                        <!-- Row 1: Pending -->
                        <tr class="border-b border-outline-variant/50 glass-row relative group">
                            <td class="p-4 font-mono text-sm text-secondary">PAY-8829-XL</td>
                            <td class="p-4 text-on-background">#ORD-092</td>
                            <td class="p-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-secondary-container text-on-secondary-container flex items-center justify-center font-label-caps text-[10px]">NA</div>
                                    <span class="text-on-background">Nour Ahmed</span>
                                </div>
                            </td>
                            <td class="p-4 text-on-surface-variant flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px]">account_balance</span> InstaPay
                            </td>
                            <td class="p-4 font-mono font-medium text-primary-container">EGP 4,500.00</td>
                            <td class="p-4">
                                <div class="w-12 h-16 bg-surface-variant rounded border border-outline-variant overflow-hidden cursor-pointer hover:opacity-80 transition-opacity">
                                    <img alt="InstaPay transfer screenshot receipt showing successful transaction of 4500 EGP. The image is a stylized digital mockup of a mobile banking transfer screen with a minimalist modern UI, clean typography, and a subtle glowing green checkmark indicating success. The aesthetic is clean, financial, and trustworthy." class="w-full h-full object-cover" data-alt="InstaPay transfer screenshot receipt showing successful transaction of 4500 EGP. The image is a stylized digital mockup of a mobile banking transfer screen with a minimalist modern UI, clean typography, and a subtle glowing green checkmark indicating success. The aesthetic is clean, financial, and trustworthy." src="https://lh3.googleusercontent.com/aida-public/AB6AXuCsQRJGmBdGGKQ_hu2Cn3iQb4oGtLqP78gGQodZaoPwYEUD7SsHjUXYz5X9JfhPO09vZgUc3vd539G8wA1OgkCm04TCEX1yfs5OFbY8u2VSmaEoVNkr9QqH1maH0txmAAtfHyd9xuREQtCFnGS2Kx9Hbmb0UCZuIIfxx54uXYFh6Gm70CKtI104tFlbiIvPGlP5TESx6ye9HuI0UDehhfwnxPDTWv-BH6KhGO97WVIYR0C1ay6oXnyZK1SD-1HaqkAnMa7Eegj_B6dk" />
                                </div>
                            </td>
                            <td class="p-4">
                                <span class="inline-flex items-center px-3 py-1 rounded-full bg-secondary-fixed text-on-secondary-fixed-variant font-label-caps text-[10px]">PENDING REVIEW</span>
                            </td>
                            <td class="p-4 text-on-surface-variant text-sm">Oct 24, 14:30</td>
                            <td class="p-4 text-right">
                                <button class="text-primary hover:text-primary-container transition-colors font-label-caps text-label-caps btn-press">VIEW</button>
                            </td>
                        </tr>
                        <!-- Row 2: Verified -->
                        <tr class="border-b border-outline-variant/50 glass-row">
                            <td class="p-4 font-mono text-sm text-secondary">PAY-8828-KV</td>
                            <td class="p-4 text-on-background">#ORD-091</td>
                            <td class="p-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-tertiary-fixed text-on-tertiary-fixed flex items-center justify-center font-label-caps text-[10px]">SM</div>
                                    <span class="text-on-background">Salma Mansour</span>
                                </div>
                            </td>
                            <td class="p-4 text-on-surface-variant flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px]">credit_card</span> Credit Card
                            </td>
                            <td class="p-4 font-mono font-medium text-primary-container">EGP 12,800.00</td>
                            <td class="p-4">
                                <span class="text-on-surface-variant/50 text-sm italic">Auto-verified</span>
                            </td>
                            <td class="p-4">
                                <span class="inline-flex items-center px-3 py-1 rounded-full bg-surface-variant text-on-surface-variant font-label-caps text-[10px] border border-outline-variant/50">VERIFIED</span>
                            </td>
                            <td class="p-4 text-on-surface-variant text-sm">Oct 24, 09:15</td>
                            <td class="p-4 text-right">
                                <button class="text-primary hover:text-primary-container transition-colors font-label-caps text-label-caps btn-press">VIEW</button>
                            </td>
                        </tr>
                        <!-- Row 3: COD -->
                        <tr class="border-b border-outline-variant/50 glass-row">
                            <td class="p-4 font-mono text-sm text-secondary">PAY-8827-CD</td>
                            <td class="p-4 text-on-background">#ORD-090</td>
                            <td class="p-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-primary-fixed text-on-primary-fixed flex items-center justify-center font-label-caps text-[10px]">YK</div>
                                    <span class="text-on-background">Youssef Kamel</span>
                                </div>
                            </td>
                            <td class="p-4 text-on-surface-variant flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px]">local_shipping</span> COD
                            </td>
                            <td class="p-4 font-mono font-medium text-primary-container">EGP 2,150.00</td>
                            <td class="p-4">
                                <span class="text-on-surface-variant/50 text-sm italic">N/A</span>
                            </td>
                            <td class="p-4">
                                <span class="inline-flex items-center px-3 py-1 rounded-full bg-surface-variant text-on-surface-variant font-label-caps text-[10px] border border-outline-variant/50">TO COLLECT</span>
                            </td>
                            <td class="p-4 text-on-surface-variant text-sm">Oct 23, 18:40</td>
                            <td class="p-4 text-right">
                                <button class="text-primary hover:text-primary-container transition-colors font-label-caps text-label-caps btn-press">VIEW</button>
                            </td>
                        </tr>
                        <!-- Row 4: Rejected -->
                        <tr class="glass-row">
                            <td class="p-4 font-mono text-sm text-secondary">PAY-8826-RJ</td>
                            <td class="p-4 text-on-background">#ORD-089</td>
                            <td class="p-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-surface-variant text-on-surface-variant flex items-center justify-center font-label-caps text-[10px]">FR</div>
                                    <span class="text-on-background">Farida R.</span>
                                </div>
                            </td>
                            <td class="p-4 text-on-surface-variant flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px]">account_balance</span> Bank Transfer
                            </td>
                            <td class="p-4 font-mono font-medium text-primary-container">EGP 8,900.00</td>
                            <td class="p-4">
                                <div class="w-12 h-16 bg-surface-variant rounded border border-error/30 overflow-hidden cursor-pointer hover:opacity-80 transition-opacity">
                                    <img alt="A blurry, illegible photo of a physical bank receipt lying on a dark wooden table. The lighting is poor and casts harsh shadows, making the numbers impossible to read. The overall aesthetic is unrefined and clearly indicates an invalid or poorly captured proof of payment." class="w-full h-full object-cover grayscale opacity-70" data-alt="A blurry, illegible photo of a physical bank receipt lying on a dark wooden table. The lighting is poor and casts harsh shadows, making the numbers impossible to read. The overall aesthetic is unrefined and clearly indicates an invalid or poorly captured proof of payment." src="https://lh3.googleusercontent.com/aida-public/AB6AXuCmbRJF8miswuUo3QzArgWj69iuJSICd8-fspvkB2Lac6t9be6kCfgxn0akf9qflzmv4wlex03LL7rH_xXyNDJzdHKb7FPKhxFUdElWHzPEdXVzMUeMpyWIs7oqmjNS_w8Fb8zIQg8B4v4aY8hAgHe9W9Nb01b_s_blKPmjC43nmSgDdD7ngRPQ7y2NA-OntoCicn8PFSEOZi3gcxWjimDv6TdMmWDJ4ukJHlIMZ4buFl22Y7K_54w1hduqufY4qBm344YYTE1974Ij" />
                                </div>
                            </td>
                            <td class="p-4">
                                <span class="inline-flex items-center px-3 py-1 rounded-full bg-error-container text-on-error-container font-label-caps text-[10px]">REJECTED</span>
                            </td>
                            <td class="p-4 text-on-surface-variant text-sm">Oct 23, 11:20</td>
                            <td class="p-4 text-right">
                                <button class="text-primary hover:text-primary-container transition-colors font-label-caps text-label-caps btn-press">VIEW</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <!-- Pagination -->
            <div class="p-4 border-t border-outline-variant flex items-center justify-between bg-surface-container-low/30">
                <p class="font-body-md text-sm text-on-surface-variant">Showing 1 to 4 of 128 entries</p>
                <div class="flex gap-2">
                    <button class="w-8 h-8 rounded border border-outline-variant flex items-center justify-center text-on-surface-variant hover:bg-surface-container-highest transition-colors disabled:opacity-50" disabled="">
                        <span class="material-symbols-outlined text-[18px]">chevron_left</span>
                    </button>
                    <button class="w-8 h-8 rounded bg-primary-container text-on-primary-container flex items-center justify-center font-body-md text-sm">1</button>
                    <button class="w-8 h-8 rounded border border-outline-variant flex items-center justify-center text-on-surface-variant hover:bg-surface-container-highest transition-colors font-body-md text-sm">2</button>
                    <button class="w-8 h-8 rounded border border-outline-variant flex items-center justify-center text-on-surface-variant hover:bg-surface-container-highest transition-colors font-body-md text-sm">3</button>
                    <button class="w-8 h-8 rounded border border-outline-variant flex items-center justify-center text-on-surface-variant hover:bg-surface-container-highest transition-colors">
                        <span class="material-symbols-outlined text-[18px]">chevron_right</span>
                    </button>
                </div>
            </div>
        </div>

@section Scripts {
    <script>
        // Simple tab switching logic for demonstration
        document.querySelectorAll('.tab-underline').forEach(tab => {
        tab.addEventListener('click', (e) => {
        document.querySelectorAll('.tab-underline').forEach(t => {
        t.classList.remove('tab-active', 'text-primary');
        t.classList.add('text-on-surface-variant');
        });
        e.currentTarget.classList.add('tab-active', 'text-primary');
        e.currentTarget.classList.remove('text-on-surface-variant');
        });
        });
    </script>
}
