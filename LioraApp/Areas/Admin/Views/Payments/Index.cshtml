@model IEnumerable<PaymentVM>
@{
    ViewData["Title"] = "Payments";
    var payments = Model.ToList();
    int currentPage = ViewBag.CurrentPage is int cp ? cp : 1;
    int totalPages = ViewBag.TotalPages is int tp ? tp : 1;
    int totalCount = ViewBag.TotalCount is int tc ? tc : payments.Count;
    int pageSize = ViewBag.PageSize is int ps ? ps : 10;
    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, currentPage + 2);
    int startItem = totalCount == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    int endItem = totalCount == 0 ? 0 : startItem + payments.Count - 1;
}

@section Styles {
    }

<div class="space-y-8 font-inter">
    <!-- --- PAGE HEADER --- -->
    <div class="flex justify-between items-end">
        <div>
            <h2 class="text-[24px] font-bold text-slate-800 leading-tight">Payments</h2>
            <p class="text-[14px] text-slate-500 mt-1">Read-only transaction records via internal gateways</p>
        </div>
        <button class="flex items-center gap-2 text-primary font-semibold text-sm px-4 py-2 hover:bg-primary/5 rounded-xl transition-all border border-transparent hover:border-primary/10">
            <span class="material-symbols-outlined text-[18px]">download</span>
            Export Ledger
        </button>
    </div>

    <!-- --- STATS ROW --- -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-surface-container-lowest p-5 rounded-xl border border-slate-100 shadow-[0_20px_40px_rgba(15,23,42,0.03)] flex flex-col gap-1">
            <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Total Volume</span>
            <div class="flex items-end justify-between">
                <span class="text-2xl font-bold text-slate-800 font-mono">EGP @(((decimal)ViewBag.TotalVolume).ToString("N2"))</span>
            </div>
        </div>

        <div class="bg-surface-container-lowest p-5 rounded-xl border border-slate-100 shadow-[0_20px_40px_rgba(15,23,42,0.03)] flex flex-col gap-1">
            <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Successful TXs</span>
            <div class="flex items-end justify-between">
                <span class="text-2xl font-bold text-emerald-600 font-mono">@ViewBag.PaidCount</span>
                <span class="text-[10px] bg-emerald-50 text-emerald-600 px-2 py-0.5 rounded-full font-bold">Paid</span>
            </div>
        </div>

        <div class="bg-surface-container-lowest p-5 rounded-xl border border-slate-100 shadow-[0_20px_40px_rgba(15,23,42,0.03)] flex flex-col gap-1">
            <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Pending</span>
            <div class="flex items-end justify-between">
                <span class="text-2xl font-bold text-amber-500 font-mono">@ViewBag.PendingCount</span>
                <span class="text-[10px] bg-amber-50 text-amber-600 px-2 py-0.5 rounded-full font-bold">Awaiting</span>
            </div>
        </div>

        <div class="bg-surface-container-lowest p-5 rounded-xl border border-slate-100 shadow-[0_20px_40px_rgba(15,23,42,0.03)] flex flex-col gap-1">
            <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Failed / Refunded</span>
            <div class="flex items-end justify-between">
                <span class="text-2xl font-bold text-error font-mono">@ViewBag.FailedCount</span>
            </div>
        </div>
    </div>

    <!-- --- FILTER BAR --- -->
    <div class="bg-surface-container-lowest p-4 rounded-xl shadow-sm border border-slate-100 flex flex-wrap items-center gap-4">
        <form asp-action="Index" method="get" class="flex flex-1 w-full gap-4">
            <div class="flex-1 min-w-[240px] relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                <input type="text" name="searchQuery" value="@ViewBag.SearchQuery" class="w-full border border-outline-variant/30 rounded-lg pl-10 pr-4 py-2 text-sm focus:ring-2 focus:ring-primary/10 focus:border-primary transition-all bg-surface" placeholder="Search by customer email or order ID..." />
            </div>
            <div class="w-48">
                <select name="statusFilter" class="w-full border border-outline-variant/30 rounded-lg py-2 pl-3 pr-8 text-sm focus:ring-2 focus:ring-primary/10 focus:border-primary transition-all bg-surface" onchange="this.form.submit()">
                    <option value="">Status: All</option>
                    <option value="Paid" selected="@(ViewBag.StatusFilter != null && ViewBag.StatusFilter.ToString() == "Paid")">Paid</option>
                    <option value="Pending" selected="@(ViewBag.StatusFilter != null && ViewBag.StatusFilter.ToString() == "Pending")">Pending</option>
                    <option value="Failed" selected="@(ViewBag.StatusFilter != null && ViewBag.StatusFilter.ToString() == "Failed")">Failed</option>
                    <option value="Refunded" selected="@(ViewBag.StatusFilter != null && ViewBag.StatusFilter.ToString() == "Refunded")">Refunded</option>
                </select>
            </div>
            <a asp-action="Index" class="p-2 text-slate-500 hover:bg-slate-100 rounded-lg transition-all border border-transparent hover:border-slate-200" title="Reset Filters">
                <span class="material-symbols-outlined text-[20px]">restart_alt</span>
            </a>
        </form>
    </div>

    <!-- --- TABLE --- -->
    <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-slate-100 overflow-hidden relative">
        <div class="space-y-3 p-4 md:hidden">
            @foreach (var p in payments)
            {
                <article class="rounded-[18px] border border-slate-200 bg-slate-50/80 p-4 shadow-sm">
                    <div class="flex items-start justify-between gap-3">
                        <div class="flex items-center gap-3">
                            <div class="flex size-10 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-500 shadow-sm">
                                <span class="material-symbols-outlined text-[18px]">receipt_long</span>
                            </div>
                            <div>
                                <p class="text-sm font-bold text-slate-900">Order #@p.OrderId</p>
                                <p class="text-xs font-mono text-slate-500">@p.CustomerEmail</p>
                            </div>
                        </div>
                        <a asp-action="Details" asp-route-id="@p.Id" class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white text-primary shadow-sm transition hover:bg-slate-100">
                            <span class="material-symbols-outlined text-[18px]">visibility</span>
                        </a>
                    </div>

                    <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
                        <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400">Amount</p>
                            <p class="mt-1 font-bold text-slate-900">$@p.Amount.ToString("N2")</p>
                        </div>
                        <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400">Provider</p>
                            <p class="mt-1 font-semibold text-slate-600">@p.Provider</p>
                        </div>
                        <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400">Status</p>
                            @if (p.Status == "Paid")
                            {
                                <span class="mt-1 inline-flex items-center gap-1 rounded-full border border-emerald-200 bg-emerald-100 px-2 py-1 text-[10px] font-extrabold uppercase text-emerald-700"><span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>Paid</span>
                            }
                            else if (p.Status == "Pending")
                            {
                                <span class="mt-1 inline-flex items-center gap-1 rounded-full border border-amber-200 bg-amber-100 px-2 py-1 text-[10px] font-extrabold uppercase text-amber-700"><span class="h-1.5 w-1.5 rounded-full bg-amber-500"></span>Pending</span>
                            }
                            else if (p.Status == "Refunded")
                            {
                                <span class="mt-1 inline-flex items-center gap-1 rounded-full border border-slate-200 bg-slate-100 px-2 py-1 text-[10px] font-extrabold uppercase text-slate-700"><span class="h-1.5 w-1.5 rounded-full bg-slate-500"></span>Refunded</span>
                            }
                            else
                            {
                                <span class="mt-1 inline-flex items-center gap-1 rounded-full border border-red-200 bg-red-100 px-2 py-1 text-[10px] font-extrabold uppercase text-error"><span class="h-1.5 w-1.5 rounded-full bg-red-500"></span>@p.Status</span>
                            }
                        </div>
                        <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400">Date</p>
                            <p class="mt-1 font-semibold text-slate-600">@p.CreatedAt.ToString("MMM dd, yyyy HH:mm")</p>
                        </div>
                    </div>
                </article>
            }
            @if (!payments.Any())
            {
                <div class="rounded-[18px] border border-dashed border-slate-200 bg-slate-50 p-6 text-center text-sm text-slate-500">
                    No payments found.
                </div>
            }
        </div>

        <div class="hidden overflow-x-auto md:block">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-container-low text-slate-500 uppercase text-[11px] font-bold tracking-widest border-b border-slate-100">
                        <th class="px-6 py-4">Transaction Details</th>
                        <th class="px-6 py-4 text-center">Amount</th>
                        <th class="px-6 py-4">Provider</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4">Date</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var p in payments)
                    {
                        <tr class="hover:bg-slate-50/70 transition-colors group">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-4">
                                    <div class="size-10 bg-slate-100 rounded-xl flex items-center justify-center border border-slate-200 shadow-sm">
                                        <span class="material-symbols-outlined text-slate-500 text-[20px]">receipt_long</span>
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="font-bold text-slate-800 text-sm">Order #@p.OrderId</span>
                                        <span class="text-xs text-slate-500 font-mono">@p.CustomerEmail</span>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-center text-sm font-bold text-slate-800 font-mono">
                                $@p.Amount.ToString("N2")
                            </td>
                            <td class="px-6 py-4">
                                <div class="inline-flex items-center gap-1.5 bg-slate-50 border border-slate-200 px-2 py-1 rounded-lg shadow-[0_1px_2px_rgba(0,0,0,0.02)]">
                                    <span class="material-symbols-outlined text-primary text-[14px]">payments</span>
                                    <span class="text-xs font-bold text-slate-700">@p.Provider</span>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                @if (p.Status == "Paid")
                                {
                                    <span class="bg-emerald-100 text-emerald-700 text-[10px] font-extrabold uppercase px-2 py-1 rounded-full border border-emerald-200 flex w-fit items-center gap-1 shadow-[0_1px_2px_rgba(0,0,0,0.05)]"><span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span>Paid</span>
                                }
                                else if (p.Status == "Pending")
                                {
                                    <span class="bg-amber-100 text-amber-700 text-[10px] font-extrabold uppercase px-2 py-1 rounded-full border border-amber-200 flex w-fit items-center gap-1"><span class="w-1.5 h-1.5 bg-amber-500 rounded-full"></span>Pending</span>
                                }
                                else if (p.Status == "Refunded")
                                {
                                    <span class="bg-slate-100 text-slate-700 text-[10px] font-extrabold uppercase px-2 py-1 rounded-full border border-slate-200 flex w-fit items-center gap-1"><span class="w-1.5 h-1.5 bg-slate-500 rounded-full"></span>Refunded</span>
                                }
                                else
                                {
                                    <span class="bg-red-100 text-error text-[10px] font-extrabold uppercase px-2 py-1 rounded-full border border-red-200 flex w-fit items-center gap-1"><span class="w-1.5 h-1.5 bg-red-500 rounded-full"></span>@p.Status</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-xs text-slate-500 font-medium whitespace-nowrap">
                                @p.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                            </td>
                            <td class="px-6 py-4 text-right">
                                <a asp-action="Details" asp-route-id="@p.Id" class="inline-flex items-center gap-1 text-xs font-bold text-primary hover:text-indigo-800 transition-colors bg-primary/10 hover:bg-primary/20 px-3 py-1.5 rounded-lg">
                                    View
                                    <span class="material-symbols-outlined text-[14px]">chevron_right</span>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!payments.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-12">
                                <span class="material-symbols-outlined text-4xl text-slate-300 mb-2">money_off</span>
                                <p class="text-slate-500 font-medium">No payments found.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <div class="px-6 py-4 bg-surface-container-low border-t border-slate-100 flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <span class="text-xs text-slate-500 font-medium">
                    Showing <span class="font-semibold text-slate-700">@startItem</span>
                    to <span class="font-semibold text-slate-700">@endItem</span>
                    of <span class="font-semibold text-slate-700">@totalCount</span> payments
                </span>
                <div class="flex flex-wrap gap-2 items-center">
                    <a asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-statusFilter="@ViewBag.StatusFilter" asp-route-searchQuery="@ViewBag.SearchQuery"
                       class="inline-flex items-center gap-1 rounded-xl border px-3 py-2 text-xs font-semibold transition-all @(currentPage == 1 ? "pointer-events-none border-slate-200 bg-slate-100 text-slate-300" : "border-slate-200 bg-white text-slate-600 hover:border-primary/30 hover:text-primary")">
                        <span class="material-symbols-outlined text-sm">chevron_left</span>
                        Previous
                    </a>

                    @for (int pg = startPage; pg <= endPage; pg++)
                    {
                        if (pg == currentPage)
                        {
                            <button class="inline-flex h-10 min-w-10 items-center justify-center rounded-xl border border-primary bg-primary px-3 text-xs font-bold text-white shadow-md shadow-primary/20">@pg</button>
                        }
                        else
                        {
                            <a asp-action="Index" asp-route-page="@pg" asp-route-statusFilter="@ViewBag.StatusFilter" asp-route-searchQuery="@ViewBag.SearchQuery" class="inline-flex h-10 min-w-10 items-center justify-center rounded-xl border border-slate-200 bg-white px-3 text-xs font-bold text-slate-600 transition-all hover:border-primary/30 hover:text-primary">@pg</a>
                        }
                    }

                    <a asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-statusFilter="@ViewBag.StatusFilter" asp-route-searchQuery="@ViewBag.SearchQuery"
                       class="inline-flex items-center gap-1 rounded-xl border px-3 py-2 text-xs font-semibold transition-all @(currentPage == totalPages ? "pointer-events-none border-slate-200 bg-slate-100 text-slate-300" : "border-slate-200 bg-white text-slate-600 hover:border-primary/30 hover:text-primary")">
                        Next
                        <span class="material-symbols-outlined text-sm">chevron_right</span>
                    </a>
                </div>
            </div>
        }
    </div>
</div>

