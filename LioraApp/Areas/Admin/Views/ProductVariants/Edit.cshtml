@using LioraApp.ViewModels.Admin
@model ProductVariantVM

@{
    ViewData["Title"] = "Edit Variant";
    var productName = ViewData["ProductName"]?.ToString() ?? "";
    var sizeLabel = string.IsNullOrWhiteSpace(Model.Size) ? "No size" : Model.Size;
    var headingLabel = string.IsNullOrWhiteSpace(Model.Size) ? Model.Color : $"{Model.Size} / {Model.Color}";
    var placeholderImage = Url.Content("~/images/product-placeholder.svg");
    var sizeSuggestions = new[] { "XS", "S", "M", "L", "XL", "XXL", "38", "39", "40", "41", "42", "43", "44", "45" };
}

<div class="max-w-2xl mx-auto space-y-6">

    <div>
        <nav class="flex text-sm text-slate-500 mb-2 items-center gap-2">
            <a asp-area="Admin" asp-controller="Product" asp-action="Index"
               class="hover:text-primary transition-colors">Products</a>
            <span class="material-symbols-outlined text-sm">chevron_right</span>
            <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Index"
               asp-route-productId="@Model.ProductId"
               class="hover:text-primary transition-colors">@productName</a>
            <span class="material-symbols-outlined text-sm">chevron_right</span>
            <span class="font-medium text-slate-900">Edit Variant</span>
        </nav>
        <h1 class="text-3xl font-black tracking-tight">Edit Variant</h1>
        <p class="text-slate-500 mt-1">
            Editing <strong>@headingLabel</strong> — <code class="text-xs font-mono bg-slate-100 px-1.5 py-0.5 rounded">@Model.SKU</code>
        </p>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
        <form asp-area="Admin" asp-controller="ProductVariants" asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="ProductId" type="hidden" />
            <input asp-for="ProductName" type="hidden" />
            <input asp-for="SelectedMainImageKey" type="hidden" id="selectedMainImageKey" />
            @if (Model.RowVersion is not null)
            {
                <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
            }

            <div class="space-y-5">

                <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                    <div>
                        <label for="Size" class="block text-sm font-semibold text-slate-700 mb-1.5">Size <span class="text-slate-400 font-normal">(Optional)</span></label>
                        <input asp-for="Size" list="variantSizeSuggestions"
                               class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm
                                      focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all
                                      placeholder:text-slate-400"
                               placeholder="Type 42 for shoes, or leave blank" autocomplete="off" />
                        <datalist id="variantSizeSuggestions">
                            @foreach (var size in sizeSuggestions)
                            {
                                <option value="@size"></option>
                            }
                        </datalist>
                        <p class="text-xs text-slate-400 mt-1">Keep it empty for size-free products like watches, wallets, and gifts.</p>
                        <span asp-validation-for="Size" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Color" class="block text-sm font-semibold text-slate-700 mb-1.5"></label>
                        <input asp-for="Color"
                               class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm
                                      focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
                        <span asp-validation-for="Color" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="SKU" class="block text-sm font-semibold text-slate-700 mb-1.5"></label>
                    <input asp-for="SKU"
                           class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm
                                  font-mono focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
                    <span asp-validation-for="SKU" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="Price" class="block text-sm font-semibold text-slate-700 mb-1.5"></label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 font-medium">$</span>
                            <input asp-for="Price" type="number" step="0.01" min="0.01"
                                   class="w-full rounded-lg border border-slate-200 bg-white pl-7 pr-4 py-2.5 text-sm
                                          focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
                        </div>
                        <span asp-validation-for="Price" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Stock" class="block text-sm font-semibold text-slate-700 mb-1.5">Stock Quantity</label>
                        <input asp-for="Stock" type="number" min="0"
                               class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm
                                      focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
                        <span asp-validation-for="Stock" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <div class="flex items-center gap-3">
                    <input asp-for="IsActive" type="checkbox" id="isActiveCheck"
                           class="size-4 rounded accent-primary" />
                    <label for="isActiveCheck" class="text-sm font-semibold text-slate-700">
                        Active (available for purchase)
                    </label>
                </div>

                <div class="pt-4 border-t border-slate-100">
                    <div class="mb-4">
                        <h3 class="text-sm font-bold text-slate-900">Variant Images <span class="font-normal text-slate-400">(main + gallery)</span></h3>
                        <p class="text-xs text-slate-400 mt-1">Current images stay in place. Any new uploads will be added to this gallery. Click any image to make it the main one.</p>
                    </div>

                    @if (Model.Images != null && Model.Images.Any())
                    {
                        <div>
                            <div class="mb-2 flex items-center justify-between">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Current Images</p>
                                <span class="rounded-full bg-slate-100 px-2.5 py-1 text-[10px] font-black text-slate-600">@Model.Images.Count image(s)</span>
                            </div>
                            <div id="existingImageGrid" class="grid grid-cols-2 gap-3 sm:grid-cols-4">
                                @foreach (var img in Model.Images)
                                {
                                    var imageKey = $"existing:{img.Id}";
                                    var isMain = Model.SelectedMainImageKey == imageKey || (string.IsNullOrWhiteSpace(Model.SelectedMainImageKey) && img.IsMain);

                                    <button type="button"
                                            class="existing-main-card group relative overflow-hidden rounded-2xl border-2 bg-white text-left shadow-sm transition-all @(isMain ? "border-primary ring-2 ring-primary/20" : "border-slate-200 hover:border-primary/40")"
                                            data-main-key="@imageKey">
                                        <div class="aspect-square overflow-hidden bg-slate-50">
                                            <img src="@img.ImageUrl" alt="Variant image"
                                                 class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                                                 loading="lazy" decoding="async"
                                                 onerror="this.onerror=null;this.src='@placeholderImage';" />
                                        </div>
                                        <div class="p-3">
                                            <div class="flex items-center justify-between gap-2">
                                                <span class="text-xs font-semibold text-slate-700">Saved image</span>
                                                @if (isMain)
                                                {
                                                    <span data-main-badge="true" class="rounded-full bg-primary px-2 py-0.5 text-[10px] font-black text-white">MAIN</span>
                                                }
                                            </div>
                                            <p class="mt-1 text-[11px] text-slate-400">Click to keep this as main</p>
                                        </div>
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    <div class="mt-5">
                        <div id="imageDropZone"
                             class="relative border-2 border-dashed border-slate-200 rounded-xl p-6 text-center
                                    hover:border-primary/50 transition-all cursor-pointer">
                            <input asp-for="ImageFiles" type="file" accept="image/*" multiple id="imageFilesInput"
                                   class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
                            <span class="material-symbols-outlined text-3xl text-slate-300 mb-2 block">add_photo_alternate</span>
                            <p class="text-sm font-semibold text-slate-500">Click or drag &amp; drop new images here</p>
                            <p class="text-xs text-slate-400 mt-1">PNG, JPG, WEBP — each new selection is added, not replaced</p>
                        </div>

                        <div id="imageQueueSummary"
                             class="mt-4 hidden items-center justify-between rounded-xl border border-primary/10 bg-primary/5 px-4 py-3 text-sm">
                            <span class="font-semibold text-slate-700">New queued images: <span id="imageQueueCount" class="text-primary">0</span></span>
                            <span class="text-xs text-slate-500">Pick any card below if one of the new uploads should be MAIN.</span>
                        </div>

                        <div id="imagePreviews" class="mt-4 hidden grid grid-cols-2 gap-3 sm:grid-cols-4"></div>
                    </div>

                    <div class="flex items-center gap-3 mt-4">
                        <input asp-for="SetAsMainProductImage" type="checkbox" id="setMainCheck"
                               class="size-4 rounded accent-primary" />
                        <label for="setMainCheck" class="text-sm font-medium text-slate-700">
                            @Html.DisplayNameFor(m => m.SetAsMainProductImage)
                        </label>
                    </div>
                </div>

            </div>

            <div class="flex items-center justify-between mt-8 pt-6 border-t border-slate-100">
                <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Index"
                   asp-route-productId="@Model.ProductId"
                   class="flex items-center gap-1.5 text-sm text-slate-500 hover:text-primary transition-colors">
                    <span class="material-symbols-outlined text-base">arrow_back</span>
                    Back to Variants
                </a>
                <div class="flex gap-3">
                    <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Index"
                       asp-route-productId="@Model.ProductId"
                       class="px-5 py-2.5 rounded-lg border border-slate-200 text-slate-600 text-sm font-semibold
                              hover:bg-slate-50 transition-colors">
                        Cancel
                    </a>
                    <button type="submit"
                            class="flex items-center gap-2 px-6 py-2.5 rounded-lg bg-primary hover:bg-primary/90
                                   text-white text-sm font-bold shadow-lg shadow-primary/20 transition-all active:scale-95">
                        <span class="material-symbols-outlined text-base">save</span>
                        Save Changes
                    </button>
                </div>
            </div>

        </form>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const input = document.getElementById('imageFilesInput');
        const dropZone = document.getElementById('imageDropZone');
        const previews = document.getElementById('imagePreviews');
        const queueSummary = document.getElementById('imageQueueSummary');
        const queueCount = document.getElementById('imageQueueCount');
        const selectedMainImageKey = document.getElementById('selectedMainImageKey');
        const existingMainCards = Array.from(document.querySelectorAll('.existing-main-card'));
        const queuedFiles = [];

        function syncInputFiles() {
            const dt = new DataTransfer();
            queuedFiles.forEach(file => dt.items.add(file));
            input.files = dt.files;
        }

        function isSameFile(left, right) {
            return left.name === right.name &&
                   left.size === right.size &&
                   left.lastModified === right.lastModified;
        }

        function getAvailableKeys() {
            return [
                ...existingMainCards.map(card => card.dataset.mainKey),
                ...queuedFiles.map((_, index) => `new:${index}`)
            ];
        }

        function ensureMainSelection() {
            const availableKeys = getAvailableKeys();

            if (availableKeys.length === 0) {
                selectedMainImageKey.value = '';
                return;
            }

            if (!availableKeys.includes(selectedMainImageKey.value)) {
                selectedMainImageKey.value = availableKeys[0];
            }
        }

        function updateDropZoneState(isDragging) {
            dropZone.classList.toggle('border-primary', isDragging);
            dropZone.classList.toggle('bg-primary/5', isDragging);
        }

        function refreshExistingCards() {
            existingMainCards.forEach(card => {
                const isMain = card.dataset.mainKey === selectedMainImageKey.value;
                card.classList.toggle('border-primary', isMain);
                card.classList.toggle('ring-2', isMain);
                card.classList.toggle('ring-primary/20', isMain);
                card.classList.toggle('border-slate-200', !isMain);

                const badge = card.querySelector('[data-main-badge]');
                if (badge) {
                    badge.remove();
                }

                if (isMain) {
                    const badgeSpan = document.createElement('span');
                    badgeSpan.dataset.mainBadge = 'true';
                    badgeSpan.className = 'rounded-full bg-primary px-2 py-0.5 text-[10px] font-black text-white';
                    badgeSpan.textContent = 'MAIN';
                    card.querySelector('.flex')?.appendChild(badgeSpan);
                }
            });
        }

        function renderPreviews() {
            previews.innerHTML = '';

            if (queuedFiles.length === 0) {
                previews.classList.add('hidden');
                queueSummary.classList.add('hidden');
                refreshExistingCards();
                return;
            }

            previews.classList.remove('hidden');
            queueSummary.classList.remove('hidden');
            queueSummary.classList.add('flex');
            queueCount.textContent = queuedFiles.length.toString();

            queuedFiles.forEach((file, index) => {
                const reader = new FileReader();
                const mainKey = `new:${index}`;

                reader.onload = event => {
                    const isMain = selectedMainImageKey.value === mainKey;
                    const card = document.createElement('button');
                    card.type = 'button';
                    card.className = `group relative overflow-hidden rounded-2xl border-2 bg-white text-left shadow-sm transition-all ${
                        isMain
                            ? 'border-primary ring-2 ring-primary/20'
                            : 'border-slate-200 hover:border-primary/40'
                    }`;
                    card.innerHTML = `
                        <div class="aspect-square overflow-hidden bg-slate-50">
                            <img src="${event.target.result}" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" alt="${file.name}" />
                        </div>
                        <div class="p-3">
                            <div class="flex items-center justify-between gap-2">
                                <span class="truncate text-xs font-semibold text-slate-700">${file.name}</span>
                                ${isMain ? '<span class="rounded-full bg-primary px-2 py-0.5 text-[10px] font-black text-white">MAIN</span>' : ''}
                            </div>
                            <p class="mt-1 text-[11px] text-slate-400">${(file.size / 1024).toFixed(1)} KB</p>
                        </div>
                    `;

                    card.addEventListener('click', () => {
                        selectedMainImageKey.value = mainKey;
                        renderPreviews();
                    });

                    previews.appendChild(card);
                };

                reader.readAsDataURL(file);
            });

            refreshExistingCards();
        }

        function appendFiles(fileList) {
            Array.from(fileList || []).forEach(file => {
                if (!queuedFiles.some(existing => isSameFile(existing, file))) {
                    queuedFiles.push(file);
                }
            });

            syncInputFiles();
            ensureMainSelection();
            renderPreviews();
        }

        existingMainCards.forEach(card => {
            card.addEventListener('click', () => {
                selectedMainImageKey.value = card.dataset.mainKey;
                renderPreviews();
            });
        });

        input.addEventListener('change', function () {
            appendFiles(this.files);
        });

        ['dragenter', 'dragover'].forEach(eventName => {
            dropZone.addEventListener(eventName, function (event) {
                event.preventDefault();
                updateDropZoneState(true);
            });
        });

        ['dragleave', 'dragend', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, function (event) {
                event.preventDefault();
                updateDropZoneState(false);
            });
        });

        dropZone.addEventListener('drop', function (event) {
            appendFiles(event.dataTransfer.files);
        });

        ensureMainSelection();
        renderPreviews();
    </script>
}
