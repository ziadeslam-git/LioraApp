@using LioraApp.Models
@using LioraApp.Repositories.IRepositories
@using LioraApp.Utilities
@using Microsoft.AspNetCore.Identity
@inject IUnitOfWork UnitOfWork
@inject UserManager<ApplicationUser> UserManager
@{
    var currentAdminUser = User.Identity?.IsAuthenticated == true ? await UserManager.GetUserAsync(User) : null;
    var displayName = currentAdminUser?.FullName;
    var controller = ViewContext.RouteData.Values["Controller"]?.ToString() ?? string.Empty;
    var currentAdminSection = controller switch
    {
        "Dashboard" => "Dashboard",
        "Product" or "ProductVariants" or "ProductImages" => "Products",
        "GiftBundles" => "Gift Bundles",
        "Category" => "Categories",
        "Orders" => "Orders",
        "Users" => "Customers",
        "Discounts" => "Discounts",
        "Payments" => "Payments",
        _ => "Dashboard"
    };

    if (string.IsNullOrWhiteSpace(displayName))
    {
        var identityName = User.Identity?.Name;
        displayName = string.IsNullOrWhiteSpace(identityName)
            ? "Admin"
            : identityName.Contains('@')
                ? identityName.Split('@')[0]
                : identityName;
    }
}
<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>@ViewData["Title"] - Liora Admin</title>
    
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&amp;family=Playfair+Display:ital,wght@0,400..900;1,400..900&amp;family=EB+Garamond:ital,wght@0,400..800;1,400..800&amp;family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@fancyapps/ui@5.0/dist/fancybox/fancybox.css" />
    <link rel="icon" type="image/png" href="~/images/site-logo.png" asp-append-version="true" />
    <link rel="shortcut icon" href="~/images/site-logo.png" asp-append-version="true" />
    
    <script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              "colors": {
                      "on-primary": "#ffffff",
                      "on-tertiary-fixed-variant": "#4b4450",
                      "secondary-fixed-dim": "#d1c0de",
                      "on-secondary-container": "#6c5f79",
                      "surface-variant": "#e8e1db",
                      "secondary": "#665972",
                      "on-tertiary": "#ffffff",
                      "inverse-on-surface": "#f7efe9",
                      "surface-dim": "#dfd9d3",
                      "primary": "#7f5446",
                      "surface-container-low": "#f9f2ec",
                      "on-secondary-fixed": "#21172c",
                      "tertiary": "#635b68",
                      "error-container": "#ffdad6",
                      "background": "#fff8f3",
                      "secondary-container": "#eedcfa",
                      "inverse-primary": "#f2baa8",
                      "surface-container": "#f4ede7",
                      "primary-fixed-dim": "#f2baa8",
                      "tertiary-fixed-dim": "#cec3d2",
                      "on-secondary-fixed-variant": "#4e425a",
                      "surface-container-highest": "#e8e1db",
                      "on-error": "#ffffff",
                      "on-tertiary-container": "#38313d",
                      "on-background": "#1e1b18",
                      "inverse-surface": "#33302c",
                      "surface-container-lowest": "#ffffff",
                      "error": "#ba1a1a",
                      "surface-tint": "#7f5446",
                      "tertiary-fixed": "#eadfee",
                      "surface": "#fff8f3",
                      "outline": "#83746f",
                      "on-primary-fixed-variant": "#643d30",
                      "primary-container": "#c49080",
                      "secondary-fixed": "#eedcfa",
                      "on-tertiary-fixed": "#1f1924",
                      "on-primary-container": "#4e2a1f",
                      "surface-bright": "#fff8f3",
                      "on-error-container": "#93000a",
                      "primary-fixed": "#ffdbd0",
                      "tertiary-container": "#a299a7",
                      "on-surface-variant": "#514440",
                      "on-surface": "#1e1b18",
                      "on-primary-fixed": "#311309",
                      "outline-variant": "#d5c2bd",
                      "surface-container-high": "#eee7e1",
                      "on-secondary": "#ffffff"
              },
              "borderRadius": {
                      "DEFAULT": "0.25rem",
                      "lg": "0.5rem",
                      "xl": "0.75rem",
                      "full": "9999px"
              },
              "spacing": {
                      "stack-sm": "8px",
                      "stack-md": "16px",
                      "unit": "8px",
                      "section-gap": "120px",
                      "stack-lg": "32px",
                      "gutter": "24px",
                      "container-padding-mobile": "20px",
                      "container-padding-desktop": "64px"
              },
              "fontFamily": {
                      "headline-lg": ["Playfair Display"],
                      "body-lg": ["DM Sans"],
                      "display-lg": ["Playfair Display"],
                      "body-md": ["DM Sans"],
                      "label-caps": ["DM Sans"],
                      "headline-md": ["Playfair Display"],
                      "accent-italic": ["EB Garamond"],
                      "headline-lg-mobile": ["Playfair Display"],
                      "display-lg-mobile": ["Playfair Display"]
              }
            }
          }
        }
    </script>
    <style>
        .font-mono { font-family: 'DM Mono', monospace; }
        .ambient-shadow-1 { box-shadow: 0px 10px 30px rgba(26, 16, 37, 0.05); }
        .ambient-shadow-2 { box-shadow: 0px 20px 50px rgba(26, 16, 37, 0.08); }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-background text-on-background antialiased font-body-md bg-surface-container-low">

    <!-- TopNavBar -->
    <header id="top-navbar" class="fixed top-0 right-0 h-[60px] w-full md:w-[calc(100%-240px)] transition-all duration-300 border-b border-outline-variant bg-surface-container text-primary flex items-center justify-between px-4 md:px-gutter z-50">
        <div class="flex items-center gap-3">
            <!-- Hamburger Menu for Desktop Collapse -->
            <button id="sidebar-toggle" class="hidden md:flex p-2 text-on-surface-variant hover:bg-surface-container-highest rounded-full transition-colors cursor-pointer">
                <span class="material-symbols-outlined">menu</span>
            </button>
            <div class="md:hidden font-bold text-lg text-primary flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg bg-primary text-white flex items-center justify-center font-bold">L</div>
                Liora Admin
            </div>
            <!-- Go to Store (Desktop + Mobile) -->
            <a asp-area="Customer" asp-controller="Home" asp-action="Index" title="Back to Store" class="flex items-center gap-1.5 px-3 py-1.5 text-on-surface-variant hover:text-primary hover:bg-surface-container-highest rounded-full transition-all duration-200 text-sm font-medium">
                <span class="material-symbols-outlined text-[18px]">storefront</span>
                <span class="hidden md:block">Visit Store</span>
            </a>
        </div>
        <div class="flex items-center gap-2 md:gap-3 relative">
            <!-- Notification Bell with Dropdown -->
            <div class="relative" id="notif-wrapper">
                <button id="notif-btn" onclick="toggleNotifPanel()" class="p-2 text-on-surface-variant hover:bg-surface-container-highest rounded-full transition-colors cursor-pointer active:scale-95 relative">
                    <span class="material-symbols-outlined">notifications</span>
                    <span class="absolute top-1 right-1 w-2 h-2 rounded-full bg-error"></span>
                </button>
                <!-- Notification Dropdown Panel -->
                <div id="notif-panel" class="hidden absolute right-0 top-[calc(100%+8px)] w-80 bg-surface rounded-2xl shadow-[0_20px_60px_rgba(0,0,0,0.12)] border border-outline-variant/30 overflow-hidden z-[100]">
                    <div class="flex items-center justify-between px-4 py-3 border-b border-outline-variant/20">
                        <h4 class="font-semibold text-sm text-on-surface">Notifications</h4>
                        <button onclick="toggleNotifPanel()" class="p-1 rounded-full hover:bg-surface-container text-on-surface-variant transition-colors"><span class="material-symbols-outlined text-[16px]">close</span></button>
                    </div>
                    <div class="flex flex-col divide-y divide-outline-variant/10">
                        @if (ViewBag.PendingOrdersForNav != null && (int)ViewBag.PendingOrdersForNav > 0)
                        {
                            <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="flex gap-3 items-start px-4 py-3 hover:bg-surface-container-low transition-colors">
                                <div class="w-8 h-8 rounded-full bg-orange-100 text-orange-600 flex items-center justify-center shrink-0 mt-0.5">
                                    <span class="material-symbols-outlined text-[16px]">hourglass_empty</span>
                                </div>
                                <div>
                                    <p class="text-sm font-medium text-on-surface">@ViewBag.PendingOrdersForNav Pending Orders</p>
                                    <p class="text-xs text-on-surface-variant">Require payment verification</p>
                                </div>
                            </a>
                        }
                        else
                        {
                            <div class="flex flex-col items-center justify-center py-10 gap-2 text-on-surface-variant">
                                <span class="material-symbols-outlined text-3xl">notifications_none</span>
                                <p class="text-sm font-medium">You're all caught up!</p>
                                <p class="text-xs">No new notifications.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <form asp-area="Identity" asp-controller="Account" asp-action="Logout" method="post" id="logoutForm-admin"></form>
            <button type="button" onclick="document.getElementById('logoutForm-admin').submit();" title="Logout" class="p-2 text-on-surface-variant hover:bg-surface-container-highest rounded-full transition-colors cursor-pointer active:scale-95">
                <span class="material-symbols-outlined">logout</span>
            </button>
        </div>
    </header>

    <!-- Desktop SideNavBar -->
    <nav id="desktop-sidebar" class="hidden md:flex fixed left-0 top-0 h-full w-[240px] bg-slate-900 text-slate-300 font-body-md flex-col overflow-y-auto z-40 shadow-xl transition-all duration-300">
        <div class="p-6 h-[60px] border-b border-slate-700/50 flex items-center gap-3 overflow-hidden shrink-0">
            <div class="w-8 h-8 shrink-0 rounded-lg bg-primary flex items-center justify-center text-white font-bold text-lg">L</div>
            <div class="sidebar-text whitespace-nowrap">
                <h2 class="font-bold text-sm text-white">Liora Admin</h2>
                <p class="text-[10px] text-slate-400 uppercase tracking-wider">@displayName</p>
            </div>
        </div>
        
        <div class="py-4 px-3 flex-1 flex flex-col gap-1">
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="flex items-center gap-3 px-3 py-3 @(controller == "Dashboard" ? "bg-primary text-white" : "hover:text-white hover:bg-slate-800") rounded-xl transition-all group" title="Overview">
                <span class="material-symbols-outlined shrink-0 text-[20px]">dashboard</span>
                <span class="font-medium sidebar-text whitespace-nowrap">Overview</span>
            </a>
            <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="flex items-center gap-3 px-3 py-3 @(controller == "Product" || controller == "ProductVariants" ? "bg-primary text-white" : "hover:text-white hover:bg-slate-800") rounded-xl transition-all group" title="Products">
                <span class="material-symbols-outlined shrink-0 text-[20px]">inventory_2</span>
                <span class="font-medium sidebar-text whitespace-nowrap">Products</span>
            </a>
            <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="flex items-center gap-3 px-3 py-3 @(controller == "Category" ? "bg-primary text-white" : "hover:text-white hover:bg-slate-800") rounded-xl transition-all group" title="Categories">
                <span class="material-symbols-outlined shrink-0 text-[20px]">category</span>
                <span class="font-medium sidebar-text whitespace-nowrap">Categories</span>
            </a>
            <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="flex items-center gap-3 px-3 py-3 @(controller == "Orders" ? "bg-primary text-white" : "hover:text-white hover:bg-slate-800") rounded-xl transition-all group" title="Orders">
                <span class="material-symbols-outlined shrink-0 text-[20px]">receipt_long</span>
                <span class="font-medium sidebar-text whitespace-nowrap">Orders</span>
            </a>
            <a asp-area="Admin" asp-controller="Payments" asp-action="Index" class="flex items-center gap-3 px-3 py-3 @(controller == "Payments" ? "bg-primary text-white" : "hover:text-white hover:bg-slate-800") rounded-xl transition-all group" title="Payments">
                <span class="material-symbols-outlined shrink-0 text-[20px]">payments</span>
                <span class="font-medium sidebar-text whitespace-nowrap">Payments</span>
            </a>
            <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="flex items-center gap-3 px-3 py-3 @(controller == "Users" ? "bg-primary text-white" : "hover:text-white hover:bg-slate-800") rounded-xl transition-all group" title="Customers">
                <span class="material-symbols-outlined shrink-0 text-[20px]">group</span>
                <span class="font-medium sidebar-text whitespace-nowrap">Customers</span>
            </a>
            <a asp-area="Admin" asp-controller="Discounts" asp-action="Index" class="flex items-center gap-3 px-3 py-3 @(controller == "Discounts" ? "bg-primary text-white" : "hover:text-white hover:bg-slate-800") rounded-xl transition-all group" title="Discounts">
                <span class="material-symbols-outlined shrink-0 text-[20px]">sell</span>
                <span class="font-medium sidebar-text whitespace-nowrap">Discounts</span>
            </a>
            <a asp-area="Admin" asp-controller="GiftBundles" asp-action="Index" class="flex items-center gap-3 px-3 py-3 @(controller == "GiftBundles" ? "bg-primary text-white" : "hover:text-white hover:bg-slate-800") rounded-xl transition-all group" title="Gift Bundles">
                <span class="material-symbols-outlined shrink-0 text-[20px]">redeem</span>
                <span class="font-medium sidebar-text whitespace-nowrap">Gift Bundles</span>
            </a>
        </div>
        
        <div class="p-4 mt-auto border-t border-slate-700/50 shrink-0">
            <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="w-full py-3 px-3 bg-slate-800 text-white rounded-xl text-xs font-medium hover:bg-slate-700 transition-all flex items-center justify-center gap-2 overflow-hidden" title="Go Home">
                <span class="material-symbols-outlined shrink-0 text-sm">home</span>
                <span class="sidebar-text whitespace-nowrap">Go Home</span>
            </a>
        </div>
    </nav>

    <!-- Mobile Bottom Nav -->
    <nav class="md:hidden fixed bottom-0 left-0 w-full h-[70px] bg-white border-t border-slate-100 flex items-center justify-around z-40 px-2 shadow-[0_-10px_40px_rgba(0,0,0,0.05)] pb-safe rounded-t-[20px]">
        <!-- Dashboard -->
        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="relative flex flex-col items-center justify-center w-full h-full group">
            @if(controller == "Dashboard") {
                <div class="absolute -top-6 w-14 h-14 bg-primary text-white rounded-full flex items-center justify-center shadow-lg border-4 border-surface-container-low transition-all duration-300">
                    <span class="material-symbols-outlined text-[26px]">dashboard</span>
                </div>
                <span class="text-[10px] mt-8 font-bold text-primary">Home</span>
            } else {
                <span class="material-symbols-outlined text-[24px] text-slate-400 group-hover:text-primary transition-colors">dashboard</span>
                <span class="text-[10px] mt-1 font-medium text-slate-400 group-hover:text-primary transition-colors">Home</span>
            }
        </a>
        <!-- Product -->
        <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="relative flex flex-col items-center justify-center w-full h-full group">
            @if(controller == "Product" || controller == "ProductVariants" || controller == "ProductImages") {
                <div class="absolute -top-6 w-14 h-14 bg-primary text-white rounded-full flex items-center justify-center shadow-lg border-4 border-surface-container-low transition-all duration-300">
                    <span class="material-symbols-outlined text-[26px]">inventory_2</span>
                </div>
                <span class="text-[10px] mt-8 font-bold text-primary">Products</span>
            } else {
                <span class="material-symbols-outlined text-[24px] text-slate-400 group-hover:text-primary transition-colors">inventory_2</span>
                <span class="text-[10px] mt-1 font-medium text-slate-400 group-hover:text-primary transition-colors">Products</span>
            }
        </a>
        <!-- Orders -->
        <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="relative flex flex-col items-center justify-center w-full h-full group">
            @if(controller == "Orders") {
                <div class="absolute -top-6 w-14 h-14 bg-primary text-white rounded-full flex items-center justify-center shadow-lg border-4 border-surface-container-low transition-all duration-300">
                    <span class="material-symbols-outlined text-[26px]">receipt_long</span>
                </div>
                <span class="text-[10px] mt-8 font-bold text-primary">Orders</span>
            } else {
                <span class="material-symbols-outlined text-[24px] text-slate-400 group-hover:text-primary transition-colors">receipt_long</span>
                <span class="text-[10px] mt-1 font-medium text-slate-400 group-hover:text-primary transition-colors">Orders</span>
            }
        </a>
        <!-- Payments -->
        <a asp-area="Admin" asp-controller="Payments" asp-action="Index" class="relative flex flex-col items-center justify-center w-full h-full group">
            @if(controller == "Payments") {
                <div class="absolute -top-6 w-14 h-14 bg-primary text-white rounded-full flex items-center justify-center shadow-lg border-4 border-surface-container-low transition-all duration-300">
                    <span class="material-symbols-outlined text-[26px]">payments</span>
                </div>
                <span class="text-[10px] mt-8 font-bold text-primary">Payments</span>
            } else {
                <span class="material-symbols-outlined text-[24px] text-slate-400 group-hover:text-primary transition-colors">payments</span>
                <span class="text-[10px] mt-1 font-medium text-slate-400 group-hover:text-primary transition-colors">Payments</span>
            }
        </a>
        <!-- More Menu -->
        <button onclick="toggleMobileMenu()" class="relative flex flex-col items-center justify-center w-full h-full group cursor-pointer">
            <span class="material-symbols-outlined text-[24px] text-slate-400 group-hover:text-primary transition-colors">grid_view</span>
            <span class="text-[10px] mt-1 font-medium text-slate-400 group-hover:text-primary transition-colors">More</span>
        </button>
    </nav>

    <!-- Mobile More Menu Overlay -->
    <div id="mobile-more-menu" class="md:hidden fixed inset-0 bg-black/60 z-[60] hidden flex-col justify-end transition-opacity duration-300 opacity-0 backdrop-blur-sm">
        <div class="bg-surface w-full rounded-t-[32px] p-6 pb-12 transform translate-y-full transition-transform duration-300 shadow-[0_-10px_40px_rgba(0,0,0,0.1)]" id="mobile-more-menu-content">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-headline-md text-2xl text-on-surface font-bold">More Pages</h3>
                <button onclick="toggleMobileMenu()" class="p-2 bg-surface-variant rounded-full text-on-surface-variant hover:bg-primary-container hover:text-primary transition-colors"><span class="material-symbols-outlined text-[20px]">close</span></button>
            </div>
            <div class="grid grid-cols-4 gap-4">
                <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="flex flex-col items-center gap-2 p-3 rounded-2xl @(controller == "Category" ? "bg-primary text-white" : "bg-surface-container-low text-on-surface-variant hover:bg-primary-container/20 hover:text-primary") transition-colors">
                    <span class="material-symbols-outlined">category</span>
                    <span class="text-[11px] font-bold">Category</span>
                </a>
                <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="flex flex-col items-center gap-2 p-3 rounded-2xl @(controller == "Users" ? "bg-primary text-white" : "bg-surface-container-low text-on-surface-variant hover:bg-primary-container/20 hover:text-primary") transition-colors">
                    <span class="material-symbols-outlined">group</span>
                    <span class="text-[11px] font-bold">Customers</span>
                </a>
                <a asp-area="Admin" asp-controller="Discounts" asp-action="Index" class="flex flex-col items-center gap-2 p-3 rounded-2xl @(controller == "Discounts" ? "bg-primary text-white" : "bg-surface-container-low text-on-surface-variant hover:bg-primary-container/20 hover:text-primary") transition-colors">
                    <span class="material-symbols-outlined">sell</span>
                    <span class="text-[11px] font-bold">Offers</span>
                </a>
                <a asp-area="Admin" asp-controller="GiftBundles" asp-action="Index" class="flex flex-col items-center gap-2 p-3 rounded-2xl @(controller == "GiftBundles" ? "bg-primary text-white" : "bg-surface-container-low text-on-surface-variant hover:bg-primary-container/20 hover:text-primary") transition-colors">
                    <span class="material-symbols-outlined">redeem</span>
                    <span class="text-[11px] font-bold">Bundles</span>
                </a>
            </div>
        </div>
    </div>

    <!-- Main Canvas -->
    <main id="main-canvas" class="md:ml-[240px] pt-[100px] md:pt-[112px] pb-[90px] md:pb-8 min-h-screen flex flex-col relative overflow-x-hidden px-4 md:px-8 transition-all duration-300">
        <div class="max-w-7xl mx-auto w-full flex flex-col flex-1">
            @if (TempData["Success"] != null || TempData["success"] != null)
            {
                <div class="mb-6 flex items-center gap-3 bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-xl text-sm font-medium">
                    <span class="material-symbols-outlined text-lg">check_circle</span>
                    @(TempData["Success"] ?? TempData["success"])
                </div>
            }
            @if (TempData["Error"] != null || TempData["error"] != null)
            {
                <div class="mb-6 flex items-center gap-3 bg-rose-50 border border-rose-200 text-rose-700 px-4 py-3 rounded-xl text-sm font-medium">
                    <span class="material-symbols-outlined text-lg">error</span>
                    @(TempData["Error"] ?? TempData["error"])
                </div>
            }

            @RenderBody()
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/@@fancyapps/ui@5.0/dist/fancybox/fancybox.umd.js"></script>
    <script>
      Fancybox.bind('[data-fancybox]', {});
      
      const sidebarToggle = document.getElementById('sidebar-toggle');
      const desktopSidebar = document.getElementById('desktop-sidebar');
      const topNavbar = document.getElementById('top-navbar');
      const mainCanvas = document.getElementById('main-canvas');
      const sidebarTexts = document.querySelectorAll('.sidebar-text');

      let isCollapsed = false;

      sidebarToggle?.addEventListener('click', () => {
          isCollapsed = !isCollapsed;
          if (isCollapsed) {
              desktopSidebar.classList.remove('w-[240px]');
              desktopSidebar.classList.add('w-[80px]');
              topNavbar.classList.remove('md:w-[calc(100%-240px)]');
              topNavbar.classList.add('md:w-[calc(100%-80px)]');
              mainCanvas.classList.remove('md:ml-[240px]');
              mainCanvas.classList.add('md:ml-[80px]');
              sidebarTexts.forEach(el => el.classList.add('hidden'));
          } else {
              desktopSidebar.classList.remove('w-[80px]');
              desktopSidebar.classList.add('w-[240px]');
              topNavbar.classList.remove('md:w-[calc(100%-80px)]');
              topNavbar.classList.add('md:w-[calc(100%-240px)]');
              mainCanvas.classList.remove('md:ml-[80px]');
              mainCanvas.classList.add('md:ml-[240px]');
              sidebarTexts.forEach(el => el.classList.remove('hidden'));
          }
      });
      function toggleMobileMenu() {
          const menu = document.getElementById('mobile-more-menu');
          const content = document.getElementById('mobile-more-menu-content');
          if (menu.classList.contains('hidden')) {
              menu.classList.remove('hidden');
              menu.classList.add('flex');
              setTimeout(() => {
                  menu.classList.remove('opacity-0');
                  content.classList.remove('translate-y-full');
              }, 10);
          } else {
              menu.classList.add('opacity-0');
              content.classList.add('translate-y-full');
              setTimeout(() => {
                  menu.classList.remove('flex');
                  menu.classList.add('hidden');
              }, 300);
          }
      }

      // Notification panel toggle
      function toggleNotifPanel() {
          const panel = document.getElementById('notif-panel');
          panel.classList.toggle('hidden');
      }
      // Close notification panel on outside click
      document.addEventListener('click', function(e) {
          const wrapper = document.getElementById('notif-wrapper');
          const panel = document.getElementById('notif-panel');
          if (wrapper && panel && !wrapper.contains(e.target)) {
              panel.classList.add('hidden');
          }
      });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
