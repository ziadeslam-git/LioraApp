@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Discount Details";
}

<!-- Page Header -->
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <div class="flex items-center gap-4">
                    <a class="w-10 h-10 rounded-full bg-surface-container-highest flex items-center justify-center text-on-surface hover:bg-outline-variant/30 transition-colors btn-scale" asp-action="Index">
                        <span class="material-symbols-outlined text-xl">arrow_back</span>
                    </a>
                    <div>
                        <h2 class="font-headline-lg text-headline-lg text-on-surface tracking-tight">Discount Details</h2>
                        <div class="flex items-center gap-2 mt-1 text-sm text-on-surface-variant">
                            <a class="hover:text-primary transition-colors" asp-controller="Dashboard" asp-action="Index">Sales</a>
                            <span class="material-symbols-outlined text-xs">chevron_right</span>
                            <a class="hover:text-primary transition-colors" asp-action="Index">Discounts</a>
                            <span class="material-symbols-outlined text-xs">chevron_right</span>
                            <span class="text-on-surface font-medium">Summer Silk '24</span>
                        </div>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <span class="px-3 py-1 bg-primary-container/20 text-on-primary-container rounded-full font-label-caps text-[10px] flex items-center gap-1">
                        <span class="w-1.5 h-1.5 rounded-full bg-primary-container"></span>
                        Active
                    </span>
                </div>
            </div>
            <!-- Two Column Layout -->
            <div class="flex flex-col lg:flex-row gap-gutter">
                <!-- Left Column: Configuration (65%) -->
                <div class="w-full lg:w-[65%] flex flex-col gap-stack-lg">
                    <!-- Main Config Card -->
                    <div class="bg-surface-container-lowest rounded-[16px] p-stack-lg shadow-rose-sm border border-outline-variant/10">
                        <!-- Section 1: Overview -->
                        <div class="pb-stack-md border-b border-outline-variant/20 mb-stack-md">
                            <h3 class="font-headline-md text-headline-md text-xl mb-4">Overview</h3>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-stack-md">
                                <div>
                                    <label class="block text-xs font-label-caps text-on-surface-variant mb-1">Discount Name</label>
                                    <p class="font-body-lg text-body-lg text-on-surface font-medium">Summer Silk '24 Collection Launch</p>
                                </div>
                                <div>
                                    <label class="block text-xs font-label-caps text-on-surface-variant mb-1">Discount Code</label>
                                    <div class="inline-flex items-center gap-2 bg-surface-variant/50 px-3 py-1.5 rounded-lg border border-outline-variant/30">
                                        <span class="font-mono text-primary font-bold tracking-wider">SUMMERSILK20</span>
                                        <button class="text-on-surface-variant hover:text-primary transition-colors ml-2" title="Copy Code">
                                            <span class="material-symbols-outlined text-[16px]">content_copy</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Section 2: Configuration -->
                        <div class="pb-stack-md border-b border-outline-variant/20 mb-stack-md">
                            <h3 class="font-headline-md text-headline-md text-xl mb-4">Configuration</h3>
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-stack-md">
                                <div class="bg-surface-container-low p-4 rounded-xl border border-outline-variant/10">
                                    <span class="material-symbols-outlined text-primary mb-2">percent</span>
                                    <label class="block text-xs font-label-caps text-on-surface-variant mb-1">Type</label>
                                    <p class="font-body-md text-body-md text-on-surface font-medium">Percentage</p>
                                </div>
                                <div class="bg-surface-container-low p-4 rounded-xl border border-outline-variant/10">
                                    <span class="material-symbols-outlined text-primary mb-2">sell</span>
                                    <label class="block text-xs font-label-caps text-on-surface-variant mb-1">Value</label>
                                    <p class="font-body-md text-body-md text-on-surface font-medium">20% Off</p>
                                </div>
                                <div class="bg-surface-container-low p-4 rounded-xl border border-outline-variant/10">
                                    <span class="material-symbols-outlined text-primary mb-2">shopping_bag</span>
                                    <label class="block text-xs font-label-caps text-on-surface-variant mb-1">Min. Requirement</label>
                                    <p class="font-body-md text-body-md text-on-surface font-medium">2 Items</p>
                                </div>
                            </div>
                        </div>
                        <!-- Section 3: Applies To -->
                        <div class="pb-stack-md border-b border-outline-variant/20 mb-stack-md">
                            <h3 class="font-headline-md text-headline-md text-xl mb-4">Applies To</h3>
                            <div class="flex flex-wrap gap-2">
                                <span class="px-4 py-2 bg-secondary-container/50 text-on-secondary-container rounded-full text-sm font-medium border border-secondary/20">Specific Categories</span>
                                <span class="px-4 py-2 bg-surface-container-highest text-on-surface rounded-full text-sm flex items-center gap-2">
                                    Silk Blouses
                                </span>
                                <span class="px-4 py-2 bg-surface-container-highest text-on-surface rounded-full text-sm flex items-center gap-2">
                                    Evening Wear
                                </span>
                            </div>
                        </div>
                        <!-- Section 4: Usage Limits -->
                        <div class="pb-stack-md border-b border-outline-variant/20 mb-stack-md">
                            <h3 class="font-headline-md text-headline-md text-xl mb-4 flex items-center justify-between">
                                Usage Limits
                                <span class="text-sm font-body-md text-on-surface-variant font-normal">342 / 500 Used</span>
                            </h3>
                            <div class="w-full bg-surface-variant rounded-full h-2.5 mb-2 overflow-hidden">
                                <div class="bg-primary-container h-2.5 rounded-full" style="width: 68%"></div>
                            </div>
                            <p class="text-xs text-on-surface-variant mt-2">Limited to 1 per customer.</p>
                        </div>
                        <!-- Section 5: Schedule -->
                        <div>
                            <h3 class="font-headline-md text-headline-md text-xl mb-4">Schedule</h3>
                            <div class="flex flex-col sm:flex-row gap-4">
                                <div class="flex-1 flex items-center gap-3 p-4 bg-surface-container-low rounded-xl border border-outline-variant/10">
                                    <div class="w-10 h-10 rounded-full bg-surface-container-highest flex items-center justify-center text-primary">
                                        <span class="material-symbols-outlined">event</span>
                                    </div>
                                    <div>
                                        <p class="text-xs font-label-caps text-on-surface-variant">Starts</p>
                                        <p class="text-sm font-medium text-on-surface">Jun 1, 2024 • 12:00 AM</p>
                                    </div>
                                </div>
                                <div class="flex-1 flex items-center gap-3 p-4 bg-surface-container-low rounded-xl border border-outline-variant/10">
                                    <div class="w-10 h-10 rounded-full bg-surface-container-highest flex items-center justify-center text-primary">
                                        <span class="material-symbols-outlined">event_busy</span>
                                    </div>
                                    <div>
                                        <p class="text-xs font-label-caps text-on-surface-variant">Ends</p>
                                        <p class="text-sm font-medium text-on-surface">Aug 31, 2024 • 11:59 PM</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Right Column: Sidebar (35%) -->
                <div class="w-full lg:w-[35%] flex flex-col gap-stack-lg">
                    <!-- Performance Summary Card -->
                    <div class="bg-surface-container-lowest rounded-[16px] p-stack-lg shadow-rose-sm border border-outline-variant/10">
                        <h3 class="font-headline-md text-headline-md text-xl mb-6 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary-container">monitoring</span>
                            Performance
                        </h3>
                        <div class="flex flex-col gap-6">
                            <div class="flex justify-between items-end pb-4 border-b border-outline-variant/10">
                                <div>
                                    <p class="text-xs font-label-caps text-on-surface-variant mb-1">Total Orders</p>
                                    <p class="font-headline-lg text-headline-lg text-3xl text-on-surface">342</p>
                                </div>
                                <span class="material-symbols-outlined text-outline-variant/50 text-4xl">shopping_cart</span>
                            </div>
                            <div class="flex justify-between items-end pb-4 border-b border-outline-variant/10">
                                <div>
                                    <p class="text-xs font-label-caps text-on-surface-variant mb-1">Total Revenue Saved</p>
                                    <p class="font-headline-lg text-headline-lg text-3xl text-on-surface">£4,250</p>
                                </div>
                                <span class="material-symbols-outlined text-outline-variant/50 text-4xl">savings</span>
                            </div>
                            <div class="flex justify-between items-end">
                                <div>
                                    <p class="text-xs font-label-caps text-on-surface-variant mb-1">Avg. Order Value (w/ Disc)</p>
                                    <p class="font-headline-lg text-headline-lg text-3xl text-on-surface">£185</p>
                                </div>
                                <span class="material-symbols-outlined text-outline-variant/50 text-4xl">receipt_long</span>
                            </div>
                        </div>
                    </div>
                    <!-- Quick Actions -->
                    <div class="bg-surface-container-lowest rounded-[16px] p-stack-md shadow-rose-sm border border-outline-variant/10 flex flex-col gap-3">
                        <button class="w-full py-3 bg-primary-container text-on-primary-container rounded-full font-label-caps text-label-caps btn-scale hover:bg-primary hover:text-on-primary transition-colors flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-[18px]">edit</span>
                            Edit Discount
                        </button>
                        <button class="w-full py-3 bg-transparent border border-outline-variant text-on-surface rounded-full font-label-caps text-label-caps btn-scale hover:bg-surface-variant transition-colors flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-[18px]">content_copy</span>
                            Duplicate
                        </button>
                        <div class="mt-2 pt-4 border-t border-outline-variant/20 flex items-center justify-between px-2">
                            <span class="text-sm font-medium text-on-surface">Discount Status</span>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input checked="" class="sr-only peer" type="checkbox" value="" />
                                <div class="w-11 h-6 bg-surface-variant peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary-container"></div>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Bottom Section: Usage History -->
            <div class="bg-surface-container-lowest rounded-[16px] shadow-rose-sm border border-outline-variant/10 overflow-hidden">
                <div class="p-stack-md border-b border-outline-variant/20 flex justify-between items-center bg-surface-container-low/50">
                    <h3 class="font-headline-md text-headline-md text-xl">Recent Usage History</h3>
                    <button class="text-sm text-primary hover:text-primary-container transition-colors font-medium">View All</button>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm text-on-surface">
                        <thead class="text-xs font-label-caps text-on-surface-variant bg-surface-container-highest/30">
                            <tr>
                                <th class="px-6 py-4 font-normal" scope="col">Order #</th>
                                <th class="px-6 py-4 font-normal" scope="col">Customer Name</th>
                                <th class="px-6 py-4 font-normal" scope="col">Date</th>
                                <th class="px-6 py-4 font-normal text-right" scope="col">Savings (LE)</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant/10">
                            <tr class="hover:bg-surface-container-low/50 transition-colors">
                                <td class="px-6 py-4 font-mono font-medium text-primary">#ORD-9021</td>
                                <td class="px-6 py-4">Amina El-Sayed</td>
                                <td class="px-6 py-4 text-on-surface-variant">Today, 10:42 AM</td>
                                <td class="px-6 py-4 text-right font-medium">£45.00</td>
                            </tr>
                            <tr class="hover:bg-surface-container-low/50 transition-colors">
                                <td class="px-6 py-4 font-mono font-medium text-primary">#ORD-9018</td>
                                <td class="px-6 py-4">Nour Youssef</td>
                                <td class="px-6 py-4 text-on-surface-variant">Yesterday, 04:15 PM</td>
                                <td class="px-6 py-4 text-right font-medium">£82.50</td>
                            </tr>
                            <tr class="hover:bg-surface-container-low/50 transition-colors">
                                <td class="px-6 py-4 font-mono font-medium text-primary">#ORD-8994</td>
                                <td class="px-6 py-4">Salma Hassan</td>
                                <td class="px-6 py-4 text-on-surface-variant">Jul 24, 02:30 PM</td>
                                <td class="px-6 py-4 text-right font-medium">£120.00</td>
                            </tr>
                            <tr class="hover:bg-surface-container-low/50 transition-colors">
                                <td class="px-6 py-4 font-mono font-medium text-primary">#ORD-8982</td>
                                <td class="px-6 py-4">Farida Kamel</td>
                                <td class="px-6 py-4 text-on-surface-variant">Jul 23, 09:12 AM</td>
                                <td class="px-6 py-4 text-right font-medium">£30.00</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
