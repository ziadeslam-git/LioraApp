@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Liora Admin - Discounts";
}

<!-- Header Section -->
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-stack-lg gap-6">
            <div>
                <div class="flex items-center gap-4 mb-2">
                    <h2 class="font-headline-lg text-headline-lg text-on-surface">Discounts</h2>
                    <span class="bg-surface-variant text-on-surface-variant font-label-caps text-label-caps px-3 py-1 rounded-full border border-outline-variant/50">24 Active</span>
                </div>
                <p class="font-body-md text-body-md text-on-surface-variant">Manage promotional codes, automatic discounts, and sales events.</p>
            </div>
            <div>
                <button class="flex items-center gap-2 bg-primary-container text-on-primary-container px-6 py-3 rounded-full font-label-caps text-label-caps shadow-[0px_10px_30px_rgba(26,16,37,0.05)] hover:shadow-[0px_20px_50px_rgba(26,16,37,0.08)] transition-all duration-250 scale-98 active:scale-95 ease-out">
                    <span class="material-symbols-outlined text-sm">add</span>
                    Create New Discount
                </button>
            </div>
        </div>
        <!-- Table Container -->
        <div class="bg-surface-container-lowest rounded-[16px] shadow-[0px_10px_30px_rgba(26,16,37,0.05)] border border-outline-variant/20 overflow-hidden">
            <!-- Table Filters (Simplified) -->
            <div class="p-6 border-b border-outline-variant/20 flex gap-4 items-center bg-surface-container-low/50">
                <div class="relative w-64">
                    <span class="material-symbols-outlined absolute left-3 top-2.5 text-on-surface-variant text-xl">search</span>
                    <input class="w-full pl-10 pr-4 py-2 bg-surface border border-outline-variant/30 rounded-lg font-body-md text-body-md focus:outline-none focus:border-primary-container focus:ring-1 focus:ring-primary-container transition-all" placeholder="Search discounts..." type="text" />
                </div>
                <button class="flex items-center gap-2 px-4 py-2 bg-surface border border-outline-variant/30 rounded-lg text-on-surface-variant font-body-md text-body-md hover:bg-surface-variant transition-colors">
                    <span class="material-symbols-outlined text-sm">filter_list</span>
                    Filter
                </button>
            </div>
            <!-- Data Table -->
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-outline-variant/20 bg-surface-container-low/30">
                            <th class="py-4 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider">Code / Name</th>
                            <th class="py-4 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider">Type &amp; Value</th>
                            <th class="py-4 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider">Applies To</th>
                            <th class="py-4 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider">Usage</th>
                            <th class="py-4 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider">Active Period</th>
                            <th class="py-4 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider">Status</th>
                            <th class="py-4 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant/10">
                        <!-- Row 1 -->
                        <tr class="hover:bg-surface-container-low/50 transition-colors duration-250 group">
                            <td class="py-4 px-6">
                                <div class="font-body-md text-body-md font-bold text-primary-container tracking-wide">SUMMER25</div>
                                <div class="font-body-md text-body-md text-sm text-on-surface-variant mt-1">Summer Collection Launch</div>
                            </td>
                            <td class="py-4 px-6">
                                <div class="flex items-center gap-2">
                                    <span class="bg-surface-variant text-on-surface-variant text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-md">Percentage</span>
                                    <span class="bg-primary-container/20 text-primary-container font-label-caps text-label-caps px-3 py-1 rounded-full">25% OFF</span>
                                </div>
                            </td>
                            <td class="py-4 px-6">
                                <div class="flex gap-2">
                                    <span class="bg-tertiary-container/20 text-tertiary-container font-body-md text-xs px-2 py-1 rounded-md">Category: Summer</span>
                                </div>
                            </td>
                            <td class="py-4 px-6">
                                <div class="font-body-md text-sm text-on-surface mb-1">45 / 100</div>
                                <div class="w-24 h-1.5 bg-surface-variant rounded-full overflow-hidden">
                                    <div class="h-full bg-primary-container w-[45%]"></div>
                                </div>
                            </td>
                            <td class="py-4 px-6 font-body-md text-sm text-on-surface">
                                Jun 1 - Aug 31
                            </td>
                            <td class="py-4 px-6">
                                <span class="bg-emerald-100 text-emerald-800 text-xs font-bold px-2.5 py-1 rounded-full border border-emerald-200">Active</span>
                            </td>
                            <td class="py-4 px-6 text-right">
                                <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-250">
                                    <button class="p-2 text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined text-sm">visibility</span></button>
                                    <button class="p-2 text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined text-sm">edit</span></button>
                                    <button class="p-2 text-error hover:text-error/80 transition-colors"><span class="material-symbols-outlined text-sm">delete</span></button>
                                </div>
                            </td>
                        </tr>
                        <!-- Row 2 -->
                        <tr class="hover:bg-surface-container-low/50 transition-colors duration-250 group">
                            <td class="py-4 px-6">
                                <div class="font-body-md text-body-md font-bold text-primary-container tracking-wide">WELCOME10</div>
                                <div class="font-body-md text-body-md text-sm text-on-surface-variant mt-1">New Subscriber Bonus</div>
                            </td>
                            <td class="py-4 px-6">
                                <div class="flex items-center gap-2">
                                    <span class="bg-surface-variant text-on-surface-variant text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-md">Fixed Amount</span>
                                    <span class="bg-primary-container/20 text-primary-container font-label-caps text-label-caps px-3 py-1 rounded-full">LE 500</span>
                                </div>
                            </td>
                            <td class="py-4 px-6">
                                <div class="flex gap-2">
                                    <span class="bg-tertiary-container/20 text-tertiary-container font-body-md text-xs px-2 py-1 rounded-md border border-tertiary-container/20">All Products</span>
                                </div>
                            </td>
                            <td class="py-4 px-6">
                                <div class="font-body-md text-sm text-on-surface mb-1">892 / ∞</div>
                                <div class="w-24 h-1.5 bg-surface-variant rounded-full overflow-hidden">
                                    <div class="h-full bg-primary-container w-[100%]"></div>
                                </div>
                            </td>
                            <td class="py-4 px-6 font-body-md text-sm text-on-surface-variant italic">
                                No end date
                            </td>
                            <td class="py-4 px-6">
                                <span class="bg-emerald-100 text-emerald-800 text-xs font-bold px-2.5 py-1 rounded-full border border-emerald-200">Active</span>
                            </td>
                            <td class="py-4 px-6 text-right">
                                <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-250">
                                    <button class="p-2 text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined text-sm">visibility</span></button>
                                    <button class="p-2 text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined text-sm">edit</span></button>
                                    <button class="p-2 text-error hover:text-error/80 transition-colors"><span class="material-symbols-outlined text-sm">delete</span></button>
                                </div>
                            </td>
                        </tr>
                        <!-- Row 3 -->
                        <tr class="hover:bg-surface-container-low/50 transition-colors duration-250 group">
                            <td class="py-4 px-6">
                                <div class="font-body-md text-body-md font-bold text-outline tracking-wide line-through">WINTERFLASH</div>
                                <div class="font-body-md text-body-md text-sm text-on-surface-variant mt-1">48h Winter Clearance</div>
                            </td>
                            <td class="py-4 px-6">
                                <div class="flex items-center gap-2 opacity-70">
                                    <span class="bg-surface-variant text-on-surface-variant text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-md">Percentage</span>
                                    <span class="bg-outline-variant/30 text-outline font-label-caps text-label-caps px-3 py-1 rounded-full">40% OFF</span>
                                </div>
                            </td>
                            <td class="py-4 px-6 opacity-70">
                                <div class="flex gap-2">
                                    <span class="bg-tertiary-container/20 text-tertiary-container font-body-md text-xs px-2 py-1 rounded-md">Category: Outerwear</span>
                                </div>
                            </td>
                            <td class="py-4 px-6 opacity-70">
                                <div class="font-body-md text-sm text-on-surface mb-1">200 / 200</div>
                                <div class="w-24 h-1.5 bg-surface-variant rounded-full overflow-hidden">
                                    <div class="h-full bg-outline w-[100%]"></div>
                                </div>
                            </td>
                            <td class="py-4 px-6 font-body-md text-sm text-on-surface opacity-70">
                                Jan 15 - Jan 17
                            </td>
                            <td class="py-4 px-6">
                                <span class="bg-surface-variant text-on-surface-variant text-xs font-bold px-2.5 py-1 rounded-full border border-outline-variant/50">Expired</span>
                            </td>
                            <td class="py-4 px-6 text-right">
                                <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-250">
                                    <button class="p-2 text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined text-sm">visibility</span></button>
                                </div>
                            </td>
                        </tr>
                        <!-- Row 4 -->
                        <tr class="hover:bg-surface-container-low/50 transition-colors duration-250 group">
                            <td class="py-4 px-6">
                                <div class="font-body-md text-body-md font-bold text-primary-container tracking-wide">EIDMUBARAK</div>
                                <div class="font-body-md text-body-md text-sm text-on-surface-variant mt-1">Eid Special Collection</div>
                            </td>
                            <td class="py-4 px-6">
                                <div class="flex items-center gap-2">
                                    <span class="bg-surface-variant text-on-surface-variant text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-md">Percentage</span>
                                    <span class="bg-primary-container/20 text-primary-container font-label-caps text-label-caps px-3 py-1 rounded-full">15% OFF</span>
                                </div>
                            </td>
                            <td class="py-4 px-6">
                                <div class="flex gap-2">
                                    <span class="bg-tertiary-container/20 text-tertiary-container font-body-md text-xs px-2 py-1 rounded-md">Tag: Eid</span>
                                </div>
                            </td>
                            <td class="py-4 px-6">
                                <div class="font-body-md text-sm text-on-surface mb-1">0 / 500</div>
                                <div class="w-24 h-1.5 bg-surface-variant rounded-full overflow-hidden">
                                    <div class="h-full bg-primary-container w-[0%]"></div>
                                </div>
                            </td>
                            <td class="py-4 px-6 font-body-md text-sm text-on-surface">
                                Starts Apr 5
                            </td>
                            <td class="py-4 px-6">
                                <span class="bg-amber-100 text-amber-800 text-xs font-bold px-2.5 py-1 rounded-full border border-amber-200">Scheduled</span>
                            </td>
                            <td class="py-4 px-6 text-right">
                                <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-250">
                                    <button class="p-2 text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined text-sm">visibility</span></button>
                                    <button class="p-2 text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined text-sm">edit</span></button>
                                    <button class="p-2 text-error hover:text-error/80 transition-colors"><span class="material-symbols-outlined text-sm">delete</span></button>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <!-- Pagination -->
            <div class="p-4 border-t border-outline-variant/20 flex items-center justify-between bg-surface-container-low/30">
                <span class="font-body-md text-sm text-on-surface-variant">Showing 1 to 4 of 24 entries</span>
                <div class="flex gap-1">
                    <button class="w-8 h-8 rounded-full flex items-center justify-center text-on-surface-variant hover:bg-surface-variant transition-colors disabled:opacity-50" disabled="">
                        <span class="material-symbols-outlined text-sm">chevron_left</span>
                    </button>
                    <button class="w-8 h-8 rounded-full flex items-center justify-center bg-primary text-on-primary shadow-sm font-label-caps">1</button>
                    <button class="w-8 h-8 rounded-full flex items-center justify-center text-on-surface-variant hover:bg-surface-variant transition-colors font-label-caps">2</button>
                    <button class="w-8 h-8 rounded-full flex items-center justify-center text-on-surface-variant hover:bg-surface-variant transition-colors font-label-caps">3</button>
                    <button class="w-8 h-8 rounded-full flex items-center justify-center text-on-surface-variant hover:bg-surface-variant transition-colors">
                        <span class="material-symbols-outlined text-sm">chevron_right</span>
                    </button>
                </div>
            </div>
        </div>
