@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Liora Admin - Create Discount";
}

<div class="mb-8 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <div>
                    <a class="text-on-surface-variant hover:text-primary transition-colors flex items-center gap-1 font-body-md text-body-md mb-2" asp-action="Index">
                        <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                        Back to Discounts
                    </a>
                    <h2 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-background">Create Discount</h2>
                </div>
                <div class="flex items-center gap-2">
                    <label class="flex items-center cursor-pointer gap-2 bg-surface-container-low px-4 py-2 rounded-full border border-outline-variant/30 shadow-sm hover:bg-surface-container-high transition-colors">
                        <div class="relative">
                            <input checked="" class="sr-only" type="checkbox" />
                            <div class="block bg-outline-variant w-10 h-6 rounded-full transition-colors duration-300 peer-checked:bg-primary-container"></div>
                            <div class="dot absolute left-1 top-1 bg-surface w-4 h-4 rounded-full transition-transform duration-300 peer-checked:translate-x-4 shadow-sm"></div>
                        </div>
                        <span class="font-label-caps text-label-caps text-on-surface">Is Active</span>
                    </label>
                </div>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Main Form Column -->
                <div class="lg:col-span-2 flex flex-col gap-8">
                    <!-- Basic Info Card -->
                    <section class="bg-surface rounded-[16px] p-6 shadow-ambient-1 border border-outline-variant/20">
                        <h3 class="font-headline-md text-[24px] mb-6 text-primary pb-4 border-b border-outline-variant/20">Discount Details</h3>
                        <div class="space-y-6">
                            <div>
                                <label class="block font-label-caps text-label-caps text-on-surface-variant mb-2" for="discountName">Discount Name / Code</label>
                                <div class="flex gap-2">
                                    <div class="relative flex-1 input-glow border border-outline-variant/50 rounded-lg bg-surface transition-all duration-250">
                                        <input class="w-full bg-transparent border-none focus:ring-0 font-body-md text-body-md p-3 text-on-surface placeholder:text-outline" id="discountName" placeholder="e.g. SUMMER24" type="text" />
                                    </div>
                                    <button class="px-4 py-2 border border-primary text-primary rounded-lg font-label-caps text-label-caps hover:bg-primary-container hover:text-on-primary-container transition-colors duration-250 whitespace-nowrap flex items-center gap-1" type="button">
                                        <span class="material-symbols-outlined text-[18px]">magic_button</span>
                                        Generate
                                    </button>
                                </div>
                                <p class="text-[12px] text-on-surface-variant mt-1 font-body-md">Customers will enter this code at checkout.</p>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <label class="cursor-pointer">
                                    <input checked="" class="peer sr-only" name="discountType" type="radio" value="percentage" />
                                    <div class="p-4 rounded-xl border border-outline-variant/30 peer-checked:border-primary peer-checked:bg-surface-container-low peer-checked:shadow-sm transition-all duration-250 flex items-start gap-3">
                                        <div class="w-5 h-5 rounded-full border-2 border-outline peer-checked:border-primary flex items-center justify-center mt-0.5">
                                            <div class="w-2.5 h-2.5 rounded-full bg-primary scale-0 peer-checked:scale-100 transition-transform"></div>
                                        </div>
                                        <div>
                                            <div class="font-body-md font-bold text-on-surface">Percentage Off</div>
                                            <div class="text-[14px] text-on-surface-variant mt-1">Discount by a percentage (e.g. 20%)</div>
                                        </div>
                                    </div>
                                </label>
                                <label class="cursor-pointer">
                                    <input class="peer sr-only" name="discountType" type="radio" value="fixed" />
                                    <div class="p-4 rounded-xl border border-outline-variant/30 peer-checked:border-primary peer-checked:bg-surface-container-low peer-checked:shadow-sm transition-all duration-250 flex items-start gap-3">
                                        <div class="w-5 h-5 rounded-full border-2 border-outline peer-checked:border-primary flex items-center justify-center mt-0.5">
                                            <div class="w-2.5 h-2.5 rounded-full bg-primary scale-0 peer-checked:scale-100 transition-transform"></div>
                                        </div>
                                        <div>
                                            <div class="font-body-md font-bold text-on-surface">Fixed Amount Off</div>
                                            <div class="text-[14px] text-on-surface-variant mt-1">Discount by a set amount (e.g. LE 100)</div>
                                        </div>
                                    </div>
                                </label>
                            </div>
                            <div>
                                <label class="block font-label-caps text-label-caps text-on-surface-variant mb-2" for="discountValue">Discount Value</label>
                                <div class="relative input-glow border border-outline-variant/50 rounded-lg bg-surface transition-all duration-250 w-full md:w-1/2">
                                    <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-on-surface-variant font-body-md">%</span>
                                    <input class="w-full bg-transparent border-none focus:ring-0 font-body-md text-body-md py-3 pl-8 pr-3 text-on-surface placeholder:text-outline" id="discountValue" placeholder="20" type="number" />
                                </div>
                            </div>
                        </div>
                    </section>
                    <!-- Conditions Card -->
                    <section class="bg-surface rounded-[16px] p-6 shadow-ambient-1 border border-outline-variant/20">
                        <h3 class="font-headline-md text-[24px] mb-6 text-primary pb-4 border-b border-outline-variant/20">Conditions</h3>
                        <div class="space-y-6">
                            <div>
                                <label class="block font-label-caps text-label-caps text-on-surface-variant mb-3">Applies To</label>
                                <div class="flex gap-4">
                                    <label class="flex items-center gap-2 cursor-pointer">
                                        <input checked="" class="text-primary focus:ring-primary h-4 w-4" name="appliesTo" type="radio" />
                                        <span class="font-body-md text-on-surface">Entire Order</span>
                                    </label>
                                    <label class="flex items-center gap-2 cursor-pointer">
                                        <input class="text-primary focus:ring-primary h-4 w-4" name="appliesTo" type="radio" />
                                        <span class="font-body-md text-on-surface">Specific Products</span>
                                    </label>
                                </div>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="block font-label-caps text-label-caps text-on-surface-variant mb-2" for="minOrder">Minimum Order Amount (Optional)</label>
                                    <div class="relative input-glow border border-outline-variant/50 rounded-lg bg-surface transition-all duration-250">
                                        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-on-surface-variant font-body-md">LE</span>
                                        <input class="w-full bg-transparent border-none focus:ring-0 font-body-md text-body-md py-3 pl-10 pr-3 text-on-surface placeholder:text-outline" id="minOrder" placeholder="0.00" type="number" />
                                    </div>
                                </div>
                                <div>
                                    <label class="block font-label-caps text-label-caps text-on-surface-variant mb-2" for="usageLimit">Usage Limit (Optional)</label>
                                    <div class="relative input-glow border border-outline-variant/50 rounded-lg bg-surface transition-all duration-250">
                                        <input class="w-full bg-transparent border-none focus:ring-0 font-body-md text-body-md p-3 text-on-surface placeholder:text-outline" id="usageLimit" placeholder="Unlimited" type="number" />
                                    </div>
                                    <p class="text-[12px] text-on-surface-variant mt-1 font-body-md">Total number of times this code can be used.</p>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>
                <!-- Sidebar Column -->
                <div class="flex flex-col gap-8">
                    <!-- Schedule Card -->
                    <section class="bg-surface rounded-[16px] p-6 shadow-ambient-1 border border-outline-variant/20">
                        <h3 class="font-headline-md text-[20px] mb-4 text-primary pb-3 border-b border-outline-variant/20">Schedule</h3>
                        <div class="space-y-4">
                            <div>
                                <label class="block font-label-caps text-label-caps text-on-surface-variant mb-2" for="startDate">Start Date</label>
                                <div class="relative input-glow border border-outline-variant/50 rounded-lg bg-surface transition-all duration-250">
                                    <input class="w-full bg-transparent border-none focus:ring-0 font-body-md text-body-md p-3 text-on-surface" id="startDate" type="date" />
                                </div>
                            </div>
                            <div>
                                <label class="block font-label-caps text-label-caps text-on-surface-variant mb-2" for="endDate">End Date (Optional)</label>
                                <div class="relative input-glow border border-outline-variant/50 rounded-lg bg-surface transition-all duration-250">
                                    <input class="w-full bg-transparent border-none focus:ring-0 font-body-md text-body-md p-3 text-on-surface" id="endDate" type="date" />
                                </div>
                            </div>
                        </div>
                    </section>
                    <!-- Live Preview Card -->
                    <section class="bg-surface-container-low rounded-[16px] p-6 shadow-ambient-1 border border-primary/20 relative overflow-hidden">
                        <div class="absolute top-0 right-0 w-32 h-32 bg-primary-container/10 rounded-bl-full -z-10"></div>
                        <h3 class="font-label-caps text-label-caps mb-4 text-primary flex items-center gap-2">
                            <span class="material-symbols-outlined text-[16px]">visibility</span>
                            Live Preview
                        </h3>
                        <div class="bg-surface rounded-xl p-4 shadow-sm border border-outline-variant/30">
                            <div class="flex justify-between items-center mb-2">
                                <span class="font-body-md text-on-surface-variant">Original Price</span>
                                <span class="font-body-md line-through text-outline">LE 500.00</span>
                            </div>
                            <div class="flex justify-between items-center mb-4">
                                <span class="font-body-md text-on-surface-variant">Discount applied</span>
                                <span class="font-body-md text-error">- LE 100.00</span>
                            </div>
                            <div class="flex justify-between items-center pt-3 border-t border-outline-variant/20">
                                <span class="font-headline-md text-[20px] text-on-surface">Final Price</span>
                                <span class="font-headline-md text-[24px] text-primary">LE 400.00</span>
                            </div>
                        </div>
                    </section>
                </div>
            </div>
            <!-- Bottom Actions -->
            <div class="mt-8 pt-6 border-t border-outline-variant/30 flex justify-end gap-4 items-center">
                <button class="px-6 py-3 font-label-caps text-label-caps text-on-surface-variant hover:text-on-surface transition-colors duration-250 bg-transparent border-none" type="button">
                    Cancel
                </button>
                <button class="px-8 py-3 rounded-full bg-primary-container text-on-primary-container font-label-caps text-label-caps shadow-ambient-1 hover:shadow-ambient-2 hover:bg-[#b07d6d] transform active:scale-98 transition-all duration-250 flex items-center gap-2" type="submit">
                    <span class="material-symbols-outlined text-[18px]">save</span>
                    Save Discount
                </button>
            </div>

@section Scripts {
    <script>
        // Simple logic for the custom toggle
        const toggleInput = document.querySelector('input[type="checkbox"]');
        const dot = document.querySelector('.dot');
        const bg = toggleInput.nextElementSibling;

        toggleInput.addEventListener('change', function() {
        if(this.checked) {
        dot.style.transform = 'translateX(16px)';
        bg.classList.add('bg-primary-container');
        bg.classList.remove('bg-outline-variant');
        } else {
        dot.style.transform = 'translateX(0)';
        bg.classList.remove('bg-primary-container');
        bg.classList.add('bg-outline-variant');
        }
        });

        // Initial state
        if(toggleInput.checked) {
        dot.style.transform = 'translateX(16px)';
        bg.classList.add('bg-primary-container');
        bg.classList.remove('bg-outline-variant');
        }
    </script>
}
