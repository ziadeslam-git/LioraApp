        </a>
        <a class="flex flex-col items-center justify-center w-full h-full text-on-surface-variant hover:text-primary transition-colors" href="#">
            <span class="material-symbols-outlined" data-icon="settings">settings</span>
            <span class="text-[10px] mt-1 font-label-caps">Settings</span>
        </a>
    </nav>
    <script>
        // Simple logic for the custom toggle
        const toggleInput = document.querySelector('input[type="checkbox"]');
        const dot = document.querySelector('.dot');
        const bg = toggleInput.nextElementSibling;

        toggleInput.addEventListener('change', function() {
        if(this.checked) {
        dot.style.transform = 'translateX(16px)';
        bg.classList.add('bg-primary-container');
        bg.classList.remove('bg-outline-variant');
        } else {
        dot.style.transform = 'translateX(0)';
        bg.classList.remove('bg-primary-container');
        bg.classList.add('bg-outline-variant');
        }
        });

        // Initial state
        if(toggleInput.checked) {
        dot.style.transform = 'translateX(16px)';
        bg.classList.add('bg-primary-container');
        bg.classList.remove('bg-outline-variant');
        }
    </script>
</body></html>