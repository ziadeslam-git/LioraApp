@using LioraApp.ViewModels.Admin
@model IEnumerable<ProductIndexVM>

@{
    ViewData["Title"] = "Products";
    var pagedProducts = Model.ToList();
    int currentPage = ViewBag.CurrentPage is int cp ? cp : 1;
    int totalPages = ViewBag.TotalPages is int tp ? tp : 1;
    int totalCount = ViewBag.TotalCount is int tc ? tc : pagedProducts.Count;
    int activeCount = ViewBag.ActiveCount is int ac ? ac : pagedProducts.Count(p => p.IsActive);
    int totalStock = ViewBag.TotalStock is int ts ? ts : pagedProducts.Sum(p => p.TotalStock);
    int withImages = ViewBag.WithImages is int wi ? wi : pagedProducts.Count(p => p.ImageCount > 0);
    int pageSize = ViewBag.PageSize is int ps ? ps : 10;
    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, currentPage + 2);
}

<div class="space-y-6">

    <!-- Page Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <nav class="flex text-sm text-slate-500 mb-2 items-center gap-2">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
                   class="hover:text-primary transition-colors">Dashboard</a>
                <span class="material-symbols-outlined text-sm">chevron_right</span>
                <span class="font-medium text-slate-900">Products</span>
            </nav>
            <h1 class="text-3xl font-black tracking-tight">Products</h1>
            <p class="text-slate-500 mt-1">Manage your product catalog, variants, and images.</p>
        </div>
        <a asp-area="Admin" asp-controller="Product" asp-action="Create"
           class="inline-flex items-center gap-2 bg-primary hover:bg-primary/90 text-white font-bold py-2.5 px-6 rounded-lg shadow-lg shadow-primary/20 transition-all active:scale-[0.98]">
            <span class="material-symbols-outlined">add</span>
            New Product
        </a>
    </div>

    <!-- Summary Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl border border-slate-200 p-4 flex flex-col gap-1">
            <span class="text-xs font-bold uppercase text-slate-400 tracking-wider">Total Products</span>
            <span class="text-2xl font-black text-slate-900">@totalCount</span>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 p-4 flex flex-col gap-1">
            <span class="text-xs font-bold uppercase text-slate-400 tracking-wider">Active</span>
            <span class="text-2xl font-black text-emerald-600">@activeCount</span>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 p-4 flex flex-col gap-1">
            <span class="text-xs font-bold uppercase text-slate-400 tracking-wider">Total Stock</span>
            <span class="text-2xl font-black text-slate-900">@totalStock.ToString("N0")</span>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 p-4 flex flex-col gap-1">
            <span class="text-xs font-bold uppercase text-slate-400 tracking-wider">With Images</span>
            <span class="text-2xl font-black text-primary">@withImages</span>
        </div>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="space-y-3 p-4 md:hidden">
            @if (!pagedProducts.Any())
            {
                <div class="rounded-[18px] border border-dashed border-slate-200 bg-slate-50 p-6 text-center text-sm text-slate-500">
                    No products yet.
                </div>
            }
            @foreach (var p in pagedProducts)
            {
                <article class="rounded-[18px] border border-slate-200 bg-slate-50/80 p-4 shadow-sm @(!p.IsActive ? "opacity-70" : "")">
                    <div class="flex items-start justify-between gap-3">
                        <div class="flex items-center gap-3">
                            <div class="size-14 overflow-hidden rounded-xl bg-slate-100">
                                @if (p.MainImageUrl is not null)
                                {
                                    <img src="@p.MainImageUrl" alt="@p.Name" class="h-full w-full object-cover" />
                                }
                                else
                                {
                                    <div class="flex h-full w-full items-center justify-center">
                                        <span class="material-symbols-outlined text-2xl text-slate-300">image</span>
                                    </div>
                                }
                            </div>
                            <div>
                                <p class="text-sm font-bold text-slate-900">@p.Name</p>
                                <p class="mt-1 text-xs text-slate-500">@p.CategoryName</p>
                            </div>
                        </div>
                        <span class="inline-flex rounded-full px-3 py-1 text-[10px] font-bold @(p.IsActive ? "bg-emerald-100 text-emerald-700" : "bg-slate-100 text-slate-600")">
                            @(p.IsActive ? "Active" : "Inactive")
                        </span>
                    </div>

                    <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
                        <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400">Base Price</p>
                            <p class="mt-1 font-bold text-slate-900">$@p.BasePrice.ToString("0.00")</p>
                        </div>
                        <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400">Variants</p>
                            <p class="mt-1 font-bold text-primary">@p.VariantCount</p>
                        </div>
                        <div class="col-span-2">
                            <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400">Stock</p>
                            <div class="mt-1 flex items-center justify-between">
                                @if (p.TotalStock > 10)
                                {
                                    <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-3 py-1 text-[11px] font-bold text-emerald-600"><span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>In Stock</span>
                                }
                                else if (p.TotalStock > 0)
                                {
                                    <span class="inline-flex items-center gap-1.5 rounded-full bg-rose-50 px-3 py-1 text-[11px] font-bold text-rose-600"><span class="h-1.5 w-1.5 rounded-full bg-rose-500"></span>Low Stock</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-3 py-1 text-[11px] font-bold text-slate-600"><span class="h-1.5 w-1.5 rounded-full bg-slate-500"></span>Out of Stock</span>
                                }
                                <span class="text-xs font-semibold text-slate-500">@p.TotalStock.ToString("N0") units</span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 flex items-center justify-end gap-2">
                        <a asp-area="Admin" asp-controller="Product" asp-action="Details" asp-route-id="@p.Id" class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white text-slate-600 shadow-sm transition hover:bg-slate-100">
                            <span class="material-symbols-outlined text-[18px]">visibility</span>
                        </a>
                        <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Index" asp-route-productId="@p.Id" class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white text-indigo-600 shadow-sm transition hover:bg-indigo-50">
                            <span class="material-symbols-outlined text-[18px]">layers</span>
                        </a>
                        <a asp-area="Admin" asp-controller="ProductImages" asp-action="Index" asp-route-productId="@p.Id" class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white text-teal-600 shadow-sm transition hover:bg-teal-50">
                            <span class="material-symbols-outlined text-[18px]">image</span>
                        </a>
                        <a asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="@p.Id" class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white text-primary shadow-sm transition hover:bg-slate-100">
                            <span class="material-symbols-outlined text-[18px]">edit</span>
                        </a>
                    </div>
                </article>
            }
        </div>

        <div class="hidden overflow-x-auto md:block">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 text-xs font-bold uppercase tracking-wider">
                        <th class="py-4 px-6">Product</th>
                        <th class="py-4 px-6">Category</th>
                        <th class="py-4 px-6 text-right">Base Price</th>
                        <th class="py-4 px-6 text-center">Variants</th>
                        <th class="py-4 px-6 text-center">Stock</th>
                        <th class="py-4 px-6 text-center">Status</th>
                        <th class="py-4 px-6 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (!pagedProducts.Any())
                    {
                        <tr>
                            <td colspan="7" class="py-16 text-center text-slate-400">
                                <span class="material-symbols-outlined text-5xl block mb-3">inventory_2</span>
                                <p class="font-medium">No products yet.</p>
                                <a asp-area="Admin" asp-controller="Product" asp-action="Create"
                                   class="text-primary hover:underline text-sm mt-1 inline-block">
                                    Create your first product →
                                </a>
                            </td>
                        </tr>
                    }
                    @foreach (var p in pagedProducts)
                    {
                        <tr class="hover:bg-primary/5 transition-colors group @(!p.IsActive ? "opacity-60 bg-slate-50" : "")">
                            <!-- Product + thumbnail -->
                            <td class="py-4 px-6">
                                <div class="flex items-center gap-3">
                                    <div class="size-12 rounded-lg bg-slate-100 overflow-hidden flex-shrink-0">
                                        @if (p.MainImageUrl is not null)
                                        {
                                            <img src="@p.MainImageUrl" alt="@p.Name"
                                                 class="w-full h-full object-cover" />
                                        }
                                        else
                                        {
                                            <div class="w-full h-full flex items-center justify-center">
                                                <span class="material-symbols-outlined text-slate-300 text-2xl">image</span>
                                            </div>
                                        }
                                    </div>
                                    <div>
                                        <p class="font-bold text-slate-900 text-sm">@p.Name</p>
                                    </div>
                                </div>
                            </td>
                            <td class="py-4 px-6">
                                <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded font-semibold">
                                    @p.CategoryName
                                </span>
                            </td>
                            <td class="py-4 px-6 text-right font-semibold text-slate-900 text-sm">
                                $@p.BasePrice.ToString("0.00")
                            </td>
                            <td class="py-4 px-6 text-center">
                                <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Index"
                                   asp-route-productId="@p.Id"
                                   class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold
                                          @(p.VariantCount > 0 ? "bg-primary/10 text-primary hover:bg-primary/20" : "bg-slate-100 text-slate-400")
                                          transition-colors">
                                    @p.VariantCount
                                </a>
                            </td>
                            <td class="py-4 px-6 text-center">
                                <div class="inline-flex flex-col items-center gap-1.5">
                                    @if (p.TotalStock > 10)
                                    {
                                        <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-3 py-1 text-[11px] font-bold text-emerald-600">
                                            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                                            In Stock
                                        </span>
                                    }
                                    else if (p.TotalStock > 0)
                                    {
                                        <span class="inline-flex items-center gap-1.5 rounded-full bg-rose-50 px-3 py-1 text-[11px] font-bold text-rose-600">
                                            <span class="h-1.5 w-1.5 rounded-full bg-rose-500"></span>
                                            Low Stock
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-3 py-1 text-[11px] font-bold text-slate-600">
                                            <span class="h-1.5 w-1.5 rounded-full bg-slate-500"></span>
                                            Out of Stock
                                        </span>
                                    }
                                    <span class="text-xs font-semibold text-slate-500">@p.TotalStock.ToString("N0") units</span>
                                </div>
                            </td>
                            <td class="py-4 px-6 text-center">
                                <form asp-area="Admin" asp-controller="Product" asp-action="ToggleActive" method="post" class="inline-block">
                                    <input type="hidden" name="id" value="@p.Id" />
                                    <button type="submit"
                                            class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 @(p.IsActive ? "bg-emerald-500" : "bg-slate-300")"
                                            role="switch" aria-checked="@p.IsActive.ToString().ToLower()">
                                        <span aria-hidden="true"
                                              class="pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out @(p.IsActive ? "translate-x-5" : "translate-x-0")"></span>
                                    </button>
                                </form>
                            </td>
                            <td class="py-4 px-6 text-right">
                                <div class="flex justify-end gap-1">
                                    <a asp-area="Admin" asp-controller="Product" asp-action="Details"
                                       asp-route-id="@p.Id"
                                       class="p-1.5 text-slate-400 hover:text-primary transition-colors" title="Details">
                                        <span class="material-symbols-outlined text-lg">visibility</span>
                                    </a>
                                    <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Index"
                                       asp-route-productId="@p.Id"
                                       class="p-1.5 text-slate-400 hover:text-indigo-600 transition-colors" title="Manage Variants">
                                        <span class="material-symbols-outlined text-lg">layers</span>
                                    </a>
                                    <a asp-area="Admin" asp-controller="ProductImages" asp-action="Index"
                                       asp-route-productId="@p.Id"
                                       class="p-1.5 text-slate-400 hover:text-teal-600 transition-colors" title="Manage Images">
                                        <span class="material-symbols-outlined text-lg">image</span>
                                    </a>
                                    <a asp-area="Admin" asp-controller="Product" asp-action="Edit"
                                       asp-route-id="@p.Id"
                                       class="p-1.5 text-slate-400 hover:text-primary transition-colors" title="Edit">
                                        <span class="material-symbols-outlined text-lg">edit</span>
                                    </a>
                                    <a asp-area="Admin" asp-controller="Product" asp-action="Delete"
                                       asp-route-id="@p.Id"
                                       class="p-1.5 text-slate-400 hover:text-red-500 transition-colors" title="Deactivate">
                                        <span class="material-symbols-outlined text-lg">delete</span>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Footer -->
        <div class="bg-slate-50 px-6 py-4 border-t border-slate-200 flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <p class="text-sm text-slate-500">
                Showing <span class="font-semibold text-slate-900">@(((currentPage - 1) * pageSize) + (pagedProducts.Any() ? 1 : 0))</span>
                to <span class="font-semibold text-slate-900">@(((currentPage - 1) * pageSize) + pagedProducts.Count)</span>
                of <span class="font-semibold text-slate-900">@totalCount</span> products
            </p>

            @if (totalPages > 1)
            {
                <div class="flex flex-wrap items-center gap-2">
                    <a asp-area="Admin" asp-controller="Product" asp-action="Index" asp-route-page="@(currentPage - 1)"
                       class="inline-flex items-center gap-1 rounded-xl border px-3 py-2 text-xs font-semibold transition-all @(currentPage == 1 ? "pointer-events-none border-slate-200 bg-slate-100 text-slate-300" : "border-slate-200 bg-white text-slate-600 hover:border-primary/30 hover:text-primary")">
                        <span class="material-symbols-outlined text-sm">chevron_left</span>
                        Previous
                    </a>

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <a asp-area="Admin" asp-controller="Product" asp-action="Index" asp-route-page="@i"
                           class="inline-flex h-10 min-w-10 items-center justify-center rounded-xl border px-3 text-xs font-bold transition-all @(i == currentPage ? "border-primary bg-primary text-white shadow-md shadow-primary/20" : "border-slate-200 bg-white text-slate-600 hover:border-primary/30 hover:text-primary")">
                            @i
                        </a>
                    }

                    <a asp-area="Admin" asp-controller="Product" asp-action="Index" asp-route-page="@(currentPage + 1)"
                       class="inline-flex items-center gap-1 rounded-xl border px-3 py-2 text-xs font-semibold transition-all @(currentPage == totalPages ? "pointer-events-none border-slate-200 bg-slate-100 text-slate-300" : "border-slate-200 bg-white text-slate-600 hover:border-primary/30 hover:text-primary")">
                        Next
                        <span class="material-symbols-outlined text-sm">chevron_right</span>
                    </a>
                </div>
            }
        </div>
    </div>

</div>
