@model IEnumerable<LioraApp.ViewModels.Admin.ProductIndexVM>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Liora - Products";
}

@section Styles {
<style>
    .font-mono {
    font-family: 'DM Mono', monospace;
    }

    /* Smooth interactions */
    .interactive {
    transition: all 250ms cubic-bezier(0.4, 0, 0.2, 1);
    }

    .interactive:active {
    transform: scale(0.98);
    }

    /* Ambient Shadows */
    .shadow-ambient-1 {
    box-shadow: 0px 10px 30px rgba(26, 16, 37, 0.05);
    }

    .shadow-ambient-2 {
    box-shadow: 0px 20px 50px rgba(26, 16, 37, 0.08);
    }

    /* Custom Checkbox */
    .custom-checkbox {
    appearance: none;
    width: 1.25rem;
    height: 1.25rem;
    border: 1px solid #d5c2bd;
    border-radius: 4px;
    background-color: #ffffff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 200ms ease;
    }

    .custom-checkbox:checked {
    background-color: #c49080;
    border-color: #c49080;
    }

    .custom-checkbox:checked::after {
    content: 'check';
    font-family: 'Material Symbols Outlined';
    color: white;
    font-size: 16px;
    font-variation-settings: 'FILL' 1;
    }

    /* Custom Input Focus */
    .custom-input {
    border: 1px solid rgba(131, 116, 111, 0.2);
    background-color: #ffffff;
    transition: all 250ms ease;
    border-radius: 12px;
    }

    .custom-input:focus {
    border-color: #c49080;
    outline: none;
    box-shadow: 0 0 0 4px rgba(196, 144, 128, 0.15);
    }

    /* Status colors */
    .status-danger {
    color: #ba1a1a;
    }

    .status-warning {
    color: #7f5446;
    }
    /* Using primary as warning in this elegant theme to avoid harsh colors */
    .status-success-bg {
    background-color: #eedcfa;
    color: #4e2a1f;
    }

    .status-muted-bg {
    background-color: #f4ede7;
    color: #514440;
    }
</style>
}

<!-- Toolbar -->
<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
    <div class="flex items-center gap-3">
        <h2 class="font-headline-lg text-headline-lg text-on-surface">Products</h2>
        <span class="bg-surface-container-highest text-on-surface-variant px-3 py-1 rounded-full font-label-caps text-label-caps">@ViewBag.TotalCount Items</span>
    </div>
    <a asp-action="Create" class="bg-primary-container text-on-primary-container px-6 py-3 rounded-full font-body-md font-medium flex items-center justify-center gap-2 interactive shadow-ambient-1 hover:shadow-ambient-2 whitespace-nowrap">
        <span class="material-symbols-outlined text-sm">add</span>
        Add New Product
    </a>
</div>
<!-- Filters Area -->
<div class="bg-white rounded-[16px] p-4 mb-6 shadow-ambient-1 flex flex-col md:flex-row gap-4 items-center">
    <div class="relative w-full md:w-80">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-sm">search</span>
        <input class="w-full pl-10 pr-4 py-2.5 custom-input text-sm font-body-md rounded-full bg-surface-bright" placeholder="Search products..." type="text" />
    </div>
    <div class="flex gap-4 w-full md:w-auto overflow-x-auto pb-2 md:pb-0">
        <select class="custom-input py-2.5 px-4 pr-10 text-sm font-body-md text-on-surface bg-surface-bright appearance-none cursor-pointer min-w-[140px]">
            <option>All Categories</option>
            <option>Silk Dresses</option>
            <option>Linen Tops</option>
            <option>Accessories</option>
        </select>
        <select class="custom-input py-2.5 px-4 pr-10 text-sm font-body-md text-on-surface bg-surface-bright appearance-none cursor-pointer min-w-[140px]">
            <option>Stock: All</option>
            <option>In Stock</option>
            <option>Low Stock</option>
            <option>Out of Stock</option>
        </select>
    </div>
</div>
<!-- Table Card -->
<div class="bg-white rounded-[16px] shadow-ambient-1 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[800px]">
            <thead>
                <tr class="border-b border-surface-container text-on-surface-variant font-label-caps text-label-caps bg-surface-bright">
                    <th class="p-4 w-12"><input class="custom-checkbox" id="selectAll" type="checkbox" /></th>
                    <th class="p-4 w-20">Image</th>
                    <th class="p-4 font-medium">Product Name</th>
                    <th class="p-4 font-medium">Price</th>
                    <th class="p-4 font-medium">Stock</th>
                    <th class="p-4 font-medium">Status</th>
                    <th class="p-4 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-surface-container font-body-md text-body-md" id="productTableBody">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="p-8 text-center text-on-surface-variant">No products found.</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-surface-bright transition-colors group @(!item.IsActive ? "bg-surface-bright/50" : "")">
                        <td class="p-4"><input class="custom-checkbox row-checkbox" type="checkbox" value="@item.Id" /></td>
                        <td class="p-4">
                            <div class="w-12 h-12 rounded-[12px] overflow-hidden bg-surface-container-low relative @(!item.IsActive ? "opacity-60" : "")">
                                <div class="absolute inset-0 bg-cover bg-center @(!item.IsActive ? "grayscale" : "")" 
                                     style="background-image: url('@(string.IsNullOrEmpty(item.MainImageUrl) ? "https://placehold.co/100x100?text=No+Img" : item.MainImageUrl)');"></div>
                            </div>
                        </td>
                        <td class="p-4 @(!item.IsActive ? "opacity-70" : "")">
                            <div class="font-medium text-on-surface mb-1">@item.Name</div>
                            <span class="inline-block px-2 py-0.5 rounded-full bg-surface-container-lowest border border-outline-variant text-[11px] font-label-caps text-on-surface-variant">@item.CategoryName</span>
                        </td>
                        <td class="p-4 font-mono text-on-surface @(!item.IsActive ? "opacity-70" : "")">EGP @item.BasePrice.ToString("N0")</td>
                        <td class="p-4 font-medium @(item.TotalStock == 0 ? "status-danger" : (item.TotalStock < 10 ? "status-warning" : "text-on-surface"))">@item.TotalStock</td>
                        <td class="p-4">
                            @if (item.IsActive)
                            {
                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium status-success-bg">Active</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium status-muted-bg">Inactive</span>
                            }
                        </td>
                        <td class="p-4 text-right">
                            <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                <a asp-action="Details" asp-route-id="@item.Id" class="p-1.5 text-on-surface-variant hover:text-primary transition-colors rounded-lg hover:bg-surface-container" title="Details"><span class="material-symbols-outlined text-sm">visibility</span></a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="p-1.5 text-on-surface-variant hover:text-primary transition-colors rounded-lg hover:bg-surface-container" title="Edit"><span class="material-symbols-outlined text-sm">edit</span></a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="p-1.5 text-on-surface-variant hover:text-error transition-colors rounded-lg hover:bg-error-container" title="Delete"><span class="material-symbols-outlined text-sm">delete</span></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    </div>
</div>

<!-- Modern Pagination (Centered under table) -->
@if (ViewBag.TotalPages > 1)
{
    <div class="mt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="text-sm text-on-surface-variant font-body-md">
            Showing <span class="font-medium text-on-surface">@Model.Count()</span> results out of <span class="font-medium text-on-surface">@ViewBag.TotalCount</span>
        </div>
        <div class="flex items-center gap-2">
            @if (ViewBag.CurrentPage > 1)
            {
                <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)" 
                   class="w-10 h-10 rounded-full flex items-center justify-center border border-outline-variant text-on-surface-variant hover:bg-surface-container hover:text-on-surface transition-colors">
                    <span class="material-symbols-outlined text-sm">chevron_left</span>
                </a>
            }
            else
            {
                <button disabled class="w-10 h-10 rounded-full flex items-center justify-center border border-outline-variant/30 text-outline-variant cursor-not-allowed">
                    <span class="material-symbols-outlined text-sm">chevron_left</span>
                </button>
            }

            <div class="px-4 py-2 rounded-full bg-primary-container text-on-primary-container font-medium text-sm">
                Page @ViewBag.CurrentPage of @ViewBag.TotalPages
            </div>

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)" 
                   class="w-10 h-10 rounded-full flex items-center justify-center border border-outline-variant text-on-surface-variant hover:bg-surface-container hover:text-on-surface transition-colors">
                    <span class="material-symbols-outlined text-sm">chevron_right</span>
                </a>
            }
            else
            {
                <button disabled class="w-10 h-10 rounded-full flex items-center justify-center border border-outline-variant/30 text-outline-variant cursor-not-allowed">
                    <span class="material-symbols-outlined text-sm">chevron_right</span>
                </button>
            }
        </div>
    </div>
}
<!-- Bottom Spacer for Bulk Actions -->
<div class="h-24"></div>
<!-- Bulk Actions Bar (Hidden by default) -->
<div class="fixed bottom-0 left-0 md:left-[240px] right-0 bg-inverse-surface text-inverse-on-surface p-4 shadow-[0_-10px_30px_rgba(26,16,37,0.1)] transform translate-y-full transition-transform duration-300 ease-out z-40 flex items-center justify-between md:px-12" id="bulkActionsBar">
    <div class="flex items-center gap-4">
        <button class="p-2 rounded-full hover:bg-white/10 transition-colors" id="closeBulkActions"><span class="material-symbols-outlined">close</span></button>
        <span class="font-body-md font-medium"><span id="selectedCount">0</span> items selected</span>
    </div>
    <div class="flex items-center gap-3">
        <button class="px-4 py-2 rounded-full border border-outline-variant text-inverse-on-surface hover:bg-white/10 transition-colors font-body-md text-sm interactive">Deactivate</button>
        <button class="px-4 py-2 rounded-full border border-outline-variant text-inverse-on-surface hover:bg-white/10 transition-colors font-body-md text-sm interactive">Activate</button>
        <button class="px-4 py-2 rounded-full bg-error-container text-on-error-container hover:bg-error hover:text-on-error transition-colors font-body-md text-sm interactive flex items-center gap-1">
            <span class="material-symbols-outlined text-[16px]">delete</span> Delete Selected
        </button>
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', () => {
    const selectAll = document.getElementById('selectAll');
    const rowCheckboxes = document.querySelectorAll('.row-checkbox');
    const bulkActionsBar = document.getElementById('bulkActionsBar');
    const selectedCountSpan = document.getElementById('selectedCount');
    const closeBulkActions = document.getElementById('closeBulkActions');

    function updateBulkActions() {
    const checkedCount = document.querySelectorAll('.row-checkbox:checked').length;
    selectedCountSpan.textContent = checkedCount;

    if (checkedCount > 0) {
    bulkActionsBar.classList.remove('translate-y-full');
    } else {
    bulkActionsBar.classList.add('translate-y-full');
    selectAll.checked = false;
    }
    }

    selectAll.addEventListener('change', (e) => {
    rowCheckboxes.forEach(cb => {
    cb.checked = e.target.checked;
    // Highlight row
    const row = cb.closest('tr');
    if(e.target.checked) row.classList.add('bg-surface-container');
    else row.classList.remove('bg-surface-container');
    });
    updateBulkActions();
    });

    rowCheckboxes.forEach(cb => {
    cb.addEventListener('change', (e) => {
    const allChecked = Array.from(rowCheckboxes).every(c => c.checked);
    selectAll.checked = allChecked;

    const row = cb.closest('tr');
    if(e.target.checked) row.classList.add('bg-surface-container');
    else row.classList.remove('bg-surface-container');

    updateBulkActions();
    });
    });

    closeBulkActions.addEventListener('click', () => {
    rowCheckboxes.forEach(cb => {
    cb.checked = false;
    cb.closest('tr').classList.remove('bg-surface-container');
    });
    selectAll.checked = false;
    updateBulkActions();
    });
    });
</script>
}