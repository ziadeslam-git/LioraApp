    <style>
        body {
        background-color: #fff8f3;
        color: #1e1b18;
        font-family: 'DM Sans', sans-serif;
        }

        .font-mono {
        font-family: 'DM Mono', monospace;
        }

        /* Smooth interactions */
        .interactive {
        transition: all 250ms cubic-bezier(0.4, 0, 0.2, 1);
        }

        .interactive:active {
        transform: scale(0.98);
        }

        /* Ambient Shadows */
        .shadow-ambient-1 {
        box-shadow: 0px 10px 30px rgba(26, 16, 37, 0.05);
        }

        .shadow-ambient-2 {
        box-shadow: 0px 20px 50px rgba(26, 16, 37, 0.08);
        }

        /* Custom Checkbox */
        .custom-checkbox {
        appearance: none;
        width: 1.25rem;
        height: 1.25rem;
        border: 1px solid #d5c2bd;
        border-radius: 4px;
        background-color: #ffffff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 200ms ease;
        }

        .custom-checkbox:checked {
        background-color: #c49080;
        border-color: #c49080;
        }

        .custom-checkbox:checked::after {
        content: 'check';
        font-family: 'Material Symbols Outlined';
        color: white;
        font-size: 16px;
        font-variation-settings: 'FILL' 1;
        }

        /* Custom Input Focus */
        .custom-input {
        border: 1px solid rgba(131, 116, 111, 0.2);
        background-color: #ffffff;
        transition: all 250ms ease;
        border-radius: 12px;
        }

        .custom-input:focus {
        border-color: #c49080;
        outline: none;
        box-shadow: 0 0 0 4px rgba(196, 144, 128, 0.15);
        }

        /* Status colors */
        .status-danger {
        color: #ba1a1a;
        }

        .status-warning {
        color: #7f5446;
        }
        /* Using primary as warning in this elegant theme to avoid harsh colors */
        .status-success-bg {
        background-color: #eedcfa;
        color: #4e2a1f;
        }

        .status-muted-bg {
        background-color: #f4ede7;
        color: #514440;
        }
    </style>
