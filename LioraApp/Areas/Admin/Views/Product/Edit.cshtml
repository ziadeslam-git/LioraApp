<body class="bg-background text-on-background font-body-md text-body-md antialiased overflow-x-hidden min-h-screen">
    <!-- TopAppBar -->
    <header class="fixed docked full-width top-0 h-20 bg-surface/80 backdrop-blur-md shadow-sm shadow-[0px_10px_30px_rgba(26,16,37,0.05)] z-40 flex justify-between items-center w-full px-container-padding-desktop md:ml-64 transition-all duration-250 hidden md:flex">
        <div class="flex items-center gap-4">
            <span class="font-display-lg text-[32px] text-primary italic tracking-wider">Liora</span>
        </div>
        <div class="flex items-center gap-6">
            <div class="relative focus-within:ring-2 focus-within:ring-primary-container rounded-full">
                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
                <input class="pl-12 pr-4 py-2 bg-surface-container-high border-none rounded-full w-64 text-on-surface placeholder-on-surface-variant focus:outline-none focus:ring-0 font-body-md text-body-md transition-all duration-250 hover:bg-surface-variant" placeholder="Search catalog..." type="text" />
            </div>
            <div class="flex items-center gap-4">
                <button class="w-10 h-10 rounded-full flex items-center justify-center text-on-surface-variant hover:bg-surface-container-high transition-all duration-250">
                    <span class="material-symbols-outlined" data-icon="notifications">notifications</span>
                </button>
                <button class="w-10 h-10 rounded-full flex items-center justify-center text-on-surface-variant hover:bg-surface-container-high transition-all duration-250">
                    <span class="material-symbols-outlined" data-icon="account_circle">account_circle</span>
                </button>
            </div>
        </div>
    </header>
    <!-- SideNavBar (Desktop) -->
    <nav class="bg-inverse-surface shadow-lg shadow-[0px_10px_30px_rgba(26,16,37,0.05)] h-screen w-64 fixed left-0 top-0 z-50 flex flex-col h-full py-stack-lg px-gutter hidden md:flex">
        <div class="mb-stack-lg flex items-center gap-4 text-on-tertiary">
            <div class="w-12 h-12 rounded-full bg-surface-container-high overflow-hidden">
                <img alt="Admin Profile" class="w-full h-full object-cover" data-alt="A professional headshot of a female luxury boutique manager. She has an elegant, confident expression, soft lighting highlighting her features, against a minimalist neutral background. The aesthetic is high-end editorial, bright, and polished." src="https://lh3.googleusercontent.com/aida-public/AB6AXuC2jwl-cdu1vqePtbhtI1PkE2yknbFoQaNVO__SNdIhDDcs1UDhnfntySNzKr6UW8859O2j5M-9eEo-0q49-9RZD3niPttk1RLbTsdE3WEtIQawkXim0ELhKNfSNH24YHn6Vmav-3hgo_Myap24uLuYBNlZPF7c-voSPWFKGgceq8H-8oy2S0Ow2SfmxOCpWW3RecZ6FGhs2HaaJFC-lY_cR2y_G1tNasIQhlXcWTIMEupE3FDr5f7wmktDA_SbX7EPAnzBubfWmCT8" />
            </div>
            <div>
                <h2 class="font-headline-md text-[20px] leading-tight text-surface">Liora Admin</h2>
                <p class="font-body-md text-[14px] text-surface-dim">Luxury Management</p>
            </div>
        </div>
        <ul class="flex flex-col gap-2 flex-grow">
            <li>
                <a class="flex items-center gap-4 p-3 rounded-lg text-on-tertiary-fixed-variant font-label-caps hover:text-primary-fixed transition-colors duration-250 ease-out group" href="#">
                    <span class="material-symbols-outlined group-hover:scale-110 transition-transform duration-250" data-icon="dashboard">dashboard</span>
                    <span>Dashboard</span>
                </a>
            </li>
            <li>
                <a class="flex items-center gap-4 p-3 rounded-lg text-primary font-bold border-b-2 border-primary pb-1 group" href="#">
                    <span class="material-symbols-outlined icon-fill" data-icon="inventory_2">inventory_2</span>
                    <span>Catalog</span>
                </a>
            </li>
            <li>
                <a class="flex items-center gap-4 p-3 rounded-lg text-on-tertiary-fixed-variant font-label-caps hover:text-primary-fixed transition-colors duration-250 ease-out group" href="#">
                    <span class="material-symbols-outlined group-hover:scale-110 transition-transform duration-250" data-icon="payments">payments</span>
                    <span>Sales</span>
                </a>
            </li>
            <li>
                <a class="flex items-center gap-4 p-3 rounded-lg text-on-tertiary-fixed-variant font-label-caps hover:text-primary-fixed transition-colors duration-250 ease-out group" href="#">
                    <span class="material-symbols-outlined group-hover:scale-110 transition-transform duration-250" data-icon="group">group</span>
                    <span>Customers</span>
                </a>
            </li>
            <li>
                <a class="flex items-center gap-4 p-3 rounded-lg text-on-tertiary-fixed-variant font-label-caps hover:text-primary-fixed transition-colors duration-250 ease-out group" href="#">
                    <span class="material-symbols-outlined group-hover:scale-110 transition-transform duration-250" data-icon="settings">settings</span>
                    <span>Settings</span>
                </a>
            </li>
        </ul>
        <button class="mt-auto mb-stack-lg w-full py-3 bg-primary-container text-on-primary-container rounded-full font-label-caps text-label-caps hover:scale-95 transition-transform duration-250 ease-out shadow-[0px_10px_30px_rgba(26,16,37,0.05)]">
            Add New Collection
        </button>
        <ul class="flex flex-col gap-2 pt-4 border-t border-surface-tint/20">
            <li>
                <a class="flex items-center gap-4 p-3 rounded-lg text-on-tertiary-fixed-variant font-label-caps hover:text-primary-fixed transition-colors duration-250 ease-out group" href="#">
                    <span class="material-symbols-outlined group-hover:scale-110 transition-transform duration-250" data-icon="help">help</span>
                    <span>Support</span>
                </a>
            </li>
            <li>
                <a class="flex items-center gap-4 p-3 rounded-lg text-on-tertiary-fixed-variant font-label-caps hover:text-primary-fixed transition-colors duration-250 ease-out group" href="#">
                    <span class="material-symbols-outlined group-hover:scale-110 transition-transform duration-250" data-icon="logout">logout</span>
