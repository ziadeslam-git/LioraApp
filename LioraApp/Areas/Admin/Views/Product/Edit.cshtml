@model LioraApp.ViewModels.Admin.ProductFormVM
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Liora Admin - Edit Product";
}

@section Styles {
<style>
    .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }

    .icon-fill {
    font-variation-settings: 'FILL' 1;
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar {
    width: 8px;
    }

    ::-webkit-scrollbar-track {
    background: #fff8f3;
    }

    ::-webkit-scrollbar-thumb {
    background: #e8e1db;
    border-radius: 4px;
    }

    ::-webkit-scrollbar-thumb:hover {
    background: #d5c2bd;
    }

    /* Focus styles */
    .input-focus-glow:focus {
    box-shadow: 0 0 0 4px rgba(196, 144, 128, 0.2);
    border-color: #c49080;
    }
</style>
}

<!-- Header Section -->
<div class="mb-stack-lg">
    <nav class="flex items-center gap-2 text-on-surface-variant mb-4 font-body-md text-[14px]">
        <a class="hover:text-primary transition-colors duration-250" asp-action="Index">Catalog</a>
        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
        <a class="hover:text-primary transition-colors duration-250" asp-action="Index">Products</a>
        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
        <span class="text-on-surface">Edit Product</span>
    </nav>
    <h1 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface tracking-tight">Edit Product: @Model.Name</h1>
</div>
<!-- Two Column Grid -->
<form id="editProductForm" asp-action="Edit" method="post" class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="All" class="text-error mb-4 col-span-full"></div>
    <!-- Left Column (Main Info & Variants) -->
    <div class="lg:col-span-8 flex flex-col gap-stack-lg">
        <!-- Basic Information Card -->
        <div class="bg-surface-container-lowest rounded-xl p-8 shadow-[0px_10px_30px_rgba(26,16,37,0.05)] border border-surface-variant/50">
            <h2 class="font-headline-md text-[24px] text-on-surface mb-6">Basic Information</h2>
            <div class="space-y-6">
                <div>
                    <label asp-for="Name" class="block font-label-caps text-label-caps text-on-surface-variant mb-2"></label>
                    <input asp-for="Name" class="w-full bg-surface-container-lowest border border-outline/20 rounded-lg px-4 py-3 text-on-surface font-body-md text-body-md focus:outline-none input-focus-glow transition-all duration-250" />
                    <span asp-validation-for="Name" class="text-xs text-error mt-1"></span>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label asp-for="CategoryId" class="block font-label-caps text-label-caps text-on-surface-variant mb-2"></label>
                        <div class="relative">
                            <select asp-for="CategoryId" asp-items="Model.Categories" class="w-full bg-surface-container-lowest border border-outline/20 rounded-lg px-4 py-3 text-on-surface font-body-md text-body-md appearance-none focus:outline-none input-focus-glow transition-all duration-250">
                                <option disabled selected value="">Select Category</option>
                            </select>
                            <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-on-surface-variant">expand_more</span>
                        </div>
                        <span asp-validation-for="CategoryId" class="text-xs text-error mt-1"></span>
                    </div>
                    <div>
                        <label asp-for="BasePrice" class="block font-label-caps text-label-caps text-on-surface-variant mb-2"></label>
                        <input asp-for="BasePrice" type="number" step="0.01" class="w-full bg-surface-container-lowest border border-outline/20 rounded-lg px-4 py-3 text-on-surface font-body-md text-body-md focus:outline-none input-focus-glow transition-all duration-250" />
                        <span asp-validation-for="BasePrice" class="text-xs text-error mt-1"></span>
                    </div>
                </div>
                <div>
                    <label asp-for="Description" class="block font-label-caps text-label-caps text-on-surface-variant mb-2"></label>
                    <textarea asp-for="Description" class="w-full bg-surface-container-lowest border border-outline/20 rounded-lg px-4 py-3 text-on-surface font-body-md text-body-md focus:outline-none input-focus-glow transition-all duration-250 resize-y" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-xs text-error mt-1"></span>
                </div>
            </div>
        </div>
        <!-- Variants & Stock Card -->
        <div class="bg-surface-container-lowest rounded-xl p-8 shadow-[0px_10px_30px_rgba(26,16,37,0.05)] border border-surface-variant/50">
            <div class="flex justify-between items-center mb-6">
                <h2 class="font-headline-md text-[24px] text-on-surface">Variants &amp; Stock</h2>
                <button class="text-primary font-label-caps text-label-caps hover:text-primary-container transition-colors duration-250 flex items-center gap-1" type="button">
                    <span class="material-symbols-outlined text-[18px]">add</span> Add Variant
                </button>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-surface-variant">
                            <th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant font-normal">Variant</th>
                            <th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant font-normal">SKU</th>
                            <th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant font-normal text-right">Stock</th>
                            <th class="py-3 px-4 font-label-caps text-label-caps text-on-surface-variant font-normal text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="border-b border-surface-variant/50 hover:bg-surface-container-low transition-colors duration-250 group">
                            <td class="py-4 px-4 flex items-center gap-3">
                                <div class="w-10 h-10 rounded-md bg-surface-variant overflow-hidden">
                                    <img alt="Variant thumbnail" class="w-full h-full object-cover" data-alt="A close up detail shot of luxurious ivory white silk fabric draping softly. High fashion editorial lighting, bright, elegant, modern minimalist aesthetic." src="https://lh3.googleusercontent.com/aida-public/AB6AXuD45SnDdj2gHb5ITHL0ZZrsfmmIgsuFkQo8n3fjd1kOScqRn8aSme-Gn86vRvoldTecdY5p7KBmdeMiOimYDScQwA1WLz44e-PSWhnYHZ_NPwD6vBV4K7uRwWHoTq5OiWuzqovh363xalQoOBiILCbC95VLZvd9ha5D3LZT9yKAVmbs_IGXojuXNfKo7oyLRIAvmtflWch5ojbgnOguZzVO3UlHS0yr8STSujTsUiktk6MrouY2y4fxPeaUJFjab-tdDK17Rppeo5iy" />
                                </div>
                                <div>
                                    <p class="font-body-md text-on-surface font-medium">Ivory / S</p>
                                </div>
                            </td>
                            <td class="py-4 px-4 font-body-md text-on-surface-variant text-[14px]">LIO-ESD-S</td>
                            <td class="py-4 px-4 text-right">
                                <input class="w-20 text-right bg-transparent border border-outline/20 rounded-md px-2 py-1 focus:outline-none input-focus-glow transition-all duration-250" type="number" value="24" />
                            </td>
                            <td class="py-4 px-4 text-right">
                                <button class="text-on-surface-variant hover:text-error transition-colors duration-250 opacity-0 group-hover:opacity-100" type="button">
                                    <span class="material-symbols-outlined text-[20px]">delete</span>
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <!-- Right Column (Media & Status) -->
    <div class="lg:col-span-4 flex flex-col gap-stack-lg">
        <!-- Product Status Card -->
        <div class="bg-surface-container-lowest rounded-xl p-6 shadow-[0px_10px_30px_rgba(26,16,37,0.05)] border border-surface-variant/50">
            <h2 class="font-headline-md text-[20px] text-on-surface mb-4">Status</h2>
            <div class="flex items-center justify-between py-2">
                <div>
                    <p class="font-body-md text-on-surface font-medium">Product Visibility</p>
                    <p class="font-body-md text-[13px] text-on-surface-variant mt-1">Active in catalog</p>
                </div>
                <!-- Custom Toggle -->
                <label class="relative inline-flex items-center cursor-pointer">
                    <input asp-for="IsActive" class="sr-only peer" type="checkbox" />
                    <div class="w-11 h-6 bg-surface-variant peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary-container rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                </label>
            </div>
        </div>
        <!-- Product Media Card -->
        <div class="bg-surface-container-lowest rounded-xl p-6 shadow-[0px_10px_30px_rgba(26,16,37,0.05)] border border-surface-variant/50">
            <h2 class="font-headline-md text-[20px] text-on-surface mb-4">Media</h2>
            <!-- Primary Upload Area -->
            <div class="aspect-[3/4] w-full rounded-lg bg-surface-variant border-2 border-dashed border-outline-variant overflow-hidden relative group cursor-pointer mb-4 flex flex-col items-center justify-center">
                <img alt="Primary Product Photo" class="absolute inset-0 w-full h-full object-cover z-0" data-alt="A full length editorial shot of an ethereal ivory silk slip dress elegantly draped on a modern minimalist dress form. The background is a soft, high-key studio setting with ambient warm lighting. The mood is intimate, luxurious, and refined, capturing the lustrous texture of the silk." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBrWsoiZuicObJlRRJrTiytXKegj831Jt4cgVNHlGdqdT7__m2uHo3pglVAcCVAOExMfpT5_ZyZ9dBlnyFLJFL5R__mXra9D7o1yILWTUTZSMTgq3uulGMGZjFIcPU_veYJBMNdkCvbsPG2kq7oG7lQjhj32QNzVRpZYyw6AsrYH8KvXyh7PaGjlIcPpJL72szi5G-gBJWiR7itWppu7tdV2mkU8NtVLbZVGJyQEsPciAfdTBG62YX-b-24cBqfBEIYP2VPGLIXd-NG" />
                <div class="absolute inset-0 bg-inverse-surface/40 opacity-0 group-hover:opacity-100 transition-opacity duration-250 z-10 flex flex-col items-center justify-center text-on-tertiary">
                    <span class="material-symbols-outlined mb-2 text-[32px]">cloud_upload</span>
                    <span class="font-label-caps text-label-caps">Replace Primary Image</span>
                </div>
            </div>
            <!-- Secondary Gallery -->
            <div class="grid grid-cols-4 gap-2">
                <div class="aspect-square rounded-md bg-surface-variant border border-outline/20 overflow-hidden cursor-pointer hover:border-primary transition-colors duration-250 relative group">
                    <img alt="Gallery thumbnail 1" class="w-full h-full object-cover" data-alt="A close-up macro shot of delicate lace detailing on ivory silk fabric. Soft, diffused lighting emphasizes the intricate textures and premium quality of the material. Modern luxury aesthetic." src="https://lh3.googleusercontent.com/aida-public/AB6AXuDdKfuKFVTEVtjnRmw060m8CpJ5BB6_xRHYYg-T7_IE8Iso03AZTppcrQpIBvri0cGH3xI4UyduQS-BFFejRSmXWkI3kWB2DvJonS9cxe7Yigr9clPyXYTPt7CIZ20Psb4RZ5vEZPwKtcSzGtfgDhBUFFpzRIP635XNt1DOReuMObJHt62xLoUaPwTBhSp-M3JGnMyTUp4I37o6TRzx_P3jG6bU4NWOwA4MpXhbOjb1kG1o1r_5hDR4QYFrg0zHL9Pb49Evt4WpPRkr" />
                    <div class="absolute inset-0 bg-inverse-surface/20 opacity-0 group-hover:opacity-100 transition-opacity duration-250 flex items-center justify-center">
                        <span class="material-symbols-outlined text-white text-[16px]">delete</span>
                    </div>
                </div>
                <button class="aspect-square rounded-md border-2 border-dashed border-outline-variant flex items-center justify-center text-on-surface-variant hover:text-primary hover:border-primary transition-all duration-250" type="button">
                    <span class="material-symbols-outlined">add</span>
                </button>
            </div>
        </div>
    </div>
    <!-- Footer Actions -->
    <div class="col-span-1 lg:col-span-12 mt-stack-md flex justify-end gap-4 border-t border-surface-variant pt-stack-lg">
        <a asp-action="Index" class="px-8 py-3 rounded-full font-label-caps text-label-caps text-on-surface hover:bg-surface-variant transition-colors duration-250 ease-out border border-transparent flex items-center justify-center">
            Cancel
        </a>
        <button type="submit" form="editProductForm" class="px-8 py-3 bg-primary-container text-on-primary-container rounded-full font-label-caps text-label-caps hover:scale-95 transition-transform duration-250 ease-out shadow-[0px_10px_30px_rgba(26,16,37,0.05)]">
            Save Changes
        </button>
    </div>
</form>

@section Scripts {
<script>
    // Simple script to handle hover states or subtle interactions if needed beyond CSS
    document.addEventListener('DOMContentLoaded', () => {
    // Future logic for drag/drop image upload could go here
    });
</script>
}