@model LioraApp.ViewModels.Admin.ProductFormVM
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Product";
}

@section Styles {
<style>
    .input-focus-glow:focus {
        box-shadow: 0 0 0 4px rgba(196, 144, 128, 0.2);
        border-color: #c49080;
    }
</style>
}

<!-- Header Section -->
<div class="mb-6">
    <nav class="flex items-center gap-2 text-on-surface-variant mb-4 font-body-md text-[14px]">
        <a class="hover:text-primary transition-colors duration-250" asp-action="Index">Products</a>
        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
        <a class="hover:text-primary transition-colors duration-250" asp-action="Details" asp-route-id="@Model.Id">@Model.Name</a>
        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
        <span class="text-on-surface">Edit</span>
    </nav>
    <h1 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface tracking-tight">Edit: @Model.Name</h1>
</div>

<!-- Main Form: Basic Info only -->
<form id="editProductForm" asp-action="Edit" asp-route-id="@Model.Id" method="post" class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="All" class="text-error mb-4 col-span-full"></div>

    <!-- Left Column: Basic Info -->
    <div class="lg:col-span-8 flex flex-col gap-6">
        <div class="bg-surface-container-lowest rounded-xl p-8 shadow-[0px_10px_30px_rgba(26,16,37,0.05)] border border-surface-variant/50">
            <h2 class="font-headline-md text-[22px] text-on-surface mb-6">Basic Information</h2>
            <div class="space-y-6">
                <div>
                    <label asp-for="Name" class="block font-label-caps text-label-caps text-on-surface-variant mb-2"></label>
                    <input asp-for="Name" class="w-full bg-surface-container-lowest border border-outline/20 rounded-lg px-4 py-3 text-on-surface font-body-md text-body-md focus:outline-none input-focus-glow transition-all duration-250" />
                    <span asp-validation-for="Name" class="text-xs text-error mt-1"></span>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label asp-for="CategoryId" class="block font-label-caps text-label-caps text-on-surface-variant mb-2"></label>
                        <div class="relative">
                            <select asp-for="CategoryId" asp-items="Model.Categories" class="w-full bg-surface-container-lowest border border-outline/20 rounded-lg px-4 py-3 text-on-surface font-body-md text-body-md appearance-none focus:outline-none input-focus-glow transition-all duration-250">
                                <option disabled value="">Select Category</option>
                            </select>
                            <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-on-surface-variant">expand_more</span>
                        </div>
                        <span asp-validation-for="CategoryId" class="text-xs text-error mt-1"></span>
                    </div>
                    <div>
                        <label asp-for="BasePrice" class="block font-label-caps text-label-caps text-on-surface-variant mb-2"></label>
                        <input asp-for="BasePrice" type="number" step="0.01" class="w-full bg-surface-container-lowest border border-outline/20 rounded-lg px-4 py-3 text-on-surface font-body-md text-body-md focus:outline-none input-focus-glow transition-all duration-250" />
                        <span asp-validation-for="BasePrice" class="text-xs text-error mt-1"></span>
                    </div>
                </div>
                <div>
                    <label asp-for="Description" class="block font-label-caps text-label-caps text-on-surface-variant mb-2"></label>
                    <textarea asp-for="Description" class="w-full bg-surface-container-lowest border border-outline/20 rounded-lg px-4 py-3 text-on-surface font-body-md text-body-md focus:outline-none input-focus-glow transition-all duration-250 resize-y" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-xs text-error mt-1"></span>
                </div>
            </div>
        </div>

        <!-- Variants Section — Link to real variants page -->
        @if (Model.Id > 0)
        {
        <div class="bg-surface-container-lowest rounded-xl p-8 shadow-[0px_10px_30px_rgba(26,16,37,0.05)] border border-surface-variant/50">
            <div class="flex justify-between items-center mb-4">
                <h2 class="font-headline-md text-[22px] text-on-surface">Variants &amp; Stock</h2>
                <a asp-controller="ProductVariants" asp-action="Index" asp-route-productId="@Model.Id"
                   class="flex items-center gap-2 text-primary font-label-caps text-label-caps hover:text-primary-container transition-colors">
                    <span class="material-symbols-outlined text-[18px]">open_in_new</span>
                    Manage Variants
                </a>
            </div>
            <p class="font-body-md text-body-md text-on-surface-variant mb-4">
                Add, edit, or remove sizes, colors, SKUs and stock levels from the dedicated Variants page.
            </p>
            <a asp-controller="ProductVariants" asp-action="Index" asp-route-productId="@Model.Id"
               class="inline-flex items-center gap-2 bg-surface-container px-6 py-3 rounded-full font-label-caps text-label-caps text-on-surface hover:bg-surface-container-high transition-colors border border-outline-variant/30">
                <span class="material-symbols-outlined text-[18px]">tune</span>
                Go to Variants Manager
            </a>
        </div>
        }
    </div>

    <!-- Right Column: Status + Media links -->
    <div class="lg:col-span-4 flex flex-col gap-6">
        <!-- Status -->
        <div class="bg-surface-container-lowest rounded-xl p-6 shadow-[0px_10px_30px_rgba(26,16,37,0.05)] border border-surface-variant/50">
            <h2 class="font-headline-md text-[20px] text-on-surface mb-4">Status</h2>
            <div class="flex items-center justify-between py-2">
                <div>
                    <p class="font-body-md text-on-surface font-medium">Product Visibility</p>
                    <p class="font-body-md text-[13px] text-on-surface-variant mt-1">Active in catalog</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input asp-for="IsActive" class="sr-only peer" type="checkbox" />
                    <div class="w-11 h-6 bg-surface-variant peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary-container rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                </label>
            </div>
        </div>

        <!-- Media — Link to real Media Gallery -->
        @if (Model.Id > 0)
        {
        <div class="bg-surface-container-lowest rounded-xl p-6 shadow-[0px_10px_30px_rgba(26,16,37,0.05)] border border-surface-variant/50">
            <h2 class="font-headline-md text-[20px] text-on-surface mb-4">Product Images</h2>
            <p class="font-body-md text-body-md text-on-surface-variant mb-4 text-[13px]">
                Upload and manage product images from the Media Gallery page.
            </p>
            <a asp-controller="ProductImages" asp-action="Index" asp-route-productId="@Model.Id"
               class="flex items-center justify-center gap-2 w-full py-3 rounded-full bg-primary-container text-on-primary-container font-label-caps text-label-caps hover:scale-[0.98] transition-transform border border-transparent">
                <span class="material-symbols-outlined text-[18px]">photo_library</span>
                Open Media Gallery
            </a>
        </div>
        }
    </div>

    <!-- Footer Actions -->
    <div class="col-span-1 lg:col-span-12 mt-2 flex justify-between items-center border-t border-surface-variant pt-6">
        <a asp-action="Details" asp-route-id="@Model.Id" class="px-6 py-3 rounded-full font-label-caps text-label-caps text-on-surface hover:bg-surface-variant transition-colors border border-outline-variant/30 flex items-center gap-2">
            <span class="material-symbols-outlined text-[16px]">arrow_back</span>
            Back to Details
        </a>
        <div class="flex gap-3">
            <a asp-action="Index" class="px-6 py-3 rounded-full font-label-caps text-label-caps text-on-surface hover:bg-surface-variant transition-colors border border-transparent">
                Cancel
            </a>
            <button type="submit" form="editProductForm" class="px-8 py-3 bg-primary-container text-on-primary-container rounded-full font-label-caps text-label-caps hover:scale-95 transition-transform duration-250 shadow-[0px_10px_30px_rgba(26,16,37,0.05)]">
                Save Changes
            </button>
        </div>
    </div>
</form>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
}