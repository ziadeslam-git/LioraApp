</head>
<body class="bg-surface text-on-surface antialiased min-h-screen font-body-md text-body-md">
    <!-- Persistent Side Navigation -->
    <nav class="fixed left-0 top-0 h-full w-[240px] bg-surface-container-low border-r border-outline-variant flex flex-col z-40 hidden md:flex">
        <div class="p-6">
            <h1 class="font-headline-md text-headline-md font-bold text-primary">Liora</h1>
        </div>
        <div class="px-4 py-2">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 rounded-full bg-primary-container flex items-center justify-center text-on-primary-container font-bold text-lg">
                    L
                </div>
                <div>
                    <p class="font-body-md text-body-md font-bold">Liora Admin</p>
                    <p class="font-label-caps text-label-caps text-on-surface-variant">Enterprise Portal</p>
                </div>
            </div>
        </div>
        <ul class="flex flex-col h-full overflow-y-auto space-y-1 py-4">
            <li>
                <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-highest hover:text-on-surface transition-colors duration-200 ease-in-out" href="#">
                    <span class="material-symbols-outlined" data-icon="dashboard">dashboard</span>
                    <span>Overview</span>
                </a>
            </li>
            <li>
                <!-- Active State Logic: Semantic Mapping -> "Catalog" -> "Product Details" implies Catalog/Inventory -->
                <a class="flex items-center gap-3 px-4 py-3 border-l-2 border-primary bg-surface-container-high text-primary font-bold transition-all duration-200 ease-in-out" href="#">
                    <span class="material-symbols-outlined" data-icon="inventory_2" data-weight="fill" style="font-variation-settings: 'FILL' 1;">inventory_2</span>
                    <span>Catalog</span>
                </a>
            </li>
            <li>
                <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-highest hover:text-on-surface transition-colors duration-200 ease-in-out" href="#">
                    <span class="material-symbols-outlined" data-icon="payments">payments</span>
                    <span>Sales</span>
                </a>
            </li>
            <li>
                <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-highest hover:text-on-surface transition-colors duration-200 ease-in-out" href="#">
                    <span class="material-symbols-outlined" data-icon="group">group</span>
                    <span>Customers</span>
                </a>
            </li>
            <li>
                <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-highest hover:text-on-surface transition-colors duration-200 ease-in-out" href="#">
                    <span class="material-symbols-outlined" data-icon="settings">settings</span>
                    <span>Settings</span>
                </a>
            </li>
        </ul>
