                        <span class="absolute top-4 right-4 bg-surface/80 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold shadow-ambient-lvl1">Cover Image</span>
                    </div>
                    <!-- Gallery Grid -->
                    <div class="grid grid-cols-3 gap-3">
                        <div class="relative aspect-square rounded-xl overflow-hidden cursor-pointer group">
                            <img alt="Silk Dress Detail" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" data-alt="A close-up macro photography shot focusing on the delicate French seams and fine stitching of a deep navy blue silk garment. The lighting is soft and directional, highlighting the lustrous sheen and smooth weave of the pure mulberry silk fabric. The mood is intimate and luxurious, set against a clean, out-of-focus light background." src="https://lh3.googleusercontent.com/aida-public/AB6AXuChT83oHOpTu2vDdyh4Nl0phXCmbtHjAsdT-xUVGh5P7RpuMDs8guQMxcm3kyKYU2hk3PR0E5PS80QwVZ7I7EThDh5_l9l20l4tjKyyqSQmCMWT0dh0LKRdfgKPDxw2IPMKuPYIZBlqWpReVR2ZxMChrOzk_puHhepVSLI72HsEZEJygRT7rv2nu3sNvPj7MMCCiQ-5SDMGEjYcEljcjT0_mbrhEnnFKyaKgaIRW2qQCX6xBTqhYm4Y9zd7ZxLngo46ZDjDvs3X5SZg" />
                        </div>
                        <div class="relative aspect-square rounded-xl overflow-hidden cursor-pointer group">
                            <img alt="Silk Dress Back" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" data-alt="A rear-view fashion editorial photograph of a navy silk slip dress showing the elegant drop back and delicate adjustable spaghetti straps. The dress is styled on a minimal form in a bright, modern gallery-like space. The lighting is high-key and pristine, creating a sense of effortless grace and quiet luxury." src="https://lh3.googleusercontent.com/aida-public/AB6AXuCjxuxr1QI67udOAGCbwc86abfGpkZPHSweQI_YWDBT76uHJokXzGQouGrCzBPy_d4MQCdH3tN7kunnWHZAu8AB-Bgiej20JxIpQbJeX4QMjaEPdvULKChsuENkKVs2NQdDpCzUWiDPCF9SYMGQI0w1IElo5BqDV55kesx-MBDwSJWQoj9tnIFHTAIlrz3a4cD-Rl8FfT9NU6Usv6dey8c3oCb_phHnSC4_g02Ea_Fc9fHkEiHX-34pjALYoV69_P4UUo4GPtzET47l" />
                        </div>
                        <div class="relative aspect-square rounded-xl overflow-hidden bg-surface-container flex items-center justify-center cursor-pointer hover:bg-surface-container-highest transition-colors">
                            <span class="material-symbols-outlined text-primary-container text-3xl" data-icon="add_photo_alternate">add_photo_alternate</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</body></html>