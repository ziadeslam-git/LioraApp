@model LioraApp.ViewModels.Admin.ProductDetailsVM
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = $"Product Details - {Model.Name}";
}

@section Styles {
<style>
    .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }

    .shadow-ambient-lvl1 {
    box-shadow: 0px 10px 30px rgba(26, 16, 37, 0.05);
    }

    .shadow-ambient-lvl2 {
    box-shadow: 0px 20px 50px rgba(26, 16, 37, 0.08);
    }

    .rose-tinted-overlay {
    background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(196,144,128,0.05) 100%);
    }
</style>
}

<!-- Page Header -->
<div class="flex justify-between items-end mb-stack-lg border-b border-outline-variant pb-4">
    <div>
        <nav class="flex text-sm text-on-surface-variant mb-2">
            <a class="hover:text-primary transition-colors" asp-action="Index">Catalog</a>
            <span class="mx-2">/</span>
            <span class="text-on-surface">@Model.CategoryName</span>
            <span class="mx-2">/</span>
            <span class="text-on-surface">@Model.Name</span>
        </nav>
        <h2 class="font-headline-lg text-headline-lg text-on-surface">Product Details</h2>
    </div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="bg-primary-container text-on-primary-container px-6 py-3 rounded-full font-label-caps text-label-caps hover:shadow-ambient-lvl2 active:scale-95 transition-all duration-250 flex items-center gap-2">
        <span class="material-symbols-outlined text-sm" data-icon="edit">edit</span>
        Edit Product
    </a>
</div>
<!-- 2-Column Layout -->
<div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
    <!-- Left Column: Info (60% -> 7 cols) -->
    <div class="lg:col-span-7 space-y-stack-lg">
        <!-- Basic Info Card -->
        <div class="bg-surface-container-lowest rounded-2xl p-8 shadow-ambient-lvl1">
            <h3 class="font-headline-md text-headline-md mb-6 border-b border-outline-variant/30 pb-4">Basic Information</h3>
            <div class="grid grid-cols-2 gap-6">
                <div>
                    <p class="font-label-caps text-label-caps text-on-surface-variant mb-1">Product Name</p>
                    <p class="font-body-lg text-body-lg text-on-surface">@Model.Name</p>
                </div>
                <div>
                    <p class="font-label-caps text-label-caps text-on-surface-variant mb-1">Status</p>
                    @if (Model.IsActive)
                    {
                        <span class="inline-flex items-center px-3 py-1 rounded-full bg-surface-container-highest text-primary font-label-caps text-label-caps">
                            <span class="w-2 h-2 rounded-full bg-primary mr-2"></span> Active
                        </span>
                    }
                    else
                    {
                        <span class="inline-flex items-center px-3 py-1 rounded-full bg-surface-container-highest text-on-surface-variant font-label-caps text-label-caps">
                            <span class="w-2 h-2 rounded-full bg-on-surface-variant mr-2"></span> Inactive
                        </span>
                    }
                </div>
                <div class="col-span-2">
                    <p class="font-label-caps text-label-caps text-on-surface-variant mb-1">Description</p>
                    <p class="text-on-surface-variant leading-relaxed whitespace-pre-line">@Model.Description</p>
                </div>
                <div>
                    <p class="font-label-caps text-label-caps text-on-surface-variant mb-1">Base Price</p>
                    <p class="font-body-lg text-body-lg text-on-surface">EGP @Model.BasePrice.ToString("N0")</p>
                </div>
                <div>
                    <p class="font-label-caps text-label-caps text-on-surface-variant mb-1">Category</p>
                    <p class="text-on-surface">@Model.CategoryName</p>
                </div>
            </div>
        </div>
        <!-- Variants List Card -->
        <div class="bg-surface-container-lowest rounded-2xl p-8 shadow-ambient-lvl1">
            <div class="flex justify-between items-center mb-6 border-b border-outline-variant/30 pb-4">
                <h3 class="font-headline-md text-headline-md">Variants &amp; Inventory</h3>
                <span class="text-sm text-on-surface-variant">Total Stock: @Model.Variants.Sum(v => v.Stock)</span>
            </div>
            <div class="space-y-3">
                @if (!Model.Variants.Any())
                {
                    <p class="text-on-surface-variant italic">No variants available for this product.</p>
                }
                @foreach (var variant in Model.Variants)
                {
                    var isLowStock = variant.Stock > 0 && variant.Stock < 10;
                    var isOutOfStock = variant.Stock == 0;
                    
                    var borderClass = "border-transparent hover:border-outline-variant/30";
                    var stockTextClass = "text-on-surface-variant";
                    var dotClass = "bg-primary-container";
                    var stockLabel = "Stock";
                    
                    if (isOutOfStock)
                    {
                        borderClass = "border-error-container hover:border-error";
                        stockTextClass = "text-error";
                        dotClass = "bg-error";
                        stockLabel = "Out of Stock";
                    }
                    else if (isLowStock)
                    {
                        borderClass = "border-outline-variant hover:border-outline-variant/60";
                        stockTextClass = "text-[#E67C22]";
                        dotClass = "bg-[#E67C22]";
                        stockLabel = "Low Stock";
                    }

                    <div class="flex items-center justify-between p-4 bg-surface-container rounded-xl border @borderClass transition-all duration-250">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-lg bg-inverse-surface flex items-center justify-center text-on-primary font-bold text-sm">
                                @(string.IsNullOrEmpty(variant.Size) ? "-" : variant.Size.Substring(0, Math.Min(2, variant.Size.Length)).ToUpper())
                            </div>
                            <div>
                                <p class="font-bold">@variant.Color / @variant.Size</p>
                                <p class="text-sm text-on-surface-variant">SKU: @variant.SKU</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-6">
                            <div class="text-right">
                                <p class="font-label-caps text-label-caps @stockTextClass mb-1">@stockLabel</p>
                                <p class="flex items-center gap-2 @stockTextClass"><span class="w-2 h-2 rounded-full @dotClass"></span> @variant.Stock units</p>
                            </div>
                            <div class="text-right">
                                <p class="font-label-caps text-label-caps text-on-surface-variant mb-1">Price</p>
                                <p>EGP @(variant.Price?.ToString("N0") ?? Model.BasePrice.ToString("N0"))</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="mt-4 pt-4 border-t border-outline-variant/30 text-right">
                <a asp-controller="ProductVariants" asp-action="Index" asp-route-productId="@Model.Id" class="text-sm font-medium text-primary hover:underline flex items-center gap-1 justify-end">
                    Manage Variants <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </a>
            </div>
        </div>
    </div>
    <!-- Right Column: Media (40% -> 5 cols) -->
    <div class="lg:col-span-5">
        <div class="bg-surface-container-lowest rounded-2xl p-6 shadow-ambient-lvl1 sticky top-[100px]">
            <h3 class="font-headline-md text-headline-md mb-4">Media Gallery</h3>
            
            @{
                var mainImage = Model.Images.FirstOrDefault(i => i.IsMain) ?? Model.Images.FirstOrDefault();
                var placeholder = "https://placehold.co/600x800?text=No+Image";
            }

            <!-- Main Hero Image -->
            <div class="relative w-full aspect-[4/5] rounded-2xl overflow-hidden mb-4 group cursor-zoom-in bg-surface-container-high flex items-center justify-center">
                <img alt="Product Main" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" 
                     src="@(mainImage?.ImageUrl ?? placeholder)" />
                @if(mainImage != null)
                {
                    <span class="absolute top-4 right-4 bg-surface/80 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold shadow-ambient-lvl1">Cover Image</span>
                }
            </div>
            
            <!-- Gallery Grid -->
            <div class="grid grid-cols-3 gap-3">
                @foreach (var img in Model.Images.Where(i => i != mainImage))
                {
                    <div class="relative aspect-square rounded-xl overflow-hidden cursor-pointer group bg-surface-container-high">
                        <img alt="Product Detail" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
                             src="@img.ImageUrl" />
                    </div>
                }
                
                <a asp-controller="ProductImages" asp-action="Index" asp-route-productId="@Model.Id" class="relative aspect-square rounded-xl overflow-hidden bg-surface-container flex flex-col items-center justify-center cursor-pointer hover:bg-surface-container-highest transition-colors">
                    <span class="material-symbols-outlined text-primary-container text-3xl" data-icon="add_photo_alternate">add_photo_alternate</span>
                    <span class="text-xs text-on-surface-variant mt-1 font-medium">Manage</span>
                </a>
            </div>
        </div>
    </div>
</div>