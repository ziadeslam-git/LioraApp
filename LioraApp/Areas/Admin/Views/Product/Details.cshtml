                    <span class="mx-2">/</span>
                    <a class="hover:text-primary transition-colors" href="#">Dresses</a>
                    <span class="mx-2">/</span>
                    <span class="text-on-surface">Midnight Silk Slip</span>
                </nav>
                <h2 class="font-headline-lg text-headline-lg text-on-surface">Product Details</h2>
            </div>
            <button class="bg-primary-container text-on-primary-container px-6 py-3 rounded-full font-label-caps text-label-caps hover:shadow-ambient-lvl2 active:scale-95 transition-all duration-250 flex items-center gap-2">
