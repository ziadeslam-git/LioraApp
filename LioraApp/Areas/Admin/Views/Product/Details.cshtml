    <style>
        .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .shadow-ambient-lvl1 {
        box-shadow: 0px 10px 30px rgba(26, 16, 37, 0.05);
        }

        .shadow-ambient-lvl2 {
        box-shadow: 0px 20px 50px rgba(26, 16, 37, 0.08);
        }

        .rose-tinted-overlay {
        background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(196,144,128,0.05) 100%);
