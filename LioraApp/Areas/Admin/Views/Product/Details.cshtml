                                <div class="w-10 h-10 rounded-lg bg-inverse-surface flex items-center justify-center text-on-primary font-bold text-sm">
                                    XS
                                </div>
                                <div>
                                    <p class="font-bold">Midnight / Extra Small</p>
                                    <p class="text-sm text-on-surface-variant">SKU: MSLIP-MID-XS</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-6">
                                <div class="text-right">
                                    <p class="font-label-caps text-label-caps text-on-surface-variant mb-1">Stock</p>
                                    <p class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-primary-container"></span> 8 units</p>
                                </div>
                                <div class="text-right">
                                    <p class="font-label-caps text-label-caps text-on-surface-variant mb-1">Price</p>
                                    <p>$450.00</p>
                                </div>
                            </div>
                        </div>
                        <!-- Variant Row 2 -->
                        <div class="flex items-center justify-between p-4 bg-surface-container rounded-xl border border-transparent hover:border-outline-variant/30 transition-all duration-250">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 rounded-lg bg-inverse-surface flex items-center justify-center text-on-primary font-bold text-sm">
                                    S
                                </div>
                                <div>
                                    <p class="font-bold">Midnight / Small</p>
                                    <p class="text-sm text-on-surface-variant">SKU: MSLIP-MID-S</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-6">
                                <div class="text-right">
                                    <p class="font-label-caps text-label-caps text-on-surface-variant mb-1">Stock</p>
                                    <p class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-primary-container"></span> 15 units</p>
                                </div>
                                <div class="text-right">
                                    <p class="font-label-caps text-label-caps text-on-surface-variant mb-1">Price</p>
                                    <p>$450.00</p>
                                </div>
                            </div>
                        </div>
                        <!-- Variant Row 3 (Low Stock) -->
                        <div class="flex items-center justify-between p-4 bg-surface-container rounded-xl border border-error-container hover:border-error transition-all duration-250">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 rounded-lg bg-inverse-surface flex items-center justify-center text-on-primary font-bold text-sm">
                                    M
                                </div>
                                <div>
                                    <p class="font-bold">Midnight / Medium</p>
                                    <p class="text-sm text-on-surface-variant">SKU: MSLIP-MID-M</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-6">
                                <div class="text-right">
                                    <p class="font-label-caps text-label-caps text-error mb-1">Low Stock</p>
                                    <p class="flex items-center gap-2 text-error"><span class="w-2 h-2 rounded-full bg-error"></span> 2 units</p>
                                </div>
                                <div class="text-right">
                                    <p class="font-label-caps text-label-caps text-on-surface-variant mb-1">Price</p>
                                    <p>$450.00</p>
                                </div>
                            </div>
                        </div>
