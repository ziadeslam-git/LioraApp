@using LioraApp.ViewModels.Admin
@model ProductFormVM

@{
    ViewData["Title"] = "New Product";
}

<div class="max-w-2xl mx-auto space-y-6">

    <!-- Breadcrumb -->
    <div>
        <nav class="flex text-sm text-slate-500 mb-2 items-center gap-2">
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
               class="hover:text-primary transition-colors">Dashboard</a>
            <span class="material-symbols-outlined text-sm">chevron_right</span>
            <a asp-area="Admin" asp-controller="Product" asp-action="Index"
               class="hover:text-primary transition-colors">Products</a>
            <span class="material-symbols-outlined text-sm">chevron_right</span>
            <span class="font-medium text-slate-900">New Product</span>
        </nav>
        <h1 class="text-3xl font-black tracking-tight">New Product</h1>
        <p class="text-slate-500 mt-1">Add a new product to your catalog.</p>
    </div>

    <!-- Form -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
        <form asp-area="Admin" asp-controller="Product" asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="space-y-5">

                <!-- Name -->
                <div>
                    <label asp-for="Name" class="block text-sm font-semibold text-slate-700 mb-1.5"></label>
                    <input asp-for="Name"
                           class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm
                                  focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all
                                  placeholder:text-slate-400"
                           placeholder="e.g. Classic White T-Shirt" autocomplete="off" />
                    <span asp-validation-for="Name" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Description -->
                <div>
                    <label asp-for="Description" class="block text-sm font-semibold text-slate-700 mb-1.5"></label>
                    <textarea asp-for="Description" rows="4"
                              class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm
                                     focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all
                                     placeholder:text-slate-400 resize-none"
                              placeholder="Product description..."></textarea>
                    <span asp-validation-for="Description" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Base Price + Category row -->
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="BasePrice" class="block text-sm font-semibold text-slate-700 mb-1.5"></label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 font-medium">$</span>
                            <input asp-for="BasePrice" type="number" step="0.01" min="0.01"
                                   class="w-full rounded-lg border border-slate-200 bg-white pl-7 pr-4 py-2.5 text-sm
                                          focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
                                   placeholder="0.00" />
                        </div>
                        <span asp-validation-for="BasePrice" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="CategoryId" class="block text-sm font-semibold text-slate-700 mb-1.5"></label>
                        <select asp-for="CategoryId" asp-items="Model.Categories"
                                class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm
                                       focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all">
                            <option value="">— Select Category —</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <!-- Active toggle -->
                <div class="flex items-center gap-3">
                    <input asp-for="IsActive" type="checkbox" id="isActiveCheck"
                           class="size-4 rounded accent-primary" />
                    <label for="isActiveCheck" class="text-sm font-semibold text-slate-700">
                        Active (visible in store)
                    </label>
                </div>

            </div>

            <!-- Actions -->
            <div class="flex items-center justify-end gap-3 mt-8 pt-6 border-t border-slate-100">
                <a asp-area="Admin" asp-controller="Product" asp-action="Index"
                   class="px-5 py-2.5 rounded-lg border border-slate-200 text-slate-600 text-sm font-semibold
                          hover:bg-slate-50 transition-colors">
                    Cancel
                </a>
                <button type="submit"
                        class="flex items-center gap-2 px-6 py-2.5 rounded-lg bg-primary hover:bg-primary/90
                               text-white text-sm font-bold shadow-lg shadow-primary/20 transition-all active:scale-95">
                    <span class="material-symbols-outlined text-base">add</span>
                    Create Product
                </button>
            </div>

        </form>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
