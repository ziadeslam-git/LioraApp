<body class="bg-background text-on-background font-body-md text-body-md antialiased overflow-hidden">
    <!-- Background (Blurred Products List Simulation) -->
    <div aria-hidden="true" class="fixed inset-0 z-0 bg-surface flex flex-col h-screen">
        <!-- Mock TopNav -->
        <div class="h-20 border-b border-surface-variant flex items-center px-container-padding-desktop justify-between w-full opacity-50">
            <div class="font-display-lg text-display-lg text-primary tracking-wider italic">Liora</div>
            <div class="flex gap-4">
                <span class="material-symbols-outlined text-on-surface-variant">search</span>
                <span class="material-symbols-outlined text-on-surface-variant">account_circle</span>
            </div>
        </div>
        <div class="flex flex-1 overflow-hidden">
            <!-- Mock SideNav -->
            <div class="w-64 border-r border-surface-variant p-stack-lg flex flex-col gap-stack-md opacity-50">
                <div class="w-full h-10 bg-surface-variant rounded-lg"></div>
                <div class="w-full h-10 bg-surface-variant rounded-lg"></div>
                <div class="w-full h-10 bg-surface-variant rounded-lg"></div>
            </div>
            <!-- Mock Content -->
            <div class="flex-1 p-container-padding-desktop opacity-50 flex flex-col gap-stack-lg">
                <div class="w-1/3 h-12 bg-surface-variant rounded-lg"></div>
                <div class="flex-1 bg-surface-container-low rounded-xl border border-surface-variant p-stack-lg flex flex-wrap gap-gutter">
                    <div class="w-64 h-80 bg-surface-variant rounded-lg"></div>
                    <div class="w-64 h-80 bg-surface-variant rounded-lg"></div>
                    <div class="w-64 h-80 bg-surface-variant rounded-lg"></div>
                </div>
            </div>
        </div>
    </div>
    <!-- Modal Overlay -->
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-inverse-surface/40 backdrop-blur-sm px-container-padding-mobile">
        <!-- Modal Card -->
        <div class="bg-surface-container-lowest rounded-[16px] shadow-[0px_20px_50px_rgba(26,16,37,0.08)] w-full max-w-md p-stack-lg flex flex-col items-center text-center transform scale-100 transition-transform duration-250 ease-out">
            <!-- Warning Icon -->
            <div class="w-16 h-16 rounded-full bg-error-container text-error flex items-center justify-center mb-stack-md">
                <span class="material-symbols-outlined" style="font-size: 32px; font-variation-settings: 'FILL' 1;">delete</span>
            </div>
            <!-- Title -->
            <h2 class="font-headline-md text-headline-md text-on-surface mb-stack-sm">Delete Product?</h2>
            <!-- Message -->
            <p class="font-body-md text-body-md text-on-surface-variant mb-stack-lg max-w-[90%]">
                Are you sure you want to delete "<span class="font-bold text-on-surface">Ethereal Silk Slip Dress</span>"? This action will permanently remove the product from your catalog and storefront. This cannot be undone.
            </p>
            <!-- Actions -->
            <div class="flex w-full gap-stack-md">
                <button class="flex-1 py-3 px-6 rounded-full font-label-caps text-label-caps text-primary border border-outline-variant hover:bg-surface-container-high hover:text-primary-fixed transition-colors duration-250 ease-out focus:outline-none focus:ring-2 focus:ring-primary-container active:scale-95" type="button">
                    Cancel
                </button>
                <button class="flex-1 py-3 px-6 rounded-full font-label-caps text-label-caps bg-error text-on-error shadow-[0px_10px_30px_rgba(26,16,37,0.05)] hover:bg-on-error-container transition-all duration-250 ease-out focus:outline-none focus:ring-2 focus:ring-error-container active:scale-95" type="button">
                    Delete Product
                </button>
            </div>
        </div>
    </div>
</body></html>