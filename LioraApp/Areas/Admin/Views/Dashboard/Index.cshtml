@using LioraApp.Models
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Liora - Dashboard Overview";
    
    var recentOrders = ViewBag.RecentOrders as List<Order> ?? new List<Order>();
}

<!-- Breadcrumb & Title Header -->
<div class="flex flex-col gap-2">
    <h1 class="font-headline-lg text-headline-lg text-on-surface">Good morning, Admin <span class="text-3xl">👋</span></h1>
    <p class="font-body-lg text-body-lg text-on-surface-variant">@DateTime.UtcNow.ToString("dddd, MMM dd, yyyy")</p>
</div>

<!-- Alert -->
<div class="bg-white border border-slate-100 p-4 rounded-[16px] shadow-sm flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
    <div class="flex items-center gap-3 text-on-surface">
        @if (ViewBag.PendingOrders > 0)
        {
            <div class="w-10 h-10 rounded-full bg-red-50 text-error flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined">warning</span>
            </div>
            <div>
                <h4 class="font-bold text-sm text-gray-900">Action Required</h4>
                <p class="font-medium text-sm text-gray-600">@ViewBag.PendingOrders orders are waiting for payment verification</p>
            </div>
        }
        else
        {
            <div class="w-10 h-10 rounded-full bg-green-50 text-green-600 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined">check_circle</span>
            </div>
            <div>
                <h4 class="font-bold text-sm text-gray-900">All Caught Up!</h4>
                <p class="font-medium text-sm text-gray-600">No pending orders require your immediate attention.</p>
            </div>
        }
    </div>
    <a asp-controller="Orders" asp-action="Index" class="shrink-0 px-5 py-2.5 bg-black text-white rounded-lg text-sm font-medium hover:bg-gray-800 transition-colors flex items-center gap-2">
        View Orders
        <span class="material-symbols-outlined text-sm">arrow_forward</span>
    </a>
</div>

<!-- Stats Row -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- Stat Card 1 -->
    <div class="bg-white border border-slate-100 p-4 rounded-[16px] shadow-sm flex flex-col gap-3">
        <div class="flex items-center justify-between">
            <h3 class="font-label-caps text-[11px] text-on-surface-variant">TOTAL ORDERS</h3>
            <div class="w-8 h-8 rounded-full bg-surface-container flex items-center justify-center text-primary-container">
                <span class="material-symbols-outlined text-[18px]">shopping_bag</span>
            </div>
        </div>
        <div class="flex items-end justify-between">
            <div>
                <div class="text-2xl font-mono font-medium text-on-surface">@ViewBag.TotalOrders.ToString("N0")</div>
            </div>
            <div class="flex items-end gap-1 h-8 w-16 opacity-70">
                <div class="w-1/5 bg-[#14532D] rounded-t-[2px] h-[30%]"></div>
                <div class="w-1/5 bg-[#14532D] rounded-t-[2px] h-[45%]"></div>
                <div class="w-1/5 bg-[#14532D] rounded-t-[2px] h-[60%]"></div>
                <div class="w-1/5 bg-[#14532D] rounded-t-[2px] h-[80%]"></div>
                <div class="w-1/5 bg-[#14532D] rounded-t-[2px] h-[100%]"></div>
            </div>
        </div>
    </div>
    <!-- Stat Card 2 -->
    <div class="bg-white border border-slate-100 p-4 rounded-[16px] shadow-sm flex flex-col gap-3">
        <div class="flex items-center justify-between">
            <h3 class="font-label-caps text-[11px] text-on-surface-variant">PENDING VERIFICATION</h3>
            <div class="w-8 h-8 rounded-full bg-surface-container flex items-center justify-center text-[#B45309]">
                <span class="material-symbols-outlined text-[18px]">hourglass_empty</span>
            </div>
        </div>
        <div class="flex items-end justify-between">
            <div>
                <div class="text-2xl font-mono font-medium text-[#B45309]">@ViewBag.PendingOrders</div>
                <a class="mt-1 flex items-center gap-1 text-xs text-[#B45309] hover:underline" asp-controller="Orders" asp-action="Index">
                    <span class="">Need Your Review</span>
                    <span class="material-symbols-outlined text-[12px]">arrow_forward</span>
                </a>
            </div>
            <div class="flex items-end gap-1 h-8 w-16 opacity-70">
                <div class="w-1/5 bg-[#B45309] rounded-t-[2px] h-[80%]"></div>
                <div class="w-1/5 bg-[#B45309] rounded-t-[2px] h-[60%]"></div>
                <div class="w-1/5 bg-[#B45309] rounded-t-[2px] h-[75%]"></div>
                <div class="w-1/5 bg-[#B45309] rounded-t-[2px] h-[90%]"></div>
                <div class="w-1/5 bg-[#B45309] rounded-t-[2px] h-[100%]"></div>
            </div>
        </div>
    </div>
    <!-- Stat Card 3 -->
    <div class="bg-white border border-slate-100 p-4 rounded-[16px] shadow-sm flex flex-col gap-3">
        <div class="flex items-center justify-between">
            <h3 class="font-label-caps text-[11px] text-on-surface-variant">TOTAL PRODUCTS</h3>
            <div class="w-8 h-8 rounded-full bg-surface-container flex items-center justify-center text-primary-container">
                <span class="material-symbols-outlined text-[18px]">sell</span>
            </div>
        </div>
        <div class="flex items-end justify-between">
            <div>
                <div class="text-2xl font-mono font-medium text-on-surface">@ViewBag.TotalProducts.ToString("N0")</div>
            </div>
            <div class="flex items-end gap-1 h-8 w-16 opacity-70">
                <div class="w-1/5 bg-primary-container rounded-t-[2px] h-[40%]"></div>
                <div class="w-1/5 bg-primary-container rounded-t-[2px] h-[55%]"></div>
                <div class="w-1/5 bg-primary-container rounded-t-[2px] h-[50%]"></div>
                <div class="w-1/5 bg-primary-container rounded-t-[2px] h-[70%]"></div>
                <div class="w-1/5 bg-primary-container rounded-t-[2px] h-[90%]"></div>
            </div>
        </div>
    </div>
    <!-- Stat Card 4 -->
    <div class="bg-white border border-slate-100 p-4 rounded-[16px] shadow-sm flex flex-col gap-3">
        <div class="flex items-center justify-between">
            <h3 class="font-label-caps text-[11px] text-on-surface-variant">TOTAL CUSTOMERS</h3>
            <div class="w-8 h-8 rounded-full bg-surface-container flex items-center justify-center text-primary-container">
                <span class="material-symbols-outlined text-[18px]">group</span>
            </div>
        </div>
        <div class="flex items-end justify-between">
            <div>
                <div class="text-2xl font-mono font-medium text-on-surface">@ViewBag.TotalCustomers.ToString("N0")</div>
            </div>
            <div class="flex items-end gap-1 h-8 w-16 opacity-70">
                <div class="w-1/5 bg-[#14532D] rounded-t-[2px] h-[20%]"></div>
                <div class="w-1/5 bg-[#14532D] rounded-t-[2px] h-[35%]"></div>
                <div class="w-1/5 bg-[#14532D] rounded-t-[2px] h-[60%]"></div>
                <div class="w-1/5 bg-[#14532D] rounded-t-[2px] h-[75%]"></div>
                <div class="w-1/5 bg-[#14532D] rounded-t-[2px] h-[100%]"></div>
            </div>
        </div>
    </div>
</div>

<!-- Content Area: Table & Quick Actions -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Recent Orders Table -->
    <div class="xl:col-span-2 bg-surface-bright rounded-[16px] ambient-shadow-1 overflow-hidden flex flex-col">
        <div class="p-6 border-b border-outline-variant/50 flex items-center justify-between">
            <h2 class="font-label-caps text-label-caps text-on-surface">RECENT ORDERS</h2>
            <a class="text-sm font-medium text-primary hover:text-primary-container transition-colors flex items-center gap-1" asp-controller="Orders" asp-action="Index">
                View All <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-container-low text-on-surface-variant text-[11px] font-label-caps uppercase border-b border-outline-variant/50">
                        <th class="px-6 py-2.5 font-medium">Order ID</th>
                        <th class="px-6 py-2.5 font-medium">Customer</th>
                        <th class="px-6 py-2.5 font-medium">Date</th>
                        <th class="px-6 py-2.5 font-medium">Total</th>
                        <th class="px-6 py-2.5 font-medium">Status</th>
                        <th class="px-6 py-2.5 font-medium text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="text-sm text-on-surface divide-y divide-outline-variant/30">
                    @if (recentOrders.Any())
                    {
                        foreach(var order in recentOrders)
                        {
                            var customerName = order.User?.FullName ?? order.Address?.FullName ?? "N/A";
                            <tr class="hover:bg-surface-container-low transition-colors group">
                                <td class="px-6 py-2.5 font-mono text-xs">#LRA-@order.Id</td>
                                <td class="px-6 py-2.5 font-medium">@customerName</td>
                                <td class="px-6 py-2.5 text-on-surface-variant text-xs">@order.CreatedAt.ToString("MMM dd")</td>
                                <td class="px-6 py-2.5 font-mono text-xs">EGP @order.TotalAmount.ToString("N0")</td>
                                <td class="px-6 py-2.5">
                                    @if(order.Status == LioraApp.Utilities.SD.Status_Pending)
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-medium bg-[#FEF2F2] text-[#991B1B] border border-[#FECACA]">@order.Status</span>
                                    }
                                    else if(order.Status == LioraApp.Utilities.SD.Status_Processing)
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-medium bg-[#FEF3C7] text-[#92400E] border border-[#FDE68A]">@order.Status</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-medium bg-[#DCFCE7] text-[#166534] border border-[#BBF7D0]">@order.Status</span>
                                    }
                                </td>
                                <td class="px-6 py-2.5 text-right">
                                    <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id" class="text-on-surface-variant hover:text-primary transition-colors p-1 rounded-full hover:bg-surface-container inline-flex">
                                        <span class="material-symbols-outlined text-[18px]">visibility</span>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-on-surface-variant text-xs">No recent orders found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Quick Actions Panel -->
    <div class="bg-surface-bright rounded-[16px] ambient-shadow-1 p-6 flex flex-col gap-6">
        <h2 class="font-label-caps text-label-caps text-on-surface">QUICK ACTIONS</h2>
        <div class="flex flex-col gap-3">
            <a asp-controller="Product" asp-action="Create" class="w-full py-3 px-4 bg-primary-container text-on-primary-container rounded-lg text-sm font-medium hover:scale-[0.98] transition-transform duration-250 flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-[20px]">add</span>
                Add Product
            </a>
            <a asp-controller="Discounts" asp-action="Create" class="w-full py-3 px-4 bg-transparent border border-primary text-primary rounded-lg text-sm font-medium hover:bg-surface-container-low transition-colors flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-[20px]">local_offer</span>
                Add Discount
            </a>
            <div class="h-px w-full bg-outline-variant/50 my-2"></div>
            <a asp-controller="Orders" asp-action="Index" class="w-full py-3 px-4 bg-surface-container text-on-surface rounded-lg text-sm font-medium hover:bg-surface-container-high transition-colors flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-[20px]">list_alt</span>
                View All Orders
            </a>
        </div>

        <!-- Minimalist Data Visualization -->
        <div class="mt-auto pt-6 border-t border-outline-variant/30">
            <p class="text-xs text-on-surface-variant text-center mb-2">Weekly Sales Overview</p>
            <div class="h-24 w-full flex items-end gap-2 justify-between px-2">
                <div class="w-1/6 bg-surface-container-high rounded-t-sm h-[30%]"></div>
                <div class="w-1/6 bg-surface-container-high rounded-t-sm h-[50%]"></div>
                <div class="w-1/6 bg-surface-container-high rounded-t-sm h-[40%]"></div>
                <div class="w-1/6 bg-primary-container/60 rounded-t-sm h-[80%]"></div>
                <div class="w-1/6 bg-surface-container-high rounded-t-sm h-[60%]"></div>
                <div class="w-1/6 bg-primary-container rounded-t-sm h-[100%]"></div>
                <div class="w-1/6 bg-surface-container-high rounded-t-sm h-[70%]"></div>
            </div>
        </div>
    </div>
</div>