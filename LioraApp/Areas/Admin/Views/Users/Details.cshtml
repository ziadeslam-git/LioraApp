@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Customer Details";
}

<!-- Header & Actions -->
        <header class="flex flex-col md:flex-row md:items-center justify-between mb-stack-lg gap-4">
            <div>
                <a class="inline-flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors mb-2 text-sm" asp-action="Index">
                    <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                    Back to Customers
                </a>
                <h1 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-primary">Eleanor Vance</h1>
            </div>
            <div class="flex items-center gap-3">
                <button class="px-6 py-2 border border-error text-error rounded-full font-label-caps text-label-caps hover:bg-error-container transition-all ease-out-smooth">
                    Block User
                </button>
                <button class="px-6 py-2 bg-primary-container text-on-primary-container rounded-full font-label-caps text-label-caps hover:bg-primary hover:text-on-primary transition-all ease-out-smooth active:scale-95 shadow-level-1">
                    Edit Profile
                </button>
            </div>
        </header>
        <!-- Bento Grid Layout -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter">
            <!-- Left Column: Customer Card & Stats -->
            <div class="lg:col-span-1 flex flex-col gap-gutter">
                <!-- Customer Info Card -->
                <div class="bg-surface rounded-[16px] p-6 shadow-level-1 border border-outline-variant/30 flex flex-col items-center text-center">
                    <div class="w-24 h-24 rounded-full bg-secondary-container mb-4 overflow-hidden relative border-2 border-surface shadow-sm">
                        <img alt="Eleanor Vance" class="w-full h-full object-cover" data-alt="A portrait of a sophisticated woman with elegant makeup and sleek hair, set against a soft, well-lit background. The lighting is flattering and high-key, conveying a sense of modern luxury and effortless grace. The color palette emphasizes warm, rosy tones and pristine whites, matching a premium editorial aesthetic." src="https://lh3.googleusercontent.com/aida-public/AB6AXuCJGgwURBzwL5E-458c6qVF_h54piU9PlkiXAkJiF8cMxB53tfe2OcoMgAE-lxjauiqWs6GX3_OtkIE9H4h1rCAFxc9nfayvclo6tspogJedv6BmOmcjd9PJdJrahIxBtXEJSDqkTwXYcHMa9OQ3eRz3UnjbzFC3JQG7GtRIUnycvFJ1wcYn7ifHBbmu7X4XdsoXX5NC92xhw5qTgLXgYUdqB_llgo1QXbFO7PKyZwFd3jk-r_2_Dj709gLvZTS17E5JZzPZrxEOGmR" />
                    </div>
                    <h2 class="font-headline-md text-[24px] text-primary mb-1">Eleanor Vance</h2>
                    <p class="text-on-surface-variant mb-6">eleanor.vance@example.com</p>
                    <div class="w-full space-y-3 text-left">
                        <div class="flex items-center gap-3 text-on-surface-variant">
                            <span class="material-symbols-outlined text-primary/70">call</span>
                            <span>+1 (555) 123-4567</span>
                        </div>
                        <div class="flex items-center gap-3 text-on-surface-variant">
                            <span class="material-symbols-outlined text-primary/70">calendar_today</span>
                            <span>Joined Oct 12, 2023</span>
                        </div>
                        <div class="flex items-center gap-3 text-on-surface-variant">
                            <span class="material-symbols-outlined text-primary/70">loyalty</span>
                            <span>Gold Tier Member</span>
                        </div>
                    </div>
                </div>
                <!-- Stats Stack -->
                <div class="bg-surface rounded-[16px] p-6 shadow-level-1 border border-outline-variant/30 space-y-6">
                    <div>
                        <p class="font-label-caps text-label-caps text-on-surface-variant mb-1">Total Orders</p>
                        <p class="font-headline-md text-[28px] text-primary">14</p>
                    </div>
                    <div class="h-[1px] w-full bg-outline-variant/50"></div>
                    <div>
                        <p class="font-label-caps text-label-caps text-on-surface-variant mb-1">Total Spent</p>
                        <p class="font-headline-md text-[28px] text-primary">$4,250.00</p>
                    </div>
                    <div class="h-[1px] w-full bg-outline-variant/50"></div>
                    <div>
                        <p class="font-label-caps text-label-caps text-on-surface-variant mb-1">Last Order</p>
                        <p class="text-on-surface">May 24, 2024</p>
                    </div>
                </div>
            </div>
            <!-- Right Column: Orders & Addresses -->
            <div class="lg:col-span-2 flex flex-col gap-gutter">
                <!-- Recent Orders Table -->
                <div class="bg-surface rounded-[16px] shadow-level-1 border border-outline-variant/30 overflow-hidden">
                    <div class="p-6 border-b border-outline-variant/30 flex justify-between items-center bg-surface-container-low">
                        <h3 class="font-headline-md text-[20px] text-primary">Recent Orders</h3>
                        <a class="text-sm font-label-caps text-primary hover:underline" asp-controller="Orders" asp-action="Index">View All</a>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="border-b border-outline-variant/30 bg-surface/50">
                                    <th class="p-4 font-label-caps text-label-caps text-on-surface-variant font-normal">Order #</th>
                                    <th class="p-4 font-label-caps text-label-caps text-on-surface-variant font-normal">Date</th>
                                    <th class="p-4 font-label-caps text-label-caps text-on-surface-variant font-normal">Status</th>
                                    <th class="p-4 font-label-caps text-label-caps text-on-surface-variant font-normal text-right">Total</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-outline-variant/20">
                                <tr class="hover:bg-surface-container-highest/50 transition-colors cursor-pointer">
                                    <td class="p-4 font-medium text-primary">#ORD-092</td>
                                    <td class="p-4 text-on-surface-variant">May 24, 2024</td>
                                    <td class="p-4">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-[#e6f4ea] text-[#1e8e3e]">Delivered</span>
                                    </td>
                                    <td class="p-4 text-right font-medium">$345.00</td>
                                </tr>
                                <tr class="hover:bg-surface-container-highest/50 transition-colors cursor-pointer">
                                    <td class="p-4 font-medium text-primary">#ORD-081</td>
                                    <td class="p-4 text-on-surface-variant">Apr 12, 2024</td>
                                    <td class="p-4">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-[#e6f4ea] text-[#1e8e3e]">Delivered</span>
                                    </td>
                                    <td class="p-4 text-right font-medium">$890.00</td>
                                </tr>
                                <tr class="hover:bg-surface-container-highest/50 transition-colors cursor-pointer">
                                    <td class="p-4 font-medium text-primary">#ORD-065</td>
                                    <td class="p-4 text-on-surface-variant">Feb 03, 2024</td>
                                    <td class="p-4">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-surface-variant text-on-surface-variant">Returned</span>
                                    </td>
                                    <td class="p-4 text-right font-medium">$120.00</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <!-- Saved Addresses -->
                <div class="bg-surface rounded-[16px] p-6 shadow-level-1 border border-outline-variant/30">
                    <h3 class="font-headline-md text-[20px] text-primary mb-6">Saved Addresses</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <!-- Address Card 1 -->
                        <div class="border border-outline-variant/50 rounded-lg p-4 relative group hover:border-primary/50 transition-colors">
                            <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity">
                                <button class="text-on-surface-variant hover:text-primary"><span class="material-symbols-outlined text-[20px]">edit</span></button>
                            </div>
                            <div class="inline-block px-2 py-1 bg-surface-container rounded text-xs font-medium text-primary mb-2">Default Billing</div>
                            <p class="font-medium text-on-background mb-1">Eleanor Vance</p>
                            <p class="text-sm text-on-surface-variant leading-relaxed">
                                123 Silkwood Lane, Apt 4B<br />
                                New York, NY 10021<br />
                                United States
                            </p>
                        </div>
                        <!-- Address Card 2 -->
                        <div class="border border-outline-variant/50 rounded-lg p-4 relative group hover:border-primary/50 transition-colors">
                            <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity">
                                <button class="text-on-surface-variant hover:text-primary"><span class="material-symbols-outlined text-[20px]">edit</span></button>
                            </div>
                            <div class="inline-block px-2 py-1 bg-surface-container rounded text-xs font-medium text-on-surface-variant mb-2">Shipping</div>
                            <p class="font-medium text-on-background mb-1">Eleanor Vance</p>
                            <p class="text-sm text-on-surface-variant leading-relaxed">
                                456 Velvet Horizon Blvd<br />
                                Los Angeles, CA 90210<br />
                                United States
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
