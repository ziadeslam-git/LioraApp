@model IEnumerable<UserAdminVM>
@{
    ViewData["Title"] = "Customers";
    int currentPage = ViewBag.CurrentPage is int cp ? cp : 1;
    int totalPages = ViewBag.TotalPages is int tp ? tp : 1;
    int totalCount = ViewBag.TotalCount is int tc ? tc : Model.Count();
    int activeCount = ViewBag.ActiveCount is int ac ? ac : Model.Count(u => u.IsActive);
    int inactiveCount = ViewBag.InactiveCount is int ic ? ic : Model.Count(u => !u.IsActive);
    int joinedRecentlyCount = ViewBag.JoinedRecentlyCount is int jc ? jc : Model.Count(u => u.CreatedAt >= DateTime.UtcNow.AddDays(-30));
    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, currentPage + 2);
    var activePercent = totalCount > 0 ? (activeCount * 100 / totalCount) : 0;
}

@section Styles {
    <style>
        .glass-effect {
            backdrop-filter: blur(12px);
            background-color: rgba(255, 255, 255, 0.8);
        }
    </style>
}

<div class="space-y-8 font-inter">
    <!-- --- PAGE HEADER --- -->
    <div class="flex justify-between items-end">
        <div>
            <h2 class="text-[24px] font-bold text-slate-800 leading-tight">Customers</h2>
            <p class="text-[14px] text-slate-500 mt-1">Manage registered customers and their account status</p>
        </div>
        <a asp-action="ExportWord" class="flex items-center gap-2 text-primary font-semibold text-sm px-4 py-2 hover:bg-primary/5 rounded-xl transition-all border border-transparent hover:border-primary/10">
            <span class="material-symbols-outlined text-[18px]">download</span>
            Export Word
        </a>
    </div>

    <!-- --- STATS ROW --- -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <!-- Total Customers -->
        <div class="bg-surface-container-lowest p-5 rounded-xl border border-slate-100 shadow-[0_20px_40px_rgba(15,23,42,0.03)] flex flex-col gap-1">
            <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Total Customers</span>
            <div class="flex items-end justify-between">
                <span class="text-2xl font-bold text-slate-800">@totalCount</span>
            </div>
        </div>

        <!-- Active -->
        <div class="bg-surface-container-lowest p-5 rounded-xl border border-slate-100 shadow-[0_20px_40px_rgba(15,23,42,0.03)] flex flex-col gap-1">
            <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Active Users</span>
            <div class="flex items-end justify-between">
                <span class="text-2xl font-bold text-emerald-600">@activeCount</span>
                <div class="h-1.5 w-16 bg-emerald-100 rounded-full overflow-hidden">
                    <div class="h-full bg-emerald-500" style="width: @activePercent%"></div>
                </div>
            </div>
        </div>

        <!-- Inactive -->
        <div class="bg-surface-container-lowest p-5 rounded-xl border border-slate-100 shadow-[0_20px_40px_rgba(15,23,42,0.03)] flex flex-col gap-1">
            <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Inactive</span>
            <div class="flex items-end justify-between">
                <span class="text-2xl font-bold text-error">@inactiveCount</span>
                <span class="text-[10px] text-error font-semibold">@((100 - activePercent))% total</span>
            </div>
        </div>

        <!-- Joined -->
        <div class="bg-surface-container-lowest p-5 rounded-xl border border-slate-100 shadow-[0_20px_40px_rgba(15,23,42,0.03)] flex flex-col gap-1">
            <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Joined (30d)</span>
            <div class="flex items-end justify-between">
                <span class="text-2xl font-bold text-primary">@joinedRecentlyCount</span>
                <span class="material-symbols-outlined text-primary text-xl" style="font-variation-settings: 'FILL' 1;">trending_up</span>
            </div>
        </div>
    </div>

    <!-- --- FILTER BAR --- -->
    <form asp-action="Index" method="get" class="bg-surface-container-lowest p-4 rounded-xl shadow-sm border border-slate-100 flex flex-wrap items-center gap-4">
        <div class="flex-1 min-w-[240px] relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
            <input type="text" name="searchQuery" value="@ViewBag.SearchQuery" class="w-full border border-outline-variant/30 rounded-lg pl-10 py-2 text-sm focus:ring-2 focus:ring-primary/10 focus:border-primary transition-all" placeholder="Filter by name or email..." />
        </div>
        <div class="w-48">
            <select name="statusFilter" class="w-full border border-outline-variant/30 rounded-lg py-2 text-sm focus:ring-2 focus:ring-primary/10 focus:border-primary transition-all">
                <option value="">All Statuses</option>
                <option value="Active" selected="@(ViewBag.StatusFilter != null && ViewBag.StatusFilter.ToString() == "Active")">Active</option>
                <option value="Inactive" selected="@(ViewBag.StatusFilter != null && ViewBag.StatusFilter.ToString() == "Inactive")">Inactive</option>
            </select>
        </div>
        <button type="submit" class="p-2 text-slate-500 hover:bg-slate-100 rounded-lg transition-all border border-transparent hover:border-slate-200">
            <span class="material-symbols-outlined">filter_list</span>
        </button>
    </form>

    <!-- --- CUSTOMERS TABLE --- -->
    <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-slate-100 overflow-hidden relative">
        <div class="space-y-3 p-4 md:hidden">
            @foreach (var user in Model)
            {
                var initial = !string.IsNullOrEmpty(user.FullName) ? user.FullName.Substring(0, 1).ToUpper() : "U";
                <article class="rounded-[18px] border border-slate-200 bg-slate-50/80 p-4 shadow-sm @(user.IsActive ? "" : "bg-red-50/30")">
                    <div class="flex items-start justify-between gap-3">
                        <div class="flex items-center gap-3">
                            <div class="flex h-11 w-11 items-center justify-center rounded-full bg-gradient-to-br from-primary to-[#6063ee] font-bold text-white shadow-sm">
                                @initial
                            </div>
                            <div>
                                <p class="text-sm font-bold text-slate-900">@user.FullName</p>
                                <p class="text-xs text-slate-500">@user.Email</p>
                            </div>
                        </div>
                        @if (user.IsActive)
                        {
                            <span class="rounded-full border border-emerald-200 bg-emerald-100 px-2 py-1 text-[10px] font-extrabold uppercase text-emerald-700">Active</span>
                        }
                        else
                        {
                            <span class="rounded-full border border-red-200 bg-red-100 px-2 py-1 text-[10px] font-extrabold uppercase text-error">Inactive</span>
                        }
                    </div>

                    <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
                        <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400">Orders</p>
                            <p class="mt-1 font-bold text-slate-900">@user.TotalOrders</p>
                        </div>
                        <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400">Joined</p>
                            <p class="mt-1 font-semibold text-slate-600">@user.CreatedAt.ToString("MMM dd, yyyy")</p>
                        </div>
                        <div class="col-span-2">
                            <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400">Last Order</p>
                            <p class="mt-1 font-semibold text-slate-600">@(user.LastOrderDate.HasValue ? user.LastOrderDate.Value.ToString("MMM dd, yyyy") : "No orders yet")</p>
                        </div>
                    </div>

                    <div class="mt-4 flex items-center justify-end gap-2">
                        <a asp-action="Details" asp-route-id="@user.Id" class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white text-slate-600 shadow-sm transition hover:bg-slate-100" title="View Details">
                            <span class="material-symbols-outlined text-[18px]">person_search</span>
                        </a>

                        <form asp-action="ToggleActive" method="post" class="inline-block">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@user.Id" />
                            @if (user.Email == User.Identity?.Name)
                            {
                                <button type="button" disabled class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-slate-100 text-slate-300 cursor-not-allowed" title="Cannot deactivate yourself">
                                    <span class="material-symbols-outlined text-[22px]">toggle_on</span>
                                </button>
                            }
                            else
                            {
                                <button type="submit"
                                        class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white shadow-sm transition @(user.IsActive ? "text-emerald-500 hover:bg-emerald-50" : "text-slate-300 hover:bg-slate-100 hover:text-slate-500")"
                                        title="@(user.IsActive ? "Set user inactive" : "Set user active")">
                                    <span class="material-symbols-outlined text-[24px]" style="font-variation-settings: 'FILL' 1;">
                                        @(user.IsActive ? "toggle_on" : "toggle_off")
                                    </span>
                                </button>
                            }
                        </form>
                    </div>
                </article>
            }
            @if (!Model.Any())
            {
                <div class="rounded-[18px] border border-dashed border-slate-200 bg-slate-50 p-6 text-center text-sm text-slate-500">
                    No customers found.
                </div>
            }
        </div>

        <div class="hidden overflow-x-auto md:block">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-container-low text-slate-500 uppercase text-[11px] font-bold tracking-widest border-b border-slate-100">
                        <th class="px-6 py-4 w-12">
                            <input type="checkbox" class="rounded border-outline-variant/80 text-primary focus:ring-primary/20" />
                        </th>
                        <th class="px-6 py-4">Customer</th>
                        <th class="px-6 py-4">Email Address</th>
                        <th class="px-6 py-4 text-center">Orders</th>
                        <th class="px-6 py-4">Last Order</th>
                        <th class="px-6 py-4">Joined</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var user in Model)
                    {
                        <tr class="hover:bg-slate-50/70 transition-colors group @(user.IsActive ? "" : "bg-red-50/20")">
                            <td class="px-6 py-4">
                                <input type="checkbox" class="rounded border-outline-variant/80 text-primary focus:ring-primary/20" />
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    @{
                                        // Generate an avatar based on initials if we don't have images
                                        var initial = !string.IsNullOrEmpty(user.FullName) ? user.FullName.Substring(0, 1).ToUpper() : "U";
                                    }
                                    <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-white bg-gradient-to-br from-primary to-[#6063ee] shadow-sm">
                                        @initial
                                    </div>
                                    <span class="font-semibold text-slate-800 text-sm">@user.FullName</span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-sm text-slate-600 font-medium">@user.Email</td>
                            <td class="px-6 py-4 text-center">
                                <span class="bg-surface-container text-on-surface text-xs font-bold px-2.5 py-1 rounded-lg">
                                    @user.TotalOrders
                                </span>
                            </td>
                            <td class="px-6 py-4 text-xs text-slate-500 font-medium whitespace-nowrap">
                                @(user.LastOrderDate.HasValue ? user.LastOrderDate.Value.ToString("MMM dd, yyyy") : "No orders yet")
                            </td>
                            <td class="px-6 py-4 text-xs text-slate-500 font-medium whitespace-nowrap">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="px-6 py-4">
                                @if (user.IsActive)
                                {
                                    <span class="bg-emerald-100 text-emerald-700 text-[10px] font-extrabold uppercase px-2 py-1 rounded-full border border-emerald-200 shadow-sm">Active</span>
                                }
                                else
                                {
                                    <span class="bg-red-100 text-error text-[10px] font-extrabold uppercase px-2 py-1 rounded-full border border-red-200">Inactive</span>
                                }
                            </td>
                            <td class="px-6 py-4 relative text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a asp-action="Details" asp-route-id="@user.Id" class="material-symbols-outlined p-1 text-slate-400 hover:text-primary hover:bg-slate-100 rounded transition-colors text-xl" title="View Details">person_search</a>
                                    
                                    <form asp-action="ToggleActive" method="post" class="inline-block">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />
                                        @if (user.Email == User.Identity?.Name)
                                        {
                                            <button type="button" disabled class="material-symbols-outlined text-slate-300 text-2xl cursor-not-allowed opacity-50" title="Cannot deactivate yourself">toggle_on</button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="material-symbols-outlined @(user.IsActive ? "text-emerald-500" : "text-slate-300 hover:text-slate-500") hover:opacity-80 transition-colors text-2xl align-middle" style="font-variation-settings: 'FILL' 1;" title="@(user.IsActive ? "Set user inactive" : "Set user active")">
                                                @(user.IsActive ? "toggle_on" : "toggle_off")
                                            </button>
                                        }
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-12">
                                <span class="material-symbols-outlined text-4xl text-slate-300 mb-2">group_off</span>
                                <p class="text-slate-500 font-medium">No customers found.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <div class="px-6 py-4 bg-surface-container-low border-t border-slate-100 flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <span class="text-xs text-slate-500 font-medium">
                    Showing <span class="font-semibold text-slate-700">@(((currentPage - 1) * (ViewBag.PageSize is int ps ? ps : 10)) + (Model.Any() ? 1 : 0))</span>
                    to <span class="font-semibold text-slate-700">@(((currentPage - 1) * (ViewBag.PageSize is int ps2 ? ps2 : 10)) + Model.Count())</span>
                    of <span class="font-semibold text-slate-700">@totalCount</span> customers
                </span>
                <div class="flex flex-wrap gap-2 items-center">
                    <a asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-searchQuery="@ViewBag.SearchQuery" asp-route-statusFilter="@ViewBag.StatusFilter"
                       class="inline-flex items-center gap-1 rounded-xl border px-3 py-2 text-xs font-semibold transition-all @(currentPage == 1 ? "pointer-events-none border-slate-200 bg-slate-100 text-slate-300" : "border-slate-200 bg-white text-slate-600 hover:border-primary/30 hover:text-primary")">
                        <span class="material-symbols-outlined text-sm">chevron_left</span>
                        Previous
                    </a>

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        if (i == currentPage)
                        {
                            <button class="inline-flex h-10 min-w-10 items-center justify-center rounded-xl border border-primary bg-primary px-3 text-xs font-bold text-white shadow-md shadow-primary/20">@i</button>
                        }
                        else
                        {
                            <a asp-action="Index" asp-route-page="@i" asp-route-searchQuery="@ViewBag.SearchQuery" asp-route-statusFilter="@ViewBag.StatusFilter" class="inline-flex h-10 min-w-10 items-center justify-center rounded-xl border border-slate-200 bg-white px-3 text-xs font-bold text-slate-600 transition-all hover:border-primary/30 hover:text-primary">@i</a>
                        }
                    }

                    <a asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-searchQuery="@ViewBag.SearchQuery" asp-route-statusFilter="@ViewBag.StatusFilter"
                       class="inline-flex items-center gap-1 rounded-xl border px-3 py-2 text-xs font-semibold transition-all @(currentPage == totalPages ? "pointer-events-none border-slate-200 bg-slate-100 text-slate-300" : "border-slate-200 bg-white text-slate-600 hover:border-primary/30 hover:text-primary")">
                        Next
                        <span class="material-symbols-outlined text-sm">chevron_right</span>
                    </a>
                </div>
            </div>
        }
    </div>
</div>

