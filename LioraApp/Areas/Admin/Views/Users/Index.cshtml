@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Users";
}

<div class="max-w-[1280px] mx-auto w-full">
                <!-- Page Header & Actions -->
                <div class="flex flex-col md:flex-row md:items-end justify-between gap-stack-lg mb-12">
                    <div>
                        <h2 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-background mb-2">Users Management</h2>
                        <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl">Manage customer accounts, roles, and order histories across the platform.</p>
                    </div>
                    <div class="flex flex-col sm:flex-row gap-4">
                        <!-- Search -->
                        <div class="relative w-full sm:w-72">
                            <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-outline">
                                <span class="material-symbols-outlined text-lg">search</span>
                            </div>
                            <input class="bg-surface-container-lowest border border-outline-variant text-on-background text-sm rounded-full focus:ring-primary focus:border-primary block w-full pl-10 p-3 outline-none transition-all ease-out-250 shadow-[0_4px_10px_rgba(26,16,37,0.02)] focus:shadow-[0_4px_20px_rgba(196,144,128,0.15)] placeholder-outline" placeholder="Search users by name, email..." type="text" />
                        </div>
                        <button class="bg-primary-container text-on-primary-container px-6 py-3 rounded-full font-label-caps text-label-caps hover:bg-primary-fixed transition-all ease-out-250 shadow-[0_10px_30px_rgba(26,16,37,0.05)] active:scale-[0.98] whitespace-nowrap flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-sm">person_add</span>
                            ADD USER
                        </button>
                    </div>
                </div>
                <!-- Users Data Grid (Bento/Card inspired list) -->
                <div class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden shadow-[0_10px_30px_rgba(26,16,37,0.02)] relative z-10">
                    <!-- Table Header (Hidden on mobile) -->
                    <div class="hidden md:grid grid-cols-12 gap-4 px-6 py-4 bg-surface-container-low border-b border-outline-variant text-on-surface-variant font-label-caps text-label-caps">
                        <div class="col-span-4">User</div>
                        <div class="col-span-2">Joined Date</div>
                        <div class="col-span-2 text-right">Orders &amp; Value</div>
                        <div class="col-span-2 text-center">Role</div>
                        <div class="col-span-2 text-right">Actions</div>
                    </div>
                    <!-- User Rows -->
                    <div class="flex flex-col divide-y divide-outline-variant relative">
                        <!-- Row 1 -->
                        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 p-6 items-center bg-surface-container-lowest transition-all ease-out-250 table-row-hover relative">
                            <!-- User Info -->
                            <div class="col-span-1 md:col-span-4 flex items-center gap-4">
                                <div class="w-12 h-12 rounded-full bg-primary-container text-on-primary-container flex items-center justify-center font-headline-md text-headline-md font-bold shrink-0">
                                    ES
                                </div>
                                <div>
                                    <p class="font-body-md text-body-md font-bold text-on-background">Eleanor Sterling</p>
                                    <p class="text-sm text-on-surface-variant">eleanor.s@example.com</p>
                                </div>
                            </div>
                            <!-- Joined Date -->
                            <div class="col-span-1 md:col-span-2 flex justify-between md:block">
                                <span class="md:hidden font-label-caps text-label-caps text-on-surface-variant">Joined</span>
                                <span class="font-body-md text-body-md text-on-surface">Oct 12, 2023</span>
                            </div>
                            <!-- Orders & Value -->
                            <div class="col-span-1 md:col-span-2 flex justify-between md:justify-end md:text-right items-center gap-2">
                                <span class="md:hidden font-label-caps text-label-caps text-on-surface-variant">Stats</span>
                                <div class="flex flex-col items-end">
                                    <a class="text-primary hover:text-surface-tint underline decoration-1 underline-offset-2 transition-colors" asp-controller="Orders" asp-action="Index">14 Orders</a>
                                    <span class="font-mono text-sm font-semibold text-primary-container">£4,250.00</span>
                                </div>
                            </div>
                            <!-- Role -->
                            <div class="col-span-1 md:col-span-2 flex justify-between md:justify-center items-center">
                                <span class="md:hidden font-label-caps text-label-caps text-on-surface-variant">Role</span>
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-surface-container-high text-on-surface">
                                    Customer
                                </span>
                            </div>
                            <!-- Actions -->
                            <div class="col-span-1 md:col-span-2 flex justify-end gap-2 mt-4 md:mt-0">
                                <button class="p-2 text-on-surface-variant hover:text-primary hover:bg-primary-fixed rounded-full transition-all ease-out-250 group relative" title="View Orders">
                                    <span class="material-symbols-outlined text-xl">visibility</span>
                                </button>
                                <button class="p-2 text-on-surface-variant hover:text-error hover:bg-error-container rounded-full transition-all ease-out-250 group relative" title="Block User">
                                    <span class="material-symbols-outlined text-xl">block</span>
                                </button>
                            </div>
                        </div>
                        <!-- Row 2 -->
                        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 p-6 items-center bg-surface-container-lowest transition-all ease-out-250 table-row-hover relative">
                            <!-- User Info -->
                            <div class="col-span-1 md:col-span-4 flex items-center gap-4">
                                <div class="w-12 h-12 rounded-full bg-secondary-container text-on-secondary-container flex items-center justify-center font-headline-md text-headline-md font-bold shrink-0">
                                    JM
                                </div>
                                <div>
                                    <p class="font-body-md text-body-md font-bold text-on-background">Julian Mercer</p>
                                    <p class="text-sm text-on-surface-variant">j.mercer@company.co.uk</p>
                                </div>
                            </div>
                            <!-- Joined Date -->
                            <div class="col-span-1 md:col-span-2 flex justify-between md:block">
                                <span class="md:hidden font-label-caps text-label-caps text-on-surface-variant">Joined</span>
                                <span class="font-body-md text-body-md text-on-surface">Jan 05, 2024</span>
                            </div>
                            <!-- Orders & Value -->
                            <div class="col-span-1 md:col-span-2 flex justify-between md:justify-end md:text-right items-center gap-2">
                                <span class="md:hidden font-label-caps text-label-caps text-on-surface-variant">Stats</span>
                                <div class="flex flex-col items-end">
                                    <span class="text-on-surface-variant opacity-50 cursor-not-allowed">0 Orders</span>
                                    <span class="font-mono text-sm font-semibold text-outline-variant">£0.00</span>
                                </div>
                            </div>
                            <!-- Role -->
                            <div class="col-span-1 md:col-span-2 flex justify-between md:justify-center items-center">
                                <span class="md:hidden font-label-caps text-label-caps text-on-surface-variant">Role</span>
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary-fixed-dim text-on-primary-fixed">
                                    Admin
                                </span>
                            </div>
                            <!-- Actions -->
                            <div class="col-span-1 md:col-span-2 flex justify-end gap-2 mt-4 md:mt-0">
                                <button class="p-2 text-on-surface-variant hover:text-primary hover:bg-primary-fixed rounded-full transition-all ease-out-250 group relative" title="View Profile">
                                    <span class="material-symbols-outlined text-xl">visibility</span>
                                </button>
                                <button class="p-2 text-on-surface-variant opacity-30 cursor-not-allowed rounded-full transition-all ease-out-250 group relative" disabled="" title="Cannot Block Admins">
                                    <span class="material-symbols-outlined text-xl">block</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Pagination -->
                <div class="mt-8 flex items-center justify-between border-t border-outline-variant pt-6">
                    <p class="text-sm text-on-surface-variant font-body-md">Showing 1 to 2 of 2 entries</p>
                    <div class="flex gap-2">
                        <button class="w-10 h-10 flex items-center justify-center rounded-full border border-outline-variant text-on-surface-variant hover:bg-surface-container-high transition-colors ease-out-250 opacity-50 cursor-not-allowed" disabled="">
                            <span class="material-symbols-outlined text-sm">chevron_left</span>
                        </button>
                        <button class="w-10 h-10 flex items-center justify-center rounded-full bg-primary text-on-primary font-bold shadow-[0_10px_30px_rgba(26,16,37,0.05)]">
                            1
                        </button>
                        <button class="w-10 h-10 flex items-center justify-center rounded-full border border-outline-variant text-on-surface-variant hover:bg-surface-container-high transition-colors ease-out-250 opacity-50 cursor-not-allowed" disabled="">
                            <span class="material-symbols-outlined text-sm">chevron_right</span>
                        </button>
                    </div>
                </div>
            </div>
