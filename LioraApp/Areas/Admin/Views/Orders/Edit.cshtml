@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Order #1234";
}

<!-- Header Section -->
        <div class="mb-stack-lg flex flex-col md:flex-row md:items-end justify-between gap-unit-stack-md">
            <div>
                <a class="inline-flex items-center gap-unit text-on-surface-variant hover:text-primary font-body-md text-sm mb-unit transition-colors duration-250" asp-action="Index">
                    <span class="material-symbols-outlined text-[16px]">arrow_back</span>
                    Back to Orders
                </a>
                <div class="flex items-center gap-stack-sm mt-unit">
                    <h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-background">Edit Order #1234</h2>
                    <span class="inline-flex items-center px-3 py-1 rounded-full bg-primary-container/20 text-primary-container font-label-caps text-[10px] uppercase tracking-wider border border-primary-container/30">
                        Confirmed
                    </span>
                </div>
                <p class="font-body-md text-on-surface-variant mt-unit opacity-80">Placed on Oct 24, 2023 at 10:42 AM</p>
            </div>
            <div class="flex gap-unit-stack-sm">
                <button class="px-unit-stack-md py-unit-stack-sm rounded-lg border border-primary text-primary font-label-caps text-label-caps hover:bg-surface-container-highest transition-all duration-250 ease-out flex items-center gap-unit">
                    <span class="material-symbols-outlined text-[16px]">receipt_long</span>
                    Invoice
                </button>
                <button class="px-unit-stack-md py-unit-stack-sm rounded-lg border border-error/50 text-error font-label-caps text-label-caps hover:bg-error-container transition-all duration-250 ease-out flex items-center gap-unit">
                    <span class="material-symbols-outlined text-[16px]">cancel</span>
                    Cancel Order
                </button>
            </div>
        </div>
        <!-- Bento Grid Layout -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter items-start">
            <!-- Left Column: Order Details (Span 8) -->
            <div class="lg:col-span-8 space-y-gutter">
                <!-- Items Editor Card -->
                <section class="bg-surface rounded-xl p-stack-lg shadow-[0px_10px_30px_rgba(26,16,37,0.05)] border border-outline-variant/10">
                    <div class="flex justify-between items-center mb-stack-md">
                        <h3 class="font-headline-md text-xl text-on-surface">Order Items</h3>
                        <button class="text-primary font-label-caps text-label-caps hover:text-primary-container transition-colors flex items-center gap-unit">
                            <span class="material-symbols-outlined text-[16px]">add</span> Add Item
                        </button>
                    </div>
                    <div class="space-y-unit-stack-md">
                        <!-- Item 1 -->
                        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-unit-stack-md p-unit-stack-md bg-surface-container-lowest rounded-lg border border-outline-variant/20 hover:border-outline-variant/40 transition-colors">
                            <img alt="Silk Evening Gown" class="w-16 h-16 sm:w-20 sm:h-20 object-cover rounded-md" data-alt="A delicate silk evening gown in muted rose gold draped gracefully over a minimalist modern hanger. The lighting is soft and studio-quality, emphasizing the luxurious sheen and fluid texture of the fabric. The background is a clean, bright ivory, aligning with a high-fashion editorial aesthetic." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBxiQ52qTSK_eFlW1IMFmkES06_gKKS_n0ZaWQdRqG1AJXSJV_j6IvnG8ZBUxeRdGpiIMVD29SShn3R7tRkh__3psG-0r3MDAy5xUy-Ajxh42eKVuVF9EOAvtCDnVo6LSKsUiLxjfGaPxP-hhZaenRebcowm37E4cwl-mYTSmjh1yxERqEXl7x3l9TCDPfSS5J44FWcY4zSLECkZxwM88EZpf4mzXpkAIL1ETMCCvWOBFbtsqe_x7ZKui9U0CL21IeN6V_Qrz6H_Lt2" />
                            <div class="flex-1 min-w-0">
                                <h4 class="font-headline-md text-lg text-on-surface truncate">Silk Evening Gown</h4>
                                <p class="font-body-md text-sm text-on-surface-variant mt-1">SKU: SG-104-ROSE • Size: S</p>
                            </div>
                            <div class="flex items-center justify-between w-full sm:w-auto gap-unit-stack-md mt-unit-stack-sm sm:mt-0">
                                <div class="flex items-center border border-outline-variant/30 rounded-md bg-surface">
                                    <button class="px-2 py-1 text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined text-[16px]">remove</span></button>
                                    <input aria-label="Quantity" class="w-12 text-center font-body-md border-none bg-transparent p-0 focus:ring-0" type="number" value="1" />
                                    <button class="px-2 py-1 text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined text-[16px]">add</span></button>
                                </div>
                                <div class="text-right">
                                    <p class="font-body-md font-medium text-on-surface">$450.00</p>
                                </div>
                                <button aria-label="Remove item" class="text-outline hover:text-error transition-colors p-1 rounded-full hover:bg-error-container">
                                    <span class="material-symbols-outlined text-[20px]">delete</span>
                                </button>
                            </div>
                        </div>
                        <!-- Item 2 -->
                        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-unit-stack-md p-unit-stack-md bg-surface-container-lowest rounded-lg border border-outline-variant/20 hover:border-outline-variant/40 transition-colors">
                            <img alt="Cashmere Wrap" class="w-16 h-16 sm:w-20 sm:h-20 object-cover rounded-md" data-alt="A luxurious cashmere wrap in a soft ivory shade, elegantly folded on a smooth marble surface. Subtle, ambient lighting casts gentle shadows, highlighting the soft, plush texture of the knit. The composition is clean and minimalist, evoking a sense of modern luxury and comfort." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBlhKbfmyhifChQir2tvuJ4jlEjyGw74r8rUC2z-2Hr2NzH6k00C9wiQih84U6iIeFh4-4BJWgWRKMF8XxIJ6-TJtNXK-KQ2V11tj_hn1ejWVa7XF1bKyMcHT78905yXRBiO7MPa9h32SzJEQcZ_dUjbhEq_0ADkkOBhG3G_t94WMzeBaExTpPp8PyqnM2KgRrs7JK3aPq8mvpVXwNEPFUgn4JFYtFTHfycKqqKWXvqqiLhT6yYrsmcKs5xnP4n3GmZ4pHNQtOicv7Y" />
                            <div class="flex-1 min-w-0">
                                <h4 class="font-headline-md text-lg text-on-surface truncate">Cashmere Wrap</h4>
                                <p class="font-body-md text-sm text-on-surface-variant mt-1">SKU: CW-201-IVY • Size: OS</p>
                            </div>
                            <div class="flex items-center justify-between w-full sm:w-auto gap-unit-stack-md mt-unit-stack-sm sm:mt-0">
                                <div class="flex items-center border border-outline-variant/30 rounded-md bg-surface">
                                    <button class="px-2 py-1 text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined text-[16px]">remove</span></button>
                                    <input aria-label="Quantity" class="w-12 text-center font-body-md border-none bg-transparent p-0 focus:ring-0" type="number" value="2" />
                                    <button class="px-2 py-1 text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined text-[16px]">add</span></button>
                                </div>
                                <div class="text-right">
                                    <p class="font-body-md font-medium text-on-surface">$250.00</p>
                                </div>
                                <button aria-label="Remove item" class="text-outline hover:text-error transition-colors p-1 rounded-full hover:bg-error-container">
                                    <span class="material-symbols-outlined text-[20px]">delete</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </section>
                <!-- Shipping & Customer Details -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
                    <!-- Customer Info -->
                    <section class="bg-surface rounded-xl p-stack-lg shadow-[0px_10px_30px_rgba(26,16,37,0.05)] border border-outline-variant/10">
                        <div class="flex justify-between items-center mb-stack-md border-b border-outline-variant/20 pb-unit-stack-sm">
                            <h3 class="font-headline-md text-xl text-on-surface flex items-center gap-unit">
                                <span class="material-symbols-outlined text-primary">person</span>
                                Customer
                            </h3>
                            <button aria-label="Edit Customer" class="text-outline hover:text-primary transition-colors">
                                <span class="material-symbols-outlined text-[18px]">edit</span>
                            </button>
                        </div>
                        <div class="space-y-unit-stack-md">
                            <div>
                                <p class="font-body-md font-medium text-on-surface">Eleanor Vance</p>
                                <p class="font-body-md text-on-surface-variant text-sm mt-1">eleanor.v@example.com</p>
                                <p class="font-body-md text-on-surface-variant text-sm">+1 (555) 123-4567</p>
                            </div>
                            <div class="pt-unit-stack-sm">
                                <p class="font-label-caps text-label-caps text-outline mb-1">Customer Notes</p>
                                <p class="font-body-md text-on-surface-variant text-sm italic">"Please ensure signature required on delivery."</p>
                            </div>
                        </div>
                    </section>
                    <!-- Shipping Info -->
                    <section class="bg-surface rounded-xl p-stack-lg shadow-[0px_10px_30px_rgba(26,16,37,0.05)] border border-outline-variant/10">
                        <div class="flex justify-between items-center mb-stack-md border-b border-outline-variant/20 pb-unit-stack-sm">
                            <h3 class="font-headline-md text-xl text-on-surface flex items-center gap-unit">
                                <span class="material-symbols-outlined text-primary">local_shipping</span>
                                Shipping
                            </h3>
                        </div>
                        <div class="space-y-unit-stack-md">
                            <div class="input-glow rounded-md border border-outline-variant/20 bg-surface-container-lowest transition-all">
                                <label class="block font-label-caps text-[10px] text-outline px-unit pt-unit">Address Line 1</label>
                                <input class="w-full bg-transparent border-none py-1 px-unit text-on-surface font-body-md focus:ring-0" type="text" value="1040 Fifth Avenue" />
                            </div>
                            <div class="grid grid-cols-2 gap-unit-stack-md">
                                <div class="input-glow rounded-md border border-outline-variant/20 bg-surface-container-lowest transition-all">
                                    <label class="block font-label-caps text-[10px] text-outline px-unit pt-unit">City</label>
                                    <input class="w-full bg-transparent border-none py-1 px-unit text-on-surface font-body-md focus:ring-0" type="text" value="New York" />
                                </div>
                                <div class="input-glow rounded-md border border-outline-variant/20 bg-surface-container-lowest transition-all">
                                    <label class="block font-label-caps text-[10px] text-outline px-unit pt-unit">Zip Code</label>
                                    <input class="w-full bg-transparent border-none py-1 px-unit text-on-surface font-body-md focus:ring-0" type="text" value="10028" />
                                </div>
                            </div>
                            <div class="pt-unit">
                                <label class="block font-label-caps text-label-caps text-outline mb-2">Shipping Method</label>
                                <select class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-md py-2 px-unit font-body-md text-on-surface focus:ring-primary focus:border-primary">
                                    <option value="standard">Standard (3-5 Days)</option>
                                    <option selected="" value="express">Express (1-2 Days) - $25.00</option>
                                    <option value="overnight">Overnight - $50.00</option>
                                </select>
                            </div>
                        </div>
                    </section>
                </div>
            </div>
            <!-- Right Column: Summary Sidebar (Span 4) -->
            <div class="lg:col-span-4 sticky top-[100px]">
                <aside class="bg-surface rounded-xl p-stack-lg shadow-[0px_10px_30px_rgba(26,16,37,0.05)] border border-outline-variant/10 flex flex-col h-full">
                    <h3 class="font-headline-md text-2xl text-on-surface mb-stack-lg pb-unit-stack-sm border-b border-outline-variant/20">Order Summary</h3>
                    <div class="space-y-unit-stack-md font-body-md text-on-surface mb-stack-lg flex-grow">
                        <div class="flex justify-between items-center">
                            <span class="text-on-surface-variant">Subtotal (3 items)</span>
                            <span>$950.00</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-on-surface-variant">Discount (VIP10)</span>
                            <span class="text-primary">-$95.00</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-on-surface-variant">Shipping (Express)</span>
                            <span>$25.00</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-on-surface-variant">Tax (8.875%)</span>
                            <span>$78.10</span>
                        </div>
                        <div class="pt-unit-stack-md mt-unit-stack-md border-t border-outline-variant/20">
                            <div class="flex justify-between items-center font-headline-md text-xl">
                                <span>Total</span>
                                <span>$958.10</span>
                            </div>
                            <p class="text-right text-sm text-on-surface-variant mt-1">Paid via Credit Card ending in 4242</p>
                        </div>
                    </div>
                    <div class="mt-auto pt-stack-md">
                        <button class="w-full bg-primary-container text-on-primary-container font-label-caps text-label-caps py-4 rounded-xl hover:scale-98 shadow-[0px_10px_30px_rgba(26,16,37,0.05)] transition-all duration-250 ease-out flex justify-center items-center gap-2">
                            <span class="material-symbols-outlined text-[18px]">save</span>
                            Save Changes
                        </button>
                    </div>
                </aside>
            </div>
        </div>
