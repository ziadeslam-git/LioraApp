    <style>
        .shadow-ambient-lvl1 {
        box-shadow: 0px 10px 30px rgba(26, 16, 37, 0.05);
        }

        .shadow-ambient-lvl2 {
        box-shadow: 0px 20px 50px rgba(26, 16, 37, 0.08);
        }

        .ease-editorial {
        transition-timing-function: cubic-bezier(0.25, 1, 0.5, 1);
        transition-duration: 250ms;
        }
