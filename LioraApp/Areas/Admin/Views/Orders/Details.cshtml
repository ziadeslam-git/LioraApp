</head>
<body class="bg-background text-on-background font-body-md min-h-screen">
    <!-- TopNavBar -->
    <header class="fixed top-0 right-0 h-[60px] w-[calc(100%-240px)] bg-surface-container dark:bg-surface-container border-b border-outline-variant flex items-center justify-between px-gutter w-full z-50">
        <div class="flex items-center gap-4">
            <!-- Search bar on left -->
            <div class="relative hidden md:block">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant" style="font-variation-settings: 'FILL' 0;">search</span>
                <input class="pl-10 pr-4 py-2 bg-surface rounded-full border border-outline-variant/50 focus:border-primary-container focus:ring-0 outline-none font-body-md text-body-md text-on-surface w-64 ease-editorial transition-all shadow-sm" placeholder="Search orders..." type="text" />
            </div>
        </div>
        <div class="flex items-center gap-4">
            <button class="p-2 text-on-surface-variant hover:bg-surface-container-highest rounded-full transition-colors cursor-pointer active:scale-95">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">notifications</span>
            </button>
            <button class="p-2 text-on-surface-variant hover:bg-surface-container-highest rounded-full transition-colors cursor-pointer active:scale-95">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">account_circle</span>
            </button>
        </div>
    </header>
    <!-- SideNavBar -->
    <nav class="fixed left-0 top-0 h-full w-[240px] bg-surface-container-low dark:bg-surface-container-low border-r border-outline-variant flex flex-col h-full overflow-y-auto z-40">
        <div class="p-6 pb-8 border-b border-outline-variant/30">
            <h1 class="font-headline-md text-headline-md font-bold text-primary">Liora</h1>
            <div class="mt-4 flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-primary-container flex items-center justify-center text-on-primary-container font-label-caps text-label-caps">
                    LA
                </div>
                <div>
                    <div class="font-body-md text-body-md font-bold text-on-surface">Liora Admin</div>
                    <div class="text-xs text-on-surface-variant">Enterprise Portal</div>
                </div>
            </div>
        </div>
        <div class="flex-1 py-6 flex flex-col gap-2 px-2">
            <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-highest hover:text-on-surface transition-colors rounded-lg ease-editorial" href="#">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">dashboard</span>
                <span class="font-body-md text-body-md">Overview</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-highest hover:text-on-surface transition-colors rounded-lg ease-editorial" href="#">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">inventory_2</span>
                <span class="font-body-md text-body-md">Catalog</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 border-l-2 border-primary bg-surface-container-high text-primary font-bold rounded-r-lg ease-editorial" href="#">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">payments</span>
                <span class="font-body-md text-body-md">Sales</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-highest hover:text-on-surface transition-colors rounded-lg ease-editorial" href="#">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">group</span>
                <span class="font-body-md text-body-md">Customers</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-highest hover:text-on-surface transition-colors rounded-lg ease-editorial" href="#">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">settings</span>
                <span class="font-body-md text-body-md">Settings</span>
            </a>
        </div>
    </nav>
    <!-- Main Content -->
    <main class="ml-[240px] mt-[60px] p-container-padding-desktop min-h-[calc(100vh-60px)]">
        <!-- Page Header -->
        <div class="mb-stack-lg flex justify-between items-end border-b border-outline-variant/30 pb-6">
            <div>
                <a class="inline-flex items-center gap-2 text-on-surface-variant hover:text-primary mb-4 transition-colors font-label-caps text-label-caps" href="#">
                    <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 0;">arrow_back</span>
                    BACK TO ORDERS
                </a>
                <div class="flex items-center gap-4">
                    <h2 class="font-display-lg text-display-lg text-primary">Order #1234</h2>
                    <span class="px-4 py-1.5 bg-surface-container-highest text-on-surface-variant rounded-full font-label-caps text-label-caps border border-outline-variant/50">PENDING PAYMENT</span>
                </div>
                <p class="font-body-md text-body-md text-on-surface-variant mt-2">Placed on October 24, 2023 at 10:42 AM</p>
            </div>
            <button class="bg-surface text-primary border border-primary px-6 py-3 rounded-full font-label-caps text-label-caps hover:bg-surface-container transition-all ease-editorial flex items-center gap-2">
                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 0;">print</span>
                PRINT INVOICE
            </button>
        </div>
        <!-- 2-Column Layout -->
        <div class="flex flex-col lg:flex-row gap-gutter">
            <!-- LEFT COLUMN: Order Info (60%) -->
            <div class="w-full lg:w-3/5 flex flex-col gap-stack-lg">
                <!-- Customer & Shipping Row -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-stack-md">
                    <!-- Customer Card -->
                    <div class="bg-surface rounded-2xl p-6 shadow-ambient-lvl1 border border-surface-container-highest">
                        <div class="flex items-center gap-3 mb-6">
                            <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 0;">person</span>
                            <h3 class="font-headline-md text-headline-md text-[24px]">Customer</h3>
                        </div>
                        <div class="flex items-center gap-4 mb-4">
                            <img alt="Customer Profile" class="w-16 h-16 rounded-full object-cover border-2 border-surface-container" data-alt="A sophisticated portrait of a modern woman with elegant styling, soft natural lighting highlighting her features against a minimalist studio background. The mood is refined and luxurious, fitting a high-end fashion or beauty context." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBmzhKrfJUMWs9CEYwlWTQAHw6LF2AaYA7zT1ZhWnQcqD2gO_8A9rD5J6jcTcaOBkzBtMvF5hAYWSMf6mVnuTYKlrl5sMAp9w4TbPrDnEjrQUhA0a57uvkAZUUlxrPkjAB945tnUBDjlV_9HbyrLKKsyg47hWu_DgVju5S3HzV4fejxLCP2d3EqAf0UNOk0D2ShUZRwEwDAhCHz5zf5WUY7b9_R0turUtx05toPBN0THGNM2jXZWEanCb7coq216dPtrtrCo2NSNN69" />
                            <div>
                                <p class="font-body-lg text-body-lg font-bold">Eleanor Vance</p>
                                <p class="font-body-md text-body-md text-on-surface-variant">eleanor.v@example.com</p>
                                <p class="font-body-md text-body-md text-on-surface-variant">+20 123 456 7890</p>
                            </div>
                        </div>
                        <div class="pt-4 border-t border-outline-variant/30 flex justify-between items-center">
                            <span class="font-body-md text-body-md text-on-surface-variant">Total Orders: <span class="font-bold text-on-surface">4</span></span>
                            <a class="font-label-caps text-label-caps text-primary hover:underline" href="#">VIEW PROFILE</a>
                        </div>
                    </div>
                    <!-- Shipping Address Card -->
                    <div class="bg-surface rounded-2xl p-6 shadow-ambient-lvl1 border border-surface-container-highest">
                        <div class="flex items-center gap-3 mb-6">
                            <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 0;">local_shipping</span>
                            <h3 class="font-headline-md text-headline-md text-[24px]">Shipping</h3>
                        </div>
                        <p class="font-body-lg text-body-lg font-bold mb-1">Eleanor Vance</p>
                        <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
                            Apt 4B, The Jasmine Building<br />
                            12 Zamalek Street<br />
                            Cairo, Cairo Governorate 11211<br />
                            Egypt
                        </p>
                        <div class="pt-4 mt-auto border-t border-outline-variant/30 flex justify-between items-center">
                            <span class="font-body-md text-body-md text-on-surface-variant">Method: <span class="font-bold text-on-surface">Premium Courier</span></span>
                        </div>
                    </div>
                </div>
                <!-- Order Items -->
                <div class="bg-surface rounded-2xl p-6 shadow-ambient-lvl1 border border-surface-container-highest">
                    <div class="flex items-center gap-3 mb-6">
                        <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 0;">shopping_bag</span>
                        <h3 class="font-headline-md text-headline-md text-[24px]">Order Items</h3>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="border-b border-outline-variant/50">
                                    <th class="pb-4 font-label-caps text-label-caps text-on-surface-variant font-normal">PRODUCT</th>
                                    <th class="pb-4 font-label-caps text-label-caps text-on-surface-variant font-normal text-right">PRICE</th>
                                    <th class="pb-4 font-label-caps text-label-caps text-on-surface-variant font-normal text-center">QTY</th>
                                    <th class="pb-4 font-label-caps text-label-caps text-on-surface-variant font-normal text-right">TOTAL</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="border-b border-outline-variant/20 group">
                                    <td class="py-4">
                                        <div class="flex items-center gap-4">
                                            <div class="w-16 h-20 rounded-lg overflow-hidden bg-surface-container-low flex-shrink-0">
                                                <img alt="Silk Dress" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" data-alt="A high-fashion editorial shot of an elegant silk slip dress in a soft ivory tone. The dress is displayed on a minimalist wooden hanger against a textured plaster wall. Soft, diffused daylight highlights the fluid drape and premium sheen of the fabric. The overall mood is quiet luxury and sophisticated elegance." src="https://lh3.googleusercontent.com/aida-public/AB6AXuDQE_bIHtUwKxQqFIH34s6bFuiGfQBzZqpR5VDHKvZxBHfKIwqCPR4LPv_7bbTCke0vYGjfK1HEdf3GcNBIiMU1wLYlrDxxm0MzZMP0y1cvE_K6TGB7nZMLpvrOPPALKg5VZ2ILH-Rdwop-bz3w-QHZKiQiCmtYaZbeZYpO7D0Rtp3T_9OzWzj2dh_bEGDxR4LUh_13tRMBPdSs14byip-IaqFgpblrjxzxbGTSEcFLcr1qdWLKIWPLhG8mKXw6cDQ__IAzhF_9fGks" />
                                            </div>
                                            <div>
                                                <p class="font-body-lg text-body-lg font-bold">Midnight Silk Slip Dress</p>
                                                <p class="font-body-md text-body-md text-on-surface-variant mt-1">Color: Ivory | Size: M</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-4 text-right font-body-md text-body-md">EGP 4,200</td>
                                    <td class="py-4 text-center font-body-md text-body-md">1</td>
                                    <td class="py-4 text-right font-body-md text-body-md font-bold">EGP 4,200</td>
                                </tr>
                                <tr class="group">
                                    <td class="py-4">
                                        <div class="flex items-center gap-4">
                                            <div class="w-16 h-20 rounded-lg overflow-hidden bg-surface-container-low flex-shrink-0">
                                                <img alt="Lace Robe" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" data-alt="A delicate, sheer lace robe in a deep plum color, elegantly styled flat on a clean marble surface. Subtle, moody lighting emphasizes the intricate floral patterns of the lace and the garment's ethereal lightness. The composition is clean, modern, and highly tactile, evoking a sense of intimate luxury." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBHawdic2cMXsxgrac3rVezGk2kMJ-S8YBC9CO5OALMEUZOWDL-t3bfOaUPwrH6ZOHTQaIu3N0BCVDZVCmmyTU7f5rApTVyo0GLReQFc-99nSU9PNeYoivkynffLnmKEu5K3DlppCKVZaZsbH3ruI16NTS73W9d8YJEnoSqaX-peC-1C_vsgNf5hf1OomP0BcVw_8GMsO2i1e7h_0QwFke0JPD-_FVKcbxx1XP21vYtCNnIFIu_4ABRcMAU8V4Pe4C4b2z_Ora68g8-" />
                                            </div>
                                            <div>
                                                <p class="font-body-lg text-body-lg font-bold">Jasmine Lace Robe</p>
                                                <p class="font-body-md text-body-md text-on-surface-variant mt-1">Color: Plum | Size: S</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-4 text-right font-body-md text-body-md">EGP 3,800</td>
                                    <td class="py-4 text-center font-body-md text-body-md">1</td>
                                    <td class="py-4 text-right font-body-md text-body-md font-bold">EGP 3,800</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <!-- Order Totals -->
                    <div class="mt-8 pt-6 border-t border-outline-variant/50 flex flex-col items-end gap-3 w-full">
                        <div class="flex justify-between w-full max-w-xs font-body-md text-body-md text-on-surface-variant">
                            <span>Subtotal</span>
                            <span>EGP 8,000</span>
                        </div>
                        <div class="flex justify-between w-full max-w-xs font-body-md text-body-md text-on-surface-variant">
                            <span>Shipping</span>
                            <span>EGP 150</span>
                        </div>
                        <div class="flex justify-between w-full max-w-xs font-body-md text-body-md text-on-surface-variant">
                            <span>Tax (14%)</span>
                            <span>EGP 1,120</span>
                        </div>
                        <div class="flex justify-between w-full max-w-xs pt-4 border-t border-outline-variant/30 font-headline-md text-headline-md text-[24px] text-primary mt-2">
                            <span>Total</span>
                            <span>EGP 9,270</span>
                        </div>
                    </div>
                </div>
            </div>
            <!-- RIGHT COLUMN: Sticky Actions & Status (40%) -->
            <div class="w-full lg:w-2/5">
                <div class="sticky top-[90px] flex flex-col gap-stack-lg">
                    <!-- Payment Status & Proof -->
                    <div class="bg-surface rounded-2xl p-6 shadow-ambient-lvl1 border border-surface-container-highest">
                        <div class="flex items-center justify-between mb-6">
                            <h3 class="font-headline-md text-headline-md text-[24px] flex items-center gap-3">
                                <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 0;">receipt_long</span>
                                Payment
                            </h3>
                            <span class="px-3 py-1 bg-surface-container-highest text-on-surface-variant rounded-full font-label-caps text-label-caps text-[10px]">UNVERIFIED</span>
                        </div>
                        <p class="font-body-md text-body-md mb-4">Customer has uploaded a payment receipt via Instapay. Please verify the amount matches the order total.</p>
                        <div class="relative w-full h-48 rounded-lg overflow-hidden bg-surface-container mb-4 group cursor-pointer border border-outline-variant/30">
                            <img alt="Payment Proof" class="w-full h-full object-cover opacity-90 group-hover:opacity-100 transition-opacity" data-alt="A close-up view of a digital transaction confirmation screen on a modern smartphone, slightly angled. The screen shows a successful money transfer with a green checkmark. The phone is resting on a clean, light-colored desk with a minimalist aesthetic. Soft, bright lighting gives it a professional and trustworthy feel." src="https://lh3.googleusercontent.com/aida-public/AB6AXuCLUpe0SFYDp-sPdilyu3ZfDQ3p56Kma3PvkypyHRLKrLaddZxUF79FRIDQf9y4nylt7gE2-ychdwfe58ZHUQJF8FqIYWV-41ZjtfN519IvTF4B7cZ9deYlv3PC3XjpfViRwYags6YblUHtAX9PyRxVJj4AfPIRv_jVvkUCORZs0GT_29Hev4uJJhuWF1rtsJ8Ld8FZaiyEHE43xhQPRutOik1LUQ0OpeZeOx-1hDDCPx9PNtND-tMFWBBm7rKWQfuOOFNyj433Pj0e" />
                            <div class="absolute inset-0 bg-inverse-surface/10 group-hover:bg-transparent transition-colors"></div>
                            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                                <span class="bg-surface/90 text-primary px-4 py-2 rounded-full font-label-caps text-label-caps shadow-sm">VIEW FULL IMAGE</span>
                            </div>
                        </div>
                        <div class="flex flex-col gap-3 mt-6">
                            <button class="w-full bg-primary-container text-on-primary-container py-4 rounded-lg font-label-caps text-label-caps hover:scale-[0.98] transition-transform ease-editorial shadow-ambient-lvl1 text-center">
                                CONFIRM PAYMENT
                            </button>
                            <button class="w-full bg-transparent border border-primary text-primary py-4 rounded-lg font-label-caps text-label-caps hover:bg-surface-container-lowest transition-colors ease-editorial text-center" onclick="document.getElementById('reject-reason-container').classList.toggle('hidden')">
                                REJECT PAYMENT
                            </button>
                            <div class="hidden mt-2 animate-[fadeIn_0.25s_ease-out]" id="reject-reason-container">
                                <label class="block font-body-md text-body-md text-on-surface mb-2">Reason for Rejection</label>
                                <textarea class="w-full bg-surface-container-lowest border border-outline-variant/50 rounded-lg p-3 font-body-md text-body-md focus:border-primary-container focus:ring-0 outline-none transition-all shadow-sm" placeholder="Explain why the payment is rejected..." rows="3"></textarea>
                                <button class="w-full mt-2 bg-error text-on-error py-3 rounded-lg font-label-caps text-label-caps hover:scale-[0.98] transition-transform ease-editorial text-center">
                                    SUBMIT REJECTION
                                </button>
                            </div>
