@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Create Order";
}

<!-- TopAppBar -->
        <header class="flex justify-between items-center px-gutter py-unit-stack-md bg-surface border-b border-outline-variant/20 sticky top-0 z-40 w-full transition-colors duration-250">
            <div class="flex items-center gap-4 w-1/3">
                <div class="relative w-full max-w-md input-focus-ring rounded-full bg-surface border border-primary/20 flex items-center px-4 py-2 transition-all duration-250">
                    <span class="material-symbols-outlined text-on-surface-variant mr-2" data-icon="search">search</span>
                    <input class="bg-transparent border-none outline-none w-full font-body-md text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:ring-0 p-0" placeholder="Search orders, customers..." type="text" />
                </div>
            </div>
            <div class="flex items-center justify-center w-1/3">
                <span class="font-headline-md text-headline-md text-primary dark:text-primary-fixed-dim">liora</span>
            </div>
            <div class="flex items-center justify-end gap-4 w-1/3 text-on-surface-variant">
                <button class="hover:text-primary hover:bg-surface-container-low p-2 rounded-full transition-colors duration-250 relative group">
                    <span class="material-symbols-outlined" data-icon="notifications">notifications</span>
                    <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-primary-container rounded-full border border-surface"></span>
                </button>
                <button class="hover:text-primary hover:bg-surface-container-low p-2 rounded-full transition-colors duration-250">
                    <span class="material-symbols-outlined" data-icon="person">person</span>
                </button>
            </div>
        </header>
        <!-- Content Area -->
        <div class="p-container-padding-desktop max-w-[1280px] mx-auto w-full">
            <!-- Page Header -->
            <div class="mb-stack-lg flex items-end justify-between">
                <div>
                    <a class="inline-flex items-center text-sm font-label-caps text-on-surface-variant hover:text-primary mb-2 transition-colors duration-250" asp-action="Index">
                        <span class="material-symbols-outlined text-[16px] mr-1" data-icon="arrow_back">arrow_back</span>
                        Back to Orders
                    </a>
                    <h2 class="font-headline-lg text-headline-lg text-on-surface">Create New Order</h2>
                </div>
                <div class="font-mono text-sm text-on-surface-variant">
                    Draft #10492
                </div>
            </div>
            <!-- 2-Column Layout -->
            <div class="flex flex-col lg:flex-row gap-gutter">
                <!-- Left Column (65%) -->
                <div class="w-full lg:w-[65%] flex flex-col gap-stack-lg">
                    <!-- Customer Information Card -->
                    <section class="bg-surface rounded-2xl shadow-level-1 p-8 relative overflow-hidden group">
                        <div class="flex justify-between items-center mb-stack-md">
                            <h3 class="font-headline-md text-xl text-on-surface">Customer Information</h3>
                            <label class="flex items-center cursor-pointer">
                                <span class="mr-3 font-body-md text-sm text-on-surface-variant">Guest Checkout</span>
                                <div class="relative">
                                    <input class="sr-only peer" type="checkbox" />
                                    <div class="w-11 h-6 bg-surface-variant rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary-container"></div>
                                </div>
                            </label>
                        </div>
                        <!-- Customer Search Picker -->
                        <div class="mb-stack-md">
                            <div class="relative w-full input-focus-ring rounded-full bg-surface-container-lowest border border-primary/20 flex items-center px-4 py-3 transition-all duration-250">
                                <span class="material-symbols-outlined text-primary mr-3" data-icon="person_search">person_search</span>
                                <input class="bg-transparent border-none outline-none w-full font-body-md text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:ring-0 p-0" placeholder="Search existing customers by name or email..." type="text" />
                            </div>
                        </div>
                        <!-- Customer Fields Form -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-stack-md">
                            <div class="flex flex-col gap-1">
                                <label class="font-label-caps text-on-surface-variant">First Name</label>
                                <div class="input-focus-ring rounded-lg bg-surface-container-lowest border border-primary/20 px-4 py-2.5 transition-all duration-250">
                                    <input class="bg-transparent border-none outline-none w-full font-body-md text-on-surface focus:ring-0 p-0" type="text" />
                                </div>
                            </div>
                            <div class="flex flex-col gap-1">
                                <label class="font-label-caps text-on-surface-variant">Last Name</label>
                                <div class="input-focus-ring rounded-lg bg-surface-container-lowest border border-primary/20 px-4 py-2.5 transition-all duration-250">
                                    <input class="bg-transparent border-none outline-none w-full font-body-md text-on-surface focus:ring-0 p-0" type="text" />
                                </div>
                            </div>
                            <div class="flex flex-col gap-1 md:col-span-2">
                                <label class="font-label-caps text-on-surface-variant">Email Address</label>
                                <div class="input-focus-ring rounded-lg bg-surface-container-lowest border border-primary/20 px-4 py-2.5 transition-all duration-250">
                                    <input class="bg-transparent border-none outline-none w-full font-body-md text-on-surface focus:ring-0 p-0" type="email" />
                                </div>
                            </div>
                            <div class="flex flex-col gap-1 md:col-span-2">
                                <label class="font-label-caps text-on-surface-variant">Phone Number</label>
                                <div class="input-focus-ring rounded-lg bg-surface-container-lowest border border-primary/20 px-4 py-2.5 transition-all duration-250">
                                    <input class="bg-transparent border-none outline-none w-full font-body-md text-on-surface focus:ring-0 p-0" type="tel" />
                                </div>
                            </div>
                            <div class="flex flex-col gap-1 md:col-span-2 mt-2">
                                <label class="font-label-caps text-on-surface-variant">Shipping Address</label>
                                <div class="input-focus-ring rounded-lg bg-surface-container-lowest border border-primary/20 px-4 py-2.5 transition-all duration-250 h-24">
                                    <textarea class="bg-transparent border-none outline-none w-full h-full resize-none font-body-md text-on-surface focus:ring-0 p-0"></textarea>
                                </div>
                            </div>
                        </div>
                    </section>
                    <!-- Order Items Card -->
                    <section class="bg-surface rounded-2xl shadow-level-1 p-8">
                        <div class="flex justify-between items-center mb-stack-md">
                            <h3 class="font-headline-md text-xl text-on-surface">Order Items</h3>
                        </div>
                        <!-- Product Search Picker -->
                        <div class="mb-stack-lg">
                            <div class="relative w-full input-focus-ring rounded-full bg-surface-container-lowest border border-primary/20 flex items-center px-4 py-3 transition-all duration-250">
                                <span class="material-symbols-outlined text-primary mr-3" data-icon="search">search</span>
                                <input class="bg-transparent border-none outline-none w-full font-body-md text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:ring-0 p-0" placeholder="Search products to add..." type="text" />
                                <button class="ml-2 font-label-caps text-primary hover:text-primary-container transition-colors">Browse</button>
                            </div>
                        </div>
                        <!-- Added Items List -->
                        <div class="flex flex-col gap-4">
                            <!-- Item Row 1 -->
                            <div class="flex items-center gap-4 p-4 rounded-xl border border-surface-variant/30 bg-surface-container-lowest hover:border-primary/20 transition-all duration-250 group">
                                <img alt="Silk Evening Gown" class="w-16 h-16 rounded-xl object-cover" data-alt="A luxurious silk evening gown in deep plum color, draped elegantly on a mannequin in a softly lit studio with a minimalist aesthetic." src="https://lh3.googleusercontent.com/aida-public/AB6AXuCYArY_bzVcsXaAA87JjJdUjhYdVWjKt5khOss_CI389Hx5ytDYrXXiRzZ98ICuyQLc9YT65h_8yqWq_l6I-Z1qsDLoODrJoBSKrg6v-BzcKhML0PljBBFHO0mk3fVXruDCln6J8j_oaE0K-4h4qf_c6ROHUFH8Mf2iWduK5w_-_RIzQr623Fts_41VXkUCoyfEsZT2TouzyN7zZSaAtGG_x_yuBUqnNF_-vTmBxP-E0CNViiM-xhEj28hXT87IB1MQmQUcPszPp9Vq" />
                                <div class="flex-grow flex flex-col justify-center">
                                    <h4 class="font-headline-md text-lg text-on-surface leading-tight mb-1">Silk Evening Gown</h4>
                                    <div class="flex gap-2 text-sm">
                                        <div class="relative">
                                            <select class="appearance-none bg-transparent border-b border-outline-variant/30 font-body-md text-on-surface-variant focus:outline-none focus:border-primary pb-1 pr-6 cursor-pointer">
                                                <option>Size S</option>
                                                <option selected="">Size M</option>
                                                <option>Size L</option>
                                            </select>
                                            <span class="material-symbols-outlined absolute right-0 top-0.5 text-[16px] text-outline-variant pointer-events-none" data-icon="arrow_drop_down">arrow_drop_down</span>
                                        </div>
                                        <span class="text-outline-variant">•</span>
                                        <div class="relative">
                                            <select class="appearance-none bg-transparent border-b border-outline-variant/30 font-body-md text-on-surface-variant focus:outline-none focus:border-primary pb-1 pr-6 cursor-pointer">
                                                <option selected="">Plum</option>
                                                <option>Rose</option>
                                                <option>Ivory</option>
                                            </select>
                                            <span class="material-symbols-outlined absolute right-0 top-0.5 text-[16px] text-outline-variant pointer-events-none" data-icon="arrow_drop_down">arrow_drop_down</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="flex items-center gap-6">
                                    <div class="flex items-center border border-outline-variant/30 rounded-lg bg-surface px-2 py-1">
                                        <button class="text-on-surface-variant hover:text-primary transition-colors p-1"><span class="material-symbols-outlined text-[16px]" data-icon="remove">remove</span></button>
                                        <input class="w-8 text-center bg-transparent border-none outline-none font-mono text-sm focus:ring-0 p-0 text-on-surface appearance-none" min="1" type="number" value="1" />
                                        <button class="text-on-surface-variant hover:text-primary transition-colors p-1"><span class="material-symbols-outlined text-[16px]" data-icon="add">add</span></button>
                                    </div>
                                    <div class="text-right w-20">
                                        <span class="font-mono text-lg text-on-surface">£850</span>
                                    </div>
                                    <button class="text-surface-variant hover:text-error transition-colors p-2 rounded-full hover:bg-error-container/20 opacity-0 group-hover:opacity-100 duration-250">
                                        <span class="material-symbols-outlined text-[20px]" data-icon="delete">delete</span>
                                    </button>
                                </div>
                            </div>
                            <!-- Item Row 2 -->
                            <div class="flex items-center gap-4 p-4 rounded-xl border border-surface-variant/30 bg-surface-container-lowest hover:border-primary/20 transition-all duration-250 group">
                                <img alt="Cashmere Wrap" class="w-16 h-16 rounded-xl object-cover" data-alt="A softly folded cashmere wrap in a gentle rose gold hue, resting on an ivory marble surface. High fashion editorial style lighting." src="https://lh3.googleusercontent.com/aida-public/AB6AXuCCHIPqADtzoTx2DzWCMsOkLwdeI_aulxOr6Ttsft6vAXB_XnSIDIydXbTbmoYJ_V8a6mlSCPkMEVGPt_qAwCLBG__56jNr2TLstO4AyFXGUP6b_YlNDJaXfW1PNBBDXmLX1OOcSGyPC_4JaXxs2hg0-B-bey6r_pXy8ZISjpTi7T8MIoEuCkmv2KTidcUFm-whKQtgUBT01FqyEpo2ZR6QS7kXz-UaOOyQC3NlWkArTTXMSXM2zPmBPjSrPCOFRoq935wbD-NJAtGn" />
                                <div class="flex-grow flex flex-col justify-center">
                                    <h4 class="font-headline-md text-lg text-on-surface leading-tight mb-1">Cashmere Wrap</h4>
                                    <div class="flex gap-2 text-sm">
                                        <span class="font-body-md text-on-surface-variant">One Size</span>
                                        <span class="text-outline-variant">•</span>
                                        <div class="relative">
                                            <select class="appearance-none bg-transparent border-b border-outline-variant/30 font-body-md text-on-surface-variant focus:outline-none focus:border-primary pb-1 pr-6 cursor-pointer">
                                                <option selected="">Rose Gold</option>
                                                <option>Oatmeal</option>
                                            </select>
                                            <span class="material-symbols-outlined absolute right-0 top-0.5 text-[16px] text-outline-variant pointer-events-none" data-icon="arrow_drop_down">arrow_drop_down</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="flex items-center gap-6">
                                    <div class="flex items-center border border-outline-variant/30 rounded-lg bg-surface px-2 py-1">
                                        <button class="text-on-surface-variant hover:text-primary transition-colors p-1"><span class="material-symbols-outlined text-[16px]" data-icon="remove">remove</span></button>
                                        <input class="w-8 text-center bg-transparent border-none outline-none font-mono text-sm focus:ring-0 p-0 text-on-surface appearance-none" min="1" type="number" value="2" />
                                        <button class="text-on-surface-variant hover:text-primary transition-colors p-1"><span class="material-symbols-outlined text-[16px]" data-icon="add">add</span></button>
                                    </div>
                                    <div class="text-right w-20 flex flex-col">
                                        <span class="font-mono text-lg text-on-surface">£500</span>
                                        <span class="font-mono text-[10px] text-on-surface-variant">£250/ea</span>
                                    </div>
                                    <button class="text-surface-variant hover:text-error transition-colors p-2 rounded-full hover:bg-error-container/20 opacity-0 group-hover:opacity-100 duration-250">
                                        <span class="material-symbols-outlined text-[20px]" data-icon="delete">delete</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <!-- Add Custom Item Line -->
                        <button class="mt-4 flex items-center gap-2 font-label-caps text-primary hover:text-primary-container transition-colors p-2 rounded-lg hover:bg-primary/5">
                            <span class="material-symbols-outlined text-[18px]" data-icon="add_circle">add_circle</span>
                            Add Custom Item
                        </button>
                    </section>
                </div>
                <!-- Right Column (35% Sticky) -->
                <div class="w-full lg:w-[35%] flex flex-col gap-stack-lg lg:sticky lg:top-24 h-fit">
                    <!-- Order Summary Card -->
                    <section class="bg-surface rounded-2xl shadow-level-1 p-8 relative">
                        <h3 class="font-headline-md text-xl text-on-surface mb-stack-md">Order Summary</h3>
                        <div class="flex flex-col gap-4 font-body-md text-on-surface">
                            <div class="flex justify-between items-center">
                                <span class="text-on-surface-variant">Subtotal (3 items)</span>
                                <span class="font-mono">£1,350.00</span>
                            </div>
                            <div class="flex justify-between items-center group">
                                <span class="text-on-surface-variant flex items-center gap-1 cursor-help" title="Click amount to edit">
                                    Shipping
                                    <span class="material-symbols-outlined text-[14px] opacity-50" data-icon="info">info</span>
                                </span>
                                <div class="relative w-24">
                                    <span class="absolute left-2 top-1 font-mono text-on-surface-variant">£</span>
                                    <input class="w-full text-right bg-transparent border-b border-dashed border-outline-variant focus:border-primary focus:outline-none focus:border-solid font-mono px-1 py-1 group-hover:border-primary/50 transition-colors" type="text" value="25.00" />
                                </div>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="text-on-surface-variant">Tax (20% VAT included)</span>
                                <span class="font-mono text-on-surface-variant">£275.00</span>
                            </div>
                            <div class="w-full h-px bg-outline-variant/30 my-2"></div>
                            <div class="flex justify-between items-end">
                                <span class="font-headline-md text-2xl">Total</span>
                                <div class="flex flex-col items-end">
                                    <span class="font-mono text-2xl font-medium text-primary">£1,375.00</span>
                                </div>
                            </div>
                        </div>
                    </section>
                    <!-- Payment Method Card -->
                    <section class="bg-surface rounded-2xl shadow-level-1 p-8">
                        <h3 class="font-headline-md text-xl text-on-surface mb-stack-md">Payment Method</h3>
                        <div class="relative w-full">
                            <div class="input-focus-ring rounded-xl bg-surface-container-lowest border border-primary/20 p-1 transition-all duration-250 relative">
                                <select class="appearance-none bg-transparent border-none w-full font-body-md text-on-surface py-3 pl-4 pr-10 focus:ring-0 cursor-pointer">
                                    <option disabled="" selected="" value="">Select a payment method...</option>
                                    <option value="vodafone_cash">Vodafone Cash</option>
                                    <option value="instapay">InstaPay</option>
                                    <option value="cod">Cash on Delivery (COD)</option>
                                    <option value="bank_transfer">Bank Transfer</option>
                                    <option value="credit_card">Credit Card (Link)</option>
                                </select>
                                <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none" data-icon="keyboard_arrow_down">keyboard_arrow_down</span>
                            </div>
                        </div>
                        <div class="mt-4 flex items-start gap-2 p-3 rounded-lg bg-surface-container-low text-sm text-on-surface-variant">
                            <span class="material-symbols-outlined text-[18px] text-primary shrink-0 mt-0.5" data-icon="receipt_long">receipt_long</span>
                            <p>An invoice link will be generated automatically and can be sent to the customer upon creation.</p>
                        </div>
                    </section>
                    <!-- Action Buttons -->
                    <div class="flex flex-col gap-3 mt-4">
                        <button class="w-full py-4 px-6 bg-primary-container text-on-primary-container rounded-full font-label-caps text-sm hover:opacity-90 active:scale-[0.98] transition-all duration-250 ease-out shadow-level-1 flex items-center justify-center gap-2 group">
                            Create Order
                            <span class="material-symbols-outlined text-[18px] group-hover:translate-x-1 transition-transform duration-250" data-icon="arrow_forward">arrow_forward</span>
                        </button>
                        <button class="w-full py-3 px-6 bg-transparent text-tertiary rounded-full font-label-caps text-sm border border-transparent hover:border-outline-variant/50 hover:bg-surface-variant/30 active:scale-[0.98] transition-all duration-250 ease-out">
                            Cancel
                        </button>
                    </div>
                </div>
            </div>
        </div>
