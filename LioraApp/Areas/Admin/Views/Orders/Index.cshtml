@model IEnumerable<LioraApp.ViewModels.Admin.OrderIndexVM>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin Orders Index";
}

<div class="flex-1 p-4 md:p-8 md:px-container-padding-desktop max-w-[1280px] mx-auto w-full">
    <!-- Page Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-stack-lg">
        <div>
            <h2 class="font-headline-lg text-headline-lg text-on-surface mb-2">Orders Management</h2>
            <p class="font-body-md text-body-md text-on-surface-variant">Review and manage recent purchases, verifications, and shipments.</p>
        </div>
        <div class="flex gap-3">
            <a asp-area="Admin" asp-controller="Orders" asp-action="ExportCsv" asp-route-status="@ViewBag.CurrentStatus"
               class="flex items-center gap-2 px-4 py-2 border border-outline text-on-surface hover:bg-surface-container-highest rounded-full font-label-caps text-label-caps transition-ease btn-scale">
                <span class="material-symbols-outlined text-[18px]">download</span>
                EXPORT CSV
            </a>
            <a asp-action="Create" class="flex items-center gap-2 px-4 py-2 bg-primary-container text-on-primary-container hover:bg-primary hover:text-on-primary rounded-full font-label-caps text-label-caps transition-ease btn-scale shadow-ambient-1">
                <span class="material-symbols-outlined text-[18px]">add</span>
                CREATE ORDER
            </a>
        </div>
    </div>
    
    <!-- Filters & Controls Card -->
    <div class="bg-surface-container-lowest rounded-2xl shadow-ambient-1 p-4 md:p-6 mb-stack-lg border border-surface-container-highest">
        <div class="flex flex-col lg:flex-row justify-between gap-6">
            <!-- Status Tabs -->
            <div class="flex overflow-x-auto pb-2 lg:pb-0 hide-scrollbar gap-2">
                <a asp-action="Index" asp-route-status="" class="px-5 py-2.5 rounded-full font-label-caps text-label-caps whitespace-nowrap transition-ease btn-scale @(string.IsNullOrEmpty(ViewBag.CurrentStatus) ? "bg-primary text-on-primary" : "bg-surface-container hover:bg-surface-container-highest text-on-surface-variant")">
                    ALL ORDERS
                </a>
                @foreach (var status in (IEnumerable<string>)ViewBag.AllStatuses)
                {
                    <a asp-action="Index" asp-route-status="@status" class="px-5 py-2.5 rounded-full font-label-caps text-label-caps whitespace-nowrap transition-ease btn-scale @(ViewBag.CurrentStatus == status ? "bg-primary text-on-primary" : "bg-surface-container hover:bg-surface-container-highest text-on-surface-variant")">
                        @status.ToUpper()
                    </a>
                }
            </div>
            <!-- Date Range & View Toggles -->
            <div class="flex items-center gap-3 shrink-0">
                <div class="relative group">
                    <button class="flex items-center gap-2 px-4 py-2.5 bg-surface-container-lowest border border-outline-variant hover:border-outline rounded-xl font-body-md text-body-md text-on-surface transition-ease">
                        <span class="material-symbols-outlined text-outline text-[20px]">calendar_today</span>
                        <span>Recent</span>
                        <span class="material-symbols-outlined text-outline text-[20px]">expand_more</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Data Table Card -->
    <div class="bg-surface-container-lowest rounded-2xl shadow-ambient-1 overflow-hidden border border-surface-container-highest">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-surface-container-high bg-surface-container-low/50">
                        <th class="p-4 font-label-caps text-label-caps text-on-surface-variant whitespace-nowrap">Order ID</th>
                        <th class="p-4 font-label-caps text-label-caps text-on-surface-variant whitespace-nowrap">Customer</th>
                        <th class="p-4 font-label-caps text-label-caps text-on-surface-variant whitespace-nowrap">Date</th>
                        <th class="p-4 font-label-caps text-label-caps text-on-surface-variant whitespace-nowrap text-center">Items</th>
                        <th class="p-4 font-label-caps text-label-caps text-on-surface-variant whitespace-nowrap text-right">Total</th>
                        <th class="p-4 font-label-caps text-label-caps text-on-surface-variant whitespace-nowrap text-center">Payment</th>
                        <th class="p-4 font-label-caps text-label-caps text-on-surface-variant whitespace-nowrap">Status</th>
                        <th class="p-4 font-label-caps text-label-caps text-on-surface-variant whitespace-nowrap text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="font-body-md text-body-md divide-y divide-surface-container-high">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var order in Model)
                        {
                            <tr class="table-row-hover transition-colors group cursor-pointer" onclick="window.location.href='@Url.Action("Details", new { id = order.Id })'">
                                <td class="p-4 align-middle">
                                    <span class="font-mono text-sm font-medium text-primary">#ORD-@order.Id</span>
                                </td>
                                <td class="p-4 align-middle">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full bg-secondary-container text-on-secondary-container flex items-center justify-center font-bold text-sm">
                                            @(string.IsNullOrWhiteSpace(order.CustomerName) ? "?" : order.CustomerName.Substring(0, 1).ToUpper())
                                        </div>
                                        <div>
                                            <div class="font-medium text-on-surface">@order.CustomerName</div>
                                            <div class="text-sm text-on-surface-variant">@order.CustomerEmail</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="p-4 align-middle text-on-surface-variant text-sm">
                                    @order.CreatedAt.ToString("MMM dd, yyyy")<br />@order.CreatedAt.ToString("HH:mm")
                                </td>
                                <td class="p-4 align-middle text-center">
                                    <span class="font-medium">@order.ItemCount</span> items
                                </td>
                                <td class="p-4 align-middle text-right font-medium text-on-surface">
                                    @order.TotalAmount.ToString("C")
                                </td>
                                <td class="p-4 align-middle text-center">
                                    @{
                                        string bgPaymentClass = order.PaymentStatus switch {
                                            "Paid" => "bg-primary-container text-on-primary-container",
                                            "Failed" => "bg-error-container text-on-error-container",
                                            _ => "bg-surface-variant text-on-surface-variant"
                                        };
                                    }
                                    <span class="inline-flex items-center px-2 py-1 rounded text-xs font-bold @bgPaymentClass">
                                        @order.PaymentStatus
                                    </span>
                                </td>
                                <td class="p-4 align-middle">
                                    @{
                                        string bgStatusClass = order.Status switch {
                                            "Pending Verification" => "bg-error-container text-on-error-container",
                                            "Processing" => "bg-secondary-container text-on-secondary-container",
                                            "Shipped" => "bg-primary-container text-on-primary-container",
                                            "Delivered" => "bg-tertiary-container text-on-tertiary-container",
                                            _ => "bg-surface-variant text-on-surface-variant"
                                        };
                                        string dotClass = order.Status switch {
                                            "Pending Verification" => "bg-error",
                                            "Processing" => "bg-secondary",
                                            "Shipped" => "bg-primary",
                                            "Delivered" => "bg-tertiary",
                                            _ => "bg-outline"
                                        };
                                    }
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full @bgStatusClass text-xs font-bold tracking-wide">
                                        <span class="w-1.5 h-1.5 rounded-full @dotClass"></span>
                                        @order.Status.ToUpper()
                                    </span>
                                </td>
                                <td class="p-4 align-middle text-right">
                                    <a asp-action="Details" asp-route-id="@order.Id" class="p-2 text-on-surface-variant hover:text-primary hover:bg-primary-container/20 rounded-full transition-ease inline-block" onclick="event.stopPropagation();">
                                        <span class="material-symbols-outlined">visibility</span>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="p-8 text-center text-on-surface-variant">
                                No orders found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <div class="p-4 border-t border-surface-container-highest flex items-center justify-between bg-surface-container-lowest">
                <span class="text-sm text-on-surface-variant">Showing page @ViewBag.CurrentPage of @ViewBag.TotalPages (Total @ViewBag.TotalCount entries)</span>
                <div class="flex items-center gap-1">
                    <a href="@Url.Action("Index", new { status = ViewBag.CurrentStatus, page = ViewBag.CurrentPage - 1 })" class="p-1 rounded text-outline hover:text-on-surface hover:bg-surface-container transition-ease @(ViewBag.CurrentPage == 1 ? "pointer-events-none opacity-50" : "")">
                        <span class="material-symbols-outlined">chevron_left</span>
                    </a>
                    
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <a href="@Url.Action("Index", new { status = ViewBag.CurrentStatus, page = i })" class="w-8 h-8 rounded flex items-center justify-center font-medium text-sm transition-ease @(i == ViewBag.CurrentPage ? "bg-primary-container text-on-primary-container" : "text-on-surface-variant hover:bg-surface-container hover:text-on-surface")">
                            @i
                        </a>
                    }

                    <a href="@Url.Action("Index", new { status = ViewBag.CurrentStatus, page = ViewBag.CurrentPage + 1 })" class="p-1 rounded text-outline hover:text-on-surface hover:bg-surface-container transition-ease @(ViewBag.CurrentPage == ViewBag.TotalPages ? "pointer-events-none opacity-50" : "")">
                        <span class="material-symbols-outlined">chevron_right</span>
                    </a>
                </div>
            </div>
        }
    </div>
</div>
