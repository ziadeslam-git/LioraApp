@model LioraApp.ViewModels.Admin.CategoryDeleteVM
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Liora - Delete Category";
}

@section Styles {
<style>
    .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }

    .material-symbols-outlined.fill {
    font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
</style>
}

<!-- Blurred Background Context (Categories List Simulation) -->
<div class="absolute inset-0 bg-surface blur-md opacity-80 z-0 select-none pointer-events-none p-container-padding-desktop">
    <div class="max-w-7xl mx-auto flex flex-col gap-stack-lg">
        <div class="flex justify-between items-center">
            <h1 class="font-headline-lg text-headline-lg">Categories</h1>
            <div class="w-32 h-10 bg-primary-container rounded-full"></div>
        </div>
        <div class="grid grid-cols-3 gap-gutter">
            <div class="h-64 bg-surface-container rounded-xl shadow-[0px_10px_30px_rgba(26,16,37,0.05)]"></div>
            <div class="h-64 bg-surface-container rounded-xl shadow-[0px_10px_30px_rgba(26,16,37,0.05)]"></div>
            <div class="h-64 bg-surface-container rounded-xl shadow-[0px_10px_30px_rgba(26,16,37,0.05)]"></div>
        </div>
    </div>
</div>
<!-- Modal Overlay -->
<div class="absolute inset-0 z-50 flex items-center justify-center bg-[#1a1025]/30 backdrop-blur-sm p-container-padding-mobile">
    <!-- Modal Container -->
    <div class="bg-surface w-full max-w-md rounded-[24px] shadow-[0px_20px_50px_rgba(26,16,37,0.08)] p-8 flex flex-col gap-6 transform transition-all scale-100 opacity-100">
        <!-- Icon & Header -->
        <div class="flex flex-col items-center text-center gap-4">
            <div class="w-16 h-16 rounded-full bg-error-container flex items-center justify-center">
                <span class="material-symbols-outlined fill text-error text-3xl" data-icon="warning">warning</span>
            </div>
            <h2 class="font-headline-md text-headline-md text-on-surface">Delete Category?</h2>
        </div>
        <!-- Body -->
        <div class="text-center font-body-lg text-body-lg text-on-surface-variant">
            <p>Are you sure you want to delete <strong>'@Model.Name'</strong>?</p>
            @if(Model.ProductsCount > 0 || Model.SubCategoriesCount > 0)
            {
                <p class="mt-2 text-error">Warning: This category has @Model.ProductsCount products and @Model.SubCategoriesCount sub-categories. You cannot delete it until they are reassigned or deleted.</p>
            }
            else
            {
                <p class="mt-2 text-error">This action cannot be undone.</p>
            }
        </div>
        <!-- Actions -->
        <form asp-action="Delete" method="post" class="flex flex-col sm:flex-row gap-4 mt-4">
            <input type="hidden" asp-for="Id" />
            <a asp-action="Index" class="flex-1 py-3 px-6 rounded-full border border-outline text-on-surface font-label-caps text-label-caps hover:bg-surface-variant transition-all duration-250 ease-out active:scale-98 text-center">
                Cancel
            </a>
            <button type="submit" class="flex-1 py-3 px-6 rounded-full bg-error text-on-error font-label-caps text-label-caps shadow-[0px_10px_30px_rgba(26,16,37,0.05)] hover:bg-on-error-container hover:shadow-[0px_20px_50px_rgba(26,16,37,0.08)] transition-all duration-250 ease-out active:scale-98">
                Delete Category
            </button>
        </form>
    </div>
</div>