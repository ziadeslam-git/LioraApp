@model IEnumerable<LioraApp.ViewModels.Admin.CategoryVM>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Liora - Category Management";
}

@section Styles {
<style>
    .tree-line::before {
    content: '';
    position: absolute;
    left: -16px;
    top: -24px;
    bottom: 50%;
    width: 1px;
    background-color: theme('colors.outline-variant');
    }

    .tree-line::after {
    content: '';
    position: absolute;
    left: -16px;
    top: 50%;
    width: 16px;
    height: 1px;
    background-color: theme('colors.outline-variant');
    }

    .last-child.tree-line::before {
    bottom: auto;
    height: 24px;
    }
</style>
}

<!-- Toolbar -->
<header class="flex justify-between items-end mb-stack-lg border-b border-outline-variant/50 pb-4">
    <div>
        <h1 class="font-headline-lg text-headline-lg text-on-surface mb-2">Categories</h1>
    </div>
    <a asp-action="Create" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-medium flex items-center gap-2 hover:bg-primary/90 transition-colors shadow-sm">
        <span class="material-symbols-outlined" style="font-size: 18px;">add</span>
        Add Category
    </a>
</header>
<!-- Tree View Container -->
<div class="bg-surface-container-lowest rounded-[16px] shadow-[0px_10px_30px_rgba(26,16,37,0.05)] p-6">
    <div class="flex flex-col gap-3">
        @if (!Model.Any())
        {
            <div class="p-8 text-center text-on-surface-variant">No categories found.</div>
        }
        @foreach (var item in Model)
        {
            <div class="group flex items-center bg-surface rounded-[12px] p-3 border border-outline-variant/30 hover:border-outline-variant transition-colors duration-250 ease-out mt-2">
                <span class="material-symbols-outlined text-outline-variant cursor-grab mr-2 hover:text-primary transition-colors">drag_indicator</span>
                <div class="w-10 h-10 rounded-[12px] bg-surface-variant overflow-hidden mr-4 shrink-0 flex items-center justify-center text-on-surface-variant">
                    <span class="material-symbols-outlined">folder</span>
                </div>
                <div class="flex-1">
                    <h3 class="font-headline-md text-xl font-medium text-on-surface">@item.Name</h3>
                    @if (!string.IsNullOrEmpty(item.ParentCategoryName))
                    {
                        <p class="text-xs text-on-surface-variant mt-1">Sub-category of: @item.ParentCategoryName</p>
                    }
                </div>
                <div class="mr-6 flex items-center gap-4">
                    <div class="flex flex-col text-right">
                        <span class="text-sm font-bold text-on-surface">@item.ProductsCount</span>
                        <span class="text-[10px] text-on-surface-variant uppercase tracking-wider">Products</span>
                    </div>
                    <div class="w-px h-6 bg-outline-variant/30"></div>
                    <div class="flex flex-col text-right">
                        <span class="text-sm font-bold text-on-surface">@item.SubCategoriesCount</span>
                        <span class="text-[10px] text-on-surface-variant uppercase tracking-wider">Sub-cats</span>
                    </div>
                </div>
                <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-250">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="p-2 text-on-surface-variant hover:text-primary hover:bg-surface-container rounded-full transition-colors" title="Edit">
                        <span class="material-symbols-outlined" style="font-size: 18px;">edit</span>
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="p-2 text-on-surface-variant hover:text-error hover:bg-error-container rounded-full transition-colors" title="Delete">
                        <span class="material-symbols-outlined" style="font-size: 18px;">delete</span>
                    </a>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="flex items-center justify-between mt-8 border-t border-outline-variant/30 pt-4">
            <p class="text-sm text-on-surface-variant">Showing page <span class="font-medium text-on-surface">@ViewBag.CurrentPage</span> of <span class="font-medium text-on-surface">@ViewBag.TotalPages</span></p>
            <div class="flex items-center gap-2">
                @if (ViewBag.CurrentPage > 1)
                {
                    <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)" class="p-2 text-on-surface-variant hover:bg-surface-container rounded-lg transition-colors flex items-center justify-center border border-outline-variant/50">
                        <span class="material-symbols-outlined text-[18px]">chevron_left</span>
                    </a>
                }
                
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <a asp-action="Index" asp-route-page="@i" class="w-8 h-8 flex items-center justify-center rounded-lg text-sm transition-colors border @(i == ViewBag.CurrentPage ? "bg-primary text-white border-primary" : "text-on-surface-variant border-outline-variant/50 hover:bg-surface-container")">@i</a>
                }
                
                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)" class="p-2 text-on-surface-variant hover:bg-surface-container rounded-lg transition-colors flex items-center justify-center border border-outline-variant/50">
                        <span class="material-symbols-outlined text-[18px]">chevron_right</span>
                    </a>
                }
            </div>
        </div>
    }
</div>