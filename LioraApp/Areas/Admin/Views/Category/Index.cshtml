    <style>
        .tree-line::before {
        content: '';
        position: absolute;
        left: -16px;
        top: -24px;
        bottom: 50%;
        width: 1px;
        background-color: theme('colors.outline-variant');
        }

        .tree-line::after {
        content: '';
        position: absolute;
        left: -16px;
        top: 50%;
        width: 16px;
        height: 1px;
        background-color: theme('colors.outline-variant');
        }

        .last-child.tree-line::before {
        bottom: auto;
        height: 24px;
        }
    </style>
</head>
<body class="bg-surface font-body-md text-on-surface antialiased">
    <!-- TopNavBar -->
    <nav class="fixed top-0 right-0 h-[60px] w-[calc(100%-240px)] border-b border-outline-variant bg-surface-container dark:bg-surface-container text-primary dark:text-primary font-title-sm text-title-sm flex items-center justify-between px-gutter w-full z-50">
        <div class="font-headline-md text-headline-md font-extrabold text-primary">Liora</div>
        <div class="flex items-center gap-4">
            <span class="material-symbols-outlined text-on-surface-variant hover:bg-surface-container-highest rounded-full transition-colors cursor-pointer active:scale-95 p-2">notifications</span>
            <span class="material-symbols-outlined text-on-surface-variant hover:bg-surface-container-highest rounded-full transition-colors cursor-pointer active:scale-95 p-2">account_circle</span>
        </div>
    </nav>
    <!-- SideNavBar -->
    <aside class="fixed left-0 top-0 h-full w-[240px] border-r border-outline-variant bg-surface-container-low dark:bg-surface-container-low text-primary dark:text-primary font-body-md text-body-md flex flex-col h-full overflow-y-auto">
        <div class="p-6 pb-2 border-b border-outline-variant/30 flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-primary-container flex items-center justify-center text-on-primary-container font-bold">LA</div>
            <div>
                <h2 class="font-bold text-on-surface">Liora Admin</h2>
                <p class="text-xs text-on-surface-variant">Enterprise Portal</p>
            </div>
        </div>
        <nav class="flex-1 py-4 flex flex-col gap-1">
            <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-highest hover:text-on-surface transition-colors duration-200 ease-in-out" href="#">
                <span class="material-symbols-outlined">dashboard</span>
                Overview
            </a>
            <a class="flex items-center gap-3 px-4 py-3 border-l-2 border-primary bg-surface-container-high text-primary font-bold duration-200 ease-in-out" href="#">
                <span class="material-symbols-outlined">inventory_2</span>
                Catalog
            </a>
            <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-highest hover:text-on-surface transition-colors duration-200 ease-in-out" href="#">
                <span class="material-symbols-outlined">payments</span>
                Sales
            </a>
            <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-highest hover:text-on-surface transition-colors duration-200 ease-in-out" href="#">
                <span class="material-symbols-outlined">group</span>
                Customers
            </a>
            <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-highest hover:text-on-surface transition-colors duration-200 ease-in-out" href="#">
                <span class="material-symbols-outlined">settings</span>
                Settings
            </a>
        </nav>
    </aside>
    <!-- Main Content Canvas -->
    <main class="ml-[240px] mt-[60px] p-container-padding-desktop min-h-screen">
        <!-- Toolbar -->
        <header class="flex justify-between items-end mb-stack-lg border-b border-outline-variant/50 pb-4">
            <div>
                <h1 class="font-headline-lg text-headline-lg text-on-surface mb-2">Categories</h1>
                <p class="text-on-surface-variant font-body-md text-body-md">Manage product taxonomy and collection hierarchies.</p>
            </div>
            <button class="bg-primary-container text-on-primary-container px-6 py-3 rounded-full font-label-caps text-label-caps uppercase tracking-wider flex items-center gap-2 hover:scale-[0.98] transition-transform duration-250 ease-out shadow-[0px_10px_30px_rgba(26,16,37,0.05)] hover:shadow-[0px_20px_50px_rgba(26,16,37,0.08)]">
                <span class="material-symbols-outlined" style="font-size: 18px;">add</span>
                Add Category
            </button>
        </header>
        <!-- Tree View Container -->
        <div class="bg-surface-container-lowest rounded-[16px] shadow-[0px_10px_30px_rgba(26,16,37,0.05)] p-6">
            <div class="flex flex-col gap-3">
                <!-- Root Category 1 -->
                <div class="group flex items-center bg-surface rounded-[12px] p-3 border border-outline-variant/30 hover:border-outline-variant transition-colors duration-250 ease-out">
                    <span class="material-symbols-outlined text-outline-variant cursor-grab mr-2 hover:text-primary transition-colors">drag_indicator</span>
                    <button class="w-6 h-6 flex items-center justify-center mr-3 text-on-surface-variant hover:bg-surface-container rounded-full transition-colors">
                        <span class="material-symbols-outlined" style="font-size: 20px;">keyboard_arrow_down</span>
                    </button>
                    <div class="w-10 h-10 rounded-[12px] bg-surface-variant overflow-hidden mr-4 shrink-0">
                        <img alt="Category Thumbnail" class="w-full h-full object-cover" data-alt="A close-up studio shot of luxurious Egyptian silk fabric draped elegantly, catching soft high-key lighting. The minimalist composition features a muted ivory and rose-gold palette, emphasizing the exquisite craftsmanship and premium texture of the textile against a clean, uncluttered background. The overall mood is sophisticated and modern." src="https://lh3.googleusercontent.com/aida-public/AB6AXuD4gCDErA2MiFK3ctDC6xtw_9qAP3I1WUznYOjqxhs4GyySbkY7w9oOJdbBWJMGyOpKd0_QTRFx1mD1takousyPYRjPbjcDVnmZjPetfj-qe1ynIm8AmzxVUKP_yzZufmXhooJGOmvmRC0G69Skv44kurVjR5d38KQIdRXv1njXMAv8yZgMSCsx4s0oR9mWCXwoqKMlJXZAvyvUon99XUEIcNm9DGdeR_K24Hjz78lLMtFS2m_1fcNqzOTfmhmZlLeGlWPKhI24K_S2" />
                    </div>
                    <div class="flex-1">
                        <h3 class="font-body-md text-body-md font-medium text-on-surface">Women's Apparel</h3>
                        <p class="text-xs text-on-surface-variant">Main Collection</p>
                    </div>
                    <div class="mr-6">
                        <span class="px-3 py-1 bg-surface-container rounded-full font-label-caps text-label-caps text-on-surface-variant">142 Products</span>
                    </div>
                    <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-250">
                        <button class="p-2 text-on-surface-variant hover:text-primary hover:bg-surface-container rounded-full transition-colors" title="Details">
                            <span class="material-symbols-outlined" style="font-size: 18px;">visibility</span>
                        </button>
                        <button class="p-2 text-on-surface-variant hover:text-primary hover:bg-surface-container rounded-full transition-colors" title="Edit">
                            <span class="material-symbols-outlined" style="font-size: 18px;">edit</span>
                        </button>
                        <button class="p-2 text-on-surface-variant hover:text-error hover:bg-error-container rounded-full transition-colors" title="Delete">
                            <span class="material-symbols-outlined" style="font-size: 18px;">delete</span>
                        </button>
                    </div>
                </div>
                <!-- Sub Categories Level 1 -->
                <div class="flex flex-col gap-3 pl-[48px] relative">
                    <!-- Sub 1 -->
                    <div class="relative group flex items-center bg-surface rounded-[12px] p-3 border border-outline-variant/30 hover:border-outline-variant transition-colors duration-250 ease-out">
                        <div class="tree-line"></div>
                        <span class="material-symbols-outlined text-outline-variant cursor-grab mr-2 hover:text-primary transition-colors">drag_indicator</span>
                        <div class="w-6 h-6 mr-3"></div> <!-- Spacer for missing expand arrow -->
                        <div class="w-10 h-10 rounded-[12px] bg-surface-variant overflow-hidden mr-4 shrink-0">
                            <img alt="Category Thumbnail" class="w-full h-full object-cover" data-alt="A minimalist editorial flat lay of a delicate lace top resting on a pristine white marble surface. Soft, diffused lighting creates subtle ambient shadows tinted with pale rose. The image highlights the intricate details of the modern Egyptian craftsmanship, conveying a mood of intimate luxury and effortless grace." src="https://lh3.googleusercontent.com/aida-public/AB6AXuDkKqgXBPV449BdAnrgbUjAssvwv_ytYjzz8OgJlFYJOZFdkIVX59aa1Zle3DE7HymTqGJanBrs7a3XPCkf_aRJWYe7duTR-GoDUCDp4eP0VayI28PB4Ufj1PSUnmoMI0YTjftCFSH7Rz9e4k2wb2YMQR2WIGxaFb8gJjDspxgIVmHRfctKfYv98w_-L8_OYv6N7hEIQits33ORJ85X675yJvqJk-pypdHlpkewoiaGxG7E2BnNGssscUUciLejb_l0AI9khHS-tTRY" />
                        </div>
                        <div class="flex-1">
                            <h3 class="font-body-md text-body-md font-medium text-on-surface">Evening Wear</h3>
                        </div>
                        <div class="mr-6">
                            <span class="px-3 py-1 bg-surface-container rounded-full font-label-caps text-label-caps text-on-surface-variant">56 Products</span>
                        </div>
                        <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-250">
                            <button class="p-2 text-on-surface-variant hover:text-primary hover:bg-surface-container rounded-full transition-colors">
                                <span class="material-symbols-outlined" style="font-size: 18px;">edit</span>
                            </button>
                        </div>
                    </div>
                    <!-- Sub 2 -->
                    <div class="relative group flex items-center bg-surface rounded-[12px] p-3 border border-outline-variant/30 hover:border-outline-variant transition-colors duration-250 ease-out last-child">
                        <div class="tree-line last-child"></div>
                        <span class="material-symbols-outlined text-outline-variant cursor-grab mr-2 hover:text-primary transition-colors">drag_indicator</span>
                        <div class="w-6 h-6 mr-3"></div> <!-- Spacer -->
                        <div class="w-10 h-10 rounded-[12px] bg-surface-variant overflow-hidden mr-4 shrink-0">
                            <img alt="Category Thumbnail" class="w-full h-full object-cover" data-alt="A highly styled, modern fashion still-life featuring a crisp white linen blouse softly draped over an abstract pedestal. High-key lighting illuminates the scene against an ivory background, accented by a subtle plum ambient shadow. The composition is clean, airy, and breathes sophisticated minimalism." src="https://lh3.googleusercontent.com/aida-public/AB6AXuCPMTgq-4sLNU_VD_lxjmMs4UOljzdbmZp2TWGCWxa3vQwJ1oWDUGgU40krzJcp6HJQXRJV6BN2el9apTCsQmUpgFoddL6_22j3fxXMeRP-OrvXtvkEDaTTmqqhHpgvmQWcTo7Seg8wj1xEcxxi6JMwJxpPF5R0Mjtji_JT9oc5CK_ncoF6vK5HaIlZl4z4HJ4iGgLBgwk2ml0cjStrlqu5pP6rUTZWNGL2ylsWUwu7WLmhzr5ifgWE-3lR8Yk8b_9p2z_gMDobZ_ki" />
                        </div>
                        <div class="flex-1">
                            <h3 class="font-body-md text-body-md font-medium text-on-surface">Casual Linens</h3>
                        </div>
                        <div class="mr-6">
                            <span class="px-3 py-1 bg-surface-container rounded-full font-label-caps text-label-caps text-on-surface-variant">86 Products</span>
                        </div>
                        <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-250">
                            <button class="p-2 text-on-surface-variant hover:text-primary hover:bg-surface-container rounded-full transition-colors">
                                <span class="material-symbols-outlined" style="font-size: 18px;">edit</span>
                            </button>
                        </div>
                    </div>
                </div>
                <!-- Root Category 2 -->
                <div class="group flex items-center bg-surface rounded-[12px] p-3 border border-outline-variant/30 hover:border-outline-variant transition-colors duration-250 ease-out mt-4">
                    <span class="material-symbols-outlined text-outline-variant cursor-grab mr-2 hover:text-primary transition-colors">drag_indicator</span>
                    <button class="w-6 h-6 flex items-center justify-center mr-3 text-on-surface-variant hover:bg-surface-container rounded-full transition-colors">
                        <span class="material-symbols-outlined" style="font-size: 20px;">keyboard_arrow_right</span>
                    </button>
                    <div class="w-10 h-10 rounded-[12px] bg-surface-variant overflow-hidden mr-4 shrink-0">
                        <img alt="Category Thumbnail" class="w-full h-full object-cover" data-alt="An elegant display of premium leather accessories arranged asymmetrically on a smooth surface. Soft, directional light highlights the rich textures and deep tones of the materials. The setting uses a modern, editorial aesthetic with ample whitespace, conveying quiet luxury and high-end craftsmanship." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBxwL2849RLuJhfiKy06Ke8kLJRGS5-aeWd0ectjzwVTo7KNcndynDRe5wUC6j80FIMlYWRBoQRtJtT_7K5KUNSzwgJSNvd-qCdKFlsFRtnA-_UWVWJTA4haFlgpmbSSC1QRduqjHeLdIF8PpbKoZmaMHnha2nYPXAnKYwD4B8CrbtqZEOiOFtbd7TlclVsvrJuhWd-pyK4GEgRspslsU7YJDZUsa_0IXhBcR5pxWFAKxWrX-sPNlMdudbA_7isEPEejvBvuHYlaeqI" />
                    </div>
                    <div class="flex-1">
                        <h3 class="font-body-md text-body-md font-medium text-on-surface">Accessories</h3>
                        <p class="text-xs text-on-surface-variant">Leather Goods &amp; Jewelry</p>
                    </div>
                    <div class="mr-6">
                        <span class="px-3 py-1 bg-surface-container rounded-full font-label-caps text-label-caps text-on-surface-variant">24 Products</span>
                    </div>
                    <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-250">
                        <button class="p-2 text-on-surface-variant hover:text-primary hover:bg-surface-container rounded-full transition-colors" title="Edit">
                            <span class="material-symbols-outlined" style="font-size: 18px;">edit</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </main>
</body></html>