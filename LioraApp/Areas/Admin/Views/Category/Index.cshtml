
@model IEnumerable<CategoryVM>

@{
    ViewData["Title"] = "Categories";
    int currentPage = ViewBag.CurrentPage is int cp ? cp : 1;
    int totalPages = ViewBag.TotalPages is int tp ? tp : 1;
    int totalCount = ViewBag.TotalCount is int tc ? tc : Model.Count();
    int pageSize = ViewBag.PageSize is int ps ? ps : 10;
    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, currentPage + 2);
}

<div class="space-y-6">

    <!-- Page Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <nav class="flex text-sm text-slate-500 mb-2 items-center gap-2">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
                   class="hover:text-primary transition-colors">Dashboard</a>
                <span class="material-symbols-outlined text-sm">chevron_right</span>
                <span class="font-medium text-slate-900">Categories</span>
            </nav>
            <h1 class="text-3xl font-black tracking-tight">Categories</h1>
            <p class="text-slate-500 mt-1">Manage your product catalog hierarchy.</p>
        </div>
        <a asp-area="Admin" asp-controller="Category" asp-action="Create"
           class="inline-flex items-center gap-2 bg-primary hover:bg-primary/90 text-white font-bold py-2.5 px-6 rounded-lg shadow-lg shadow-primary/20 transition-all active:scale-[0.98]">
            <span class="material-symbols-outlined">add</span>
            New Category
        </a>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="space-y-3 p-4 md:hidden">
            @if (!Model.Any())
            {
                <div class="rounded-[18px] border border-dashed border-slate-200 bg-slate-50 p-6 text-center text-sm text-slate-500">
                    No categories yet.
                </div>
            }
            @{ int mobileRowIndex = (currentPage - 1) * pageSize; }
            @foreach (var cat in Model)
            {
                mobileRowIndex++;
                bool isSub = cat.ParentCategoryName is not null;
                <article class="rounded-[18px] border border-slate-200 bg-slate-50/80 p-4 shadow-sm">
                    <div class="flex items-start justify-between gap-3">
                        <div class="flex items-center gap-3">
                            @if (isSub)
                            {
                                <span class="material-symbols-outlined text-slate-300">subdirectory_arrow_right</span>
                            }
                            else
                            {
                                <div class="flex size-10 items-center justify-center rounded-xl bg-primary/10 text-primary">
                                    <span class="material-symbols-outlined text-[18px]">folder_open</span>
                                </div>
                            }
                            <div>
                                <p class="text-sm font-bold text-slate-900">@cat.Name</p>
                                <p class="mt-1 text-xs text-slate-500">#@mobileRowIndex @(isSub ? $"· under {cat.ParentCategoryName}" : string.Empty)</p>
                            </div>
                        </div>
                        <a asp-area="Admin" asp-controller="Category" asp-action="Details" asp-route-id="@cat.Id" class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white text-slate-600 shadow-sm transition hover:bg-slate-100">
                            <span class="material-symbols-outlined text-[18px]">visibility</span>
                        </a>
                    </div>

                    <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
                        <div class="col-span-2">
                            <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400">Slug</p>
                            <code class="mt-1 inline-flex rounded bg-slate-100 px-2 py-1 text-xs text-slate-600">@cat.Slug</code>
                        </div>
                        <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400">Sub-categories</p>
                            <p class="mt-1 font-bold text-primary">@cat.SubCategoriesCount</p>
                        </div>
                        <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400">Products</p>
                            <p class="mt-1 font-bold text-emerald-600">@cat.ProductsCount</p>
                        </div>
                    </div>

                    <div class="mt-4 flex items-center justify-end gap-2">
                        <a asp-area="Admin" asp-controller="Category" asp-action="Edit" asp-route-id="@cat.Id" class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white text-primary shadow-sm transition hover:bg-slate-100">
                            <span class="material-symbols-outlined text-[18px]">edit</span>
                        </a>
                        <a asp-area="Admin" asp-controller="Category" asp-action="Delete" asp-route-id="@cat.Id" class="inline-flex items-center rounded-xl bg-rose-50 px-4 py-2.5 text-sm font-semibold text-rose-600 transition hover:bg-rose-100">
                            Delete
                        </a>
                    </div>
                </article>
            }
        </div>

        <div class="hidden overflow-x-auto md:block">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 text-xs font-bold uppercase tracking-wider">
                        <th class="py-4 px-6">#</th>
                        <th class="py-4 px-6">Category Name</th>
                        <th class="py-4 px-6">Slug</th>
                        <th class="py-4 px-6 text-center">Sub-categories</th>
                        <th class="py-4 px-6 text-center">Products</th>
                        <th class="py-4 px-6 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="py-16 text-center text-slate-400">
                                <span class="material-symbols-outlined text-5xl block mb-3">category</span>
                                <p class="font-medium">No categories yet.</p>
                                <a asp-area="Admin" asp-controller="Category" asp-action="Create"
                                   class="text-primary hover:underline text-sm mt-1 inline-block">Create your first category →</a>
                            </td>
                        </tr>
                    }
                    @{ int rowIndex = (currentPage - 1) * pageSize; }
                    @foreach (var cat in Model)
                    {
                        rowIndex++;
                        bool isSub = cat.ParentCategoryName is not null;
                        <tr class="hover:bg-primary/5 transition-colors group">
                            <td class="py-4 px-6 text-sm text-slate-400">@rowIndex</td>
                            <td class="py-4 px-6">
                                <div class="flex items-center gap-3">
                                    @if (isSub)
                                    {
                                        <span class="material-symbols-outlined text-slate-300 text-base">subdirectory_arrow_right</span>
                                        <div>
                                            <p class="text-sm font-semibold text-slate-700">@cat.Name</p>
                                            <p class="text-xs text-slate-400">under @cat.ParentCategoryName</p>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="size-8 rounded-lg bg-primary/10 flex items-center justify-center">
                                            <span class="material-symbols-outlined text-primary" style="font-size:16px">folder_open</span>
                                        </div>
                                        <p class="text-sm font-bold text-slate-900">@cat.Name</p>
                                    }
                                </div>
                            </td>
                            <td class="py-4 px-6">
                                <code class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded">@cat.Slug</code>
                            </td>
                            <td class="py-4 px-6 text-center">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold
                                    @(cat.SubCategoriesCount > 0 ? "bg-primary/10 text-primary" : "bg-slate-100 text-slate-400")">
                                    @cat.SubCategoriesCount
                                </span>
                            </td>
                            <td class="py-4 px-6 text-center">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold
                                    @(cat.ProductsCount > 0 ? "bg-emerald-50 text-emerald-700" : "bg-slate-100 text-slate-400")">
                                    @cat.ProductsCount
                                </span>
                            </td>
                            <td class="py-4 px-6 text-right">
                                <div class="flex justify-end gap-1">
                                    <a asp-area="Admin" asp-controller="Category" asp-action="Details"
                                       asp-route-id="@cat.Id"
                                       class="p-1.5 text-slate-400 hover:text-primary transition-colors"
                                       title="Details">
                                        <span class="material-symbols-outlined text-lg">visibility</span>
                                    </a>
                                    <a asp-area="Admin" asp-controller="Category" asp-action="Edit"
                                       asp-route-id="@cat.Id"
                                       class="p-1.5 text-slate-400 hover:text-primary transition-colors"
                                       title="Edit">
                                        <span class="material-symbols-outlined text-lg">edit</span>
                                    </a>
                                    <a asp-area="Admin" asp-controller="Category" asp-action="Delete"
                                       asp-route-id="@cat.Id"
                                       class="p-1.5 text-slate-400 hover:text-red-500 transition-colors"
                                       title="Delete">
                                        <span class="material-symbols-outlined text-lg">delete</span>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Footer -->
        <div class="bg-slate-50 px-6 py-4 border-t border-slate-200 flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <p class="text-sm text-slate-500">
                Showing <span class="font-semibold text-slate-900">@(((currentPage - 1) * pageSize) + (Model.Any() ? 1 : 0))</span>
                to <span class="font-semibold text-slate-900">@(((currentPage - 1) * pageSize) + Model.Count())</span>
                of <span class="font-semibold text-slate-900">@totalCount</span> categories
            </p>

            @if (totalPages > 1)
            {
                <div class="flex flex-wrap items-center gap-2">
                    <a asp-area="Admin" asp-controller="Category" asp-action="Index" asp-route-page="@(currentPage - 1)"
                       class="inline-flex items-center gap-1 rounded-xl border px-3 py-2 text-xs font-semibold transition-all @(currentPage == 1 ? "pointer-events-none border-slate-200 bg-slate-100 text-slate-300" : "border-slate-200 bg-white text-slate-600 hover:border-primary/30 hover:text-primary")">
                        <span class="material-symbols-outlined text-sm">chevron_left</span>
                        Previous
                    </a>

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <a asp-area="Admin" asp-controller="Category" asp-action="Index" asp-route-page="@i"
                           class="inline-flex h-10 min-w-10 items-center justify-center rounded-xl border px-3 text-xs font-bold transition-all @(i == currentPage ? "border-primary bg-primary text-white shadow-md shadow-primary/20" : "border-slate-200 bg-white text-slate-600 hover:border-primary/30 hover:text-primary")">
                            @i
                        </a>
                    }

                    <a asp-area="Admin" asp-controller="Category" asp-action="Index" asp-route-page="@(currentPage + 1)"
                       class="inline-flex items-center gap-1 rounded-xl border px-3 py-2 text-xs font-semibold transition-all @(currentPage == totalPages ? "pointer-events-none border-slate-200 bg-slate-100 text-slate-300" : "border-slate-200 bg-white text-slate-600 hover:border-primary/30 hover:text-primary")">
                        Next
                        <span class="material-symbols-outlined text-sm">chevron_right</span>
                    </a>
                </div>
            }
        </div>
    </div>

</div> 
















