@model LioraApp.ViewModels.Admin.CategoryFormVM
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Liora - Admin Create Category";
}

@section Styles {
<style>
    .shadow-ambient-level-1 {
    box-shadow: 0px 10px 30px rgba(26, 16, 37, 0.05);
    }

    .shadow-ambient-level-2 {
    box-shadow: 0px 20px 50px rgba(26, 16, 37, 0.08);
    }

    /* Smooth transitions */
    .btn-transition {
    transition: all 250ms ease-out;
    }

    .btn-transition:active {
    transform: scale(0.98);
    }

    /* Input focus effects */
    .input-focus-ring:focus {
    border-color: #c49080 !important;
    box-shadow: 0 0 0 4px rgba(196, 144, 128, 0.2) !important;
    outline: none;
    }
</style>
}

<div class="w-full max-w-[600px] mb-stack-lg">
    <h2 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface">Create Category</h2>
    <p class="text-on-surface-variant mt-2">Add a new product grouping to your catalog structure.</p>
</div>
<!-- Form Card -->
<div class="w-full max-w-[600px] bg-surface-container-lowest rounded-[16px] shadow-ambient-level-1 p-stack-lg border border-outline-variant/20">
    <div class="mb-stack-lg pb-stack-sm border-b border-outline-variant/30">
        <h3 class="font-headline-md text-headline-md text-on-surface text-xl">Add New Category</h3>
    </div>
    <form id="createCategoryForm" asp-action="Create" method="post" class="flex flex-col gap-stack-lg">
        <div asp-validation-summary="All" class="text-error mb-4 col-span-full"></div>
        <!-- Category Name -->
        <div class="flex flex-col gap-2">
            <label asp-for="Name" class="font-label-caps text-label-caps text-on-surface"></label>
            <input asp-for="Name" class="w-full rounded-[12px] border border-outline/20 bg-surface-container-lowest px-4 py-3 text-on-surface placeholder:text-on-surface-variant/50 input-focus-ring transition-all duration-200 ease-out" placeholder="e.g. Silk Loungewear" />
            <span asp-validation-for="Name" class="text-xs text-error mt-1"></span>
        </div>
        <!-- Category Slug -->
        <div class="flex flex-col gap-2">
            <label asp-for="Slug" class="font-label-caps text-label-caps text-on-surface"></label>
            <input asp-for="Slug" class="w-full rounded-[12px] border border-outline/20 bg-surface-container-lowest px-4 py-3 text-on-surface placeholder:text-on-surface-variant/50 input-focus-ring transition-all duration-200 ease-out" placeholder="e.g. silk-loungewear" />
            <span asp-validation-for="Slug" class="text-xs text-error mt-1"></span>
        </div>
        <!-- Parent Category -->
        <div class="flex flex-col gap-2">
            <label asp-for="ParentCategoryId" class="font-label-caps text-label-caps text-on-surface"></label>
            <div class="relative">
                <select asp-for="ParentCategoryId" asp-items="Model.ParentCategories" class="w-full appearance-none rounded-[12px] border border-outline/20 bg-surface-container-lowest px-4 py-3 text-on-surface input-focus-ring transition-all duration-200 ease-out">
                    <option value="">None (Top Level)</option>
                </select>
                <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none">arrow_drop_down</span>
            </div>
            <span asp-validation-for="ParentCategoryId" class="text-xs text-error mt-1"></span>
        </div>
        <!-- Image Upload -->
        <div class="flex flex-col gap-2">
            <label class="font-label-caps text-label-caps text-on-surface">CATEGORY IMAGE</label>
            <div class="w-full rounded-[16px] border-2 border-dashed border-outline-variant/50 hover:border-primary-container/80 bg-surface-container-low p-stack-lg flex flex-col items-center justify-center text-center cursor-pointer transition-colors duration-250 ease-out group">
                <div class="w-12 h-12 rounded-full bg-surface-variant flex items-center justify-center mb-4 group-hover:bg-primary-container/20 group-hover:text-primary transition-colors duration-250">
                    <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary">cloud_upload</span>
                </div>
                <p class="font-body-md text-body-md text-on-surface mb-1">Click or drag image here to upload</p>
                <p class="text-sm text-on-surface-variant">PNG, JPG or WebP up to 5MB</p>
            </div>
        </div>
        <!-- Actions -->
        <div class="mt-stack-md pt-stack-md flex items-center justify-end gap-4 border-t border-outline-variant/30">
            <a asp-action="Index" class="btn-transition px-6 py-3 rounded-full text-primary hover:bg-surface-variant font-label-caps text-label-caps flex items-center justify-center">
                Cancel
            </a>
            <button class="btn-transition px-8 py-3 rounded-full bg-primary-container text-on-primary-container hover:bg-primary hover:text-on-primary font-label-caps text-label-caps shadow-ambient-level-1 hover:shadow-ambient-level-2" type="submit" form="createCategoryForm">
                Save Category
            </button>
        </div>
    </form>
</div>