<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Liora</title>
    <!-- Tailwind + Fonts -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="~/images/site-logo.png" asp-append-version="true" />
    <link rel="shortcut icon" href="~/images/site-logo.png" asp-append-version="true" />
    
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: { "primary": "#6467f2", "background-light": "#f6f6f8", "background-dark": "#101122" },
                    fontFamily: { "display": ["Inter", "sans-serif"] },
                },
            },
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .filled-icon { font-variation-settings: 'FILL' 1; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="font-display bg-background-light dark:bg-background-dark min-h-screen antialiased text-slate-900 dark:text-slate-100">
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

    @if (TempData["success"] != null)
    {
        <div class="fixed top-4 right-4 bg-emerald-500 text-white px-6 py-3 rounded-lg shadow-lg z-50 animate-bounce">
            @TempData["success"]
        </div>
    }
    @if (TempData["error"] != null)
    {
        <div class="fixed top-4 right-4 bg-rose-500 text-white px-6 py-3 rounded-lg shadow-lg z-50 animate-bounce">
            @TempData["error"]
        </div>
    }

    @RenderBody()
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
