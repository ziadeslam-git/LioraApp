@{
    ViewData["Title"] = "Email Confirmed";
}

<div class="min-h-[calc(100vh-80px)] flex items-center justify-center p-4">
    <div class="w-full max-w-[480px]">
        <div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200/60 dark:border-slate-800 p-10 flex flex-col items-center text-center">

            @if (TempData["success"] is string successMsg)
            {
                <div class="w-16 h-16 bg-violet-100 dark:bg-violet-900/30 rounded-full flex items-center justify-center mb-6">
                    <span class="material-symbols-outlined text-violet-500 text-4xl">verified</span>
                </div>

                <h1 class="text-slate-900 dark:text-slate-100 text-2xl font-bold tracking-tight mb-4">
                    Email Confirmed!
                </h1>
                <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed mb-8">
                    @successMsg Your account is now active and ready to use.
                </p>

                <a asp-action="Login"
                   class="w-full h-11 bg-violet-600 hover:bg-violet-700 text-white font-semibold rounded-lg transition-colors flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-base">login</span>
                    Sign In Now
                </a>
            }
            else
            {
                <div class="w-16 h-16 bg-red-100 dark:bg-red-900/30 rounded-full flex items-center justify-center mb-6">
                    <span class="material-symbols-outlined text-red-500 text-4xl">error</span>
                </div>

                <h1 class="text-slate-900 dark:text-slate-100 text-2xl font-bold tracking-tight mb-4">
                    Confirmation Failed
                </h1>
                <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed mb-8">
                    @(TempData["error"] as string ?? "The confirmation link may have expired or is invalid.")
                </p>

                <a asp-action="ResendConfirmation"
                   class="w-full h-11 bg-violet-600 hover:bg-violet-700 text-white font-semibold rounded-lg transition-colors flex items-center justify-center gap-2 mb-3">
                    <span class="material-symbols-outlined text-base">send</span>
                    Resend Confirmation Email
                </a>
                <a asp-action="Login"
                   class="w-full h-11 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-200 font-semibold rounded-lg transition-colors flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-base">arrow_back</span>
                    Back to login
                </a>
            }

        </div>
    </div>
</div>
