    <style>
        .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        @@keyframes scale-up-elastic {
        0% {
        transform: scale(0.5);
        opacity: 0;
        }

        60% {
        transform: scale(1.1);
        opacity: 1;
        }

        100% {
        transform: scale(1);
        opacity: 1;
        }
        }

