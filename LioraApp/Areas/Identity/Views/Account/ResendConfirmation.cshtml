<body class="bg-surface text-on-surface min-h-screen flex items-center justify-center p-container-padding-mobile md:p-container-padding-desktop antialiased">
    <!-- Top Navigation Suppressed: Transactional Screen -->
    <main class="w-full max-w-[440px]">
        <!-- Centered Card -->
        <div class="bg-surface-container-lowest rounded-[16px] p-8 md:p-10 shadow-ambient-lvl1 relative overflow-hidden group">
            <!-- Top Subtle Highlight Gradient -->
            <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-primary-container/20 via-primary-container to-primary-container/20 opacity-80"></div>
            <!-- Back Link -->
            <a class="inline-flex items-center gap-2 text-on-surface-variant font-body-md text-body-md hover:text-primary transition-colors duration-250 ease-out mb-stack-lg w-fit group/link" href="#">
                <span class="material-symbols-outlined text-[20px] group-hover/link:-translate-x-1 transition-transform duration-250 ease-out" data-icon="arrow_back">arrow_back</span>
                <span>Back to Login</span>
            </a>
            <!-- Header -->
            <div class="mb-stack-lg">
                <h1 class="font-headline-md text-headline-md text-on-surface mb-stack-sm">Resend confirmation email</h1>
                <p class="font-body-md text-body-md text-on-surface-variant">Enter your email and we'll send a new confirmation link.</p>
            </div>
            <!-- Form Area (Default State) -->
            <form class="flex flex-col gap-stack-md transition-opacity duration-250 ease-out" id="resendForm">
                <!-- Email Input -->
                <div class="flex flex-col gap-unit">
                    <label class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-widest" for="email">Email Address</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant/50 material-symbols-outlined" data-icon="mail">mail</span>
                        <input class="w-full pl-12 pr-4 py-3 bg-surface border border-outline-variant/20 rounded-[12px] font-body-md text-body-md text-on-surface placeholder:text-on-surface-variant/40 focus:outline-none focus:ring-0 focus:border-primary-container focus:shadow-[0_0_15px_rgba(196,144,128,0.3)] transition-all duration-250 ease-out" id="email" name="email" placeholder="name@example.com" required="" type="email" />
                    </div>
                </div>
                <!-- Submit Button -->
                <button class="mt-stack-sm w-full bg-primary-container text-on-primary bg-primary-container hover:bg-primary transition-all duration-250 ease-out active:scale-98 rounded-full py-4 px-6 flex items-center justify-center gap-2 group/btn shadow-ambient-lvl1 hover:shadow-ambient-lvl2 relative overflow-hidden" type="submit">
                    <span class="font-label-caps text-label-caps tracking-widest relative z-10">RESEND EMAIL</span>
                    <span class="material-symbols-outlined text-[18px] relative z-10 group-hover/btn:translate-x-1 transition-transform duration-250 ease-out" data-icon="arrow_forward">arrow_forward</span>
                    <!-- Ripple effect container -->
                    <div class="absolute inset-0 bg-white/20 opacity-0 group-active/btn:opacity-100 transition-opacity duration-150 rounded-full"></div>
                </button>
            </form>
            <!-- Success State Simulation (Hidden by default) -->
            <div class="hidden flex-col items-center text-center gap-stack-md pt-stack-sm opacity-0 transition-opacity duration-500 ease-out" id="successState">
                <div class="w-16 h-16 rounded-full bg-primary-container/10 flex items-center justify-center text-primary-container mb-2">
                    <span class="material-symbols-outlined text-[32px]" data-icon="mark_email_read" data-weight="fill">mark_email_read</span>
                </div>
                <h2 class="font-headline-md text-headline-md text-on-surface">Check your inbox</h2>
                <p class="font-body-md text-body-md text-on-surface-variant">We've sent a new confirmation link to your email address. It may take a few minutes to arrive.</p>
                <button class="mt-stack-sm text-primary font-label-caps text-label-caps hover:text-primary-container transition-colors duration-250 ease-out border-b border-transparent hover:border-primary-container pb-1" id="resetFormBtn" type="button">TRY ANOTHER EMAIL</button>
            </div>
        </div>
    </main>
    <!-- Footer Suppressed: Transactional Screen -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('resendForm');
        const successState = document.getElementById('successState');
        const resetBtn = document.getElementById('resetFormBtn');
        const emailInput = document.getElementById('email');

        // Simulate form submission to show success state
        form.addEventListener('submit', (e) => {
        e.preventDefault();

        if(emailInput.value) {
        // Fade out form
        form.style.opacity = '0';
        form.style.pointerEvents = 'none';

        setTimeout(() => {
        form.classList.add('hidden');

        // Show and fade in success state
        successState.classList.remove('hidden');
        successState.classList.add('flex');

        // Small delay for DOM update before triggering opacity transition
        requestAnimationFrame(() => {
        successState.style.opacity = '1';
        });
        }, 250); // Matches transition duration
        }
        });

        // Reset back to form state
        resetBtn.addEventListener('click', () => {
        successState.style.opacity = '0';

        setTimeout(() => {
        successState.classList.add('hidden');
        successState.classList.remove('flex');

        form.classList.remove('hidden');
        emailInput.value = ''; // Clear input

        requestAnimationFrame(() => {
        form.style.opacity = '1';
        form.style.pointerEvents = 'auto';
        });
        }, 500); // Wait for fade out
        });
        });
    </script>
</body></html>