<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Reset Password - ELÉGANCE</title>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&amp;family=EB+Garamond:ital,wght@0,400..800;1,400..800&amp;family=Playfair+Display:ital,wght@0,400..900;1,400..900&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
        darkMode: "class",
        theme: {
        extend: {
        "colors": {
        "on-tertiary-fixed-variant": "#4b4450",
        "surface-container-low": "#f9f2ec",
        "on-background": "#1e1b18",
        "tertiary-container": "#a299a7",
        "surface-variant": "#e8e1db",
        "secondary-fixed": "#eedcfa",
        "on-tertiary": "#ffffff",
        "surface": "#fff8f3",
        "on-error-container": "#93000a",
        "on-primary-container": "#4e2a1f",
        "tertiary-fixed": "#eadfee",
        "outline": "#83746f",
        "primary-fixed-dim": "#f2baa8",
        "secondary": "#665972",
        "inverse-surface": "#33302c",
        "error": "#ba1a1a",
        "surface-container": "#f4ede7",
        "on-primary-fixed-variant": "#643d30",
        "on-surface": "#1e1b18",
        "secondary-container": "#eedcfa",
        "inverse-on-surface": "#f7efe9",
        "on-surface-variant": "#514440",
        "on-secondary-fixed-variant": "#4e425a",
        "on-secondary-container": "#6c5f79",
        "on-primary": "#ffffff",
        "surface-container-highest": "#e8e1db",
        "surface-container-lowest": "#ffffff",
        "secondary-fixed-dim": "#d1c0de",
        "on-tertiary-container": "#38313d",
        "tertiary": "#635b68",
        "on-secondary-fixed": "#21172c",
        "on-primary-fixed": "#311309",
        "primary": "#7f5446",
        "surface-tint": "#7f5446",
        "error-container": "#ffdad6",
        "primary-fixed": "#ffdbd0",
        "tertiary-fixed-dim": "#cec3d2",
        "on-error": "#ffffff",
        "inverse-primary": "#f2baa8",
        "surface-container-high": "#eee7e1",
        "surface-bright": "#fff8f3",
        "primary-container": "#c49080",
        "background": "#fff8f3",
        "outline-variant": "#d5c2bd",
        "on-tertiary-fixed": "#1f1924",
        "surface-dim": "#dfd9d3",
        "on-secondary": "#ffffff"
        },
        "borderRadius": {
        "DEFAULT": "0.25rem",
        "lg": "0.5rem",
        "xl": "0.75rem",
        "full": "9999px"
        },
        "spacing": {
        "stack-sm": "8px",
        "gutter": "24px",
        "container-padding-desktop": "64px",
        "stack-lg": "32px",
        "section-gap": "120px",
        "stack-md": "16px",
        "unit": "8px",
        "container-padding-mobile": "20px"
        },
        "fontFamily": {
        "display-lg-mobile": ["Playfair Display"],
        "headline-lg-mobile": ["Playfair Display"],
        "display-lg": ["Playfair Display"],
        "body-lg": ["DM Sans"],
        "accent-italic": ["EB Garamond"],
        "label-caps": ["DM Sans"],
        "headline-md": ["Playfair Display"],
        "body-md": ["DM Sans"],
        "headline-lg": ["Playfair Display"]
        },
        "fontSize": {
        "display-lg-mobile": ["40px", { "lineHeight": "1.2", "fontWeight": "700" }],
        "headline-lg-mobile": ["32px", { "lineHeight": "1.2", "fontWeight": "600" }],
        "display-lg": ["64px", { "lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "700" }],
        "body-lg": ["18px", { "lineHeight": "1.6", "fontWeight": "400" }],
        "accent-italic": ["20px", { "lineHeight": "1.5", "fontWeight": "400" }],
        "label-caps": ["12px", { "lineHeight": "1.2", "letterSpacing": "0.1em", "fontWeight": "700" }],
        "headline-md": ["32px", { "lineHeight": "1.3", "fontWeight": "500" }],
        "body-md": ["16px", { "lineHeight": "1.6", "fontWeight": "400" }],
        "headline-lg": ["40px", { "lineHeight": "1.2", "fontWeight": "600" }]
        }
        }
        }
        }
    </script>
    <style>
        .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="bg-surface-bright min-h-screen flex items-center justify-center p-container-padding-mobile md:p-container-padding-desktop font-body-md text-body-md text-on-surface antialiased selection:bg-primary-container selection:text-on-primary">
    <!-- Main Container - Transactional Intent (No Shell Navigation) -->
    <main class="w-full max-w-[440px] relative z-10">
        <!-- Glassmorphism/Solid Plum Card -->
        <div class="bg-on-tertiary-fixed rounded-[24px] p-8 md:p-10 shadow-[0_20px_50px_rgba(26,16,37,0.15)] backdrop-blur-sm border border-tertiary-fixed-dim/10 relative overflow-hidden">
            <!-- Subtle ambient glow inside card -->
            <div class="absolute -top-24 -right-24 w-48 h-48 bg-primary-container/20 rounded-full blur-3xl pointer-events-none"></div>
            <!-- Brand Header -->
            <div class="text-center mb-8 relative z-10">
                <h1 class="font-display-lg-mobile text-display-lg-mobile text-primary-container tracking-tighter mb-6">ELÉGANCE</h1>
                <h2 class="font-headline-md text-headline-md text-surface-bright mb-2">Set your new password</h2>
                <p class="font-body-md text-body-md text-tertiary-fixed-dim">Choose something you'll remember.</p>
            </div>
            <!-- Form -->
            <form class="relative z-10" id="reset-form">
                <!-- Hidden fields required by prompt context -->
                <input name="Email" type="hidden" value="" />
                <input name="Token" type="hidden" value="" />
                <div class="space-y-6">
                    <!-- New Password Input -->
                    <div>
                        <label class="block font-label-caps text-label-caps text-tertiary-fixed-dim mb-2 uppercase tracking-widest" for="new-password">New Password</label>
                        <div class="relative group">
                            <input class="w-full bg-surface-bright text-on-surface rounded-xl px-4 py-3 border border-outline-variant/20 focus:outline-none focus:border-primary-container focus:ring-4 focus:ring-primary-container/20 transition-all duration-250 ease-out font-body-md placeholder:text-outline" id="new-password" name="NewPassword" placeholder="Enter new password" required="" type="password" />
                            <button class="absolute right-3 top-1/2 -translate-y-1/2 text-outline hover:text-primary-container transition-colors duration-250 focus:outline-none" onclick="togglePassword('new-password', 'toggle-new')" type="button">
                                <span class="material-symbols-outlined" id="toggle-new">visibility_off</span>
                            </button>
                        </div>
                        <!-- 4-Segment Strength Indicator -->
                        <div class="flex gap-2 mt-3" id="strength-bars">
                            <div class="h-1 w-1/4 rounded-full bg-tertiary-fixed-dim/20 transition-colors duration-500 ease-out" id="bar-1"></div>
                            <div class="h-1 w-1/4 rounded-full bg-tertiary-fixed-dim/20 transition-colors duration-500 ease-out" id="bar-2"></div>
                            <div class="h-1 w-1/4 rounded-full bg-tertiary-fixed-dim/20 transition-colors duration-500 ease-out" id="bar-3"></div>
                            <div class="h-1 w-1/4 rounded-full bg-tertiary-fixed-dim/20 transition-colors duration-500 ease-out" id="bar-4"></div>
                        </div>
                        <p class="font-label-caps text-label-caps text-tertiary-fixed-dim mt-2 text-right opacity-0 transition-opacity duration-250" id="strength-text">WEAK</p>
                    </div>
                    <!-- Confirm Password Input -->
                    <div>
                        <label class="block font-label-caps text-label-caps text-tertiary-fixed-dim mb-2 uppercase tracking-widest" for="confirm-password">Confirm Password</label>
                        <div class="relative group">
                            <input class="w-full bg-surface-bright text-on-surface rounded-xl px-4 py-3 border border-outline-variant/20 focus:outline-none focus:border-primary-container focus:ring-4 focus:ring-primary-container/20 transition-all duration-250 ease-out font-body-md placeholder:text-outline" id="confirm-password" name="ConfirmPassword" placeholder="Repeat new password" required="" type="password" />
                            <button class="absolute right-3 top-1/2 -translate-y-1/2 text-outline hover:text-primary-container transition-colors duration-250 focus:outline-none" onclick="togglePassword('confirm-password', 'toggle-confirm')" type="button">
                                <span class="material-symbols-outlined" id="toggle-confirm">visibility_off</span>
                            </button>
                        </div>
                    </div>
                </div>
                <!-- Submit Action -->
                <div class="mt-10">
                    <button class="w-full bg-primary-container text-on-primary font-label-caps text-label-caps py-4 rounded-full shadow-[0_10px_30px_rgba(196,144,128,0.2)] hover:shadow-[0_20px_50px_rgba(196,144,128,0.4)] active:scale-95 transition-all duration-250 ease-out flex justify-center items-center gap-2" type="submit">
                        RESET PASSWORD
                        <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                    </button>
                </div>
                <div class="mt-6 text-center">
                    <a class="font-label-caps text-label-caps text-tertiary-fixed-dim hover:text-primary-container transition-colors duration-250 border-b border-transparent hover:border-primary-container pb-0.5" href="#">RETURN TO LOGIN</a>
                </div>
            </form>
        </div>
    </main>
    <script>
        // Toggle password visibility
        function togglePassword(inputId, iconId) {
        const input = document.getElementById(inputId);
        const icon = document.getElementById(iconId);

        if (input.type === 'password') {
        input.type = 'text';
        icon.textContent = 'visibility';
        } else {
        input.type = 'password';
        icon.textContent = 'visibility_off';
        }
        }

        // Simple password strength simulation
        const newPasswordInput = document.getElementById('new-password');
        const bars = [
        document.getElementById('bar-1'),
        document.getElementById('bar-2'),
        document.getElementById('bar-3'),
        document.getElementById('bar-4')
        ];
        const strengthText = document.getElementById('strength-text');

        newPasswordInput.addEventListener('input', function(e) {
        const val = e.target.value;
        let strength = 0;

        if (val.length > 0) strengthText.style.opacity = '1';
        else strengthText.style.opacity = '0';

        if (val.length > 5) strength++;
        if (val.length > 8) strength++;
        if (/[A-Z]/.test(val) && /[0-9]/.test(val)) strength++;
        if (/[^A-Za-z0-9]/.test(val)) strength++;

        // Reset bars
        bars.forEach(bar => {
        bar.className = 'h-1 w-1/4 rounded-full bg-tertiary-fixed-dim/20 transition-colors duration-500 ease-out';
        });

        // Apply strength colors
        if (strength >= 1) {
        bars[0].classList.replace('bg-tertiary-fixed-dim/20', 'bg-error');
        strengthText.textContent = 'WEAK';
        strengthText.classList.remove('text-primary-container', 'text-surface-tint');
        strengthText.classList.add('text-error');
        }
        if (strength >= 2) {
        bars[0].classList.replace('bg-error', 'bg-primary-container');
        bars[1].classList.replace('bg-tertiary-fixed-dim/20', 'bg-primary-container');
        strengthText.textContent = 'FAIR';
        strengthText.classList.remove('text-error', 'text-surface-tint');
        strengthText.classList.add('text-primary-container');
        }
        if (strength >= 3) {
        bars[0].classList.replace('bg-primary-container', 'bg-surface-tint');
        bars[1].classList.replace('bg-primary-container', 'bg-surface-tint');
        bars[2].classList.replace('bg-tertiary-fixed-dim/20', 'bg-surface-tint');
        strengthText.textContent = 'GOOD';
        strengthText.classList.remove('text-error', 'text-primary-container');
        strengthText.classList.add('text-surface-tint');
        }
        if (strength >= 4) {
        bars[0].classList.replace('bg-surface-tint', 'bg-surface-container-lowest');
        bars[1].classList.replace('bg-surface-tint', 'bg-surface-container-lowest');
        bars[2].classList.replace('bg-surface-tint', 'bg-surface-container-lowest');
        bars[3].classList.replace('bg-tertiary-fixed-dim/20', 'bg-surface-container-lowest');
        strengthText.textContent = 'STRONG';
        strengthText.classList.remove('text-error', 'text-primary-container', 'text-surface-tint');
        strengthText.classList.add('text-surface-container-lowest');
        }
        });
    </script>
</body></html>