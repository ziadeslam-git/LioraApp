@model LioraApp.ViewModels.Identity.ForgotPasswordVM
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="min-h-[calc(100vh-80px)] flex items-center justify-center p-4">
    <!-- Main Container -->
    <div class="w-full max-w-[480px]">
        <!-- Card Wrapper -->
        <div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200/60 dark:border-slate-800 p-10 flex flex-col items-center">
            
            <!-- Icon Circle -->
            <div class="w-14 h-14 bg-primary rounded-full flex items-center justify-center mb-6 shadow-lg shadow-primary/20">
                <span class="material-symbols-outlined text-white text-3xl">key</span>
            </div>
            
            <!-- Header Content -->
            <div class="text-center mb-8">
                <h1 class="text-slate-900 dark:text-slate-100 text-2xl font-bold tracking-tight mb-2">
                    Forgot your password?
                </h1>
                <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed max-w-[320px] mx-auto">
                    No worries! Enter your email address below and we'll send you a password reset link.
                </p>
            </div>
            
            <!-- Form -->
            <form asp-action="ForgotPassword" method="post" class="w-full space-y-6">
                <div asp-validation-summary="ModelOnly" class="text-rose-500 text-sm font-semibold mb-4"></div>

                <div class="space-y-2">
                    <label asp-for="Email" class="block text-sm font-medium text-slate-700 dark:text-slate-300"></label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <span class="material-symbols-outlined text-slate-400 text-xl">mail</span>
                        </div>
                        <input asp-for="Email" class="block w-full pl-10 pr-4 h-11 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 placeholder-slate-400 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-sm outline-none" placeholder="name@company.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-rose-500 text-xs mt-1 block"></span>
                </div>
                
                <button type="submit" class="w-full h-11 bg-primary hover:bg-primary/90 text-white font-semibold rounded-lg shadow-md shadow-primary/10 transition-colors flex items-center justify-center gap-2">
                    <span>Send Reset Link</span>
                </button>
            </form>
            
            <!-- Footer Link -->
            <div class="mt-8">
                <a asp-action="Login" class="flex items-center gap-2 text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-primary transition-colors text-sm font-medium">
                    <span class="material-symbols-outlined text-base">arrow_back</span>
                    Back to login
                </a>
            </div>
        </div>
        
        <!-- Subtle Branding -->
        <div class="mt-8 text-center">
            <div class="flex items-center justify-center gap-2 text-slate-400">
                <img src="~/images/site-logo.png" asp-append-version="true" alt="Liora logo" class="h-6 w-6 object-contain" />
                <span class="text-xs font-semibold uppercase tracking-widest">Liora</span>
            </div>
        </div>
    </div>
</div>
