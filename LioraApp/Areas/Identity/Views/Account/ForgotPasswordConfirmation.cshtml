    <style>
        .envelope-draw {
        stroke-dasharray: 1000;
        stroke-dashoffset: 1000;
        animation: draw 2s ease-out forwards;
        }

        @@keyframes draw {
        to {
        stroke-dashoffset: 0;
        }
        }

        /* Simulating the "void" and "plum" colors requested from prompt using config equivalents */
        .bg-void {
        background-color: #1e1b18;
        }
        /* Using on-background as a dark void proxy */
        .bg-plum {
        background-color: #1A1025;
        }
        /* Using the plum tint mentioned in brand guide */
        .text-rose-gold {
        color: #C49080;
        }
        /* Using primary-container */
        .border-rose-gold {
        border-color: #C49080;
        }

        .bg-rose-gold-15 {
        background-color: rgba(196, 144, 128, 0.15);
        }
    </style>
