<body class="bg-void min-h-screen flex items-center justify-center p-container-padding-mobile md:p-container-padding-desktop antialiased font-body-md text-body-md text-surface">
    <main class="w-full max-w-[440px]">
        <!-- Centered Card -->
        <div class="bg-plum rounded-[24px] p-8 md:p-12 shadow-[0_20px_50px_rgba(26,16,37,0.5)] flex flex-col items-center text-center relative overflow-hidden transition-transform duration-250 ease-out hover:-translate-y-1">
            <!-- Icon Container -->
            <div class="w-[100px] h-[100px] rounded-full bg-rose-gold-15 flex items-center justify-center mb-8 relative">
                <!-- SVG Envelope with draw animation instead of Material Icon to achieve the specific stroke effect requested -->
                <svg class="w-10 h-10 text-rose-gold" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewbox="0 0 24 24">
                    <path class="envelope-draw" d="M4 7.00005L10.2 11.65C11.2667 12.45 12.7333 12.45 13.8 11.65L20 7"></path>
                    <rect class="envelope-draw" height="14" rx="2" style="animation-delay: 0.5s;" width="18" x="3" y="5"></rect>
                </svg>
            </div>
            <!-- Content -->
            <h1 class="font-headline-md text-headline-md text-surface-container-lowest mb-4">Check your inbox</h1>
            <p class="font-body-lg text-body-lg text-surface-variant mb-6 opacity-90">
                We sent a reset link to your email address.
            </p>
            <p class="font-body-md text-body-md text-tertiary-fixed-dim mb-8 italic">
                Didn't receive it? Check spam folder.
            </p>
            <!-- Actions -->
            <a class="w-full py-4 px-6 rounded-full border border-rose-gold text-rose-gold font-label-caps text-label-caps tracking-widest uppercase transition-all duration-250 ease-out hover:bg-rose-gold-15 hover:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-primary-container focus:ring-offset-2 focus:ring-offset-plum" href="#">
                Back to Login
            </a>
            <!-- Decorative subtle glow -->
            <div class="absolute -top-24 -right-24 w-48 h-48 bg-primary-container rounded-full blur-[80px] opacity-10 pointer-events-none"></div>
        </div>
    </main>
