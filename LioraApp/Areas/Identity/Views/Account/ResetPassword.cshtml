@model LioraApp.ViewModels.Identity.ResetPasswordVM
@{
    ViewData["Title"] = "Set New Password";
}

<div class="min-h-[calc(100vh-80px)] flex items-center justify-center p-6">
    <div class="w-full max-w-[480px] bg-white dark:bg-slate-900 shadow-xl rounded-xl overflow-hidden border border-slate-200 dark:border-slate-800 relative z-10">
        <!-- Header -->
        <div class="pt-10 pb-6 flex flex-col items-center text-center px-8">
            <div class="w-16 h-16 bg-primary/10 dark:bg-primary/20 rounded-full flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-primary text-4xl">shield_lock</span>
            </div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-50 tracking-tight">Set new password</h1>
            <p class="mt-2 text-slate-500 dark:text-slate-400 text-sm leading-relaxed">
                Your new password must be different from previous used passwords to keep your account secure.
            </p>
        </div>
        
        <!-- Form Area -->
        <form asp-action="ResetPassword" method="post" class="px-8 pb-10 space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-rose-500 text-sm font-semibold mb-4"></div>

            <input type="hidden" asp-for="Token" />
            <input type="hidden" asp-for="Email" />

            <!-- New Password -->
            <div class="space-y-2">
                <label asp-for="NewPassword" class="block text-sm font-semibold text-slate-700 dark:text-slate-300"></label>
                <div class="relative group">
                    <input asp-for="NewPassword" class="block w-full px-4 py-3 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-50 placeholder-slate-400 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none" placeholder="••••••••" />
                    <button type="button" onclick="const p = document.getElementById('NewPassword'); p.type = p.type === 'password' ? 'text' : 'password';" class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-primary transition-colors">
                        <span class="material-symbols-outlined text-[20px]">visibility</span>
                    </button>
                </div>
                <span asp-validation-for="NewPassword" class="text-rose-500 text-xs mt-1 block"></span>
            </div>
            
            <!-- Confirm Password Input -->
            <div class="space-y-2">
                <label asp-for="ConfirmPassword" class="block text-sm font-semibold text-slate-700 dark:text-slate-300"></label>
                <div class="relative">
                    <input asp-for="ConfirmPassword" class="block w-full px-4 py-3 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-50 placeholder-slate-400 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none" placeholder="••••••••" />
                    <div class="absolute inset-y-0 right-0 pr-3 flex items-center">
                        <span class="material-symbols-outlined text-emerald-500 text-[20px]">check_circle</span>
                    </div>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-rose-500 text-xs mt-1 block"></span>
            </div>
            
            <!-- Submit Button -->
            <button type="submit" class="w-full flex items-center justify-center gap-2 bg-primary hover:bg-primary/90 text-white font-bold py-3 px-4 rounded-lg shadow-lg shadow-primary/20 transition-all active:scale-[0.98]">
                Reset Password
                <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
            </button>
            
            <!-- Back to Login -->
            <div class="text-center pt-2">
                <a asp-action="Login" class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-500 hover:text-primary transition-colors">
                    <span class="material-symbols-outlined text-[16px]">arrow_back</span>
                    Back to sign in
                </a>
            </div>
        </form>
        
        <!-- Footer / Security Note -->
        <div class="bg-slate-50 dark:bg-slate-800/50 px-8 py-4 border-t border-slate-100 dark:border-slate-800 flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-slate-400 text-[18px]">verified_user</span>
            <span class="text-[11px] text-slate-400 uppercase tracking-widest font-medium">Secure Encrypted Connection</span>
        </div>
    </div>
    
    <!-- Decorative Elements -->
    <div class="fixed top-0 left-0 w-full h-full -z-10 overflow-hidden pointer-events-none opacity-40">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-primary/10 blur-[100px]"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-primary/10 blur-[100px]"></div>
    </div>
</div>
