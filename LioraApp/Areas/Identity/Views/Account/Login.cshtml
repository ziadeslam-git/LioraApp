@model LioraApp.ViewModels.Identity.LoginVM
@{
    ViewData["Title"] = "Log In";
}

@section Styles {
    <style>
        .grid-pattern {
            background-image: radial-gradient(circle, rgba(99, 102, 241, 0.15) 1px, transparent 1px);
            background-size: 30px 30px;
        }
    </style>
}

<div class="flex min-h-screen w-full flex-col lg:flex-row">
    <!-- Left Panel: Branding (40%) -->
    <div class="relative hidden w-full flex-col items-center justify-center bg-[#0F172A] lg:flex lg:w-[40%] overflow-hidden">
        <div class="grid-pattern absolute inset-0 h-full w-full"></div>
        <div class="relative z-10 flex flex-col items-center px-12 text-center">
            <div class="mb-8 flex h-24 w-24 items-center justify-center rounded-3xl bg-white/10 shadow-xl shadow-primary/10 ring-1 ring-white/10 backdrop-blur-sm">
                <img src="~/images/site-logo.png" asp-append-version="true" alt="Liora logo" class="h-16 w-16 object-contain" />
            </div>
            <h1 class="text-4xl font-black tracking-tight text-white lg:text-5xl">
                Liora
            </h1>
            <p class="mt-4 text-lg text-slate-400">
                Revolutionizing your shopping experience with intelligence.
            </p>
            <div class="mt-12 grid grid-cols-2 gap-4 w-full max-w-sm">
                <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-4 backdrop-blur-sm">
                    <span class="material-symbols-outlined text-primary mb-2">bolt</span>
                    <p class="text-xs font-semibold text-white uppercase tracking-wider">Fast Setup</p>
                </div>
                <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-4 backdrop-blur-sm">
                    <span class="material-symbols-outlined text-primary mb-2">security</span>
                    <p class="text-xs font-semibold text-white uppercase tracking-wider">Secure Tech</p>
                </div>
            </div>
        </div>
        <div class="absolute bottom-8 left-8 right-8 flex justify-between text-xs text-slate-500">
            <span>© 2026 Liora</span>
            <div class="flex gap-4">
                <a class="hover:text-white transition-colors" href="#">Privacy</a>
                <a class="hover:text-white transition-colors" href="#">Terms</a>
            </div>
        </div>
    </div>
    
    <!-- Right Panel: Login Form (60%) -->
    <div class="flex w-full flex-1 flex-col items-center justify-center px-6 py-12 bg-background-light dark:bg-background-dark lg:w-[60%] lg:px-20">
        <div class="w-full max-w-md">
            <!-- Mobile Header -->
            <div class="mb-10 flex items-center gap-3 lg:hidden">
                <img src="~/images/site-logo.png" asp-append-version="true" alt="Liora logo" class="h-10 w-10 object-contain" />
                <span class="text-2xl font-bold text-slate-900 dark:text-slate-100">Liora</span>
            </div>
            
            <div class="mb-10">
                <h2 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100">Welcome Back</h2>
                <p class="mt-2 text-slate-600 dark:text-slate-400">Please enter your details to sign in to your account</p>
            </div>

            @if (ViewBag.ShowConfirmEmailAlert == true)
            {
                <div class="mb-6 rounded-2xl border border-amber-200 bg-amber-50/90 p-4 shadow-sm dark:border-amber-900/50 dark:bg-amber-950/30">
                    <div class="flex items-start gap-3">
                        <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-amber-100 text-amber-700 dark:bg-amber-900/50 dark:text-amber-300">
                            <span class="material-symbols-outlined text-[20px]">mail</span>
                        </div>
                        <div class="min-w-0 flex-1">
                            <h3 class="text-sm font-bold text-amber-900 dark:text-amber-200">Confirm your email first</h3>
                            <p class="mt-1 text-sm leading-6 text-amber-800 dark:text-amber-300">
                                We sent a confirmation link to
                                <span class="font-semibold">@(ViewBag.UnconfirmedEmail ?? Model.Email)</span>.
                                Please check your inbox and spam folder, then confirm your email before signing in.
                            </p>
                            <a asp-action="ResendConfirmation"
                               asp-route-email="@(ViewBag.UnconfirmedEmail ?? Model.Email)"
                               class="mt-3 inline-flex items-center gap-2 rounded-xl bg-amber-600 px-4 py-2 text-xs font-bold text-white transition hover:bg-amber-700">
                                <span class="material-symbols-outlined text-[16px]">send</span>
                                <span>Resend confirmation email</span>
                            </a>
                        </div>
                    </div>
                </div>
            }
            
            <form asp-action="Login" method="post" class="space-y-6">
                <div asp-validation-summary="ModelOnly" class="text-rose-500 text-sm font-semibold mb-4"></div>

                <div>
                    <label asp-for="Email" class="block text-sm font-semibold text-slate-900 dark:text-slate-100 mb-2"></label>
                    <input asp-for="Email" class="block w-full rounded-lg border border-slate-200 bg-white px-4 py-3.5 text-slate-900 placeholder-slate-400 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all dark:border-slate-800 dark:bg-slate-900/50 dark:text-slate-100" placeholder="name@company.com" />
                    <span asp-validation-for="Email" class="text-rose-500 text-xs mt-1 block"></span>
                </div>
                
                <div>
                    <div class="flex items-center justify-between mb-2">
                        <label asp-for="Password" class="block text-sm font-semibold text-slate-900 dark:text-slate-100"></label>
                        <a asp-action="ForgotPassword" class="text-sm font-semibold text-primary hover:opacity-80 transition-opacity">Forgot password?</a>
                    </div>
                    <div class="relative">
                        <input asp-for="Password" class="block w-full rounded-lg border border-slate-200 bg-white px-4 py-3.5 text-slate-900 placeholder-slate-400 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all dark:border-slate-800 dark:bg-slate-900/50 dark:text-slate-100" placeholder="••••••••" />
                        <button class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-200" type="button" onclick="const p = document.getElementById('Password'); p.type = p.type === 'password' ? 'text' : 'password';">
                            <span class="material-symbols-outlined text-xl">visibility</span>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-rose-500 text-xs mt-1 block"></span>
                </div>
                
                <div class="flex items-center">
                    <input asp-for="RememberMe" class="h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary dark:border-slate-700 dark:bg-slate-800" />
                    <label asp-for="RememberMe" class="ml-2 block text-sm text-slate-600 dark:text-slate-400">Stay signed in for 30 days</label>
                </div>
                
                <button type="submit" class="w-full rounded-lg bg-primary px-4 py-4 text-sm font-bold text-white shadow-lg shadow-primary/25 hover:brightness-110 active:scale-[0.98] transition-all">
                    Sign In
                </button>
            </form>
            
            <div class="relative my-8">
                <div aria-hidden="true" class="absolute inset-0 flex items-center">
                    <div class="w-full border-t border-slate-200 dark:border-slate-800"></div>
                </div>
                <div class="relative flex justify-center text-sm font-medium">
                    <span class="bg-background-light dark:bg-background-dark px-4 text-slate-500 uppercase tracking-widest text-xs">Or continue with</span>
                </div>
            </div>
            
            <form asp-area="Identity" asp-controller="ExternalLogin" asp-action="ExternalLogin" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                <div class="grid grid-cols-2 gap-4" contenteditable>
                    <button type="submit" name="provider" value="Google" class="flex items-center justify-center gap-2 rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 transition-colors dark:border-slate-800 dark:bg-slate-900/50 dark:text-slate-300 dark:hover:bg-slate-800">
                        <svg class="h-5 w-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                        </svg>
                        <span>Google</span>
                    </button>
               
                </div>
            </form>
            
            <p class="mt-10 text-center text-sm text-slate-600 dark:text-slate-400">
                Don't have an account? 
                <a asp-action="Register" class="font-bold text-primary hover:underline">Create an account</a>
            </p>
        </div>
    </div>
</div>
