@{ Layout = null; }
@using LioraApp.ViewModels.Identity
@model LoginVM
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Login - Liora</title>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@100..900&family=Playfair+Display:wght@100..900&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary": "#7f5446",
                        "background": "#fff8f3",
                        "outline": "#83746f",
                        "surface-container-high": "#eee7e1",
                        "surface-container-lowest": "#ffffff",
                        "mist": "#83746f",
                        "error": "#ba1a1a",
                        "primary-container": "#c49080",
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'DM Sans', sans-serif; }
        .font-serif { font-family: 'Playfair Display', serif; }
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(24px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .animate-in { animation: fadeInUp 0.55s cubic-bezier(0.4,0,0.2,1) forwards; }
    </style>
</head>
<body class="bg-background min-h-screen flex items-center justify-center p-4">

    <div class="bg-white rounded-3xl shadow-[0_20px_60px_rgba(127,84,70,0.12)] w-full max-w-md p-8 md:p-12 border border-outline/10 animate-in">

        <!-- Logo -->
        <div class="text-center mb-8">
            <a href="/" class="font-serif text-4xl italic text-primary tracking-tight">liora</a>
            <p class="text-mist text-sm mt-2">Sign in to continue</p>
        </div>

        <!-- Error Banner -->
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(string.Empty))
        {
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl mb-6 text-sm flex items-start gap-2">
                <span class="material-symbols-outlined text-[18px] mt-0.5 flex-shrink-0">error</span>
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        <!-- Success / Info Toasts from TempData -->
        @if (TempData["success"] != null)
        {
            <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl mb-6 text-sm flex items-start gap-2">
                <span class="material-symbols-outlined text-[18px] mt-0.5 flex-shrink-0">check_circle</span>
                <span>@TempData["success"]</span>
            </div>
        }

        <form asp-area="Identity" asp-controller="Account" asp-action="Login" method="post" class="flex flex-col gap-5">

            <!-- Email -->
            <div class="flex flex-col gap-1.5">
                <label asp-for="Email" class="text-xs font-bold tracking-widest text-mist uppercase">Email Address</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-mist/60 text-[20px]">mail</span>
                    <input asp-for="Email" autocomplete="email"
                           class="w-full bg-stone-50 border border-stone-200 text-stone-800 rounded-xl pl-10 pr-4 py-3.5 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all placeholder:text-stone-400"
                           placeholder="you@example.com" />
                </div>
                <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
            </div>

            <!-- Password -->
            <div class="flex flex-col gap-1.5">
                <label asp-for="Password" class="text-xs font-bold tracking-widest text-mist uppercase">Password</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-mist/60 text-[20px]">lock</span>
                    <input asp-for="Password" autocomplete="current-password"
                           class="w-full bg-stone-50 border border-stone-200 text-stone-800 rounded-xl pl-10 pr-4 py-3.5 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all placeholder:text-stone-400"
                           placeholder="••••••••" />
                </div>
                <span asp-validation-for="Password" class="text-red-500 text-xs"></span>
            </div>

            <!-- Remember Me -->
            <div class="flex items-center gap-2">
                <input asp-for="RememberMe" class="w-4 h-4 rounded border-stone-300 text-primary focus:ring-primary/30" />
                <label asp-for="RememberMe" class="text-sm text-mist cursor-pointer select-none">Keep me signed in</label>
            </div>

            <!-- Submit -->
            <button type="submit"
                    class="w-full bg-primary text-white font-bold tracking-widest text-xs uppercase py-4 rounded-xl hover:opacity-90 active:scale-[0.98] transition-all duration-200 shadow-[0_6px_20px_rgba(127,84,70,0.25)] mt-1">
                Sign In
            </button>
        </form>

        <!-- Divider -->
        <div class="flex items-center gap-3 my-6">
            <div class="flex-1 h-px bg-stone-200"></div>
            <span class="text-xs font-bold tracking-widest text-mist uppercase">Or</span>
            <div class="flex-1 h-px bg-stone-200"></div>
        </div>

        <!-- Google -->
        <form asp-area="Identity" asp-controller="ExternalLogin" asp-action="ExternalLogin" method="post">
            <button type="submit" name="provider" value="Google"
                    class="w-full bg-white border border-stone-200 text-stone-700 flex items-center justify-center gap-3 py-3.5 rounded-xl hover:bg-stone-50 active:scale-[0.98] transition-all font-medium text-sm shadow-sm">
                <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="Google" class="w-5 h-5" />
                Continue with Google
            </button>
        </form>

        <!-- Sign Up Link -->
        <p class="text-center text-sm text-mist mt-7">
            Don't have an account?
            <a href="@Url.Action("Register", "Account", new { area = "Identity" })" class="text-primary font-bold hover:underline">Sign Up</a>
        </p>
    </div>

</body>
</html>
