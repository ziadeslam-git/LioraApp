        </div>
        <!-- Warning Icon -->
        <div class="w-[120px] h-[120px] rounded-full bg-error-container/30 flex items-center justify-center mb-stack-md shrink-0">
            <span class="material-symbols-outlined text-[48px] text-error" style="font-variation-settings: 'FILL' 0;">
                pause_circle
            </span>
        </div>
        <!-- Typography Content -->
        <h1 class="font-headline-md text-headline-md text-on-background italic mb-stack-sm">
            Account Deactivated
        </h1>
        <p class="font-body-md text-body-md text-on-surface-variant mb-stack-lg max-w-[90%]">
            Your account has been temporarily deactivated. Please contact our support team to reactivate it.
        </p>
        <!-- Info Callout Box -->
        <div class="w-full bg-surface-container border-l-4 border-primary-container p-stack-md rounded-r-xl rounded-l-sm text-left mb-stack-lg shadow-sm">
            <div class="flex items-center gap-stack-sm mb-unit">
                <span class="material-symbols-outlined text-primary-container text-[20px]">mail</span>
                <span class="font-body-md text-body-md text-on-background">support@elegance.com</span>
            </div>
            <div class="flex items-center gap-stack-sm">
                <span class="material-symbols-outlined text-primary-container text-[20px]">chat</span>
                <span class="font-body-md text-body-md text-on-background">+1 (555) 123-4567</span>
            </div>
        </div>
        <!-- Primary Action -->
        <button class="w-full bg-primary-container text-on-primary-container font-label-caps text-label-caps py-4 px-8 rounded-full shadow-level-1 hover:shadow-level-2 transform scale-100 hover:scale-[0.98] transition-all duration-250 ease-out flex items-center justify-center gap-unit">
