<body class="bg-background min-h-screen flex items-center justify-center p-container-padding-mobile md:p-container-padding-desktop">
    <!--
        Navigation Shell Suppressed:
        As per the "Semantic Shell Mandate", transactional/dead-end screens
        (like Account Deactivated) must exclude the navigation shell to focus the canvas.
    -->
    <main class="w-full max-w-[480px] bg-surface-container-lowest rounded-2xl shadow-level-1 p-8 md:p-12 flex flex-col items-center text-center relative overflow-hidden">
        <!-- Subtle background decoration -->
