<body class="bg-background text-on-background font-body-md text-body-md antialiased h-screen w-full overflow-hidden flex flex-col md:flex-row">
    <!-- Top Navigation Placeholder (Hidden for transactional page per rules, only a simplified brand header visible on mobile) -->
    <header class="md:hidden flex justify-between items-center px-container-padding-mobile py-stack-md w-full z-50 fixed top-0 bg-transparent">
        <a class="font-display-lg-mobile text-display-lg-mobile text-primary tracking-tighter" href="#">ELÉGANCE</a>
    </header>
    <!-- Left Screen: AuthQuote (Hidden on Mobile) -->
    <div class="hidden md:flex w-1/2 h-full bg-on-secondary-fixed relative items-center justify-center p-container-padding-desktop overflow-hidden">
        <!-- Background Image overlaying dark void -->
        <div class="absolute inset-0 w-full h-full opacity-30 bg-cover bg-center" data-alt="A moody, high-fashion editorial portrait of a woman draped in delicate silk, bathed in soft, ethereal lighting against a dark void. The scene exudes luxury, empowerment, and intimate elegance, perfectly complementing a sophisticated, modern Egyptian craftsmanship brand identity. The palette is rich with deep plums, soft ivories, and subtle rose gold highlights, embodying effortless grace." style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuD1QE0cMwKp41TzYC3uLby438OytRKfsu1KsNkfPjZwsOlQA7kvnfYdAgWkCYVwtrMWZ3gs1VT5i4ChLmbRILOeX-_iHqQifJk3Pt5JtarjDX0he-mmXLLhBYCxuy7t118kCHUngJYNFPgfKimIRAXvq1GHoZQCueNrbEp1h_sKuaONJqC7ZnCzxXPc6suY1XPiCLZzxkmRUW_B9vijrPttGY9TuW5RFkRPFsQUfHD2Z_CkLD62pw9Ulo4Jn_oqiY7fqdD7B627CCPt');">
        </div>
        <div class="relative z-10 text-center max-w-lg">
            <a class="font-display-lg text-display-lg text-primary-fixed tracking-tighter mb-section-gap block" href="#">ELÉGANCE</a>
            <p class="font-headline-lg text-headline-lg text-surface-container-low mb-stack-md">"Your journey to confidence starts here."</p>
            <p class="font-accent-italic text-accent-italic text-surface-variant opacity-80">Discover modern Egyptian craftsmanship.</p>
        </div>
    </div>
    <!-- Right Screen: Registration Form -->
    <div class="w-full md:w-1/2 h-full bg-surface flex items-center justify-center p-container-padding-mobile md:p-container-padding-desktop overflow-y-auto">
        <div class="w-full max-w-md mt-16 md:mt-0">
            <!-- Form Header -->
            <div class="mb-stack-lg text-center md:text-left">
                <span class="font-label-caps text-label-caps text-secondary uppercase tracking-[0.1em] block mb-stack-sm">JOIN liora</span>
                <h1 class="font-headline-md text-headline-md text-on-surface mb-stack-sm">Create your account</h1>
                <p class="font-body-md text-body-md text-on-surface-variant">Experience effortless grace and premium quality.</p>
            </div>
            <!-- Registration Form -->
            <form action="#" class="space-y-stack-md" method="POST">
                <!-- Row 1: First & Last Name -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-stack-md">
                    <div class="flex flex-col space-y-unit">
                        <label class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-[0.1em]" for="firstName">First Name</label>
                        <div class="relative rounded-xl overflow-hidden input-glow border border-outline-variant/50 transition-all duration-250 ease-out bg-surface-container-lowest">
                            <input class="w-full bg-transparent border-none text-on-surface py-3 px-4 focus:ring-0 font-body-md" id="firstName" name="firstName" placeholder="Jane" required="" type="text" />
                        </div>
                    </div>
                    <div class="flex flex-col space-y-unit">
                        <label class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-[0.1em]" for="lastName">Last Name</label>
                        <div class="relative rounded-xl overflow-hidden input-glow border border-outline-variant/50 transition-all duration-250 ease-out bg-surface-container-lowest">
                            <input class="w-full bg-transparent border-none text-on-surface py-3 px-4 focus:ring-0 font-body-md" id="lastName" name="lastName" placeholder="Doe" required="" type="text" />
                        </div>
                    </div>
                </div>
                <!-- Row 2: Email -->
                <div class="flex flex-col space-y-unit">
                    <label class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-[0.1em]" for="email">Email</label>
                    <div class="relative rounded-xl overflow-hidden input-glow border border-outline-variant/50 transition-all duration-250 ease-out bg-surface-container-lowest">
                        <input class="w-full bg-transparent border-none text-on-surface py-3 px-4 focus:ring-0 font-body-md" id="email" name="email" placeholder="jane@example.com" required="" type="email" />
                    </div>
                </div>
                <!-- Row 3: Password -->
                <div class="flex flex-col space-y-unit">
                    <label class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-[0.1em]" for="password">Password</label>
                    <div class="relative rounded-xl overflow-hidden input-glow border border-outline-variant/50 transition-all duration-250 ease-out bg-surface-container-lowest flex items-center">
                        <input class="w-full bg-transparent border-none text-on-surface py-3 px-4 focus:ring-0 font-body-md" id="password" name="password" placeholder="••••••••" required="" type="password" />
                        <button aria-label="Toggle password visibility" class="absolute right-4 text-outline hover:text-primary transition-colors duration-250 focus:outline-none" type="button">
                            <span class="material-symbols-outlined" data-icon="visibility">visibility</span>
                        </button>
                    </div>
                </div>
                <!-- Password Strength Meter (4 segments) -->
                <div class="flex space-x-2 mt-unit">
                    <div class="h-1 w-1/4 rounded-full bg-primary-container"></div>
                    <div class="h-1 w-1/4 rounded-full bg-surface-variant"></div>
                    <div class="h-1 w-1/4 rounded-full bg-surface-variant"></div>
                    <div class="h-1 w-1/4 rounded-full bg-surface-variant"></div>
                </div>
                <!-- Row 4: Confirm Password -->
                <div class="flex flex-col space-y-unit pt-stack-sm">
                    <label class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-[0.1em]" for="confirmPassword">Confirm Password</label>
                    <div class="relative rounded-xl overflow-hidden input-glow border border-outline-variant/50 transition-all duration-250 ease-out bg-surface-container-lowest">
                        <input class="w-full bg-transparent border-none text-on-surface py-3 px-4 focus:ring-0 font-body-md" id="confirmPassword" name="confirmPassword" placeholder="••••••••" required="" type="password" />
                    </div>
                </div>
                <!-- Terms Checkbox -->
                <div class="flex items-start py-stack-sm">
                    <div class="flex items-center h-5">
                        <input aria-describedby="terms-description" class="w-5 h-5 bg-surface-container-lowest border-outline-variant rounded-md text-primary focus:ring-primary focus:ring-offset-surface" id="terms" name="terms" required="" type="checkbox" />
                    </div>
                    <div class="ml-3 text-sm">
                        <label class="font-body-md text-body-md text-on-surface-variant" for="terms">
                            I agree to the <a class="text-primary hover:underline transition-all duration-250" href="#">Terms</a> &amp; <a class="text-primary hover:underline transition-all duration-250" href="#">Privacy Policy</a>
                        </label>
                    </div>
                </div>
                <!-- Submit Button -->
                <button class="w-full bg-primary-container text-on-primary py-4 px-6 rounded-full font-label-caps text-label-caps uppercase tracking-[0.1em] hover:opacity-90 active:scale-95 transition-all duration-250 ease-out shadow-level-1 hover:shadow-level-2 mt-stack-md" type="submit">
                    CREATE MY ACCOUNT
                </button>
            </form>
            <!-- Footer Link -->
            <div class="mt-stack-lg text-center">
                <p class="font-body-md text-body-md text-on-surface-variant">
                    Already have an account?
                    <a class="text-primary hover:underline transition-all duration-250 font-medium inline-flex items-center" href="#">
                        Sign in <span class="material-symbols-outlined ml-1 text-sm" data-icon="arrow_forward">arrow_forward</span>
                    </a>
                </p>
            </div>
        </div>
    </div>
</body></html>