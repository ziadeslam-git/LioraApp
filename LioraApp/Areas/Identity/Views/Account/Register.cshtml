@{ Layout = null; }
@using LioraApp.ViewModels.Identity
@model RegisterVM
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Register - Liora</title>
    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@100..900&family=Playfair+Display:wght@100..900&display=swap" rel="stylesheet" />
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "primary-fixed": "#ffdbd0",
                        "primary": "#7f5446",
                        "background": "#fff8f3",
                        "surface": "#fff8f3",
                        "outline": "#83746f",
                        "surface-container-high": "#eee7e1",
                        "surface-container-lowest": "#ffffff",
                        "mist": "#83746f",
                        "error": "#ba1a1a",
                        "primary-container": "#c49080",
                    },
                    "fontFamily": {
                        "headline-lg": ["Playfair Display"],
                        "body-md": ["DM Sans"],
                        "label-caps": ["DM Sans"],
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'DM Sans', sans-serif; }
        .font-headline-lg { font-family: 'Playfair Display', serif; }
        .animate-fade-in-up {
            animation: fadeInUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        }
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="bg-background min-h-screen flex items-center justify-center p-4">

    <div class="bg-surface-container-lowest shadow-[0_20px_40px_rgba(127,84,70,0.08)] rounded-[2rem] w-full max-w-md p-8 md:p-12 relative overflow-hidden animate-fade-in-up border border-outline/10 mt-10 mb-10">
        <!-- Decorative corner highlight -->
        <div class="absolute top-0 right-0 w-32 h-32 bg-primary-container/10 rounded-bl-full pointer-events-none"></div>

        <div class="text-center mb-8 relative z-10">
            <h1 class="font-headline-lg text-3xl md:text-4xl text-primary mb-2">Create Account</h1>
            <p class="text-mist text-sm md:text-base">Join the exclusive Liora portfolio</p>
        </div>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty] != null)
        {
            <div class="bg-error/10 border border-error/20 text-error px-4 py-3 rounded-xl mb-6 text-sm flex items-start gap-2">
                <span class="material-symbols-outlined text-[20px]">error</span>
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        <form asp-area="Identity" asp-controller="Account" asp-action="Register" method="post" class="flex flex-col gap-4 relative z-10">
            <!-- FullName -->
            <div class="flex flex-col gap-1.5">
                <label asp-for="FullName" class="text-xs font-bold tracking-widest text-mist uppercase">Full Name</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-mist/70">person</span>
                    <input asp-for="FullName" class="w-full bg-surface-container-high/30 border border-outline/20 text-primary rounded-xl pl-11 pr-4 py-3.5 text-sm placeholder-mist/50 focus:border-primary focus:ring-1 focus:ring-primary focus:bg-surface-container-lowest transition-all" placeholder="Jane Doe" />
                </div>
                <span asp-validation-for="FullName" class="text-error text-xs mt-1 block"></span>
            </div>

            <!-- Email -->
            <div class="flex flex-col gap-1.5">
                <label asp-for="Email" class="text-xs font-bold tracking-widest text-mist uppercase"></label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-mist/70">mail</span>
                    <input asp-for="Email" class="w-full bg-surface-container-high/30 border border-outline/20 text-primary rounded-xl pl-11 pr-4 py-3.5 text-sm placeholder-mist/50 focus:border-primary focus:ring-1 focus:ring-primary focus:bg-surface-container-lowest transition-all" placeholder="name@example.com" />
                </div>
                <span asp-validation-for="Email" class="text-error text-xs mt-1 block"></span>
            </div>

            <!-- PhoneNumber -->
            <div class="flex flex-col gap-1.5">
                <label asp-for="PhoneNumber" class="text-xs font-bold tracking-widest text-mist uppercase">Phone Number</label>
                <div class="relative flex">
                    <!-- Hardcoded EG for now, but bindable logic supports it -->
                    <input type="hidden" asp-for="PhoneCountryIso2" value="EG" />
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-mist/70 z-10">call</span>
                    <input asp-for="PhoneNumber" class="w-full bg-surface-container-high/30 border border-outline/20 text-primary rounded-xl pl-11 pr-4 py-3.5 text-sm placeholder-mist/50 focus:border-primary focus:ring-1 focus:ring-primary focus:bg-surface-container-lowest transition-all" placeholder="01234567890" />
                </div>
                <span asp-validation-for="PhoneNumber" class="text-error text-xs mt-1 block"></span>
            </div>

            <!-- Password -->
            <div class="flex flex-col gap-1.5">
                <label asp-for="Password" class="text-xs font-bold tracking-widest text-mist uppercase"></label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-mist/70">lock</span>
                    <input asp-for="Password" class="w-full bg-surface-container-high/30 border border-outline/20 text-primary rounded-xl pl-11 pr-4 py-3.5 text-sm placeholder-mist/50 focus:border-primary focus:ring-1 focus:ring-primary focus:bg-surface-container-lowest transition-all" placeholder="••••••••" />
                </div>
                <span asp-validation-for="Password" class="text-error text-xs mt-1 block"></span>
            </div>

            <!-- ConfirmPassword -->
            <div class="flex flex-col gap-1.5">
                <label asp-for="ConfirmPassword" class="text-xs font-bold tracking-widest text-mist uppercase">Confirm Password</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-mist/70">lock_reset</span>
                    <input asp-for="ConfirmPassword" class="w-full bg-surface-container-high/30 border border-outline/20 text-primary rounded-xl pl-11 pr-4 py-3.5 text-sm placeholder-mist/50 focus:border-primary focus:ring-1 focus:ring-primary focus:bg-surface-container-lowest transition-all" placeholder="••••••••" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-error text-xs mt-1 block"></span>
            </div>

            <!-- Submit Button -->
            <button type="submit" class="w-full bg-primary text-white font-bold tracking-wider text-sm uppercase py-4 rounded-xl hover:bg-primary-fixed hover:text-primary-fixed-variant transition-all duration-300 shadow-[0_8px_20px_rgba(127,84,70,0.2)] hover:shadow-[0_10px_25px_rgba(127,84,70,0.3)] mt-2">
                Sign Up
            </button>
        </form>

        <div class="relative flex py-6 items-center">
            <div class="flex-grow border-t border-outline/20"></div>
            <span class="flex-shrink-0 mx-4 text-mist text-xs font-bold tracking-widest uppercase">Or</span>
            <div class="flex-grow border-t border-outline/20"></div>
        </div>

        <!-- Google Sign In -->
        <form asp-area="Identity" asp-controller="ExternalLogin" asp-action="ExternalLogin" method="post" class="w-full relative z-10">
            <button type="submit" name="provider" value="Google" class="w-full bg-surface-container-lowest border border-outline/20 text-primary flex items-center justify-center gap-3 py-3.5 rounded-xl hover:bg-surface-container-high/50 transition-all font-medium text-sm">
                <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="Google Logo" class="w-5 h-5" />
                Continue with Google
            </button>
        </form>

        <div class="text-center mt-8 relative z-10">
            <p class="text-sm text-mist">
                Already have an account? 
                <a href="@Url.Action("Login", "Account", new { area = "Identity" })" class="text-primary font-bold hover:underline transition-all">Sign In</a>
            </p>
        </div>
    </div>

</body>
</html>