@model LioraApp.ViewModels.Identity.RegisterVM
@{
    ViewData["Title"] = "Register";
}

@section Styles {
    <style>
        .geometric-pattern {
            background-color: #101122;
            background-image: radial-gradient(#6467f2 0.5px, transparent 0.5px);
            background-size: 24px 24px;
        }

        .iti {
            width: 100%;
        }

        .iti__country-container {
            border-radius: 0.75rem 0 0 0.75rem;
        }

        .iti input.smart-phone-input {
            padding-left: 3.75rem !important;
        }

        .field-validation-error {
            color: #f43f5e;
            display: block;
            font-size: 0.75rem;
            font-weight: 500;
            margin-top: 0.25rem;
        }
    </style>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@28.0.4/build/css/intlTelInput.css" />
}

<div class="flex min-h-screen">
    <!-- Left Section: Branding & Graphics -->
    <div class="hidden lg:flex lg:w-1/2 relative flex-col justify-between p-12 overflow-hidden bg-background-dark text-white">
        <!-- Abstract Background -->
        <div class="absolute inset-0 geometric-pattern opacity-20"></div>
        <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-primary/20 rounded-full blur-3xl"></div>
        <div class="absolute -top-24 -right-24 w-96 h-96 bg-primary/10 rounded-full blur-3xl"></div>
        
        <div class="relative z-10 flex items-center gap-3">
            <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-white/10 ring-1 ring-white/10 backdrop-blur-sm">
                <img src="~/images/site-logo.png" asp-append-version="true" alt="Liora logo" class="h-9 w-9 object-contain" />
            </div>
            <h1 class="text-2xl font-bold tracking-tight">Liora</h1>
        </div>
        
        <div class="relative z-10">
            <h2 class="text-5xl font-extrabold leading-tight mb-6">Elevate your <br/><span class="text-primary">shopping experience</span></h2>
            <p class="text-slate-400 text-lg max-w-md leading-relaxed">
                Join our community of millions of shoppers and get access to exclusive deals, personalized recommendations, and seamless checkout.
            </p>
        </div>
        
        <div class="relative z-10 flex items-center gap-4 text-sm text-slate-500">
            <span>© 2026 Liora</span>
            <span class="h-1 w-1 rounded-full bg-slate-700"></span>
            <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
            <span class="h-1 w-1 rounded-full bg-slate-700"></span>
            <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
        </div>
    </div>
    
    <!-- Right Section: Registration Form -->
    <div class="w-full lg:w-1/2 flex items-center justify-center p-8 lg:p-16 bg-white dark:bg-background-dark">
        <div class="max-w-[480px] w-full space-y-8">
            <div class="space-y-2">
                <h3 class="text-3xl font-black text-slate-900 dark:text-slate-100 tracking-tight">Create your account</h3>
                <p class="text-slate-500 dark:text-slate-400">Already have an account? <a asp-action="Login" class="text-primary font-semibold hover:underline">Log in</a></p>
            </div>
            
            <form asp-action="Register" method="post" class="space-y-6">
                <div asp-validation-summary="ModelOnly" class="text-rose-500 text-sm font-semibold mb-4"></div>

                <!-- Full Name -->
                <div class="space-y-2">
                    <label asp-for="FullName" class="text-sm font-semibold text-slate-700 dark:text-slate-300 px-1"></label>
                    <div class="relative group">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <span class="material-symbols-outlined text-slate-400 group-focus-within:text-primary transition-colors text-[20px]">person</span>
                        </div>
                        <input asp-for="FullName" class="w-full pl-11 pr-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none" placeholder="John Doe" />
                    </div>
                    <span asp-validation-for="FullName" class="text-rose-500 text-xs mt-1 block"></span>
                </div>
                
                <!-- Email Address -->
                <div class="space-y-2">
                    <label asp-for="Email" class="text-sm font-semibold text-slate-700 dark:text-slate-300 px-1"></label>
                    <div class="relative group">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <span class="material-symbols-outlined text-slate-400 group-focus-within:text-primary transition-colors text-[20px]">mail</span>
                        </div>
                        <input asp-for="Email" class="w-full pl-11 pr-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none" placeholder="name@company.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-rose-500 text-xs mt-1 block"></span>
                </div>

                <!-- Phone Number -->
                <div class="space-y-2">
                    <label asp-for="PhoneNumber" class="text-sm font-semibold text-slate-700 dark:text-slate-300 px-1"></label>
                    <input asp-for="PhoneCountryIso2" type="hidden" class="js-phone-country" />
                    <input asp-for="PhoneNumber"
                           type="tel"
                           autocomplete="tel"
                           inputmode="tel"
                           class="js-phone-input smart-phone-input w-full pr-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none"
                           data-phone-required="true"
                           data-phone-error-required="Phone number is required."
                           data-phone-error-invalid="Please enter a valid phone number for the selected country."
                           placeholder="+20 10 1234 5678" />
                    <span asp-validation-for="PhoneNumber" class="text-rose-500 text-xs mt-1 block"></span>
                </div>
                
                <!-- Password -->
                <div class="space-y-2">
                    <label asp-for="Password" class="text-sm font-semibold text-slate-700 dark:text-slate-300 px-1"></label>
                    <div class="relative group">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <span class="material-symbols-outlined text-slate-400 group-focus-within:text-primary transition-colors text-[20px]">lock</span>
                        </div>
                        <input asp-for="Password" class="w-full pl-11 pr-12 py-3.5 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none" placeholder="Create a strong password" />
                        <button type="button" onclick="const p = document.getElementById('Password'); p.type = p.type === 'password' ? 'text' : 'password';" class="absolute inset-y-0 right-0 pr-4 flex items-center text-slate-400 hover:text-slate-600 transition-colors">
                            <span class="material-symbols-outlined text-[20px]">visibility</span>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-rose-500 text-xs mt-1 block"></span>
                </div>
                
                <!-- Confirm Password -->
                <div class="space-y-2">
                    <label asp-for="ConfirmPassword" class="text-sm font-semibold text-slate-700 dark:text-slate-300 px-1"></label>
                    <div class="relative group">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <span class="material-symbols-outlined text-slate-400 group-focus-within:text-primary transition-colors text-[20px]">lock_reset</span>
                        </div>
                        <input asp-for="ConfirmPassword" class="w-full pl-11 pr-12 py-3.5 rounded-xl border border-primary bg-primary/5 dark:bg-primary/10 text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none" placeholder="Repeat your password" />
                        <div class="absolute inset-y-0 right-0 pr-4 flex items-center text-primary">
                            <span class="material-symbols-outlined text-[20px] font-bold">check_circle</span>
                        </div>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-rose-500 text-xs mt-1 block"></span>
                </div>
                
                <!-- Terms -->
                <div class="flex items-start gap-3 px-1 py-1">
                    <input type="checkbox" id="terms" required class="mt-1 size-4 rounded border-slate-300 text-primary focus:ring-primary" />
                    <label for="terms" class="text-sm text-slate-600 dark:text-slate-400 leading-snug">
                        I agree to the <a href="#" class="text-primary font-medium">Terms of Service</a> and <a href="#" class="text-primary font-medium">Privacy Policy</a>.
                    </label>
                </div>
                
                <!-- Action Button -->
                <button type="submit" class="w-full py-4 bg-primary hover:bg-primary/90 text-white font-bold rounded-xl transition-all shadow-lg shadow-primary/25 flex items-center justify-center gap-2 group">
                    <span>Create Account</span>
                    <span class="material-symbols-outlined text-[20px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
                </button>
                
            </form>
            
            <!-- Social Login Divider -->
            <div class="relative py-4">
                <div class="absolute inset-0 flex items-center">
                    <div class="w-full border-t border-slate-200 dark:border-slate-800"></div>
                </div>
                <div class="relative flex justify-center text-sm">
                    <span class="px-4 bg-white dark:bg-background-dark text-slate-500 uppercase tracking-widest text-[10px] font-bold">Or continue with</span>
                </div>
            </div>
            
            <form asp-area="Identity" asp-controller="ExternalLogin" asp-action="ExternalLogin" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                <div class="grid grid-cols-1 gap-4">
                    <button type="submit" name="provider" value="Google" class="flex items-center justify-center gap-3 px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                        <svg class="size-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                        </svg>
                        <span class="text-sm font-semibold text-slate-700 dark:text-slate-300">Google</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/intl-tel-input@28.0.4/build/js/intlTelInput.min.js"></script>
    <script src="~/js/phone-input.js" asp-append-version="true"></script>
}
