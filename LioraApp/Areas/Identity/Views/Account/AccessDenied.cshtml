@{
    ViewData["Title"] = "Access Denied";
}

<section class="min-h-[70vh] flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-xl rounded-3xl border border-slate-200 bg-white p-8 text-center shadow-sm">
        <div class="mx-auto mb-5 grid h-16 w-16 place-items-center rounded-full bg-rose-100 text-rose-600">
            <span class="material-symbols-outlined text-3xl">lock</span>
        </div>
        <h1 class="text-2xl font-bold text-slate-900">Access Denied</h1>
        <p class="mt-3 text-sm leading-6 text-slate-600">
            You do not have permission to access this page with the current account.
        </p>

        @if (!string.IsNullOrWhiteSpace(Context.Request.Query["ReturnUrl"]))
        {
            <p class="mt-3 rounded-xl bg-slate-50 px-4 py-3 text-xs text-slate-500">
                Requested URL: @Context.Request.Query["ReturnUrl"]
            </p>
        }

        <div class="mt-6 flex flex-col justify-center gap-3 sm:flex-row">
            <a asp-area="Customer" asp-controller="Home" asp-action="Index"
               class="inline-flex items-center justify-center rounded-lg bg-primary px-5 py-3 font-semibold text-white">
                Go to Store
            </a>
            @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
            {
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
                   class="inline-flex items-center justify-center rounded-lg border border-slate-300 px-5 py-3 font-semibold text-slate-700">
                    Back to Dashboard
                </a>
            }
            else
            {
                <a asp-area="Identity" asp-controller="Account" asp-action="Login"
                   class="inline-flex items-center justify-center rounded-lg border border-slate-300 px-5 py-3 font-semibold text-slate-700">
                    Login
                </a>
            }
        </div>
    </div>
</section>
