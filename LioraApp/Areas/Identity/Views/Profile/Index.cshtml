@model LioraApp.ViewModels.Identity.ProfileVM
@{ Layout = "/Areas/Customer/Views/Shared/_CustomerLayout.cshtml"; ViewData["Title"] = "Profile"; }
<main class="min-h-screen bg-[#f9f6f1] px-4 md:px-8 py-10">
    <div class="max-w-7xl mx-auto">
        <!-- Alerts -->
        @if (TempData["success"] != null)
        {
            <div class="max-w-xl mx-auto mb-6 bg-white border border-gray-100 rounded-2xl shadow-sm p-4 text-sm text-green-800">
                @TempData["success"]
            </div>
        }
        @if (TempData["error"] != null)
        {
            <div class="max-w-xl mx-auto mb-6 bg-white border border-gray-100 rounded-2xl shadow-sm p-4 text-sm text-red-700">
                @TempData["error"]
            </div>
        }

        <!-- Header -->
        <section class="mb-6 flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
            <div class="flex items-center gap-4">
                <div class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-black text-white flex items-center justify-center text-lg md:text-2xl font-semibold">@((Model.FullName ?? "").Split(' ').FirstOrDefault() ?? "U")</div>
                <div>
                    <h1 class="text-xl md:text-2xl font-semibold text-gray-900">@Model.FullName</h1>
                    <p class="text-sm text-gray-700">@Model.Email</p>
                    <p class="text-sm text-gray-500">Member since @Model.RecentOrders.FirstOrDefault()?.CreatedAt.ToString("yyyy")</p>
                </div>
            </div>
            <div class="flex items-center gap-3">
                <a asp-area="Identity" asp-controller="Profile" asp-action="ChangePassword" class="bg-black text-white rounded-lg px-6 py-2.5 text-sm font-medium hover:bg-gray-800 transition">Change Password</a>
                <a asp-area="Identity" asp-controller="Profile" asp-action="Addresses" class="border border-gray-200 text-gray-700 rounded-lg px-6 py-2.5 text-sm font-medium hover:bg-gray-50">Manage Addresses</a>
            </div>
        </section>

        <!-- Quick Links -->
        <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
            <a href="@Url.Action("Index", "Orders", new { area = "Customer" })" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <span class="material-symbols-outlined text-2xl text-gray-700">shopping_bag</span>
                    <div>
                        <div class="text-sm font-medium text-gray-900">Orders</div>
                        <div class="text-xs text-gray-500">View your order history</div>
                    </div>
                </div>
                <span class="material-symbols-outlined text-gray-400">chevron_right</span>
            </a>
            <a href="@Url.Action("ChangePassword", "Profile", new { area = "Identity" })" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <span class="material-symbols-outlined text-2xl text-gray-700">lock</span>
                    <div>
                        <div class="text-sm font-medium text-gray-900">Security</div>
                        <div class="text-xs text-gray-500">Change your password</div>
                    </div>
                </div>
                <span class="material-symbols-outlined text-gray-400">chevron_right</span>
            </a>
            <a href="@Url.Action("Addresses", "Profile", new { area = "Identity" })" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <span class="material-symbols-outlined text-2xl text-gray-700">location_on</span>
                    <div>
                        <div class="text-sm font-medium text-gray-900">Addresses</div>
                        <div class="text-xs text-gray-500">Manage saved addresses</div>
                    </div>
                </div>
                <span class="material-symbols-outlined text-gray-400">chevron_right</span>
            </a>
        </section>

        <!-- Stats & Recent Orders -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <div class="lg:col-span-2 space-y-4">
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-10">
                    <h2 class="text-xl font-semibold text-gray-900 mb-6">Recent Orders</h2>
                    @if (!Model.RecentOrders.Any())
                    {
                        <div class="text-center text-gray-500 py-8">No recent orders found.</div>
                    }
                    else
                    {
                        <ul class="space-y-3">
                            @foreach (var order in Model.RecentOrders)
                            {
                                <li class="flex items-center justify-between bg-white border border-gray-100 rounded-lg p-4">
                                    <div>
                                        <div class="text-sm text-gray-700">ORDER #@order.Id</div>
                                        <div class="text-sm text-gray-500">Placed on @order.CreatedAt.ToString("MMM dd, yyyy")</div>
                                    </div>
                                    <div class="text-sm font-medium text-gray-900">@order.Status</div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
            <aside class="space-y-4">
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 text-sm">
                    <div class="text-sm text-gray-700">Total Orders</div>
                    <div class="text-xl font-semibold text-gray-900">@Model.TotalOrders</div>
                </div>
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 text-sm">
                    <div class="text-sm text-gray-700">Total Spent</div>
                    <div class="text-xl font-semibold text-gray-900">EGP @Model.TotalSpent.ToString("N0")</div>
                </div>
            </aside>
        </div>
    </div>
</main>
