@model LioraApp.ViewModels.Identity.ProfileVM
@{
    ViewData["Title"] = "Personal Information";
    Layout = "_ProfileLayout";
}

<div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200/60 dark:border-slate-800 p-8">
    <!-- Header Section -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-10 gap-2">
        <h1 class="text-lg font-bold text-slate-800 dark:text-white">Personal Information</h1>
        <span class="text-xs font-medium text-slate-400">Manage your profile details</span>
    </div>

    <!-- Profile Form -->
    <form asp-action="Index" method="post" enctype="multipart/form-data" class="space-y-8">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-rose-500 text-sm font-semibold mb-4"></div>
        <input asp-for="ProfileImage" id="profileImageInput" accept="image/jpeg,image/png,image/webp" class="hidden" />
        <input asp-for="CroppedProfileImageDataUrl" id="croppedProfileImageDataUrl" class="hidden" />

        <div class="grid grid-cols-1 gap-8 lg:grid-cols-[260px,1fr]">
            <div class="rounded-[18px] border border-slate-200/80 bg-slate-50/70 p-6 dark:border-slate-700 dark:bg-slate-800/40">
                <div class="flex flex-col items-center text-center">
                    <div class="relative mb-5">
                        <div class="flex h-36 w-36 items-center justify-center overflow-hidden rounded-full bg-slate-100 ring-4 ring-white shadow-sm dark:bg-slate-800 dark:ring-slate-700">
                            @if (!string.IsNullOrWhiteSpace(Model.ProfileImageUrl))
                            {
                                <img id="profileAvatarPreview" src="@Model.ProfileImageUrl" alt="@Model.FullName" class="h-full w-full object-cover" />
                                <span id="profileAvatarFallback" class="hidden material-symbols-outlined text-[60px] text-primary/80">person</span>
                            }
                            else
                            {
                                <img id="profileAvatarPreview" src="" alt="@Model.FullName" class="hidden h-full w-full object-cover" />
                                <span id="profileAvatarFallback" class="material-symbols-outlined text-[60px] text-primary/80">person</span>
                            }
                        </div>
                        <button id="changePhotoButton" type="button" class="absolute bottom-2 right-2 flex size-10 items-center justify-center rounded-full bg-primary text-white shadow-lg shadow-primary/30 transition hover:bg-primary/90">
                            <span class="material-symbols-outlined text-[20px]">photo_camera</span>
                        </button>
                    </div>

                    <h2 class="text-base font-bold text-slate-800 dark:text-white">Profile Photo</h2>
                    <p class="mt-2 text-sm leading-6 text-slate-500 dark:text-slate-400">
                        Upload a square photo, then drag and zoom to choose exactly which part appears.
                    </p>

                    <div class="mt-5 flex w-full flex-col gap-3">
                        <button id="uploadPhotoButton" type="button" class="inline-flex items-center justify-center gap-2 rounded-[18px] bg-primary px-4 py-3 text-sm font-semibold text-white transition hover:bg-primary/90">
                            <span class="material-symbols-outlined text-[18px]">upload</span>
                            Upload New Photo
                        </button>
                        <p class="text-xs text-slate-400">JPG, PNG or WebP. Max size 5 MB.</p>
                        <span asp-validation-for="ProfileImage" class="text-rose-500 text-xs mt-1 block"></span>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Full Name -->
                <div class="space-y-2">
                    <label asp-for="FullName" class="text-[13px] font-semibold text-slate-700 dark:text-slate-300 ml-1"></label>
                    <input asp-for="FullName" class="w-full h-11 px-4 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none" />
                    <span asp-validation-for="FullName" class="text-rose-500 text-xs mt-1 block"></span>
                </div>

                <!-- Email -->
                <div class="space-y-2">
                    <div class="flex items-center justify-between gap-3">
                        <label asp-for="Email" class="text-[13px] font-semibold text-slate-700 dark:text-slate-300 ml-1"></label>
                        <a asp-action="ChangeEmail" class="text-primary text-xs font-semibold hover:underline ml-2">Change Email</a>
                    </div>
                    <input asp-for="Email" readonly disabled class="w-full h-11 px-4 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50 text-slate-500 text-sm cursor-default outline-none" />
                </div>

                <!-- Phone -->
                <div class="space-y-2">
                    <label asp-for="PhoneNumber" class="text-[13px] font-semibold text-slate-700 dark:text-slate-300 ml-1"></label>
                    <input asp-for="PhoneCountryIso2" type="hidden" class="js-phone-country" />
                    <input asp-for="PhoneNumber"
                           type="tel"
                           autocomplete="tel"
                           inputmode="tel"
                           class="js-phone-input smart-phone-input w-full h-11 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none"
                           data-phone-required="false"
                           data-phone-error-invalid="Please enter a valid phone number for the selected country."
                           placeholder="+20 10 1234 5678" />
                    <span asp-validation-for="PhoneNumber" class="text-rose-500 text-xs mt-1 block"></span>
                </div>
            </div>
        </div>

        <!-- Form Footer Buttons -->
        <div class="pt-8 flex justify-end items-center gap-4 border-t border-slate-100 dark:border-slate-800 mt-6">
            <button type="submit" class="px-8 py-2.5 bg-primary text-white text-sm font-bold rounded-lg shadow-sm shadow-primary/30 hover:bg-primary/90 transition-all">
                Save Changes
            </button>
        </div>
    </form>
</div>

<div id="profileCropperModal" class="fixed inset-0 z-[80] hidden items-center justify-center bg-slate-950/70 px-4 py-6">
    <div class="w-full max-w-5xl rounded-[22px] bg-white p-5 shadow-2xl dark:bg-slate-900 md:p-6">
        <div class="mb-5 flex items-start justify-between gap-4">
            <div>
                <h3 class="text-lg font-bold text-slate-800 dark:text-white">Adjust Profile Photo</h3>
                <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Move and zoom the image to choose the exact part that will be shown.</p>
            </div>
            <button id="closeCropperModalButton" type="button" class="flex size-10 items-center justify-center rounded-full bg-slate-100 text-slate-500 transition hover:bg-slate-200 dark:bg-slate-800 dark:text-slate-300">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <div class="grid gap-6 lg:grid-cols-[1fr,240px]">
            <div class="overflow-hidden rounded-[22px] bg-slate-100 dark:bg-slate-800">
                <img id="profileCropperImage" src="" alt="Crop profile image" class="max-h-[65vh] w-full object-contain" />
            </div>

            <div class="flex flex-col gap-4">
                <div class="rounded-[22px] border border-slate-200 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-800/60">
                    <p class="text-sm font-semibold text-slate-700 dark:text-slate-200">Live Preview</p>
                    <div class="mt-4 flex justify-center">
                        <div class="profile-crop-preview h-36 w-36 overflow-hidden rounded-full border-4 border-white bg-slate-200 shadow-sm dark:border-slate-700 dark:bg-slate-700"></div>
                    </div>
                </div>

                <div class="rounded-[22px] border border-slate-200 bg-slate-50 p-4 text-sm leading-6 text-slate-500 dark:border-slate-700 dark:bg-slate-800/60 dark:text-slate-400">
                    Tip: drag the image to reposition it, then use your mouse wheel or trackpad to zoom in and out.
                </div>
            </div>
        </div>

        <div class="mt-6 flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
            <button id="cancelCropButton" type="button" class="rounded-[18px] border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-600 transition hover:bg-slate-50 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-800">
                Cancel
            </button>
            <button id="applyCropButton" type="button" class="rounded-[18px] bg-primary px-5 py-3 text-sm font-semibold text-white transition hover:bg-primary/90">
                Use This Photo
            </button>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@28.0.4/build/css/intlTelInput.css" />
    <style>
        .iti {
            width: 100%;
        }

        .iti input.smart-phone-input {
            padding-left: 3.75rem !important;
        }

        .field-validation-error {
            color: #f43f5e;
            display: block;
            font-size: 0.75rem;
            font-weight: 500;
            margin-top: 0.25rem;
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/intl-tel-input@28.0.4/build/js/intlTelInput.min.js"></script>
    <script src="~/js/phone-input.js" asp-append-version="true"></script>
    <script>
        (function () {
            const fileInput = document.getElementById('profileImageInput');
            const uploadButton = document.getElementById('uploadPhotoButton');
            const changeButton = document.getElementById('changePhotoButton');
            const modal = document.getElementById('profileCropperModal');
            const cropImage = document.getElementById('profileCropperImage');
            const croppedImageDataInput = document.getElementById('croppedProfileImageDataUrl');
            const cancelButton = document.getElementById('cancelCropButton');
            const closeButton = document.getElementById('closeCropperModalButton');
            const applyButton = document.getElementById('applyCropButton');
            const mainAvatar = document.getElementById('profileAvatarPreview');
            const mainFallback = document.getElementById('profileAvatarFallback');
            const sidebarAvatar = document.getElementById('profileSidebarAvatarImage');
            const sidebarFallback = document.getElementById('profileSidebarAvatarFallback');

            if (!fileInput || !uploadButton || !modal || !cropImage || !applyButton || !croppedImageDataInput) {
                return;
            }

            let cropper = null;
            let sourceFile = null;

            const openPicker = function () {
                fileInput.click();
            };

            const openModal = function () {
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                document.body.classList.add('overflow-hidden');
            };

            const closeModal = function (resetImage) {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
                document.body.classList.remove('overflow-hidden');

                if (cropper) {
                    cropper.destroy();
                    cropper = null;
                }

                if (resetImage) {
                    cropImage.src = '';
                }
            };

            const setPreview = function (imageUrl) {
                if (mainAvatar) {
                    mainAvatar.src = imageUrl;
                    mainAvatar.classList.remove('hidden');
                }

                if (mainFallback) {
                    mainFallback.classList.add('hidden');
                }

                if (sidebarAvatar) {
                    sidebarAvatar.src = imageUrl;
                } else if (mainAvatar) {
                    const sidebarContainer = document.getElementById('profileSidebarAvatarContainer');
                    if (sidebarContainer) {
                        const img = document.createElement('img');
                        img.id = 'profileSidebarAvatarImage';
                        img.src = imageUrl;
                        img.alt = 'Profile Photo';
                        img.className = 'h-full w-full object-cover';
                        sidebarContainer.innerHTML = '';
                        sidebarContainer.appendChild(img);
                    }
                }

                if (sidebarFallback) {
                    sidebarFallback.classList.add('hidden');
                }
            };

            const initializeCropper = function (dataUrl) {
                cropImage.src = dataUrl;
                openModal();

                cropImage.onload = function () {
                    if (cropper) {
                        cropper.destroy();
                    }

                    cropper = new Cropper(cropImage, {
                        aspectRatio: 1,
                        viewMode: 1,
                        dragMode: 'move',
                        background: false,
                        autoCropArea: 1,
                        responsive: true,
                        preview: '.profile-crop-preview'
                    });
                };
            };

            uploadButton.addEventListener('click', openPicker);
            if (changeButton) {
                changeButton.addEventListener('click', openPicker);
            }

            fileInput.addEventListener('click', function () {
                fileInput.value = '';
            });

            fileInput.addEventListener('change', function (event) {
                const file = event.target.files && event.target.files[0];
                if (!file) {
                    return;
                }

                sourceFile = file;
                const reader = new FileReader();
                reader.onload = function (loadEvent) {
                    initializeCropper(loadEvent.target.result);
                };
                reader.readAsDataURL(file);
            });

            const stopCropping = function () {
                closeModal(true);
            };

            cancelButton.addEventListener('click', stopCropping);
            closeButton.addEventListener('click', stopCropping);

            applyButton.addEventListener('click', function () {
                if (!cropper || !sourceFile) {
                    return;
                }

                const canvas = cropper.getCroppedCanvas({
                    width: 700,
                    height: 700,
                    imageSmoothingEnabled: true,
                    imageSmoothingQuality: 'high'
                });

                canvas.toBlob(function (blob) {
                    if (!blob) {
                        return;
                    }

                    const previewUrl = URL.createObjectURL(blob);
                    croppedImageDataInput.value = canvas.toDataURL('image/jpeg', 0.92);
                    setPreview(previewUrl);
                    closeModal(true);
                }, 'image/jpeg', 0.92);
            });

            modal.addEventListener('click', function (event) {
                if (event.target === modal) {
                    stopCropping();
                }
            });
        })();
    </script>
}
