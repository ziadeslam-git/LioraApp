                <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors hover:translate-x-1 transition-transform duration-200" href="#">Privacy</a>
                <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors hover:translate-x-1 transition-transform duration-200" href="#">Refunds</a>
                <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors hover:translate-x-1 transition-transform duration-200" href="#">Size Guide</a>
                <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors hover:translate-x-1 transition-transform duration-200" href="#">FAQ</a>
                <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors hover:translate-x-1 transition-transform duration-200" href="#">Track Order</a>
            </div>
        </div>
    </footer>
