@model LioraApp.ViewModels.Identity.ChangePasswordVM
@{
    Layout = "/Areas/Customer/Views/Shared/_CustomerLayout.cshtml"; ViewData["Title"] = "Change Password";
}

<a asp-area="Identity" asp-controller="Profile" asp-action="Index" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-black mb-6">← Back to Profile</a>

<main class="min-h-screen bg-[#f9f6f1] px-4 md:px-8 py-10">
    <div class="max-w-xl mx-auto">
        @if (TempData["success"] != null)
        {
            <div class="mb-4 bg-white border border-gray-100 rounded-2xl shadow-sm p-4 text-sm text-green-800">@TempData["success"]</div>
        }
        @if (TempData["error"] != null)
        {
            <div class="mb-4 bg-white border border-gray-100 rounded-2xl shadow-sm p-4 text-sm text-red-700">@TempData["error"]</div>
        }

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-10">
            <h2 class="text-xl font-semibold text-gray-900 mb-6">Change Password</h2>
            <form method="post" asp-area="Identity" asp-controller="Profile" asp-action="ChangePassword" class="space-y-4">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm mb-4"></div>
                <div>
                    <label class="text-sm font-medium text-gray-700 mb-1 block" asp-for="CurrentPassword"></label>
                    <div class="relative">
                        <input asp-for="CurrentPassword" type="password" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-black" />
                        <button type="button" onclick="togglePwd('CurrentPassword', this)" class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-500">
                            <span class="material-symbols-outlined">visibility</span>
                        </button>
                    </div>
                    <span class="text-sm text-red-600" data-valmsg-for="CurrentPassword" data-valmsg-replace="true"></span>
                </div>

                <div>
                    <label class="text-sm font-medium text-gray-700 mb-1 block" asp-for="NewPassword"></label>
                    <div class="relative">
                        <input asp-for="NewPassword" type="password" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-black" />
                        <button type="button" onclick="togglePwd('NewPassword', this)" class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-500">
                            <span class="material-symbols-outlined">visibility</span>
                        </button>
                    </div>
                    <span class="text-sm text-red-600" data-valmsg-for="NewPassword" data-valmsg-replace="true"></span>
                </div>

                <div>
                    <label class="text-sm font-medium text-gray-700 mb-1 block" asp-for="ConfirmNewPassword"></label>
                    <div class="relative">
                        <input asp-for="ConfirmNewPassword" type="password" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-black" />
                        <button type="button" onclick="togglePwd('ConfirmNewPassword', this)" class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-500">
                            <span class="material-symbols-outlined">visibility</span>
                        </button>
                    </div>
                    <span class="text-sm text-red-600" data-valmsg-for="ConfirmNewPassword" data-valmsg-replace="true"></span>
                </div>

                <div class="pt-4">
                    <button type="submit" class="bg-black text-white rounded-lg px-6 py-2.5 text-sm font-medium hover:bg-gray-800 transition">Update Password</button>
                </div>
            </form>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        function togglePwd(id, btn){
            var el = document.getElementById(id);
            if(!el) return;
            if(el.type === 'password') el.type = 'text'; else el.type = 'password';
        }
    </script>
}
