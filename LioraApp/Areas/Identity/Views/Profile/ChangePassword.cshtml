                <a class="text-on-surface-variant hover:text-primary transition-colors duration-300 hover:scale-105 transition-transform duration-200" href="#">CONTACT</a>
            </div>
            <!-- Brand Logo -->
            <div class="font-accent-italic text-headline-md italic text-primary dark:text-primary-fixed absolute left-1/2 -translate-x-1/2">
                liora
            </div>
            <!-- Trailing Icons -->
            <div class="flex items-center gap-4 text-primary dark:text-primary-fixed">
                <button class="hover:scale-105 transition-transform duration-200">
                    <span class="material-symbols-outlined" data-icon="search">search</span>
                </button>
                <button class="text-primary dark:text-primary-fixed border-b-2 border-primary hover:scale-105 transition-transform duration-200 pb-1">
                    <span class="material-symbols-outlined" data-icon="person">person</span>
                </button>
                <button class="hover:scale-105 transition-transform duration-200">
                    <span class="material-symbols-outlined" data-icon="shopping_bag">shopping_bag</span>
                </button>
            </div>
        </div>
    </nav>
    <!-- Main Canvas: Profile Layout -->
    <main class="flex-grow w-full max-w-[1280px] mx-auto px-container-padding-mobile md:px-container-padding-desktop py-stack-lg md:py-section-gap flex flex-col md:flex-row gap-gutter">
        <!-- SideNav / Profile Menu -->
        <aside class="hidden md:block w-64 shrink-0">
            <h2 class="font-headline-md text-headline-md text-on-surface mb-stack-lg">My Account</h2>
            <nav class="flex flex-col gap-unit">
                <a class="font-label-caps text-label-caps py-2 text-on-surface-variant hover:text-primary transition-colors" href="#">PROFILE</a>
                <a class="font-label-caps text-label-caps py-2 text-primary border-b border-primary w-fit inline-block mb-2" href="#">SECURITY &amp; PASSWORD</a>
                <a class="font-label-caps text-label-caps py-2 text-on-surface-variant hover:text-primary transition-colors" href="#">ORDER HISTORY</a>
                <a class="font-label-caps text-label-caps py-2 text-on-surface-variant hover:text-primary transition-colors" href="#">ADDRESSES</a>
                <a class="font-label-caps text-label-caps py-2 text-on-surface-variant hover:text-primary transition-colors mt-stack-md text-error" href="#">LOG OUT</a>
            </nav>
        </aside>
        <!-- Mobile Profile Menu Dropdown (Simplified representation) -->
        <div class="md:hidden mb-stack-lg">
            <select class="w-full input-elegant font-label-caps text-label-caps p-3 rounded-DEFAULT text-primary">
                <option>SECURITY &amp; PASSWORD</option>
                <option>PROFILE</option>
                <option>ORDER HISTORY</option>
            </select>
        </div>
        <!-- Content Area: Change Password Form -->
        <section class="flex-grow flex justify-center">
            <div class="w-full max-w-[500px] bg-surface-container-lowest rounded-[16px] p-stack-lg md:p-[48px] ambient-shadow-1">
                <div class="text-center mb-stack-lg">
                    <h1 class="font-headline-md text-headline-md text-on-surface mb-unit">Change Password</h1>
                    <p class="font-body-md text-body-md text-on-surface-variant">Update your security credentials below.</p>
                </div>
                <form class="flex flex-col gap-stack-md" onsubmit="event.preventDefault();">
                    <!-- Current Password -->
                    <div class="flex flex-col gap-2">
                        <label class="font-label-caps text-label-caps text-on-surface-variant" for="current_password">CURRENT PASSWORD</label>
                        <input class="input-elegant rounded-DEFAULT p-3 font-body-md text-body-md w-full" id="current_password" placeholder="Enter current password" type="password" />
                    </div>
                    <!-- New Password -->
                    <div class="flex flex-col gap-2">
                        <label class="font-label-caps text-label-caps text-on-surface-variant" for="new_password">NEW PASSWORD</label>
                        <input class="input-elegant rounded-DEFAULT p-3 font-body-md text-body-md w-full" id="new_password" placeholder="Enter new password" type="password" />
                        <!-- Strength Indicator -->
                        <div class="flex gap-1 mt-1">
                            <div class="h-2 flex-1 rounded-full bg-primary-container"></div>
                            <div class="h-2 flex-1 rounded-full bg-primary-container"></div>
                            <div class="h-2 flex-1 rounded-full bg-surface-variant"></div>
                            <div class="h-2 flex-1 rounded-full bg-surface-variant"></div>
                        </div>
                        <p class="font-label-caps text-[10px] text-on-surface-variant text-right">FAIR</p>
                    </div>
                    <!-- Confirm New Password -->
                    <div class="flex flex-col gap-2">
                        <label class="font-label-caps text-label-caps text-on-surface-variant" for="confirm_password">CONFIRM NEW PASSWORD</label>
                        <input class="input-elegant rounded-DEFAULT p-3 font-body-md text-body-md w-full" id="confirm_password" placeholder="Re-enter new password" type="password" />
                    </div>
                    <!-- Info Callout -->
                    <div class="bg-surface p-4 rounded-lg border border-outline-variant/30 flex items-start gap-3 mt-stack-sm">
                        <span class="material-symbols-outlined text-primary-container mt-0.5" data-icon="info">info</span>
                        <p class="font-body-md text-body-md text-on-surface-variant text-sm">
                            You'll receive a confirmation link at your new email address.
                        </p>
                    </div>
                    <!-- Action -->
                    <button class="btn-primary w-full py-4 rounded-full font-label-caps text-label-caps mt-stack-md tracking-wider" type="submit">
                        UPDATE PASSWORD
                    </button>
                </form>
            </div>
        </section>
    </main>
    <!-- Footer -->
    <footer class="bg-surface-container-high dark:bg-surface-container-high rounded-t-[32px] mt-auto border-t border-outline-variant/10 shadow-[0_-8px_24px_rgba(196,144,128,0.08)]">
