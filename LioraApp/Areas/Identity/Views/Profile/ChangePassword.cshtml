@model LioraApp.ViewModels.Identity.ChangePasswordVM
@inject Microsoft.Extensions.Options.IOptions<Microsoft.AspNetCore.Identity.IdentityOptions> IdentityOptionsAccessor
@{
    ViewData["Title"] = "Change Password";
    Layout = "_ProfileLayout";
    var passwordOptions = IdentityOptionsAccessor.Value.Password;
    var requiredLength = passwordOptions.RequiredLength;
    var requireUppercase = passwordOptions.RequireUppercase;
    var requireLowercase = passwordOptions.RequireLowercase;
    var requireDigit = passwordOptions.RequireDigit;
    var requireSpecial = passwordOptions.RequireNonAlphanumeric;
}

<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl overflow-hidden shadow-sm">
    <div class="p-6 md:p-8 border-b border-slate-100 dark:border-slate-800">
        <h1 class="text-slate-900 dark:text-white text-2xl font-bold leading-tight">Change Password</h1>
        <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Please enter your current password to change your settings.</p>
    </div>
    
    <div class="p-6 md:p-8 flex flex-col gap-8">
        <form asp-action="ChangePassword" method="post">
            <div asp-validation-summary="ModelOnly" class="text-rose-500 text-sm font-semibold mb-4"></div>

            <!-- Current Password Field -->
            <div class="max-w-md mb-8">
                <label class="flex flex-col gap-2">
                    <span class="text-slate-700 dark:text-slate-300 text-sm font-semibold">Current Password</span>
                    <div class="relative">
                        <input asp-for="CurrentPassword" type="password" id="CurrentPassword" class="w-full rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-primary focus:border-primary py-3 px-4 transition-all" placeholder="••••••••••••" />
                        <button type="button" onclick="const p = document.getElementById('CurrentPassword'); p.type = p.type === 'password' ? 'text' : 'password';" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                            <span class="material-symbols-outlined text-[20px]">visibility</span>
                        </button>
                    </div>
                </label>
                <span asp-validation-for="CurrentPassword" class="text-rose-500 text-xs mt-1 block"></span>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
                <!-- New Password Fields -->
                <div class="flex flex-col gap-6">
                    <div class="flex flex-col gap-2">
                        <label asp-for="NewPassword" class="text-slate-700 dark:text-slate-300 text-sm font-semibold"></label>
                        <div class="relative">
                            <input asp-for="NewPassword" id="NewPassword" class="w-full rounded-lg border-primary bg-primary/5 text-slate-900 dark:text-white focus:ring-primary focus:border-primary py-3 px-4 transition-all" placeholder="••••••••••••" autocomplete="new-password" />
                            <button type="button" data-password-toggle="NewPassword" class="absolute right-3 top-1/2 -translate-y-1/2 text-primary">
                                <span class="material-symbols-outlined text-[20px]">visibility_off</span>
                            </button>
                        </div>
                        <span asp-validation-for="NewPassword" class="text-rose-500 text-xs mt-1 block"></span>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label asp-for="ConfirmNewPassword" class="text-slate-700 dark:text-slate-300 text-sm font-semibold"></label>
                        <div class="relative">
                            <input asp-for="ConfirmNewPassword" id="ConfirmNewPassword" class="w-full rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-primary focus:border-primary py-3 px-4 transition-all" placeholder="••••••••••••" autocomplete="new-password" />
                            <button type="button" data-password-toggle="ConfirmNewPassword" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                                <span class="material-symbols-outlined text-[20px]">visibility_off</span>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmNewPassword" class="text-rose-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <!-- Password Requirements Checklist -->
                <div class="bg-slate-50 dark:bg-slate-800/50 p-5 rounded-xl border border-slate-100 dark:border-slate-800 self-start">
                    <h4 class="text-slate-900 dark:text-white text-sm font-bold mb-4">Password Requirements</h4>
                    <ul class="flex flex-col gap-3" id="passwordRequirements">
                        <li data-rule="length" class="flex items-center gap-3 rounded-lg bg-primary/5 p-2 text-slate-500 dark:text-slate-400">
                            <span class="material-symbols-outlined text-[18px]">radio_button_unchecked</span>
                            <span class="text-xs font-medium">Minimum @requiredLength characters long</span>
                        </li>
                        @if (requireUppercase || requireLowercase)
                        {
                            <li data-rule="letterCase" class="flex items-center gap-3 rounded-lg bg-primary/5 p-2 text-slate-500 dark:text-slate-400">
                                <span class="material-symbols-outlined text-[18px]">radio_button_unchecked</span>
                                <span class="text-xs font-medium">
                                    @(requireUppercase && requireLowercase
                                        ? "At least one uppercase and one lowercase letter"
                                        : requireUppercase
                                            ? "At least one uppercase letter"
                                            : "At least one lowercase letter")
                                </span>
                            </li>
                        }
                        @if (requireDigit)
                        {
                            <li data-rule="digit" class="flex items-center gap-3 rounded-lg bg-primary/5 p-2 text-slate-500 dark:text-slate-400">
                                <span class="material-symbols-outlined text-[18px]">radio_button_unchecked</span>
                                <span class="text-xs font-medium">At least one number</span>
                            </li>
                        }
                        @if (requireSpecial)
                        {
                            <li data-rule="special" class="flex items-center gap-3 rounded-lg bg-primary/5 p-2 text-slate-500 dark:text-slate-400">
                                <span class="material-symbols-outlined text-[18px]">radio_button_unchecked</span>
                                <span class="text-xs font-medium">At least one special character (!@@#$%^&*)</span>
                            </li>
                        }
                        <li data-rule="match" class="flex items-center gap-3 rounded-lg bg-primary/5 p-2 text-slate-500 dark:text-slate-400">
                            <span class="material-symbols-outlined text-[18px]">radio_button_unchecked</span>
                            <span class="text-xs font-medium">Confirm password must match the new password</span>
                        </li>
                    </ul>
                    <p id="passwordHelperText" class="mt-4 text-xs text-slate-500 dark:text-slate-400">
                        Start typing your new password and we will tell you what is complete and what is still missing.
                    </p>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="flex flex-col sm:flex-row gap-3 pt-6 mt-6 border-t border-slate-100 dark:border-slate-800">
                <button type="submit" class="flex-1 sm:flex-none px-8 py-3 bg-primary hover:bg-primary/90 text-white rounded-lg font-bold text-sm transition-all shadow-md shadow-primary/20">
                    Update Password
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const newPasswordInput = document.getElementById('NewPassword');
            const confirmPasswordInput = document.getElementById('ConfirmNewPassword');
            const helperText = document.getElementById('passwordHelperText');
            const requirements = document.getElementById('passwordRequirements');

            if (!newPasswordInput || !confirmPasswordInput || !requirements) {
                return;
            }

            const rules = {
                length: {
                    enabled: true,
                    test: (value) => value.length >= @requiredLength
                },
                letterCase: {
                    enabled: @requireUppercase.ToString().ToLowerInvariant() || @requireLowercase.ToString().ToLowerInvariant(),
                    test: (value) => {
                        const hasUpper = /[A-Z]/.test(value);
                        const hasLower = /[a-z]/.test(value);
                        return (!@requireUppercase.ToString().ToLowerInvariant() || hasUpper)
                            && (!@requireLowercase.ToString().ToLowerInvariant() || hasLower);
                    }
                },
                digit: {
                    enabled: @requireDigit.ToString().ToLowerInvariant(),
                    test: (value) => /\d/.test(value)
                },
                special: {
                    enabled: @requireSpecial.ToString().ToLowerInvariant(),
                    test: (value) => /[^A-Za-z0-9]/.test(value)
                },
                match: {
                    enabled: true,
                    test: (value) => confirmPasswordInput.value.length > 0 && confirmPasswordInput.value === value
                }
            };

            function setRequirementState(element, state) {
                const icon = element.querySelector('.material-symbols-outlined');
                element.classList.remove(
                    'bg-primary/5', 'text-slate-500', 'dark:text-slate-400',
                    'bg-emerald-100/50', 'dark:bg-emerald-900/20', 'text-emerald-700', 'dark:text-emerald-400',
                    'bg-rose-100/70', 'dark:bg-rose-900/20', 'text-rose-700', 'dark:text-rose-400'
                );

                if (state === 'pass') {
                    icon.textContent = 'check_circle';
                    element.classList.add('bg-emerald-100/50', 'dark:bg-emerald-900/20', 'text-emerald-700', 'dark:text-emerald-400');
                    return;
                }

                if (state === 'fail') {
                    icon.textContent = 'cancel';
                    element.classList.add('bg-rose-100/70', 'dark:bg-rose-900/20', 'text-rose-700', 'dark:text-rose-400');
                    return;
                }

                icon.textContent = 'radio_button_unchecked';
                element.classList.add('bg-primary/5', 'text-slate-500', 'dark:text-slate-400');
            }

            function updatePasswordFeedback() {
                const passwordValue = newPasswordInput.value;
                const confirmValue = confirmPasswordInput.value;
                let passedCount = 0;
                let enabledCount = 0;

                requirements.querySelectorAll('[data-rule]').forEach((element) => {
                    const ruleName = element.getAttribute('data-rule');
                    const rule = rules[ruleName];

                    if (!rule || !rule.enabled) {
                        return;
                    }

                    enabledCount++;

                    if (!passwordValue.length) {
                        setRequirementState(element, 'idle');
                        return;
                    }

                    const passed = rule.test(passwordValue);
                    if (passed) {
                        passedCount++;
                    }

                    if (ruleName === 'match' && !confirmValue.length) {
                        setRequirementState(element, 'idle');
                        return;
                    }

                    setRequirementState(element, passed ? 'pass' : 'fail');
                });

                if (!passwordValue.length) {
                    helperText.textContent = 'Start typing your new password and we will tell you what is complete and what is still missing.';
                    newPasswordInput.classList.remove('border-emerald-500', 'bg-emerald-50/60', 'border-rose-500', 'bg-rose-50/40');
                    return;
                }

                if (passedCount === enabledCount) {
                    helperText.textContent = 'Great. Your new password currently satisfies all required rules.';
                    newPasswordInput.classList.remove('border-rose-500', 'bg-rose-50/40');
                    newPasswordInput.classList.add('border-emerald-500', 'bg-emerald-50/60');
                } else {
                    helperText.textContent = 'Almost there. Keep going until all items turn green.';
                    newPasswordInput.classList.remove('border-emerald-500', 'bg-emerald-50/60');
                    newPasswordInput.classList.add('border-rose-500', 'bg-rose-50/40');
                }
            }

            document.querySelectorAll('[data-password-toggle]').forEach((button) => {
                button.addEventListener('click', function () {
                    const targetId = this.getAttribute('data-password-toggle');
                    const input = document.getElementById(targetId);
                    const icon = this.querySelector('.material-symbols-outlined');

                    if (!input || !icon) {
                        return;
                    }

                    const showPassword = input.type === 'password';
                    input.type = showPassword ? 'text' : 'password';
                    icon.textContent = showPassword ? 'visibility' : 'visibility_off';
                });
            });

            newPasswordInput.addEventListener('input', updatePasswordFeedback);
            confirmPasswordInput.addEventListener('input', updatePasswordFeedback);
            updatePasswordFeedback();
        })();
    </script>
}
