<body class="antialiased min-h-screen flex flex-col">
    <!-- TopNavBar -->
    <nav class="bg-surface/80 backdrop-blur-md dark:bg-surface/80 font-label-caps text-label-caps docked full-width top-0 sticky border-b border-white/5 shadow-sm z-50">
