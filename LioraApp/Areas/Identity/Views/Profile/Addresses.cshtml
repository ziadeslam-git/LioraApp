@model IEnumerable<LioraApp.Models.Address>
@{
    Layout = "/Areas/Customer/Views/Shared/_CustomerLayout.cshtml"; ViewData["Title"] = "My Addresses";
}

<a asp-area="Identity" asp-controller="Profile" asp-action="Index" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-black mb-6">← Back to Profile</a>

<main class="min-h-screen bg-[#f9f6f1] px-4 md:px-8 py-10">
    <div class="max-w-5xl mx-auto">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
            <div>
                <h2 class="text-xl font-semibold text-gray-900 mb-1">My Addresses</h2>
                <p class="text-sm text-gray-700">Manage your shipping addresses for a faster checkout.</p>
            </div>
            <div class="shrink-0 w-full sm:w-auto">
                <a asp-area="Identity" asp-controller="Profile" asp-action="AddAddress" class="w-full sm:w-auto text-center inline-block bg-black text-white rounded-lg px-6 py-2.5 text-sm font-medium hover:bg-gray-800 transition">+ Add New Address</a>
            </div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                @foreach(var item in Model)
                {
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                        <div class="flex justify-between items-start">
                            <div>
                                <div class="text-sm font-medium text-gray-900">@item.FullName</div>
                                <div class="text-sm text-gray-700 mt-2">@Html.Raw(item.Street.Replace("\n", "<br/>"))<br/>@item.City, @item.State, @item.PostalCode</div>
                                <div class="text-sm text-gray-500 mt-3">@item.PhoneNumber</div>
                            </div>
                            <div class="flex flex-col items-end gap-2">
                                <a asp-area="Identity" asp-controller="Profile" asp-action="EditAddress" asp-route-id="@item.Id" class="text-sm text-gray-700 border border-gray-200 rounded-lg px-4 py-2 hover:bg-gray-50">تعديل</a>
                                <form method="post" asp-area="Identity" asp-controller="Profile" asp-action="DeleteAddress" asp-route-id="@item.Id" class="inline" onsubmit="return confirm('Are you sure you want to delete this address?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="text-sm text-red-600 border border-red-200 rounded-lg px-4 py-2 hover:bg-red-50">حذف</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-12">
                <div class="text-4xl text-gray-400 mb-4">📭</div>
                <div class="text-lg text-gray-700 mb-4">لا توجد عناوين محفوظة</div>
                <a asp-area="Identity" asp-controller="Profile" asp-action="AddAddress" class="bg-black text-white rounded-lg px-6 py-2.5 text-sm font-medium hover:bg-gray-800 transition">إضافة عنوان</a>
            </div>
        }



        <!-- Empty state (example) -->
        <!--
        <div class="text-center py-12">
            <div class="text-4xl text-gray-400 mb-4">📭</div>
            <div class="text-lg text-gray-700 mb-4">No addresses saved yet</div>
            <a asp-area="Identity" asp-controller="Profile" asp-action="AddAddress" class="bg-black text-white rounded-lg px-6 py-2.5 text-sm font-medium hover:bg-gray-800 transition">Add Address</a>
        </div>
        -->
    </div>
</main>
