<!DOCTYPE html>

<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Liora - Address Book</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&amp;family=EB+Garamond:ital,wght@0,400..800;1,400..800&amp;family=Playfair+Display:ital,wght@0,400..900;1,400..900&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
        darkMode: "class",
        theme: {
        extend: {
        "colors": {
        "outline": "#83746f",
        "on-tertiary-fixed-variant": "#4b4450",
        "secondary-fixed": "#eedcfa",
        "primary-container": "#c49080",
        "secondary-fixed-dim": "#d1c0de",
        "on-secondary-container": "#6c5f79",
        "tertiary-fixed-dim": "#cec3d2",
        "on-secondary": "#ffffff",
        "on-error-container": "#93000a",
        "surface-variant": "#e8e1db",
        "secondary": "#665972",
        "on-tertiary": "#ffffff",
        "on-primary": "#ffffff",
        "surface": "#fff8f3",
        "primary-fixed": "#ffdbd0",
        "surface-tint": "#7f5446",
        "surface-dim": "#dfd9d3",
        "primary": "#7f5446",
        "on-tertiary-fixed": "#1f1924",
        "surface-container-low": "#f9f2ec",
        "on-primary-fixed": "#311309",
        "tertiary-container": "#a299a7",
        "on-background": "#1e1b18",
        "inverse-primary": "#f2baa8",
        "on-surface": "#1e1b18",
        "on-secondary-fixed": "#21172c",
        "surface-container-highest": "#e8e1db",
        "on-surface-variant": "#514440",
        "on-error": "#ffffff",
        "tertiary": "#635b68",
        "surface-bright": "#fff8f3",
        "secondary-container": "#eedcfa",
        "inverse-surface": "#33302c",
        "outline-variant": "#d5c2bd",
        "error-container": "#ffdad6",
        "surface-container": "#f4ede7",
        "surface-container-lowest": "#ffffff",
        "surface-container-high": "#eee7e1",
        "on-primary-fixed-variant": "#643d30",
        "primary-fixed-dim": "#f2baa8",
        "on-tertiary-container": "#38313d",
        "on-primary-container": "#4e2a1f",
        "tertiary-fixed": "#eadfee",
        "background": "#fff8f3",
        "error": "#ba1a1a",
        "on-secondary-fixed-variant": "#4e425a",
        "inverse-on-surface": "#f7efe9"
        },
        "borderRadius": {
        "DEFAULT": "0.25rem",
        "lg": "0.5rem",
        "xl": "0.75rem",
        "full": "9999px",
        "card": "16px",
        "modal": "20px"
        },
        "spacing": {
        "stack-sm": "8px",
        "container-padding-mobile": "20px",
        "container-padding-desktop": "64px",
        "section-gap": "120px",
        "stack-md": "16px",
        "unit": "8px",
        "stack-lg": "32px",
        "gutter": "24px"
        },
        "fontFamily": {
        "label-caps": [
        "DM Sans"
        ],
        "body-md": [
        "DM Sans"
        ],
        "headline-md": [
        "Playfair Display"
        ],
        "display-lg-mobile": [
        "Playfair Display"
        ],
        "accent-italic": [
        "EB Garamond"
        ],
        "headline-lg-mobile": [
        "Playfair Display"
        ],
        "display-lg": [
        "Playfair Display"
        ],
        "headline-lg": [
        "Playfair Display"
        ],
        "body-lg": [
        "DM Sans"
        ]
        },
        "fontSize": {
        "label-caps": [
        "12px",
        {
        "lineHeight": "1.2",
        "letterSpacing": "0.1em",
        "fontWeight": "700"
        }
        ],
        "body-md": [
        "16px",
        {
        "lineHeight": "1.6",
        "fontWeight": "400"
        }
        ],
        "headline-md": [
        "32px",
        {
        "lineHeight": "1.3",
        "fontWeight": "500"
        }
        ],
        "display-lg-mobile": [
        "40px",
        {
        "lineHeight": "1.2",
        "fontWeight": "700"
        }
        ],
        "accent-italic": [
        "20px",
        {
        "lineHeight": "1.5",
        "fontWeight": "400"
        }
        ],
        "headline-lg-mobile": [
        "32px",
        {
        "lineHeight": "1.2",
        "fontWeight": "600"
        }
        ],
        "display-lg": [
        "64px",
        {
        "lineHeight": "1.1",
        "letterSpacing": "-0.02em",
        "fontWeight": "700"
        }
        ],
        "headline-lg": [
        "40px",
        {
        "lineHeight": "1.2",
        "fontWeight": "600"
        }
        ],
        "body-lg": [
        "18px",
        {
        "lineHeight": "1.6",
        "fontWeight": "400"
        }
        ]
        }
        },
        },
        }
    </script>
    <style>
        body {
        background-color: theme('colors.background');
        color: theme('colors.on-background');
        }

        .shadow-level-1 {
        box-shadow: 0px 10px 30px rgba(26, 16, 37, 0.05);
        }

        .shadow-level-2 {
        box-shadow: 0px 20px 50px rgba(26, 16, 37, 0.08);
        }

        .transition-tactile {
        transition: all 250ms ease-out;
        }
    </style>
</head>
<body class="antialiased min-h-screen flex flex-col">
    <!-- AnnouncementBar -->
    <div class="bg-primary dark:bg-primary-container text-on-primary dark:text-on-primary-container font-label-caps text-label-caps full-width top-0 hover:opacity-90 flex justify-center items-center py-2 px-4 text-center w-full z-[60]">
        <span>COMPLIMENTARY SHIPPING ON ORDERS OVER 5000 EGP</span>
    </div>
    <!-- TopNavBar -->
    <nav class="bg-surface/80 backdrop-blur-md dark:bg-surface/80 text-primary dark:text-primary-fixed font-label-caps text-label-caps docked full-width top-0 sticky border-b border-white/5 shadow-sm hover:scale-105 transition-transform duration-200 flex justify-between items-center w-full px-container-padding-mobile md:px-container-padding-desktop h-20 max-w-7xl mx-auto z-50">
        <div class="flex items-center gap-6 hidden md:flex">
            <a class="text-on-surface-variant hover:text-primary transition-colors duration-300" href="#">HOME</a>
            <a class="text-on-surface-variant hover:text-primary transition-colors duration-300" href="#">SHOP ALL</a>
            <a class="text-on-surface-variant hover:text-primary transition-colors duration-300" href="#">COLLECTIONS</a>
            <a class="text-on-surface-variant hover:text-primary transition-colors duration-300" href="#">ABOUT</a>
            <a class="text-on-surface-variant hover:text-primary transition-colors duration-300" href="#">CONTACT</a>
        </div>
        <div class="flex-1 md:flex-none text-center">
            <a class="font-accent-italic text-headline-sm italic text-primary dark:text-primary-fixed text-2xl tracking-widest" href="#">liora</a>
        </div>
        <div class="flex items-center gap-4">
            <button class="text-on-surface-variant hover:text-primary transition-tactile" data-icon="search">
                <span class="material-symbols-outlined">search</span>
            </button>
            <button class="text-primary dark:text-primary-fixed border-b-2 border-primary transition-tactile" data-icon="person">
                <span class="material-symbols-outlined">person</span>
            </button>
            <button class="text-on-surface-variant hover:text-primary transition-tactile" data-icon="shopping_bag">
                <span class="material-symbols-outlined">shopping_bag</span>
            </button>
        </div>
    </nav>
    <!-- Main Profile Content -->
    <main class="flex-grow w-full max-w-7xl mx-auto px-container-padding-mobile md:px-container-padding-desktop py-section-gap grid grid-cols-1 md:grid-cols-12 gap-gutter">
        <!-- Profile Sidebar Navigation -->
        <aside class="md:col-span-3 mb-12 md:mb-0">
            <div class="sticky top-32">
                <h2 class="font-headline-md text-headline-md mb-8 text-primary">My Account</h2>
                <nav class="flex flex-col gap-4">
                    <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors duration-300 py-2 border-b border-transparent hover:border-outline-variant/30 flex justify-between items-center group" href="#">
                        Orders
                        <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-sm">chevron_right</span>
                    </a>
                    <a class="font-label-caps text-label-caps text-primary border-b-2 border-primary-container py-2 flex justify-between items-center group" href="#">
                        Addresses
                        <span class="material-symbols-outlined text-sm">chevron_right</span>
                    </a>
                    <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors duration-300 py-2 border-b border-transparent hover:border-outline-variant/30 flex justify-between items-center group" href="#">
                        Profile Details
                        <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-sm">chevron_right</span>
                    </a>
                    <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors duration-300 py-2 border-b border-transparent hover:border-outline-variant/30 flex justify-between items-center group mt-8" href="#">
                        Sign Out
                        <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-sm">logout</span>
                    </a>
                </nav>
            </div>
        </aside>
        <!-- Addresses Content -->
        <section class="md:col-span-9">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-6">
                <div>
                    <h1 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-background mb-2">My Addresses</h1>
                    <p class="font-body-md text-body-md text-on-surface-variant">Manage your shipping and billing addresses for a seamless checkout experience.</p>
                </div>
                <button class="bg-primary-container text-on-primary hover:bg-primary transition-tactile px-8 py-4 rounded-full font-label-caps text-label-caps flex items-center gap-2 shadow-level-1 active:scale-95">
                    <span class="material-symbols-outlined text-[18px]">add</span>
                    Add New Address
                </button>
            </div>
            <!-- Address Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Address Card 1 (Default) -->
                <div class="bg-surface-container-lowest rounded-card p-8 shadow-level-1 border border-outline-variant/20 flex flex-col h-full relative group hover:shadow-level-2 transition-tactile">
                    <div class="absolute top-0 left-0 w-full h-1 bg-primary-container rounded-t-card"></div>
                    <div class="flex justify-between items-start mb-6">
                        <div class="flex items-center gap-3">
                            <span class="bg-primary-container/20 text-primary-container font-label-caps text-[10px] px-3 py-1 rounded-full border border-primary-container/30">DEFAULT</span>
                            <span class="font-label-caps text-label-caps text-on-surface-variant">HOME</span>
                        </div>
                    </div>
                    <h3 class="font-headline-md text-2xl text-on-background mb-4">Amina Hassan</h3>
                    <div class="font-body-md text-body-md text-on-surface-variant flex-grow mb-8 space-y-1">
                        <p>Apt 14, Building 5</p>
                        <p>26th of July Corridor, Zamalek</p>
                        <p>Cairo, 11211</p>
                        <p>Egypt</p>
                        <p class="pt-4 flex items-center gap-2">
                            <span class="material-symbols-outlined text-[18px] text-outline">phone_iphone</span>
                            +20 10 1234 5678
                        </p>
                    </div>
                    <div class="flex items-center gap-4 pt-6 border-t border-outline-variant/20 mt-auto">
                        <button class="font-label-caps text-label-caps text-primary hover:text-primary-container transition-colors tracking-widest flex items-center gap-1">
                            <span class="material-symbols-outlined text-[16px]">edit</span>
                            EDIT
                        </button>
                    </div>
                </div>
                <!-- Address Card 2 -->
                <div class="bg-surface-container-lowest rounded-card p-8 shadow-level-1 border border-outline-variant/20 flex flex-col h-full relative group hover:shadow-level-2 transition-tactile">
                    <div class="flex justify-between items-start mb-6">
                        <div class="flex items-center gap-3">
                            <span class="font-label-caps text-label-caps text-on-surface-variant">OFFICE</span>
                        </div>
                    </div>
                    <h3 class="font-headline-md text-2xl text-on-background mb-4">Amina Hassan</h3>
                    <div class="font-body-md text-body-md text-on-surface-variant flex-grow mb-8 space-y-1">
                        <p>Floor 8, Liora Studios</p>
                        <p>15 Maadi Corniche</p>
                        <p>Cairo, 11431</p>
                        <p>Egypt</p>
                        <p class="pt-4 flex items-center gap-2">
                            <span class="material-symbols-outlined text-[18px] text-outline">phone_iphone</span>
                            +20 12 9876 5432
                        </p>
                    </div>
                    <div class="flex items-center justify-between pt-6 border-t border-outline-variant/20 mt-auto">
                        <div class="flex gap-4">
                            <button class="font-label-caps text-label-caps text-primary hover:text-primary-container transition-colors tracking-widest flex items-center gap-1">
                                <span class="material-symbols-outlined text-[16px]">edit</span>
                                EDIT
                            </button>
                            <button class="font-label-caps text-label-caps text-error hover:text-error/80 transition-colors tracking-widest flex items-center gap-1" onclick="document.getElementById('delete-modal').classList.remove('hidden'); document.getElementById('delete-modal').classList.add('flex');">
                                <span class="material-symbols-outlined text-[16px]">delete</span>
                                DELETE
                            </button>
                        </div>
                        <button class="text-xs font-label-caps text-outline hover:text-primary transition-colors">
                            SET DEFAULT
                        </button>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <!-- Footer -->
    <footer class="bg-surface-container-high dark:bg-surface-container-high text-primary dark:text-primary rounded-t-footer-radius-top mt-stack-lg border-t border-outline-variant/10 shadow-[0_-8px_24px_rgba(196,144,128,0.08)] grid grid-cols-1 md:grid-cols-3 gap-stack-lg px-container-padding-mobile md:px-container-padding-desktop py-20 max-w-7xl mx-auto w-full">
        <div class="flex flex-col gap-6">
            <a class="font-accent-italic text-headline-md italic text-primary hover:translate-x-1 transition-transform duration-200" href="#">liora</a>
            <p class="font-body-sm text-body-sm text-on-surface-variant mt-4 max-w-xs">Elevating modern Egyptian craftsmanship through intimate luxury and empowered elegance.</p>
            <div class="flex gap-4 mt-2">
                <a class="text-on-surface-variant hover:text-primary transition-colors hover:scale-110 duration-200" href="#"><span class="material-symbols-outlined">camera_alt</span></a>
                <a class="text-on-surface-variant hover:text-primary transition-colors hover:scale-110 duration-200" href="#"><span class="material-symbols-outlined">mail</span></a>
            </div>
        </div>
        <div class="flex flex-col gap-4">
            <h4 class="font-label-caps text-label-caps text-primary mb-2">SHOP</h4>
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary transition-colors hover:translate-x-1 duration-200" href="#">Shop All</a>
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary transition-colors hover:translate-x-1 duration-200" href="#">My Orders</a>
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary transition-colors hover:translate-x-1 duration-200" href="#">Size Guide</a>
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary transition-colors hover:translate-x-1 duration-200" href="#">Track Order</a>
        </div>
        <div class="flex flex-col gap-4">
            <h4 class="font-label-caps text-label-caps text-primary mb-2">INFORMATION</h4>
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary transition-colors hover:translate-x-1 duration-200" href="#">About</a>
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary transition-colors hover:translate-x-1 duration-200" href="#">Contact</a>
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary transition-colors hover:translate-x-1 duration-200" href="#">Privacy</a>
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary transition-colors hover:translate-x-1 duration-200" href="#">Refunds</a>
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary transition-colors hover:translate-x-1 duration-200" href="#">FAQ</a>
        </div>
        <div class="md:col-span-3 text-center mt-12 pt-8 border-t border-outline-variant/20">
            <p class="font-label-caps text-[10px] text-on-surface-variant opacity-60">© 2024 liora. All rights reserved.</p>
        </div>
    </footer>
    <!-- Delete Confirmation Modal -->
    <div class="fixed inset-0 z-[100] hidden items-center justify-center bg-on-background/40 backdrop-blur-sm p-4 transition-opacity" id="delete-modal">
        <div class="bg-surface rounded-modal w-full max-w-md p-8 shadow-level-2 transform transition-all">
            <div class="flex justify-between items-start mb-6">
                <div class="bg-error-container/30 p-3 rounded-full text-error">
                    <span class="material-symbols-outlined text-[24px]">delete_forever</span>
                </div>
                <button class="text-on-surface-variant hover:text-on-background transition-colors" onclick="document.getElementById('delete-modal').classList.add('hidden'); document.getElementById('delete-modal').classList.remove('flex');">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <h3 class="font-headline-md text-2xl text-on-background mb-3">Remove Address?</h3>
            <p class="font-body-md text-on-surface-variant mb-8">Are you sure you want to delete this address? This action cannot be undone and you will need to re-enter it for future orders.</p>
            <div class="flex flex-col sm:flex-row gap-4 w-full">
                <button class="flex-1 py-3 px-6 rounded-full border border-outline-variant/50 text-on-background font-label-caps text-label-caps hover:bg-surface-variant transition-tactile text-center" onclick="document.getElementById('delete-modal').classList.add('hidden'); document.getElementById('delete-modal').classList.remove('flex');">
                    CANCEL
                </button>
                <button class="flex-1 py-3 px-6 rounded-full bg-error text-on-error font-label-caps text-label-caps hover:opacity-90 transition-tactile shadow-level-1 text-center active:scale-95" onclick="document.getElementById('delete-modal').classList.add('hidden'); document.getElementById('delete-modal').classList.remove('flex');">
                    DELETE
                </button>
            </div>
        </div>
    </div>
</body></html>