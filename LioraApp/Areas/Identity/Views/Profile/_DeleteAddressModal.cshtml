@model int

<div id="deleteAddressModal" class="fixed inset-0 hidden items-center justify-center z-50">
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="bg-white rounded-lg shadow-lg p-6 relative z-10 max-w-md w-full">
        <h3 class="text-lg font-semibold mb-4">حذف العنوان</h3>
        <p class="mb-6">هل أنت متأكد أنك تريد حذف هذا العنوان؟</p>
        <div class="flex justify-end gap-3">
            <button type="button" class="px-4 py-2 border rounded-lg" onclick="closeDeleteModal()">إلغاء</button>
            <form id="deleteAddressForm" method="post" asp-area="Identity" asp-controller="Profile" asp-action="DeleteAddress">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="deleteAddressId" value="@Model" />
                <button type="submit" class="px-4 py-2 bg-red-600 text-white rounded-lg">حذف</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openDeleteModal(id){
            var modal = document.getElementById('deleteAddressModal');
            var input = document.getElementById('deleteAddressId');
            if(input) input.value = id;
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }
        function closeDeleteModal(){
            var modal = document.getElementById('deleteAddressModal');
            modal.classList.remove('flex');
            modal.classList.add('hidden');
        }
    </script>
}