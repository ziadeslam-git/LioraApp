@model LioraApp.ViewModels.Identity.AddressVM
@{
    Layout = "/Areas/Customer/Views/Shared/_CustomerLayout.cshtml"; ViewData["Title"] = "Add Address";
}

<a asp-area="Identity" asp-controller="Profile" asp-action="Index" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-black mb-6">← Back to Profile</a>

<main class="min-h-screen bg-[#f9f6f1] px-4 md:px-8 py-10">
    <div class="max-w-xl mx-auto">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-10">
            <h2 class="text-xl font-semibold text-gray-900 mb-6">Add New Address</h2>
            <form method="post" asp-area="Identity" asp-controller="Profile" asp-action="AddAddress" class="space-y-4">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm mb-4"></div>
                <input type="hidden" name="Country" value="Egypt" />
                <input type="hidden" name="PostalCode" value="00000" />
                <div>
                    <label class="text-sm font-medium text-gray-700 mb-1 block">الاسم الكامل *</label>
                    <input asp-for="FullName" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-black" />
                    <span class="text-sm text-red-600" data-valmsg-for="FullName" data-valmsg-replace="true"></span>
                </div>
                <div>
                    <label class="text-sm font-medium text-gray-700 mb-1 block">رقم الهاتف *</label>
                    <input asp-for="PhoneNumber" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-black" />
                    <span class="text-sm text-red-600" data-valmsg-for="PhoneNumber" data-valmsg-replace="true"></span>
                </div>
                <div>
                    <label class="text-sm font-medium text-gray-700 mb-1 block">العنوان (شارع/تفاصيل) *</label>
                    <input asp-for="Street" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-black" />
                    <span class="text-sm text-red-600" data-valmsg-for="Street" data-valmsg-replace="true"></span>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="text-sm font-medium text-gray-700 mb-1 block">المدينة *</label>
                        <input asp-for="City" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-black" />
                        <span class="text-sm text-red-600" data-valmsg-for="City" data-valmsg-replace="true"></span>
                    </div>
                    <div>
                        <label class="text-sm font-medium text-gray-700 mb-1 block">المحافظة *</label>
                        <select asp-for="State" asp-items="@(ViewBag.Governorates as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-black"></select>
                        <span class="text-sm text-red-600" data-valmsg-for="State" data-valmsg-replace="true"></span>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <input asp-for="IsDefault" id="IsDefault" class="w-4 h-4" />
                    <label for="IsDefault" class="text-sm text-gray-700">اجعل هذا العنوان هو الافتراضي</label>
                </div>

                <div class="pt-4 flex justify-end gap-3">
                    <a asp-area="Identity" asp-controller="Profile" asp-action="Addresses" class="text-sm text-gray-700 border border-gray-200 rounded-lg px-4 py-2 hover:bg-gray-50">Cancel</a>
                    <button type="submit" class="bg-black text-white rounded-lg px-6 py-2.5 text-sm font-medium hover:bg-gray-800 transition">Save Address</button>
                </div>
            </form>
        </div>
    </div>
</main>
