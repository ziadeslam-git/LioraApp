    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
        darkMode: "class",
        theme: {
        extend: {
        "colors": {
        "outline": "#83746f",
        "on-tertiary-fixed-variant": "#4b4450",
        "secondary-fixed": "#eedcfa",
        "primary-container": "#c49080",
        "secondary-fixed-dim": "#d1c0de",
        "on-secondary-container": "#6c5f79",
        "tertiary-fixed-dim": "#cec3d2",
        "on-secondary": "#ffffff",
        "on-error-container": "#93000a",
        "surface-variant": "#e8e1db",
        "secondary": "#665972",
        "on-tertiary": "#ffffff",
        "on-primary": "#ffffff",
        "surface": "#fff8f3",
