</head>
<body class="bg-background text-on-surface font-body-md min-h-screen flex flex-col antialiased">
    <!-- Announcement Bar -->
    <div class="bg-primary dark:bg-primary-container text-on-primary dark:text-on-primary-container font-label-caps text-label-caps w-full top-0 flex justify-center items-center py-2 px-4 text-center z-[60] hover:opacity-90 transition-opacity">
        FREE STANDARD SHIPPING ON ALL ORDERS OVER £150
    </div>
    <!-- TopNavBar -->
    <header class="bg-surface/80 backdrop-blur-md dark:bg-surface/80 docked full-width top-0 sticky border-b border-white/5 shadow-sm z-50 transition-all duration-300">
        <div class="flex justify-between items-center w-full px-container-padding-mobile md:px-margin-screen h-20 max-w-7xl mx-auto">
            <!-- Navigation Links -->
            <nav class="hidden md:flex gap-8">
                <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary hover:scale-105 transition-all duration-300" href="#">HOME</a>
                <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary hover:scale-105 transition-all duration-300" href="#">SHOP ALL</a>
                <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary hover:scale-105 transition-all duration-300" href="#">COLLECTIONS</a>
                <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary hover:scale-105 transition-all duration-300" href="#">ABOUT</a>
                <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary hover:scale-105 transition-all duration-300" href="#">CONTACT</a>
            </nav>
            <!-- Brand Logo -->
            <div class="flex-shrink-0 flex items-center justify-center">
                <a class="font-accent-italic text-[28px] italic text-primary dark:text-primary-fixed hover:scale-105 transition-transform duration-200" href="#">
                    liora
                </a>
            </div>
            <!-- Trailing Icons -->
            <div class="flex items-center gap-6">
                <button class="text-primary dark:text-primary-fixed hover:scale-105 transition-transform duration-200 active:scale-95">
                    <span class="material-symbols-outlined text-[24px]">search</span>
                </button>
                <button class="text-primary dark:text-primary-fixed border-b-2 border-primary hover:scale-105 transition-transform duration-200 active:scale-95 pb-1">
                    <span class="material-symbols-outlined text-[24px]">person</span>
                </button>
                <button class="text-primary dark:text-primary-fixed hover:scale-105 transition-transform duration-200 active:scale-95 relative">
                    <span class="material-symbols-outlined text-[24px]">shopping_bag</span>
                    <span class="absolute -top-1 -right-1 bg-rose-gold text-white text-[10px] w-4 h-4 rounded-full flex items-center justify-center font-label-caps">2</span>
                </button>
            </div>
        </div>
    </header>
    <!-- Main Content -->
    <main class="flex-grow w-full max-w-7xl mx-auto px-container-padding-mobile md:px-margin-screen py-16 flex justify-center">
        <!-- Form Container -->
        <div class="w-full max-w-[600px] bg-surface rounded-card shadow-level-1 p-8 md:p-12 border border-outline-variant/20">
            <div class="mb-10 text-center">
                <h1 class="font-headline-md text-headline-md text-on-surface mb-2">Add New Address</h1>
                <p class="font-body-md text-body-md text-on-surface-variant">Please fill in the details for your new delivery address.</p>
            </div>
            <form class="space-y-6">
                <!-- Full Name -->
                <div class="space-y-2">
                    <label class="block font-label-caps text-label-caps text-on-surface" for="fullName">Full Name *</label>
                    <input class="w-full bg-surface border border-plum/20 rounded-input px-4 py-3 font-body-md text-on-surface input-glow transition-all duration-250 placeholder-on-surface-variant/50" id="fullName" placeholder="e.g. Amina Hassan" required="" type="text" />
                </div>
                <!-- Phone Number -->
                <div class="space-y-2">
                    <label class="block font-label-caps text-label-caps text-on-surface" for="phone">Phone Number *</label>
                    <div class="flex">
                        <span class="inline-flex items-center px-4 rounded-l-input border border-r-0 border-plum/20 bg-surface-container-high text-on-surface font-body-md">
                            +20
                        </span>
                        <input class="flex-1 bg-surface border border-plum/20 rounded-r-input px-4 py-3 font-body-md text-on-surface input-glow transition-all duration-250 placeholder-on-surface-variant/50" id="phone" placeholder="1X XXXX XXXX" required="" type="tel" />
                    </div>
                </div>
                <!-- Street Address -->
                <div class="space-y-2">
                    <label class="block font-label-caps text-label-caps text-on-surface" for="street">Street Address *</label>
                    <input class="w-full bg-surface border border-plum/20 rounded-input px-4 py-3 font-body-md text-on-surface input-glow transition-all duration-250 placeholder-on-surface-variant/50" id="street" placeholder="Street name and house number" required="" type="text" />
                </div>
                <!-- Apartment (Optional) -->
                <div class="space-y-2">
                    <label class="block font-label-caps text-label-caps text-on-surface" for="apartment">Apartment, suite, etc. (Optional)</label>
                    <input class="w-full bg-surface border border-plum/20 rounded-input px-4 py-3 font-body-md text-on-surface input-glow transition-all duration-250 placeholder-on-surface-variant/50" id="apartment" placeholder="Apartment, suite, unit, etc." type="text" />
                </div>
                <!-- City and Governorate -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label class="block font-label-caps text-label-caps text-on-surface" for="city">City *</label>
                        <input class="w-full bg-surface border border-plum/20 rounded-input px-4 py-3 font-body-md text-on-surface input-glow transition-all duration-250 placeholder-on-surface-variant/50" id="city" placeholder="City" required="" type="text" />
                    </div>
                    <div class="space-y-2">
                        <label class="block font-label-caps text-label-caps text-on-surface" for="governorate">Governorate *</label>
                        <div class="relative">
                            <select class="w-full bg-surface border border-plum/20 rounded-input px-4 py-3 font-body-md text-on-surface input-glow transition-all duration-250 appearance-none pr-10" id="governorate" required="">
                                <option disabled="" selected="" value="">Select Governorate</option>
                                <option value="cairo">Cairo</option>
                                <option value="giza">Giza</option>
                                <option value="alexandria">Alexandria</option>
                                <option value="luxor">Luxor</option>
                                <option value="aswan">Aswan</option>
                            </select>
                            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none">expand_more</span>
                        </div>
                    </div>
                </div>
                <!-- Postal Code (Optional) -->
                <div class="space-y-2">
                    <label class="block font-label-caps text-label-caps text-on-surface" for="postal">Postal Code (Optional)</label>
                    <input class="w-full md:w-1/2 bg-surface border border-plum/20 rounded-input px-4 py-3 font-body-md text-on-surface input-glow transition-all duration-250 placeholder-on-surface-variant/50" id="postal" placeholder="Postal / Zip Code" type="text" />
                </div>
                <!-- Set as Default Checkbox -->
                <div class="flex items-center gap-3 pt-2">
                    <input class="w-5 h-5 rounded border-plum/30 text-primary-container focus:ring-primary-container focus:ring-offset-surface bg-surface transition-colors duration-250 cursor-pointer" id="defaultAddress" type="checkbox" />
                    <label class="font-body-md text-body-md text-on-surface cursor-pointer select-none" for="defaultAddress">
                        Set as default shipping address
                    </label>
                </div>
                <!-- Actions -->
                <div class="pt-8 flex flex-col md:flex-row gap-4 items-center justify-end border-t border-outline-variant/20 mt-8">
                    <button class="w-full md:w-auto px-8 py-3 font-label-caps text-label-caps text-on-surface bg-transparent hover:bg-surface-container-high rounded-pill transition-all duration-250 hover:scale-[0.98] active:scale-95" type="button">
                        CANCEL
                    </button>
                    <button class="w-full md:w-auto px-8 py-3 font-label-caps text-label-caps text-ivory bg-rose-gold hover:opacity-90 rounded-pill shadow-level-1 hover:shadow-level-2 transition-all duration-250 hover:scale-[0.98] active:scale-95" type="submit">
                        SAVE ADDRESS
                    </button>
                </div>
            </form>
        </div>
    </main>
    <!-- Footer -->
    <footer class="bg-surface-container-high dark:bg-surface-container-high rounded-t-footer-radius-top mt-stack-lg border-t border-outline-variant/10 shadow-footer">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-stack-lg px-container-padding-mobile md:px-margin-screen py-20 max-w-7xl mx-auto">
            <!-- Brand Section -->
            <div class="flex flex-col gap-6">
                <a class="font-accent-italic text-headline-md italic text-primary" href="#">liora</a>
                <p class="font-body-sm text-body-md text-on-surface-variant max-w-xs">
                    Empowered elegance and intimate luxury, crafted for the modern narrative.
                </p>
                <div class="flex gap-4">
                    <a class="text-on-surface-variant hover:text-primary transition-colors duration-200 hover:scale-110" href="#">
                        <span class="material-symbols-outlined">camera_alt</span>
                    </a>
                    <a class="text-on-surface-variant hover:text-primary transition-colors duration-200 hover:scale-110" href="#">
                        <span class="material-symbols-outlined">mail</span>
                    </a>
                </div>
            </div>
            <!-- Links Section 1 -->
            <div class="flex flex-col gap-4">
                <h4 class="font-label-caps text-label-caps text-primary tracking-widest mb-2">SHOP &amp; DISCOVER</h4>
                <a class="font-body-md text-body-md text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-200" href="#">Shop All</a>
                <a class="font-body-md text-body-md text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-200" href="#">Size Guide</a>
                <a class="font-body-md text-body-md text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-200" href="#">About</a>
                <a class="font-body-md text-body-md text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-200" href="#">Contact</a>
            </div>
            <!-- Links Section 2 -->
            <div class="flex flex-col gap-4">
                <h4 class="font-label-caps text-label-caps text-primary tracking-widest mb-2">CUSTOMER CARE</h4>
                <a class="font-body-md text-body-md text-primary font-bold hover:translate-x-1 transition-all duration-200" href="#">My Orders</a>
                <a class="font-body-md text-body-md text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-200" href="#">Track Order</a>
                <a class="font-body-md text-body-md text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-200" href="#">FAQ</a>
                <a class="font-body-md text-body-md text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-200" href="#">Refunds</a>
                <a class="font-body-md text-body-md text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-200" href="#">Privacy</a>
            </div>
        </div>
        <div class="text-center py-6 border-t border-outline-variant/10 font-body-md text-[14px] text-on-surface-variant">
            © 2024 liora. All rights reserved.
        </div>
    </footer>
</body></html>