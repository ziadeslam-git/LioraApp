@using System.Security.Claims
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> SR
@inject LioraApp.Repositories.IRepositories.IUnitOfWork Uow
@{
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var isRtl = culture.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    string T(string en, string ar) => isRtl ? ar : en;
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    var cartCount = 0;
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? string.Empty;
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var localizedUiJson = System.Text.Json.JsonSerializer.Serialize(new
    {
        Successful = T("Successful", "تم بنجاح"),
        Canceled = T("Canceled", "تم الإلغاء"),
        Invalid = T("Invalid", "غير صالح"),
        Failed = T("Failed", "فشل"),
        Ok = T("OK", "حسنًا"),
        ItemAddedToCartTitle = T("Item added to cart", "تمت إضافة المنتج إلى السلة"),
        ItemAddedToCartDescription = T("Your Liora selection is ready.", "اختيارك أصبح جاهزًا داخل السلة."),
        CouldNotAddItem = T("Could not add item", "تعذر إضافة المنتج"),
        PleaseTryAgain = T("Please try again.", "حاول مرة أخرى."),
        SomethingWentWrong = T("Something went wrong", "حدث خطأ ما"),
        Done = T("Done", "تم"),
        ViewCart = T("View Cart", "عرض السلة"),
        Checkout = T("Checkout", "إتمام الطلب"),
        GenericTryAgain = T("Something went wrong. Please try again.", "حدث خطأ ما. حاول مرة أخرى.")
    });
    bool IsCurrent(string area, string controller, string? action = null)
    {
        if (!string.Equals(currentArea, area, StringComparison.OrdinalIgnoreCase) ||
            !string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        return string.IsNullOrWhiteSpace(action) ||
               string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
    }

    var homeActive = IsCurrent("Customer", "Home");
    var productsActive = IsCurrent("Customer", "Products");
    var cartActive = IsCurrent("Customer", "Cart");
    var profileActive = IsCurrent("Identity", "Profile") || IsCurrent("Identity", "Account", "Login");
    var ordersActive = IsCurrent("Customer", "Orders");

    if (User.Identity?.IsAuthenticated == true)
    {
        var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (!string.IsNullOrWhiteSpace(userId))
        {
            var currentCart = await Uow.Carts.GetCartByUserIdAsync(userId);
            cartCount = currentCart?.Items.Sum(i => i.Quantity) ?? 0;
        }
    }
}
<!DOCTYPE html>
<html lang="@culture" dir="@(isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Liora</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="~/images/site-logo.png" asp-append-version="true" />
    <link rel="shortcut icon" href="~/images/site-logo.png" asp-append-version="true" />
    <script>
        tailwind.config = {
            theme: { extend: { colors: { primary: '#6467f2' }, fontFamily: { sans: ['Inter','sans-serif'] } } }
        }
    </script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-slate-50 text-slate-900">
    <div class="min-h-screen flex flex-col">
        <header class="sticky top-0 z-40 bg-white/95 backdrop-blur border-b border-slate-200">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">
                <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="inline-flex items-center gap-3 text-primary transition-opacity hover:opacity-90">
                    <img src="~/images/site-logo.png" asp-append-version="true" alt="Liora logo" class="h-9 w-9 shrink-0 object-contain" />
                    <span class="text-xl font-extrabold tracking-tight">Liora</span>
                </a>
                <nav class="hidden md:flex items-center gap-5 text-sm font-medium">
                    <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="inline-flex items-center gap-1.5 @(homeActive ? "text-primary" : "hover:text-primary")">
                        <span class="material-symbols-outlined text-[18px]" style="font-variation-settings:'FILL' @(homeActive ? "1" : "0")">home</span>
                        <span>@T("Home","الرئيسية")</span>
                    </a>
                    <a asp-area="Customer" asp-controller="Products" asp-action="Index" class="@(productsActive ? "text-primary" : "hover:text-primary")">@T("Products","المنتجات")</a>
                    <a asp-area="Customer" asp-controller="Orders" asp-action="Index" class="@(ordersActive ? "text-primary" : "hover:text-primary")">@T("My Orders","طلباتي")</a>
                </nav>
                <div class="flex items-center gap-2">
                    <div class="flex items-center rounded-full border border-slate-200 p-1">
                        <form asp-area="Customer" asp-controller="Home" asp-action="SetLanguage" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="culture" value="en-US" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                            <button class="px-2 py-1 text-xs rounded-full @(culture == "en-US" ? "bg-primary text-white" : "text-slate-600")" type="submit">EN</button>
                        </form>
                        <form asp-area="Customer" asp-controller="Home" asp-action="SetLanguage" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="culture" value="ar-EG" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                            <button class="px-2 py-1 text-xs rounded-full @(culture == "ar-EG" ? "bg-primary text-white" : "text-slate-600")" type="submit">AR</button>
                        </form>
                    </div>
                    <a asp-area="Customer" asp-controller="Cart" asp-action="Index" class="hidden md:inline-flex relative items-center justify-center h-10 w-10 rounded-full border border-slate-200 hover:border-primary hover:text-primary transition" title="@T("Cart","سلة التسوق")">
                        <span class="material-symbols-outlined">shopping_cart</span>
                        <span data-cart-count-badge class="absolute -top-1 -right-1 text-[10px] min-w-5 h-5 px-1 rounded-full bg-primary text-white @(cartCount > 0 ? "grid" : "hidden") place-items-center">@cartCount</span>
                    </a>
                    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                    {
                        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="inline-flex items-center justify-center h-10 w-10 rounded-full border border-amber-200 bg-amber-50 text-amber-700 hover:bg-amber-100 transition" title="Admin Dashboard">
                            <span class="material-symbols-outlined">shield_person</span>
                        </a>
                    }
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-area="Identity" asp-controller="Profile" asp-action="Index" class="hidden md:inline-flex items-center justify-center h-10 w-10 rounded-full border border-slate-200 hover:border-primary hover:text-primary transition" title="Profile">
                            <span class="material-symbols-outlined">person</span>
                        </a>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-controller="Account" asp-action="Login" class="inline-flex md:hidden items-center justify-center h-10 px-4 rounded-full border border-slate-200 bg-white text-slate-700 hover:border-primary hover:text-primary transition text-sm font-semibold shadow-sm">
                            @T("Login","تسجيل الدخول")
                        </a>
                        <a asp-area="Identity" asp-controller="Account" asp-action="Login" class="hidden md:inline-flex items-center justify-center h-10 px-4 rounded-full border border-slate-200 hover:border-primary hover:text-primary transition text-sm font-medium">
                            @T("Login","تسجيل الدخول")
                        </a>
                    }
                </div>
            </div>
        </header>

        <main class="flex-1 pb-28 md:pb-0">
            @RenderBody()
        </main>

        <footer class="border-t border-slate-200 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 text-sm text-slate-500">© @DateTime.UtcNow.Year Liora</div>
        </footer>

        <nav class="md:hidden fixed inset-x-0 bottom-0 z-50 px-3 pb-[max(env(safe-area-inset-bottom),0.75rem)] pt-3">
            <div class="mx-auto max-w-lg rounded-[1.75rem] border border-slate-200/80 bg-white/95 px-2 py-2 shadow-[0_-10px_35px_rgba(15,23,42,0.10)] backdrop-blur-xl">
                <div class="grid grid-cols-5 gap-1">
                    <a asp-area="Customer" asp-controller="Home" asp-action="Index"
                       class="flex min-w-0 flex-col items-center justify-center rounded-2xl px-1.5 py-2 text-[10px] font-semibold transition @(homeActive ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-slate-500 hover:bg-slate-100")">
                        <span class="material-symbols-outlined text-[21px]" style="font-variation-settings:'FILL' @(homeActive ? "1" : "0")">home</span>
                        <span class="mt-1 leading-none">@T("Home", "الرئيسية")</span>
                    </a>

                    <a asp-area="Customer" asp-controller="Products" asp-action="Index"
                       class="flex min-w-0 flex-col items-center justify-center rounded-2xl px-1.5 py-2 text-[10px] font-semibold transition @(productsActive ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-slate-500 hover:bg-slate-100")">
                        <span class="material-symbols-outlined text-[21px]" style="font-variation-settings:'FILL' @(productsActive ? "1" : "0")">storefront</span>
                        <span class="mt-1 leading-none">@T("Shop", "التسوق")</span>
                    </a>

                    <a asp-area="Customer" asp-controller="Orders" asp-action="Index"
                       class="flex min-w-0 flex-col items-center justify-center rounded-2xl px-1.5 py-2 text-[10px] font-semibold transition @(ordersActive ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-slate-500 hover:bg-slate-100")">
                        <span class="material-symbols-outlined text-[21px]" style="font-variation-settings:'FILL' @(ordersActive ? "1" : "0")">receipt_long</span>
                        <span class="mt-1 leading-none">@T("Orders", "طلباتي")</span>
                    </a>

                    <a asp-area="Customer" asp-controller="Cart" asp-action="Index"
                       class="relative flex min-w-0 flex-col items-center justify-center rounded-2xl px-1.5 py-2 text-[10px] font-semibold transition @(cartActive ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-slate-500 hover:bg-slate-100")">
                        <span class="material-symbols-outlined text-[21px]" style="font-variation-settings:'FILL' @(cartActive ? "1" : "0")">shopping_cart</span>
                        <span data-cart-count-badge class="absolute right-3 top-1.5 min-w-5 rounded-full bg-rose-500 px-1.5 py-0.5 text-[10px] font-bold text-white @(cartCount > 0 ? "inline-block" : "hidden")">@(cartCount > 99 ? "99+" : cartCount)</span>
                        <span class="mt-1 leading-none">@T("Cart", "السلة")</span>
                    </a>

                    <a asp-area="Identity"
                       asp-controller="@(User.Identity?.IsAuthenticated == true ? "Profile" : "Account")"
                       asp-action="@(User.Identity?.IsAuthenticated == true ? "Index" : "Login")"
                       class="flex min-w-0 flex-col items-center justify-center rounded-2xl px-1.5 py-2 text-[10px] font-semibold transition @(profileActive ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-slate-500 hover:bg-slate-100")">
                        <span class="material-symbols-outlined text-[21px]" style="font-variation-settings:'FILL' @(profileActive ? "1" : "0")">person</span>
                        <span class="mt-1 leading-none">@T("Profile", "الحساب")</span>
                    </a>
                </div>
            </div>
        </nav>
    </div>

    <div id="site-notice-modal" class="fixed inset-0 z-[80] hidden items-center justify-center bg-slate-950/45 px-4 backdrop-blur-sm">
        <div class="w-full max-w-md overflow-hidden rounded-[28px] border border-slate-200 bg-white shadow-2xl shadow-slate-950/15">
            <div id="site-notice-accent" class="h-1.5 w-full bg-emerald-500"></div>
            <div class="px-6 pb-6 pt-7 text-center">
                <div id="site-notice-icon-wrap" class="mx-auto mb-4 flex size-16 items-center justify-center rounded-full bg-emerald-50 text-emerald-600">
                    <span id="site-notice-icon" class="material-symbols-outlined text-[32px]" style="font-variation-settings:'FILL' 1">check_circle</span>
                </div>
                <h3 id="site-notice-title" class="text-2xl font-extrabold tracking-tight text-slate-900">Successful</h3>
                <p id="site-notice-message" class="mt-3 text-sm leading-6 text-slate-500"></p>
                <button id="site-notice-ok"
                        type="button"
                        class="mt-6 inline-flex min-w-28 items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-bold text-white shadow-lg shadow-primary/20 transition hover:opacity-90">
                    OK
                </button>
            </div>
        </div>
    </div>

    <div id="site-inline-toast-host" class="pointer-events-none fixed right-4 top-20 z-[85] flex w-[calc(100%-2rem)] max-w-sm flex-col gap-3 sm:right-6"></div>

    @if (TempData["success"] is string success)
    {
        <div id="page-notice-success" data-notice-message="@success" data-notice-type="success" class="hidden"></div>
    }
    @if (TempData["error"] is string error)
    {
        <div id="page-notice-error" data-notice-message="@error" data-notice-type="error" class="hidden"></div>
    }

    <script>
        const noticeModal = document.getElementById('site-notice-modal');
        const noticeTitle = document.getElementById('site-notice-title');
        const noticeMessage = document.getElementById('site-notice-message');
        const noticeIconWrap = document.getElementById('site-notice-icon-wrap');
        const noticeIcon = document.getElementById('site-notice-icon');
        const noticeAccent = document.getElementById('site-notice-accent');
        const noticeOkButton = document.getElementById('site-notice-ok');
        const inlineToastHost = document.getElementById('site-inline-toast-host');
        const localizedUi = @Html.Raw(localizedUiJson);

        function getNoticeTitle(message, type = 'success') {
            const value = (message || '').toLowerCase();

            if (type === 'success') {
                return localizedUi.Successful;
            }

            if (value.includes('cancel')) {
                return localizedUi.Canceled;
            }

            if (value.includes('invalid') || value.includes('expired') || value.includes('not valid')) {
                return localizedUi.Invalid;
            }

            return localizedUi.Failed;
        }

        function applyNoticeTheme(type = 'success') {
            const isError = type === 'error';

            noticeAccent.className = `h-1.5 w-full ${isError ? 'bg-rose-500' : 'bg-emerald-500'}`;
            noticeIconWrap.className = `mx-auto mb-4 flex size-16 items-center justify-center rounded-full ${isError ? 'bg-rose-50 text-rose-600' : 'bg-emerald-50 text-emerald-600'}`;
            noticeIcon.textContent = isError ? 'error' : 'check_circle';
        }

        function closeNoticeModal() {
            if (!noticeModal) return;
            noticeModal.classList.add('hidden');
            noticeModal.classList.remove('flex');
            document.body.classList.remove('overflow-hidden');
        }

        function escapeHtml(value) {
            return (value || '').replace(/[&<>"']/g, match => ({
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#39;'
            }[match]));
        }

        function getInlineToastMeta(message, type = 'success', source = 'generic') {
            const value = (message || '').toLowerCase();

            if (source === 'cart') {
                if (type === 'success') {
                    return {
                        title: localizedUi.ItemAddedToCartTitle,
                        description: localizedUi.ItemAddedToCartDescription,
                        icon: 'shopping_bag',
                        showActions: true
                    };
                }

                return {
                    title: localizedUi.CouldNotAddItem,
                    description: message || localizedUi.PleaseTryAgain,
                    icon: 'error',
                    showActions: false
                };
            }

            return {
                title: type === 'error' ? localizedUi.SomethingWentWrong : localizedUi.Done,
                description: message || '',
                icon: type === 'error' ? 'error' : 'check_circle',
                showActions: false
            };
        }

        function showInlineToast(message, type = 'success', options = {}) {
            if (!message || !inlineToastHost) return;

            const toast = document.createElement('div');
            const isError = type === 'error';
            const meta = getInlineToastMeta(message, type, options.source || 'generic');
            const duration = options.duration || (meta.showActions ? 3800 : 2600);
            const tone = isError
                ? {
                    border: 'border-rose-200',
                    chip: 'bg-rose-100 text-rose-600',
                    progress: 'bg-rose-500'
                }
                : {
                    border: 'border-slate-200',
                    chip: 'bg-emerald-100 text-emerald-700',
                    progress: 'bg-primary'
                };

            toast.className = 'pointer-events-auto translate-y-2 opacity-0 transition-all duration-300';
            toast.innerHTML = `
                <div class="relative overflow-hidden rounded-[22px] border ${tone.border} bg-white shadow-[0_20px_40px_rgba(15,23,42,0.10)]">
                    <div class="flex items-start gap-4 p-4">
                        <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-2xl ${tone.chip}">
                            <span class="material-symbols-outlined text-[20px]" style="font-variation-settings:'FILL' 1">${meta.icon}</span>
                        </div>
                        <div class="min-w-0 flex-1 pt-0.5">
                            <h4 class="text-sm font-bold text-slate-900">${escapeHtml(meta.title)}</h4>
                            <p class="mt-1 text-sm leading-6 text-slate-500">${escapeHtml(meta.description)}</p>
                            ${meta.showActions ? `
                                <div class="mt-3 flex items-center gap-4 text-xs font-semibold">
                                    <a href="/Customer/Cart" class="text-primary transition hover:text-indigo-700">${escapeHtml(localizedUi.ViewCart)}</a>
                                    <a href="/Customer/Orders/Checkout" class="text-slate-500 transition hover:text-slate-900">${escapeHtml(localizedUi.Checkout)}</a>
                                </div>
                            ` : ''}
                        </div>
                        <button type="button" data-toast-close class="rounded-full p-1 text-slate-400 transition hover:bg-slate-100 hover:text-slate-700">
                            <span class="material-symbols-outlined text-[18px]">close</span>
                        </button>
                    </div>
                    <div class="h-1 w-full bg-slate-100">
                        <div data-toast-progress class="h-full w-full ${tone.progress}"></div>
                    </div>
                </div>
            `;

            inlineToastHost.appendChild(toast);

            const dismiss = () => {
                toast.classList.add('opacity-0', 'translate-y-[-8px]');
                setTimeout(() => toast.remove(), 250);
            };

            toast.querySelector('[data-toast-close]')?.addEventListener('click', dismiss);

            requestAnimationFrame(() => {
                toast.classList.remove('translate-y-2', 'opacity-0');
                const progressBar = toast.querySelector('[data-toast-progress]');
                if (progressBar) {
                    progressBar.style.transition = `width ${duration}ms linear`;
                    requestAnimationFrame(() => progressBar.style.width = '0%');
                }
            });

            setTimeout(dismiss, duration);
        }

        function showToast(message, type = 'success') {
            if (!message) return;

            applyNoticeTheme(type);
            noticeTitle.textContent = getNoticeTitle(message, type);
            noticeMessage.textContent = message;
            noticeModal.classList.remove('hidden');
            noticeModal.classList.add('flex');
            document.body.classList.add('overflow-hidden');
        }

        function restoreButtonState(button) {
            if (!button) return;
            if (button.dataset.originalClass) {
                button.className = button.dataset.originalClass;
            }
            if (button.dataset.originalHtml) {
                button.innerHTML = button.dataset.originalHtml;
            }
            button.disabled = false;
        }

        function setButtonState(button, state) {
            if (!button) return;

            if (!button.dataset.originalHtml) {
                button.dataset.originalHtml = button.innerHTML;
            }

            if (!button.dataset.originalClass) {
                button.dataset.originalClass = button.className;
            }

            const classMap = {
                idle: button.dataset.idleClass || button.dataset.originalClass,
                loading: button.dataset.loadingClass || button.dataset.originalClass,
                success: button.dataset.successClass || button.dataset.originalClass,
                error: button.dataset.errorClass || button.dataset.originalClass
            };

            const textMap = {
                idle: button.dataset.idleText || button.textContent.trim(),
                loading: button.dataset.loadingText || 'Loading...',
                success: button.dataset.successText || 'Done',
                error: button.dataset.errorText || 'Try again'
            };

            button.className = classMap[state] || button.dataset.originalClass;
            button.disabled = state === 'loading';

            if (state === 'loading') {
                button.innerHTML = `<span class="inline-flex items-center justify-center gap-2"><svg class="h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity=".28"></circle><path d="M22 12a10 10 0 0 1-10 10" stroke="currentColor" stroke-width="3"></path></svg><span>${escapeHtml(textMap.loading)}</span></span>`;
                return;
            }

            const icon = state === 'success'
                ? 'check_circle'
                : state === 'error'
                    ? 'error'
                    : 'shopping_cart';

            button.innerHTML = `<span class="inline-flex items-center justify-center gap-2"><span class="material-symbols-outlined text-[18px]" style="font-variation-settings:'FILL' 1">${icon}</span><span>${escapeHtml(textMap[state] || textMap.idle)}</span></span>`;
        }

        function updateCartBadge(count) {
            if (count === undefined || count === null) return;

            document.querySelectorAll('[data-cart-count-badge]').forEach(badge => {
                const normalized = Number(count) || 0;
                badge.textContent = normalized > 99 ? '99+' : normalized;
                badge.classList.toggle('hidden', normalized <= 0);
                badge.classList.toggle('grid', normalized > 0 && badge.classList.contains('h-5'));
                badge.classList.toggle('inline-block', normalized > 0 && !badge.classList.contains('h-5'));
            });
        }

        document.querySelectorAll('form[data-loading="true"]:not([data-ajax-form])').forEach(form => {
            form.addEventListener('submit', function (event) {
                const btn = event.submitter || this.querySelector('button[type="submit"]');
                if (btn && this.checkValidity()) {
                    setTimeout(() => setButtonState(btn, 'loading'), 0);
                }
            });
        });

        document.querySelectorAll('form[data-ajax-form]').forEach(form => {
            form.addEventListener('submit', async function (event) {
                event.preventDefault();

                if (!this.checkValidity()) {
                    this.reportValidity();
                    return;
                }

                const submitButton = this.querySelector('button[type="submit"]');
                const supportsStatefulButton = this.dataset.ajaxForm === 'cart';
                if (supportsStatefulButton) {
                    setButtonState(submitButton, 'loading');
                } else if (submitButton) {
                    submitButton.disabled = true;
                    submitButton.classList.add('opacity-70', 'pointer-events-none');
                }

                try {
                    const response = await fetch(this.action, {
                        method: this.method || 'POST',
                        body: new FormData(this),
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest',
                            'Accept': 'application/json'
                        }
                    });

                    if (response.redirected) {
                        window.location.href = response.url;
                        return;
                    }

                    const contentType = response.headers.get('content-type') || '';
                    if (!contentType.includes('application/json')) {
                        window.location.reload();
                        return;
                    }

                    const result = await response.json();
                    const isSuccess = result.success !== false;

                    if (typeof result.cartCount !== 'undefined') {
                        updateCartBadge(result.cartCount);
                    }

                    if (result.message) {
                        const useInlineToast = this.dataset.ajaxForm === 'cart';
                        if (useInlineToast) {
                            showInlineToast(result.message, isSuccess ? 'success' : 'error', { source: this.dataset.ajaxForm });
                        } else {
                            showToast(result.message, isSuccess ? 'success' : 'error');
                        }
                    }

                    if (supportsStatefulButton && submitButton) {
                        setButtonState(submitButton, isSuccess ? 'success' : 'error');
                        await new Promise(resolve => setTimeout(resolve, 950));
                    }
                } catch {
                    const useInlineToast = this.dataset.ajaxForm === 'cart' || this.dataset.ajaxForm === 'wishlist';
                    if (useInlineToast) {
                        showInlineToast(localizedUi.GenericTryAgain, 'error', { source: this.dataset.ajaxForm });
                    } else {
                        showToast(localizedUi.GenericTryAgain, 'error');
                    }

                    if (supportsStatefulButton && submitButton) {
                        setButtonState(submitButton, 'error');
                        await new Promise(resolve => setTimeout(resolve, 1050));
                    }
                } finally {
                    if (supportsStatefulButton) {
                        restoreButtonState(submitButton);
                    } else if (submitButton) {
                        submitButton.disabled = false;
                        submitButton.classList.remove('opacity-70', 'pointer-events-none');
                    }
                }
            });
        });

        noticeOkButton?.addEventListener('click', closeNoticeModal);
        if (noticeOkButton) {
            noticeOkButton.textContent = localizedUi.Ok;
        }

        noticeModal?.addEventListener('click', function (event) {
            if (event.target === noticeModal) {
                closeNoticeModal();
            }
        });

        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape' && noticeModal && !noticeModal.classList.contains('hidden')) {
                closeNoticeModal();
            }
        });

        const initialSuccessNotice = document.getElementById('page-notice-success');
        const initialErrorNotice = document.getElementById('page-notice-error');

        if (initialSuccessNotice?.dataset.noticeMessage) {
            showToast(initialSuccessNotice.dataset.noticeMessage, initialSuccessNotice.dataset.noticeType || 'success');
        } else if (initialErrorNotice?.dataset.noticeMessage) {
            showToast(initialErrorNotice.dataset.noticeMessage, initialErrorNotice.dataset.noticeType || 'error');
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
