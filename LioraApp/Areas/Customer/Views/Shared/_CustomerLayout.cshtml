@using System.Security.Claims
@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var cartUrl = Url.Action("Index", "Cart", new { area = "Customer" });
    var ordersUrl = Url.Action("Index", "Orders", new { area = "Customer" });
    var profileUrl = Url.Action("Index", "Profile", new { area = "Identity" });
    var loginUrl = Url.Action("Login", "Account", new { area = "Identity" });
    var homeUrl = Url.Action("Index", "Home", new { area = "Customer" });
    var shopUrl = Url.Action("Index", "Products", new { area = "Customer" });
    var logoutUrl = Url.Action("Logout", "Account", new { area = "Identity" });
    var currentPath = Context.Request.Path.Value ?? "";
    bool IsActive(string? path) => path != null && (path == "/" ? currentPath == "/" : currentPath.StartsWith(path, StringComparison.OrdinalIgnoreCase));
}
<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} - liora" : "liora | Wear Your Confidence")</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect"/>
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@@9..40,400;9..40,500;9..40,700&family=EB+Garamond:ital,wght@@0,400;0,500;1,400;1,500&family=Playfair+Display:ital,wght@@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet"/>
    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@@100..700,0..1&display=swap" rel="stylesheet"/>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <!-- Tailwind Config -->
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "surface-dim": "#dfd9d3",
                        "error": "#ba1a1a",
                        "on-secondary": "#ffffff",
                        "inverse-on-surface": "#f7efe9",
                        "tertiary": "#635b68",
                        "on-primary-fixed-variant": "#643d30",
                        "surface-container-low": "#f9f2ec",
                        "surface-tint": "#7f5446",
                        "secondary": "#665972",
                        "on-tertiary-fixed": "#1f1924",
                        "on-primary-container": "#4e2a1f",
                        "secondary-fixed": "#eedcfa",
                        "on-tertiary-container": "#38313d",
                        "on-secondary-fixed": "#21172c",
                        "on-surface": "#1e1b18",
                        "surface-variant": "#e8e1db",
                        "background": "#fff8f3",
                        "surface-container-high": "#eee7e1",
                        "secondary-container": "#eedcfa",
                        "on-tertiary-fixed-variant": "#4b4450",
                        "on-primary-fixed": "#311309",
                        "primary": "#7f5446",
                        "inverse-surface": "#33302c",
                        "surface-container": "#f4ede7",
                        "primary-fixed-dim": "#f2baa8",
                        "on-tertiary": "#ffffff",
                        "on-background": "#1e1b18",
                        "on-secondary-fixed-variant": "#4e425a",
                        "primary-container": "#c49080",
                        "on-error-container": "#93000a",
                        "primary-fixed": "#ffdbd0",
                        "secondary-fixed-dim": "#d1c0de",
                        "surface": "#fff8f3",
                        "on-error": "#ffffff",
                        "on-secondary-container": "#6c5f79",
                        "outline-variant": "#d5c2bd",
                        "on-primary": "#ffffff",
                        "tertiary-fixed-dim": "#cec3d2",
                        "tertiary-container": "#a299a7",
                        "surface-container-lowest": "#ffffff",
                        "surface-bright": "#fff8f3",
                        "tertiary-fixed": "#eadfee",
                        "outline": "#83746f",
                        "on-surface-variant": "#514440",
                        "error-container": "#ffdad6",
                        "surface-container-highest": "#e8e1db",
                        "inverse-primary": "#f2baa8"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "2xl": "1rem",
                        "3xl": "1.5rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "stack-sm": "8px",
                        "stack-md": "16px",
                        "stack-lg": "32px",
                        "gutter": "24px",
                        "unit": "8px",
                        "section-gap": "120px",
                        "container-padding-desktop": "64px",
                        "container-padding-mobile": "20px"
                    },
                    "fontFamily": {
                        "display-lg": ["Playfair Display"],
                        "display-lg-mobile": ["Playfair Display"],
                        "headline-lg": ["Playfair Display"],
                        "headline-lg-mobile": ["Playfair Display"],
                        "headline-md": ["Playfair Display"],
                        "accent-italic": ["EB Garamond"],
                        "label-caps": ["DM Sans"],
                        "body-lg": ["DM Sans"],
                        "body-md": ["DM Sans"]
                    },
                    "fontSize": {
                        "display-lg": ["64px", {"lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                        "display-lg-mobile": ["40px", {"lineHeight": "1.2", "fontWeight": "700"}],
                        "headline-lg": ["40px", {"lineHeight": "1.2", "fontWeight": "600"}],
                        "headline-lg-mobile": ["32px", {"lineHeight": "1.2", "fontWeight": "600"}],
                        "headline-md": ["32px", {"lineHeight": "1.3", "fontWeight": "500"}],
                        "accent-italic": ["20px", {"lineHeight": "1.5", "fontWeight": "400"}],
                        "label-caps": ["12px", {"lineHeight": "1.2", "letterSpacing": "0.1em", "fontWeight": "700"}],
                        "body-lg": ["18px", {"lineHeight": "1.6", "fontWeight": "400"}],
                        "body-md": ["16px", {"lineHeight": "1.6", "fontWeight": "400"}]
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'DM Sans', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .shadow-ambient-1 { box-shadow: 0px 10px 30px rgba(196, 144, 128, 0.08); }
        .shadow-ambient-2 { box-shadow: 0px 20px 50px rgba(26, 16, 37, 0.1); }
        .shadow-level-1 { box-shadow: 0px 10px 30px rgba(26, 16, 37, 0.05); }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #fff8f3; }
        ::-webkit-scrollbar-thumb { background: #e8e1db; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #d5c2bd; }
        @@keyframes ticker { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
        @@keyframes shake { 10%, 90% { transform: translate3d(-1px, 0, 0); } 20%, 80% { transform: translate3d(2px, 0, 0); } 30%, 50%, 70% { transform: translate3d(-4px, 0, 0); } 40%, 60% { transform: translate3d(4px, 0, 0); } }
        @@keyframes slide-in { from { transform: translateY(100%); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        .toast { animation: slide-in 0.4s ease-out; }
        @@media (max-width: 768px) { .text-hero { font-size: 48px; } .text-statement { font-size: 36px; } }
        .text-hero { font-size: 80px; line-height: 1; font-weight: 700; font-family: 'Playfair Display', serif; }
        .text-statement { font-size: 56px; line-height: 1.2; font-style: italic; font-family: 'Playfair Display', serif; }
        .fade-in-section { opacity: 0; transform: translateY(20px); transition: opacity 0.8s ease-out, transform 0.8s ease-out; will-change: opacity, transform; }
        .fade-in-section.is-visible { opacity: 1; transform: none; }
        .fade-in-up { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
        .fade-in-up.visible { opacity: 1; transform: translateY(0); }
        .ease-tactile { transition-timing-function: cubic-bezier(0.25, 1, 0.5, 1); }
        .shadow-ambient-lvl1 { box-shadow: 0px 10px 30px rgba(26, 16, 37, 0.05); }
        details > summary { list-style: none; }
        details > summary::-webkit-details-marker { display: none; }
        .shadow-level-2:hover { box-shadow: 0px 20px 50px rgba(26, 16, 37, 0.08); transform: translateY(-2px); }
        .shake { animation: shake 0.82s cubic-bezier(.36,.07,.19,.97) both; transform: translate3d(0, 0, 0); backface-visibility: hidden; }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body class="bg-background text-on-background antialiased selection:bg-primary-container selection:text-on-primary-container min-h-screen flex flex-col">

<!-- ─── TOAST NOTIFICATIONS ──────────────────────────────────── -->
@if (TempData["success"] != null || TempData["error"] != null || TempData["info"] != null || TempData["Success"] != null || TempData["Error"] != null || TempData["Info"] != null)
{
    var msg = TempData["success"]?.ToString() ?? TempData["Success"]?.ToString();
    var err = TempData["error"]?.ToString() ?? TempData["Error"]?.ToString();
    var inf = TempData["info"]?.ToString() ?? TempData["Info"]?.ToString();
    if (msg != null)
    {
        <div class="toast fixed bottom-6 left-1/2 -translate-x-1/2 z-[100] flex items-center gap-3 bg-inverse-surface text-inverse-on-surface px-6 py-4 rounded-full shadow-level-1 font-body-md text-body-md max-w-sm text-center" id="toast-success" style="animation: slide-in 0.4s ease-out;">
            <span class="material-symbols-outlined text-[18px] text-primary-fixed-dim">check_circle</span>
            @msg
        </div>
        <script>setTimeout(() => { const t = document.getElementById('toast-success'); if(t) t.style.opacity='0'; }, 4000);</script>
    }
    if (err != null)
    {
        <div class="toast fixed bottom-6 left-1/2 -translate-x-1/2 z-[100] flex items-center gap-3 bg-error text-on-error px-6 py-4 rounded-full shadow-level-1 font-body-md text-body-md max-w-sm text-center" id="toast-error">
            <span class="material-symbols-outlined text-[18px]">error</span>
            @err
        </div>
        <script>setTimeout(() => { const t = document.getElementById('toast-error'); if(t) t.style.opacity='0'; }, 5000);</script>
    }
    if (inf != null)
    {
        <div class="toast fixed bottom-6 left-1/2 -translate-x-1/2 z-[100] flex items-center gap-3 bg-secondary-container text-on-secondary-container px-6 py-4 rounded-full shadow-level-1 font-body-md text-body-md max-w-sm text-center" id="toast-info">
            <span class="material-symbols-outlined text-[18px]">info</span>
            @inf
        </div>
        <script>setTimeout(() => { const t = document.getElementById('toast-info'); if(t) t.style.opacity='0'; }, 4000);</script>
    }
}

<!-- ─── NAVBAR ──────────────────────────────────────────────── -->
<header class="bg-surface/80 backdrop-blur-md sticky top-0 w-full z-50 border-b border-outline-variant/10 shadow-level-1">
    <nav class="flex justify-between items-center w-full px-container-padding-mobile md:px-container-padding-desktop h-20 max-w-7xl mx-auto">
        <!-- Mobile Menu Toggle -->
        <button class="md:hidden text-on-surface-variant hover:text-primary transition-colors duration-300" id="mobile-menu-btn" aria-label="Menu">
            <span class="material-symbols-outlined">menu</span>
        </button>
        <!-- Brand Logo -->
        <a class="font-accent-italic text-headline-md md:text-headline-lg italic text-primary hover:scale-105 transition-transform duration-200" href="@homeUrl">liora</a>
        <!-- Navigation Links (Desktop) -->
        <ul class="hidden md:flex items-center space-x-8">
            <li>
                <a class="font-label-caps text-label-caps @(IsActive(homeUrl) && !IsActive(shopUrl) ? "text-primary border-b-2 border-primary pb-1" : "text-on-surface-variant hover:text-primary transition-colors duration-300")" href="@homeUrl">HOME</a>
            </li>
            <li>
                <a class="font-label-caps text-label-caps @(IsActive(shopUrl) ? "text-primary border-b-2 border-primary pb-1" : "text-on-surface-variant hover:text-primary transition-colors duration-300")" href="@shopUrl">SHOP ALL</a>
            </li>
            @if (isAuthenticated)
            {
                <li>
                    <a class="font-label-caps text-label-caps @(IsActive(ordersUrl) ? "text-primary border-b-2 border-primary pb-1" : "text-on-surface-variant hover:text-primary transition-colors duration-300")" href="@ordersUrl">MY ORDERS</a>
                </li>
            }
        </ul>
        <!-- Trailing Icons -->
        <div class="flex items-center space-x-4 md:space-x-6 text-on-surface-variant">
            <a href="@cartUrl" aria-label="Cart" class="hover:text-primary hover:scale-105 transition-all duration-200 relative p-2">
                <span class="material-symbols-outlined">shopping_bag</span>
                @await Component.InvokeAsync("CartCount")
            </a>
            @if (isAuthenticated)
            {
                @if (User.IsInRole(LioraApp.Utilities.SD.Role_Admin))
                {
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" aria-label="Admin Dashboard" class="flex items-center gap-1 bg-primary/10 text-primary hover:bg-primary hover:text-white px-2 py-1 md:px-3 rounded-full transition-all duration-200" title="Admin Dashboard">
                        <span class="material-symbols-outlined text-[20px]">dashboard</span>
                        <span class="font-label-caps text-[11px] uppercase tracking-wider hidden md:block">Dashboard</span>
                    </a>
                }
                <a href="@profileUrl" aria-label="Profile" class="hidden md:block hover:text-primary hover:scale-105 transition-all duration-200">
                    <span class="material-symbols-outlined">person</span>
                </a>
                <form asp-area="Identity" asp-controller="Account" asp-action="Logout" method="post" class="hidden md:block">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="hover:text-primary hover:scale-105 transition-all duration-200 font-label-caps text-label-caps" title="Logout">
                        <span class="material-symbols-outlined">logout</span>
                    </button>
                </form>
            }
            else
            {
                <a href="@loginUrl" aria-label="Login" class="hidden md:flex items-center gap-1 hover:text-primary hover:scale-105 transition-all duration-200 font-label-caps text-label-caps">
                    <span class="material-symbols-outlined">login</span>
                    <span class="text-[11px] uppercase tracking-wider">Login</span>
                </a>
            }
            <button class="md:hidden hover:text-primary transition-colors duration-300" aria-label="Mobile Cart">
                <span class="material-symbols-outlined">shopping_bag</span>
            </button>
        </div>
    </nav>
    <!-- Mobile Menu -->
    <div class="hidden md:hidden bg-surface border-t border-outline-variant/10 px-container-padding-mobile py-stack-md" id="mobile-menu">
        <ul class="flex flex-col space-y-4">
            <li><a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary" href="@homeUrl">HOME</a></li>
            <li><a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary" href="@shopUrl">SHOP ALL</a></li>
            @if (isAuthenticated)
            {
                <li><a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary" href="@ordersUrl">MY ORDERS</a></li>
                <li><a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary" href="@profileUrl">PROFILE</a></li>
                <li>
                    <form asp-area="Identity" asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary">LOGOUT</button>
                    </form>
                </li>
            }
            else
            {
                <li><a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary" href="@loginUrl">LOGIN</a></li>
            }
        </ul>
    </div>
</header>

<!-- ─── PAGE BODY ─────────────────────────────────────────────── -->
@RenderBody()

<!-- ─── FOOTER ────────────────────────────────────────────────── -->
<footer class="bg-surface-container-high rounded-t-xl mt-stack-lg border-t border-outline-variant/10 shadow-[0_-8px_24px_rgba(196,144,128,0.08)]">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-stack-lg px-container-padding-mobile md:px-container-padding-desktop py-10 max-w-7xl mx-auto w-full">
        <div class="flex flex-col gap-4">
            <a class="font-accent-italic text-headline-md italic text-primary hover:opacity-80 transition-opacity" href="@homeUrl">liora</a>
            <p class="font-body-md text-body-md text-on-surface-variant max-w-xs leading-relaxed">Modern Egyptian Craftsmanship. Designed to flow with your life.</p>
        </div>
        <div class="col-span-1 md:col-span-2 grid grid-cols-2 gap-8">
            <div class="flex flex-col gap-3">
                <a class="font-label-caps text-label-caps @(IsActive(shopUrl) ? "text-primary font-bold" : "text-on-surface-variant hover:text-primary transition-colors")" href="@shopUrl">Shop All</a>
                @if (isAuthenticated)
                {
                    <a class="font-label-caps text-label-caps @(IsActive(ordersUrl) ? "text-primary font-bold" : "text-on-surface-variant hover:text-primary transition-colors")" href="@ordersUrl">My Orders</a>
                    <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors" href="@profileUrl">My Profile</a>
                }
                else
                {
                    <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors" href="@loginUrl">Login</a>
                }
            </div>
            <div class="flex flex-col gap-3">
                <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors" href="#">Privacy Policy</a>
                <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors" href="#">Shipping & Returns</a>
                <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors" href="#">Size Guide</a>
                <a class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors" href="#">Contact</a>
            </div>
        </div>
        <div class="col-span-1 md:col-span-3 mt-8 pt-6 border-t border-outline-variant/20 flex justify-between items-center">
            <p class="font-label-caps text-label-caps text-on-surface-variant">© @DateTime.Now.Year liora. All rights reserved.</p>
        </div>
    </div>
</footer>

<!-- ─── MOBILE BOTTOM NAV ─────────────────────────────────────── -->
<nav class="md:hidden fixed bottom-0 left-0 w-full h-[70px] bg-white border-t border-slate-100 flex items-center justify-around z-40 px-2 shadow-[0_-10px_40px_rgba(0,0,0,0.05)] pb-safe rounded-t-[20px]">
    <!-- Home -->
    <a href="@homeUrl" class="relative flex flex-col items-center justify-center w-full h-full group">
        @if(IsActive(homeUrl) && !IsActive(shopUrl)) {
            <div class="absolute -top-6 w-14 h-14 bg-primary text-white rounded-full flex items-center justify-center shadow-lg border-4 border-background transition-all duration-300">
                <span class="material-symbols-outlined text-[26px]">home</span>
            </div>
            <span class="text-[10px] mt-8 font-bold text-primary">Home</span>
        } else {
            <span class="material-symbols-outlined text-[24px] text-slate-400 group-hover:text-primary transition-colors">home</span>
            <span class="text-[10px] mt-1 font-medium text-slate-400 group-hover:text-primary transition-colors">Home</span>
        }
    </a>
    <!-- Shop All -->
    <a href="@shopUrl" class="relative flex flex-col items-center justify-center w-full h-full group">
        @if(IsActive(shopUrl)) {
            <div class="absolute -top-6 w-14 h-14 bg-primary text-white rounded-full flex items-center justify-center shadow-lg border-4 border-background transition-all duration-300">
                <span class="material-symbols-outlined text-[26px]">shopping_bag</span>
            </div>
            <span class="text-[10px] mt-8 font-bold text-primary">Shop</span>
        } else {
            <span class="material-symbols-outlined text-[24px] text-slate-400 group-hover:text-primary transition-colors">shopping_bag</span>
            <span class="text-[10px] mt-1 font-medium text-slate-400 group-hover:text-primary transition-colors">Shop</span>
        }
    </a>
    <!-- Dashboard (Only for Admin) -->
    @if (isAuthenticated && User.IsInRole(LioraApp.Utilities.SD.Role_Admin))
    {
        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="relative flex flex-col items-center justify-center w-full h-full group">
            <span class="material-symbols-outlined text-[24px] text-slate-400 group-hover:text-primary transition-colors">dashboard</span>
            <span class="text-[10px] mt-1 font-medium text-slate-400 group-hover:text-primary transition-colors">Dashboard</span>
        </a>
    }
    <!-- My Orders -->
    @if (isAuthenticated)
    {
        <a href="@ordersUrl" class="relative flex flex-col items-center justify-center w-full h-full group">
            @if(IsActive(ordersUrl)) {
                <div class="absolute -top-6 w-14 h-14 bg-primary text-white rounded-full flex items-center justify-center shadow-lg border-4 border-background transition-all duration-300">
                    <span class="material-symbols-outlined text-[26px]">receipt_long</span>
                </div>
                <span class="text-[10px] mt-8 font-bold text-primary">Orders</span>
            } else {
                <span class="material-symbols-outlined text-[24px] text-slate-400 group-hover:text-primary transition-colors">receipt_long</span>
                <span class="text-[10px] mt-1 font-medium text-slate-400 group-hover:text-primary transition-colors">Orders</span>
            }
        </a>
    }
    <!-- Profile -->
    <a href="@(isAuthenticated ? profileUrl : loginUrl)" class="relative flex flex-col items-center justify-center w-full h-full group">
        @if(IsActive(profileUrl)) {
            <div class="absolute -top-6 w-14 h-14 bg-primary text-white rounded-full flex items-center justify-center shadow-lg border-4 border-background transition-all duration-300">
                <span class="material-symbols-outlined text-[26px]">person</span>
            </div>
            <span class="text-[10px] mt-8 font-bold text-primary">Profile</span>
        } else {
            <span class="material-symbols-outlined text-[24px] text-slate-400 group-hover:text-primary transition-colors">person</span>
            <span class="text-[10px] mt-1 font-medium text-slate-400 group-hover:text-primary transition-colors">Profile</span>
        }
    </a>
</nav>

<!-- ─── SCRIPTS ───────────────────────────────────────────────── -->
<script>
    // Mobile Menu Toggle
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    if (menuBtn && mobileMenu) {
        menuBtn.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));
    }
    // Scroll Fade-In
    document.addEventListener("DOMContentLoaded", () => {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible', 'visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });
        document.querySelectorAll('.fade-in-section, .fade-in-up').forEach(el => observer.observe(el));
    });
</script>
@RenderSection("Scripts", required: false)
</body>
</html>
