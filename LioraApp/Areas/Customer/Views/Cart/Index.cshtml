@model LioraApp.ViewModels.Customer.CartIndexVM
@{
    Layout = "_CustomerLayout";
    ViewData["Title"] = "Your Cart";
    var itemCount = Model.Items.Sum(i => i.Quantity);
    var subtotal = Model.Items.Sum(i => i.Quantity * i.UnitPrice);
}

<main class="flex-grow w-full px-container-padding-mobile md:px-container-padding-desktop max-w-[1280px] mx-auto py-stack-lg md:py-section-gap">
<!-- Cart Layout: 2 Columns on Desktop, Stacked on Mobile -->
<div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter items-start fade-in-up">
<!-- LEFT COLUMN: Cart Items -->
<section class="lg:col-span-8 flex flex-col gap-stack-lg">
<header class="flex justify-between items-end border-b border-outline-variant/30 pb-stack-sm">
<h1 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface">Your Cart (@itemCount items)</h1>
</header>

@if (!Model.Items.Any())
{
    <div class="py-stack-lg text-center">
        <p class="font-body-lg text-on-surface-variant mb-4">Your cart is currently empty.</p>
        <a href="@Url.Action("Index", "Products", new { area = "Customer" })" class="inline-flex items-center gap-2 font-label-caps text-label-caps text-primary-container hover:text-primary transition-colors duration-250 ease-out group">
            <span class="material-symbols-outlined text-[16px] group-hover:-translate-x-1 transition-transform duration-250">arrow_back</span>
            Continue Shopping
        </a>
    </div>
}
else
{
    <div class="flex flex-col gap-stack-md" id="cart-items-container">
        @foreach (var item in Model.Items)
        {
            var imgSrc = item.ImageUrl ?? Url.Content("~/images/product-placeholder.svg");
            var itemSubtotal = item.Quantity * item.UnitPrice;

            <div class="flex items-center gap-stack-md py-stack-md border-b border-outline-variant/30 group" id="cart-item-@item.CartItemId">
            <div class="w-[80px] h-[100px] rounded-xl overflow-hidden bg-surface-container flex-shrink-0 relative shadow-[0px_10px_30px_rgba(26,16,37,0.05)]">
            <img alt="@item.ProductName" class="w-full h-full object-cover mix-blend-multiply group-hover:scale-105 transition-transform duration-500 ease-out" src="@imgSrc"/>
            </div>
            <div class="flex-grow flex flex-col gap-unit">
            <div class="flex justify-between items-start">
            <div>
            <h3 class="font-headline-md text-[16px] md:text-[18px] text-on-surface leading-snug">
                @if (item.GiftBundleId.HasValue)
                {
                    <text>@item.GiftBundleTitle</text>
                }
                else
                {
                    <text>@item.ProductName</text>
                }
            </h3>
            @if (!item.GiftBundleId.HasValue)
            {
                <p class="font-body-md text-[12px] text-on-surface-variant">Size: @item.Size | Color: @item.Color</p>
            }
            </div>
            <form method="post" asp-action="RemoveItem" asp-controller="Cart" asp-area="Customer">
                @Html.AntiForgeryToken()
                <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                <button type="submit" aria-label="Remove item" class="text-outline hover:text-primary-container transition-colors duration-250 ease-out p-1">
                <span class="material-symbols-outlined text-[20px]">close</span>
                </button>
            </form>
            </div>
            <div class="flex justify-between items-end mt-auto">
            <div class="flex items-center border border-outline-variant rounded-full bg-surface-container-low px-2 py-1">
            <button type="button" class="text-on-surface-variant hover:text-primary px-2 transition-colors duration-250 ease-out update-qty" data-id="@item.CartItemId" data-action="minus" data-max="@item.MaxStock"><span class="material-symbols-outlined text-[16px]">remove</span></button>
            <input type="text" class="qty-input bg-transparent font-body-md text-[14px] text-on-surface w-6 text-center border-none p-0 focus:ring-0" value="@item.Quantity" readonly />
            <button type="button" class="text-on-surface-variant hover:text-primary px-2 transition-colors duration-250 ease-out update-qty" data-id="@item.CartItemId" data-action="plus" data-max="@item.MaxStock"><span class="material-symbols-outlined text-[16px]">add</span></button>
            </div>
            <span class="font-body-lg text-[16px] text-primary-container font-medium item-subtotal" data-unitprice="@item.UnitPrice">@itemSubtotal.ToString("C")</span>
            </div>
            </div>
            </div>
        }
    </div>

    <!-- Continue Shopping Link -->
    <div class="mt-stack-sm flex justify-between items-center">
    <a class="inline-flex items-center gap-2 font-label-caps text-label-caps text-primary-container hover:text-primary transition-colors duration-250 ease-out group" href="@Url.Action("Index", "Products", new { area = "Customer" })">
    <span class="material-symbols-outlined text-[16px] group-hover:-translate-x-1 transition-transform duration-250">arrow_back</span>
                            Continue Shopping
                        </a>
    <form method="post" asp-action="ClearCart" asp-controller="Cart" asp-area="Customer">
        @Html.AntiForgeryToken()
        <button type="submit" class="font-label-caps text-[12px] text-on-surface-variant underline hover:text-error transition-colors">CLEAR CART</button>
    </form>
    </div>
}
</section>

<!-- RIGHT COLUMN: Order Summary -->
@if (Model.Items.Any())
{
<section class="lg:col-span-4 lg:sticky lg:top-28">
<div class="bg-on-secondary-fixed text-surface rounded-2xl p-stack-lg shadow-[0px_20px_50px_rgba(26,16,37,0.08)] flex flex-col gap-stack-md">
<h2 class="font-headline-md text-[24px] mb-2 text-surface-bright border-b border-surface/10 pb-stack-sm">Order Summary</h2>
<div class="flex justify-between items-center text-surface-variant font-body-md">
<span>Subtotal</span>
<span id="cart-subtotal">@subtotal.ToString("C")</span>
</div>
<div class="flex justify-between items-center text-surface-variant font-body-md">
<span>Shipping</span>
<span class="text-xs italic text-tertiary-fixed-dim">Calculated at checkout</span>
</div>
<div class="border-t border-surface/10 my-2"></div>
<div class="flex justify-between items-center text-surface-bright font-headline-md text-[20px]">
<span>Total</span>
<span class="text-primary-fixed-dim" id="cart-total">@subtotal.ToString("C")</span>
</div>

<!-- Checkout CTA -->
<a href="@Url.Action("Checkout", "Cart", new { area = "Customer" })" class="w-full bg-primary-container hover:bg-primary text-on-primary font-label-caps text-label-caps py-4 rounded-full mt-stack-sm transition-all duration-250 ease-out active:scale-[0.98] shadow-md shadow-primary-container/20 flex justify-center items-center gap-2">
                        PROCEED TO CHECKOUT
                        <span class="material-symbols-outlined text-[18px]">lock</span>
</a>

<!-- Trust Badges -->
<div class="mt-stack-md flex flex-col items-center gap-3">
<p class="font-body-md text-[12px] text-surface/60 flex items-center gap-1">
<span class="material-symbols-outlined text-[14px]">verified_user</span> Safe &amp; Easy Payment
                        </p>
<div class="flex gap-3 justify-center opacity-70 grayscale hover:grayscale-0 transition-all duration-500">
<div class="bg-surface rounded-full px-3 py-1 flex items-center justify-center text-on-surface text-[10px] font-bold h-6">V-CASH</div>
<div class="bg-surface rounded-full px-3 py-1 flex items-center justify-center text-on-surface text-[10px] font-bold h-6">INSTAPAY</div>
<div class="bg-surface rounded-full px-3 py-1 flex items-center justify-center text-on-surface text-[10px] font-bold h-6">COD</div>
</div>
</div>
</div>
</section>
}
</div>
</main>

@Html.AntiForgeryToken()

@section Scripts {
<script>
    document.querySelectorAll('.update-qty').forEach(btn => {
        btn.addEventListener('click', async function() {
            const action = this.dataset.action;
            const itemId = this.dataset.id;
            const max = parseInt(this.dataset.max);
            const container = this.closest('div');
            const input = container.querySelector('.qty-input');
            let currentQty = parseInt(input.value);

            if (action === 'plus' && currentQty < max) {
                currentQty++;
            } else if (action === 'minus' && currentQty > 1) {
                currentQty--;
            } else {
                return;
            }

            const formData = new FormData();
            formData.append('cartItemId', itemId);
            formData.append('quantity', currentQty);
            formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

            try {
                const response = await fetch('@Url.Action("UpdateQuantity", "Cart", new { area = "Customer" })', {
                    method: 'POST',
                    body: formData
                });
                
                if (response.ok) {
                    const data = await response.json();
                    if (data.success) {
                        window.location.reload();
                    } else {
                        alert(data.message);
                    }
                }
            } catch (err) {
                console.error(err);
            }
        });
    });
</script>
}