@model CheckoutVM
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> SR
@{
    ViewData["Title"] = SR["Checkout"];
    var items = Model?.Items ?? [];
    var addresses = Model?.Addresses ?? [];
    var subtotal = Model?.Subtotal ?? 0m;
    var total = Model?.Total ?? subtotal;
    var selectedAddressId = Model?.AddressId ?? Model?.DefaultAddressId;
    var couponCode = Model?.CouponCode ?? string.Empty;
    var paymentMethod = Model?.PaymentMethod ?? "CashOnDelivery";
    var showNewAddressForm = Model?.ShowNewAddressForm == true || !addresses.Any();
}

<section class="mx-auto w-full max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-6 flex items-center justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-slate-900">@SR["Checkout"]</h1>
            <p class="mt-2 text-sm text-slate-500">@SR["CheckoutDescription"]</p>
        </div>
        <a asp-area="Customer"
           asp-controller="Cart"
           asp-action="Index"
           class="inline-flex items-center gap-1 text-sm font-medium text-primary transition hover:underline">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            @SR["BackToCart"]
        </a>
    </div>

    <form id="place-order-form"
          asp-area="Customer"
          asp-controller="Orders"
          asp-action="PlaceOrder"
          method="post"
          class="flex flex-col gap-8 lg:flex-row lg:items-start">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="ShowNewAddressForm" value="@(showNewAddressForm ? "true" : "false")" />

        <div class="flex-1 space-y-8">
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700"></div>
            }

            <section class="rounded-[1.75rem] bg-slate-100/80 p-5 sm:p-6 lg:p-8">
                <div class="mb-6 flex items-center gap-3">
                    <div class="flex h-8 w-8 items-center justify-center rounded-full bg-primary font-bold text-white">1</div>
                    <h2 class="text-xl font-semibold text-slate-900">@SR["ShippingAddress"]</h2>
                </div>

                @if (addresses.Any())
                {
                    <div class="space-y-4">
                        @foreach (var address in addresses)
                        {
                            <div class="relative overflow-hidden rounded-2xl border border-slate-200 bg-white p-5 shadow-[0_20px_40px_rgba(15,23,42,0.04)] transition hover:border-primary/30 @(address.Id == selectedAddressId ? "border-primary/30 ring-2 ring-primary/10" : "")"
                                 data-address-card>
                                <input type="radio"
                                       asp-for="AddressId"
                                       value="@address.Id"
                                       class="sr-only"
                                       data-saved-address-radio />

                                <div class="block cursor-pointer" data-select-address>
                                    <div class="flex items-start justify-between gap-4">
                                        <div>
                                            <div class="flex items-center gap-2">
                                                <p class="font-semibold text-slate-900">@address.FullName</p>
                                                @if (address.IsDefault)
                                                {
                                                    <span class="rounded-full bg-primary/10 px-2 py-1 text-[11px] font-semibold text-primary" data-default-badge>@SR["Default"]</span>
                                                }
                                            </div>
                                            <p class="mt-2 text-sm leading-6 text-slate-500">
                                                @address.PhoneNumber<br />
                                                @address.DisplayLine
                                            </p>
                                        </div>

                                        <div class="mt-1 flex h-5 w-5 items-center justify-center rounded-full border-2 @(address.Id == selectedAddressId ? "border-primary" : "border-slate-300")" data-address-indicator>
                                            <div class="h-2.5 w-2.5 rounded-full bg-primary @(address.Id == selectedAddressId ? "" : "hidden")" data-address-indicator-dot></div>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-4 flex justify-end">
                                    <button type="submit"
                                            formaction="@Url.Action("DeleteAddress", "Orders", new { area = "Customer" })"
                                            formmethod="post"
                                            name="deleteAddressId"
                                            value="@address.Id"
                                            data-delete-address-button
                                            class="inline-flex items-center gap-2 rounded-xl bg-rose-50 px-3 py-2 text-xs font-semibold text-rose-600 transition hover:bg-rose-100"
                                            title="@SR["DeleteAddress"]">
                                        <span class="material-symbols-outlined text-[16px]">delete</span>
                                        @SR["Delete"]
                                    </button>
                                </div>
                            </div>
                        }

                        <span asp-validation-for="AddressId" class="block text-sm text-rose-600"></span>
                    </div>

                    <button type="submit"
                            id="select-saved-address-submit"
                            formaction="@Url.Action("SelectSavedAddress", "Orders", new { area = "Customer" })"
                            formmethod="post"
                            class="hidden">
                    </button>

                    <div class="mt-4">
                        <button type="button"
                                id="toggle-new-address"
                                class="inline-flex items-center gap-2 rounded-2xl border border-primary/15 bg-primary/5 px-4 py-2.5 text-sm font-semibold text-primary transition hover:bg-primary/10">
                            <span class="material-symbols-outlined text-[18px]">add_circle</span>
                            @SR["AddNewAddress"]
                        </button>
                    </div>
                }
                <div id="new-address-panel" class="@(showNewAddressForm ? "mt-5" : "hidden mt-5")">
                    <div class="space-y-5 rounded-[1.5rem] border border-primary/20 bg-white p-5 shadow-[0_20px_40px_rgba(15,23,42,0.06)]">
                        <div class="flex items-center gap-2">
                            <div class="flex items-center gap-2">
                                <div class="flex h-5 w-5 items-center justify-center rounded-full border-2 border-primary">
                                    <div class="h-2.5 w-2.5 rounded-full bg-primary"></div>
                                </div>
                                <h3 class="font-semibold text-primary">@SR["AddNewAddress"]</h3>
                            </div>
                        </div>

                        @if (addresses.Any())
                        {
                            <p class="text-sm leading-6 text-slate-500">@SR["AddNewAddressHelp"]</p>
                        }

                        <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
                            <div class="space-y-1.5">
                                <label asp-for="NewAddressFullName" class="text-sm font-medium text-slate-800">@SR["FullName"]</label>
                                <input asp-for="NewAddressFullName" class="w-full rounded-xl border-slate-300 bg-white px-3 py-2.5 text-slate-900 shadow-sm focus:border-primary focus:ring-primary/20" placeholder="@SR["FullNamePlaceholder"]" />
                                <span asp-validation-for="NewAddressFullName" class="text-sm text-rose-600"></span>
                            </div>

                            <div class="space-y-1.5">
                                <label asp-for="NewAddressPhoneNumber" class="text-sm font-medium text-slate-800">@SR["PhoneNumber"]</label>
                                <input asp-for="NewAddressPhoneNumber" class="w-full rounded-xl border-slate-300 bg-white px-3 py-2.5 text-slate-900 shadow-sm focus:border-primary focus:ring-primary/20" placeholder="@SR["PhoneNumberPlaceholder"]" />
                                <span asp-validation-for="NewAddressPhoneNumber" class="text-sm text-rose-600"></span>
                            </div>
                        </div>

                        <div class="space-y-1.5">
                            <label asp-for="NewAddressStreet" class="text-sm font-medium text-slate-800">@SR["StreetAddress"]</label>
                            <input asp-for="NewAddressStreet" class="w-full rounded-xl border-slate-300 bg-white px-3 py-2.5 text-slate-900 shadow-sm focus:border-primary focus:ring-primary/20" placeholder="@SR["StreetAddressPlaceholder"]" />
                            <span asp-validation-for="NewAddressStreet" class="text-sm text-rose-600"></span>
                        </div>

                        <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
                            <div class="space-y-1.5">
                                <label asp-for="NewAddressCity" class="text-sm font-medium text-slate-800">@SR["City"]</label>
                                <input asp-for="NewAddressCity" class="w-full rounded-xl border-slate-300 bg-white px-3 py-2.5 text-slate-900 shadow-sm focus:border-primary focus:ring-primary/20" placeholder="@SR["CityPlaceholder"]" />
                                <span asp-validation-for="NewAddressCity" class="text-sm text-rose-600"></span>
                            </div>

                            <div class="space-y-1.5">
                                <label asp-for="NewAddressState" class="text-sm font-medium text-slate-800">@SR["StateProvince"]</label>
                                <input asp-for="NewAddressState" class="w-full rounded-xl border-slate-300 bg-white px-3 py-2.5 text-slate-900 shadow-sm focus:border-primary focus:ring-primary/20" placeholder="@SR["StateProvincePlaceholder"]" />
                                <span asp-validation-for="NewAddressState" class="text-sm text-rose-600"></span>
                            </div>

                            <div class="space-y-1.5">
                                <label asp-for="NewAddressPostalCode" class="text-sm font-medium text-slate-800">@SR["PostalCode"]</label>
                                <input asp-for="NewAddressPostalCode" class="w-full rounded-xl border-slate-300 bg-white px-3 py-2.5 text-slate-900 shadow-sm focus:border-primary focus:ring-primary/20" placeholder="@SR["PostalCodePlaceholder"]" />
                                <span asp-validation-for="NewAddressPostalCode" class="text-sm text-rose-600"></span>
                            </div>
                        </div>

                        <div class="space-y-1.5">
                            <label asp-for="NewAddressCountry" class="text-sm font-medium text-slate-800">@SR["Country"]</label>
                            <input asp-for="NewAddressCountry" class="w-full rounded-xl border-slate-300 bg-white px-3 py-2.5 text-slate-900 shadow-sm focus:border-primary focus:ring-primary/20" placeholder="@SR["CountryPlaceholder"]" />
                            <span asp-validation-for="NewAddressCountry" class="text-sm text-rose-600"></span>
                        </div>

                        <label class="flex items-center gap-3 rounded-xl bg-slate-50 px-4 py-3 text-sm text-slate-600">
                            <input asp-for="SaveNewAddress" class="h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary" />
                            <span>@SR["SaveAsDefaultAddressForFutureOrders"]</span>
                        </label>

                        <div class="flex flex-wrap items-center justify-end gap-3 border-t border-slate-100 pt-2">
                            @if (addresses.Any())
                            {
                                <button type="button"
                                        id="cancel-new-address"
                                        class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-600 transition hover:bg-slate-50">
                                    <span class="material-symbols-outlined text-[18px]">close</span>
                                    @SR["Cancel"]
                                </button>
                            }
                            <button type="submit"
                                    formaction="@Url.Action("UseNewAddress", "Orders", new { area = "Customer" })"
                                    formmethod="post"
                                    class="inline-flex items-center gap-2 rounded-xl bg-gradient-to-br from-primary to-primary px-4 py-2.5 text-sm font-semibold text-white shadow-[0_10px_20px_rgba(70,72,212,0.16)] transition hover:opacity-95">
                                <span class="material-symbols-outlined text-[18px]">check_circle</span>
                                @SR["SaveAddress"]
                            </button>
                        </div>
                    </div>
                </div>
            </section>

            <section class="rounded-[1.75rem] bg-slate-100/80 p-5 sm:p-6 lg:p-8">
                <div class="mb-6 flex items-center gap-3">
                    <div class="flex h-8 w-8 items-center justify-center rounded-full bg-primary font-bold text-white">2</div>
                    <h2 class="text-xl font-semibold text-slate-900">@SR["PaymentMethod"]</h2>
                </div>

                <div class="space-y-4">
                    <label class="cursor-pointer">
                        <input asp-for="PaymentMethod" type="radio" value="CashOnDelivery" class="sr-only peer" />
                        <span class="flex items-center justify-between gap-4 rounded-2xl border border-slate-200 bg-white px-5 py-5 shadow-[0_20px_40px_rgba(15,23,42,0.04)] transition peer-checked:border-primary peer-checked:bg-white peer-checked:ring-2 peer-checked:ring-primary/10 peer-checked:[&_[data-payment-indicator]]:border-primary peer-checked:[&_[data-payment-indicator]]:bg-primary/5 peer-checked:[&_[data-payment-indicator-dot]]:scale-100 peer-checked:[&_[data-payment-indicator-dot]]:opacity-100">
                            <span class="flex items-center gap-4">
                                <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-primary text-white shadow-md shadow-primary/20">
                                    <span class="material-symbols-outlined text-[22px]">local_shipping</span>
                                </span>
                                <span class="space-y-1">
                                    <span class="block text-xl font-semibold text-slate-900">@SR["CashOnDelivery"]</span>
                                    <span class="block text-sm leading-6 text-slate-500">@SR["PayWithCashOnDelivery"]</span>
                                </span>
                            </span>
                            <span data-payment-indicator class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-slate-300 transition">
                                <span data-payment-indicator-dot class="h-3.5 w-3.5 scale-50 rounded-full bg-primary opacity-0 transition duration-200"></span>
                            </span>
                        </span>
                    </label>

                    <label class="cursor-pointer">
                        <input asp-for="PaymentMethod" type="radio" value="VodafoneCash" class="sr-only peer" />
                        <span class="flex items-center justify-between gap-4 rounded-2xl border border-slate-200 bg-white px-5 py-5 shadow-[0_20px_40px_rgba(15,23,42,0.04)] transition peer-checked:border-primary peer-checked:bg-white peer-checked:ring-2 peer-checked:ring-primary/10 peer-checked:[&_[data-payment-indicator]]:border-primary peer-checked:[&_[data-payment-indicator]]:bg-primary/5 peer-checked:[&_[data-payment-indicator-dot]]:scale-100 peer-checked:[&_[data-payment-indicator-dot]]:opacity-100">
                            <span class="flex items-center gap-4">
                                <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-600 text-white shadow-md shadow-emerald-600/20">
                                    <span class="material-symbols-outlined text-[22px]">phone_iphone</span>
                                </span>
                                <span class="space-y-1">
                                    <span class="block text-xl font-semibold text-slate-900">Vodafone Cash</span>
                                    <span class="block text-sm leading-6 text-slate-500">Pay manually and upload/send the transfer proof.</span>
                                </span>
                            </span>
                            <span data-payment-indicator class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-slate-300 transition">
                                <span data-payment-indicator-dot class="h-3.5 w-3.5 scale-50 rounded-full bg-primary opacity-0 transition duration-200"></span>
                            </span>
                        </span>
                    </label>

                    <label class="cursor-pointer">
                        <input asp-for="PaymentMethod" type="radio" value="InstaPay" class="sr-only peer" />
                        <span class="flex items-center justify-between gap-4 rounded-2xl border border-slate-200 bg-white px-5 py-5 shadow-[0_20px_40px_rgba(15,23,42,0.04)] transition peer-checked:border-primary peer-checked:bg-white peer-checked:ring-2 peer-checked:ring-primary/10 peer-checked:[&_[data-payment-indicator]]:border-primary peer-checked:[&_[data-payment-indicator]]:bg-primary/5 peer-checked:[&_[data-payment-indicator-dot]]:scale-100 peer-checked:[&_[data-payment-indicator-dot]]:opacity-100">
                            <span class="flex items-center gap-4">
                                <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-violet-600 text-white shadow-md shadow-violet-600/20">
                                    <span class="material-symbols-outlined text-[22px]">account_balance_wallet</span>
                                </span>
                                <span class="space-y-1">
                                    <span class="block text-xl font-semibold text-slate-900">InstaPay</span>
                                    <span class="block text-sm leading-6 text-slate-500">Transfer manually, then wait for admin confirmation.</span>
                                </span>
                            </span>
                            <span data-payment-indicator class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-slate-300 transition">
                                <span data-payment-indicator-dot class="h-3.5 w-3.5 scale-50 rounded-full bg-primary opacity-0 transition duration-200"></span>
                            </span>
                        </span>
                    </label>
                </div>

                @if (paymentMethod == "VodafoneCash" || paymentMethod == "InstaPay")
                {
                    <p class="mt-4 text-sm text-slate-500">Manual payments stay pending until the admin confirms the transfer.</p>
                }
            </section>
        </div>

        <aside class="w-full lg:w-96 lg:flex-shrink-0">
            <div class="sticky top-24 rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-[0_20px_40px_rgba(15,23,42,0.05)]">
                <h2 class="mb-6 text-lg font-semibold text-slate-900">@SR["OrderSummary"]</h2>

                <div class="mb-6 space-y-4">
                    @foreach (var item in items)
                    {
                        @if (item.IsGiftBundle)
                        {
                            <div class="rounded-2xl border border-primary/10 bg-primary/5 p-4">
                                <div class="flex items-start justify-between gap-3">
                                    <div>
                                        <span class="rounded-full bg-primary/10 px-2.5 py-1 text-[10px] font-black uppercase tracking-[0.16em] text-primary">Gift Bundle</span>
                                        <h3 class="mt-2 text-base font-bold text-slate-900">@item.GiftBundleTitle</h3>
                                    </div>
                                    <div class="text-right">
                                        <p class="font-semibold text-slate-900">@item.LineTotal.ToString("0.00") EGP</p>
                                        @if (item.GiftBundleOriginalTotal.HasValue && item.GiftBundleOriginalTotal.Value > item.PriceSnapshot)
                                        {
                                            <p class="text-xs text-slate-400 line-through">@item.GiftBundleOriginalTotal.Value.ToString("0.00") EGP</p>
                                        }
                                    </div>
                                </div>

                                <div class="mt-4 space-y-3">
                                    @foreach (var bundleProduct in item.BundleItems)
                                    {
                                        <div class="flex gap-3 rounded-xl border border-white/70 bg-white/80 p-3">
                                            <div class="h-14 w-14 flex-shrink-0 overflow-hidden rounded-xl bg-white">
                                                <img src="@(bundleProduct.ImageUrl ?? "https://placehold.co/100")"
                                                     alt="@bundleProduct.ProductName"
                                                     class="h-full w-full object-cover" />
                                            </div>
                                            <div class="min-w-0">
                                                <p class="line-clamp-1 text-sm font-semibold text-slate-900">@bundleProduct.ProductName</p>
                                                <p class="mt-1 text-xs text-slate-500">@bundleProduct.Size / @bundleProduct.Color</p>
                                            </div>
                                        </div>
                                    }
                                </div>

                                <div class="mt-4 flex items-center justify-between gap-2 text-sm">
                                    <span class="text-slate-500">@SR["QuantityShort"] @item.Quantity</span>
                                    <span class="font-semibold text-primary">@item.PriceSnapshot.ToString("0.00") EGP per bundle</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="flex gap-4 rounded-2xl border border-slate-100 bg-slate-50 p-3">
                                <div class="h-20 w-20 flex-shrink-0 overflow-hidden rounded-xl bg-white">
                                    <img src="@(item.ImageUrl ?? "https://placehold.co/100")"
                                         alt="@item.ProductName"
                                         class="h-full w-full object-cover" />
                                </div>
                                <div class="flex flex-1 flex-col justify-between">
                                    <div>
                                        <h3 class="line-clamp-1 font-medium text-slate-900">@item.ProductName</h3>
                                        <p class="mt-1 text-sm text-slate-500">@item.Size / @item.Color</p>
                                    </div>
                                    <div class="flex items-center justify-between gap-2">
                                        <span class="text-sm text-slate-500">@SR["QuantityShort"] @item.Quantity</span>
                                        <span class="font-semibold text-slate-900">@item.LineTotal.ToString("0.00") EGP</span>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>

                <div class="mb-6 rounded-2xl border border-slate-200 bg-slate-50 p-4">
                    <div class="mb-3 flex items-center justify-between gap-2">
                        <label asp-for="CouponCode" class="text-sm font-semibold text-slate-800">@SR["DiscountCode"]</label>
                        @if (Model?.CouponApplied == true)
                        {
                            <span class="rounded-full bg-emerald-100 px-2.5 py-1 text-[11px] font-semibold text-emerald-700">@SR["Applied"]</span>
                        }
                    </div>

                    <div class="flex gap-2">
                        <input asp-for="CouponCode"
                               placeholder="@SR["DiscountCode"]"
                               class="w-full rounded-xl border-slate-300 bg-white text-sm shadow-sm focus:border-primary focus:ring-primary/20" />
                        <button type="submit"
                                formmethod="get"
                                formaction="@Url.Action("Checkout", "Orders", new { area = "Customer" })"
                                class="rounded-xl bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-300">
                            @SR["Apply"]
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model?.CouponMessage))
                    {
                        <p class="mt-3 text-sm @(Model?.CouponApplied == true ? "text-emerald-600" : "text-rose-600")">
                            @Model?.CouponMessage
                        </p>
                    }
                </div>

                <div class="mb-6 space-y-3 border-b border-slate-200 pb-5 text-sm">
                    <div class="flex items-center justify-between">
                        <span class="text-slate-500">@SR["ItemsCount"]</span>
                        <span class="font-medium text-slate-900">@Model?.ItemsCount</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-slate-500">@SR["Subtotal"]</span>
                        <span class="font-medium text-slate-900">@subtotal.ToString("0.00") EGP</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-slate-500">@SR["Discount"]</span>
                        <span class="font-medium text-slate-900">@((Model?.DiscountAmount ?? 0m).ToString("0.00")) EGP</span>
                    </div>
                    @if (Model?.CouponApplied == true && !string.IsNullOrWhiteSpace(Model.CouponCode))
                    {
                        <div class="flex items-center justify-between">
                            <span class="text-slate-500">@SR["Code"]</span>
                            <span class="font-medium text-emerald-600">@Model.CouponCode</span>
                        </div>
                    }
                </div>

                <div class="mb-6 flex items-end justify-between gap-3">
                    <span class="text-lg font-semibold text-slate-900">@SR["Total"]</span>
                    <div class="text-right">
                        <span class="mr-1 text-xs text-slate-400">EGP</span>
                        <span class="text-2xl font-bold text-slate-900">@total.ToString("0.00")</span>
                    </div>
                </div>

                <button type="submit"
                        class="flex w-full items-center justify-center gap-2 rounded-2xl bg-gradient-to-br from-primary to-primary py-3.5 text-base font-semibold text-white shadow-[0_10px_20px_rgba(70,72,212,0.18)] transition hover:opacity-95">
                    <span class="material-symbols-outlined text-xl" style="font-variation-settings:'FILL' 1">lock</span>
                    @SR["PlaceOrder"]
                </button>
            </div>
        </aside>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const showNewAddressInput = document.getElementById('ShowNewAddressForm');
        const newAddressPanel = document.getElementById('new-address-panel');
        const toggleNewAddressButton = document.getElementById('toggle-new-address');
        const cancelNewAddressButton = document.getElementById('cancel-new-address');
        const selectSavedAddressSubmit = document.getElementById('select-saved-address-submit');
        const savedAddressRadios = Array.from(document.querySelectorAll('[data-saved-address-radio]'));
        const deleteAddressButtons = Array.from(document.querySelectorAll('[data-delete-address-button]'));
        const newAddressFullNameInput = document.getElementById('NewAddressFullName');
        const newAddressPhoneNumberInput = document.getElementById('NewAddressPhoneNumber');
        const newAddressStreetInput = document.getElementById('NewAddressStreet');
        const newAddressCityInput = document.getElementById('NewAddressCity');
        const newAddressStateInput = document.getElementById('NewAddressState');
        const newAddressCountryInput = document.getElementById('NewAddressCountry');
        const newAddressPostalCodeInput = document.getElementById('NewAddressPostalCode');
        const saveNewAddressInput = document.getElementById('SaveNewAddress');
        const defaultCountryValue = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model?.NewAddressCountry ?? "Egypt"));

        function setNewAddressPanelState(visible) {
            if (!newAddressPanel || !showNewAddressInput) return;

            newAddressPanel.classList.toggle('hidden', !visible);
            showNewAddressInput.value = visible ? 'true' : 'false';
        }

        function clearNewAddressInputs() {
            if (newAddressFullNameInput) newAddressFullNameInput.value = '';
            if (newAddressPhoneNumberInput) newAddressPhoneNumberInput.value = '';
            if (newAddressStreetInput) newAddressStreetInput.value = '';
            if (newAddressCityInput) newAddressCityInput.value = '';
            if (newAddressStateInput) newAddressStateInput.value = '';
            if (newAddressPostalCodeInput) newAddressPostalCodeInput.value = '';
            if (newAddressCountryInput) newAddressCountryInput.value = defaultCountryValue;
            if (saveNewAddressInput) saveNewAddressInput.checked = true;
        }

        function refreshAddressSelectionUi() {
            savedAddressRadios.forEach(function (radio) {
                const card = radio.closest('[data-address-card]');
                const indicator = card?.querySelector('[data-address-indicator]');
                const indicatorDot = card?.querySelector('[data-address-indicator-dot]');

                if (!card || !indicator || !indicatorDot) return;

                card.classList.toggle('border-primary/30', radio.checked);
                card.classList.toggle('ring-2', radio.checked);
                card.classList.toggle('ring-primary/10', radio.checked);
                card.classList.toggle('border-slate-200', !radio.checked);

                indicator.classList.toggle('border-primary', radio.checked);
                indicator.classList.toggle('border-slate-300', !radio.checked);
                indicatorDot.classList.toggle('hidden', !radio.checked);
            });
        }

        toggleNewAddressButton?.addEventListener('click', function () {
            setNewAddressPanelState(true);
        });

        cancelNewAddressButton?.addEventListener('click', function () {
            clearNewAddressInputs();
            setNewAddressPanelState(false);

            const checkedAddress = savedAddressRadios.find(radio => radio.checked);
            if (!checkedAddress && savedAddressRadios.length > 0) {
                savedAddressRadios[0].checked = true;
            }

            refreshAddressSelectionUi();
        });

        savedAddressRadios.forEach(function (radio) {
            const card = radio.closest('[data-address-card]');
            const selectArea = card?.querySelector('[data-select-address]');

            selectArea?.addEventListener('click', function () {
                if (!radio.checked) {
                    radio.checked = true;
                    setNewAddressPanelState(false);
                    refreshAddressSelectionUi();
                    selectSavedAddressSubmit?.click();
                }
            });

            radio.addEventListener('change', function () {
                setNewAddressPanelState(false);
                refreshAddressSelectionUi();
                selectSavedAddressSubmit?.click();
            });
        });

        deleteAddressButtons.forEach(function (button) {
            button.addEventListener('click', function (event) {
                event.preventDefault();
                event.stopPropagation();

                const form = button.form;
                if (!form) return;

                const action = button.getAttribute('formaction');
                const method = button.getAttribute('formmethod');

                if (action) {
                    form.action = action;
                }

                if (method) {
                    form.method = method;
                }

                form.submit();
            });
        });

        refreshAddressSelectionUi();
    </script>
}
