@model LioraApp.ViewModels.Customer.CheckoutVM
@{
    Layout = "_CustomerLayout";
    ViewData["Title"] = "Checkout";
}

<main class="min-h-screen pt-12 pb-section-gap px-container-padding-mobile md:px-container-padding-desktop max-w-7xl mx-auto">
<!-- Top: Progress Indicator -->
<div class="flex justify-center space-x-2 md:space-x-6 mb-stack-lg md:mb-section-gap">
<div class="px-6 py-2 rounded-full border border-outline-variant text-on-surface-variant bg-surface-container-lowest font-label-caps text-label-caps transition-all duration-250">Cart</div>
<div class="px-6 py-2 rounded-full bg-primary-container text-on-primary-container font-label-caps text-label-caps shadow-[0_10px_30px_rgba(26,16,37,0.05)] transition-all duration-250">Checkout</div>
<div class="px-6 py-2 rounded-full border border-outline-variant text-on-surface-variant bg-surface-container-lowest font-label-caps text-label-caps transition-all duration-250 opacity-50">Confirm</div>
</div>

@if (TempData["error"] != null)
{
    <div class="mb-4 p-4 text-error-container bg-error rounded-xl font-body-md text-center">
        @TempData["error"]
    </div>
}
@if (TempData["success"] != null)
{
    <div class="mb-4 p-4 text-on-primary bg-primary rounded-xl font-body-md text-center">
        @TempData["success"]
    </div>
}

<form method="post" asp-controller="Orders" asp-action="PlaceOrder" id="checkout-form">
    @Html.AntiForgeryToken()

<div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter lg:gap-[64px]">
<!-- Left Column: Forms -->
<div class="lg:col-span-7 xl:col-span-8 flex flex-col space-y-section-gap">

<!-- Shipping Details -->
<section>
<div class="flex items-baseline justify-between mb-stack-md">
<h2 class="font-headline-md text-headline-md text-on-surface">Shipping Details</h2>
@if (Model.Addresses.Any() && Model.ShowNewAddressForm)
{
    <button type="button" onclick="document.getElementById('show-saved-addresses').submit();" class="font-body-sm text-body-md text-on-surface-variant hover:text-primary transition-colors duration-250 underline">Use Saved Address</button>
}
else if (!Model.ShowNewAddressForm)
{
    <button type="button" onclick="document.getElementById('show-new-address').submit();" class="font-body-sm text-body-md text-on-surface-variant hover:text-primary transition-colors duration-250 underline">+ Add New Address</button>
}
</div>

@if (Model.ShowNewAddressForm)
{
    <div class="grid grid-cols-1 md:grid-cols-2 gap-stack-md">
        <div class="flex flex-col">
            <label class="font-label-caps text-label-caps text-on-surface-variant mb-2 ml-2">Full Name</label>
            <input asp-for="NewAddressFullName" class="w-full bg-surface-container-lowest border border-on-surface/20 rounded-xl px-4 py-3 font-body-md text-body-md text-on-surface focus:border-primary-container focus:ring-4 focus:ring-primary-container/20 transition-all duration-250 outline-none" placeholder="e.g. Laila Hassan" type="text"/>
            <span asp-validation-for="NewAddressFullName" class="text-error text-sm mt-1"></span>
        </div>
        <div class="flex flex-col">
            <label class="font-label-caps text-label-caps text-on-surface-variant mb-2 ml-2">Phone Number</label>
            <input asp-for="NewAddressPhoneNumber" class="w-full bg-surface-container-lowest border border-on-surface/20 rounded-xl px-4 py-3 font-body-md text-body-md text-on-surface focus:border-primary-container focus:ring-4 focus:ring-primary-container/20 transition-all duration-250 outline-none" placeholder="+20 100 123 4567" type="tel"/>
            <span asp-validation-for="NewAddressPhoneNumber" class="text-error text-sm mt-1"></span>
        </div>
        <div class="flex flex-col md:col-span-2">
            <label class="font-label-caps text-label-caps text-on-surface-variant mb-2 ml-2">Street Address</label>
            <input asp-for="NewAddressStreet" class="w-full bg-surface-container-lowest border border-on-surface/20 rounded-xl px-4 py-3 font-body-md text-body-md text-on-surface focus:border-primary-container focus:ring-4 focus:ring-primary-container/20 transition-all duration-250 outline-none" placeholder="123 Zamalek St, Apt 4" type="text"/>
            <span asp-validation-for="NewAddressStreet" class="text-error text-sm mt-1"></span>
        </div>
        <div class="flex flex-col">
            <label class="font-label-caps text-label-caps text-on-surface-variant mb-2 ml-2">City</label>
            <input asp-for="NewAddressCity" class="w-full bg-surface-container-lowest border border-on-surface/20 rounded-xl px-4 py-3 font-body-md text-body-md text-on-surface focus:border-primary-container focus:ring-4 focus:ring-primary-container/20 transition-all duration-250 outline-none" placeholder="Cairo" type="text"/>
            <span asp-validation-for="NewAddressCity" class="text-error text-sm mt-1"></span>
        </div>
        <div class="flex flex-col">
            <label class="font-label-caps text-label-caps text-on-surface-variant mb-2 ml-2">State (Optional)</label>
            <input asp-for="NewAddressState" class="w-full bg-surface-container-lowest border border-on-surface/20 rounded-xl px-4 py-3 font-body-md text-body-md text-on-surface focus:border-primary-container focus:ring-4 focus:ring-primary-container/20 transition-all duration-250 outline-none" placeholder="Cairo" type="text"/>
        </div>
        <div class="flex flex-col">
            <label class="font-label-caps text-label-caps text-on-surface-variant mb-2 ml-2">Country</label>
            <input asp-for="NewAddressCountry" class="w-full bg-surface-container-lowest border border-on-surface/20 rounded-xl px-4 py-3 font-body-md text-body-md text-on-surface focus:border-primary-container focus:ring-4 focus:ring-primary-container/20 transition-all duration-250 outline-none" type="text" value="Egypt" readonly/>
        </div>
        <div class="flex flex-col">
            <label class="font-label-caps text-label-caps text-on-surface-variant mb-2 ml-2">Postal Code</label>
            <input asp-for="NewAddressPostalCode" class="w-full bg-surface-container-lowest border border-on-surface/20 rounded-xl px-4 py-3 font-body-md text-body-md text-on-surface focus:border-primary-container focus:ring-4 focus:ring-primary-container/20 transition-all duration-250 outline-none" placeholder="11511" type="text"/>
            <span asp-validation-for="NewAddressPostalCode" class="text-error text-sm mt-1"></span>
        </div>
        <div class="flex flex-col md:col-span-2">
            <label class="flex items-center space-x-2 mt-2">
                <input asp-for="SaveNewAddress" type="checkbox" class="w-5 h-5 text-primary focus:ring-primary border-outline-variant rounded" />
                <span class="font-body-md text-on-surface-variant">Save this address for future orders</span>
            </label>
        </div>
        
        <input type="hidden" name="ShowNewAddressForm" value="true" />
    </div>
}
else
{
    <div class="space-y-4">
        @foreach (var address in Model.Addresses)
        {
            var isChecked = address.Id == Model.AddressId;
            var activeClass = isChecked ? "border-primary-container bg-surface-container-low" : "border-outline-variant/30 bg-surface-container-lowest";
            
            <label class="flex items-start p-4 border-2 rounded-xl cursor-pointer hover:border-primary-container/50 transition-colors @activeClass">
                <input type="radio" name="AddressId" value="@address.Id" class="mt-1 sr-only peer" @(isChecked ? "checked" : "") onchange="this.form.action='@Url.Action("SelectSavedAddress", "Orders")'; this.form.submit();" />
                <div class="w-5 h-5 rounded-full border-2 border-outline-variant flex items-center justify-center mr-4 mt-0.5 peer-checked:border-primary">
                    <div class="w-2.5 h-2.5 rounded-full bg-primary scale-0 peer-checked:scale-100 transition-transform"></div>
                </div>
                <div class="flex-1">
                    <span class="block font-body-lg text-on-surface">@address.FullName <span class="text-sm text-on-surface-variant">(@address.PhoneNumber)</span></span>
                    <span class="block font-body-md text-on-surface-variant">@address.DisplayLine</span>
                    @if (address.IsDefault)
                    {
                        <span class="inline-block mt-2 px-2 py-0.5 bg-primary-container text-on-primary-container text-[10px] font-label-caps rounded-full">Default</span>
                    }
                </div>
            </label>
        }
        <input type="hidden" name="ShowNewAddressForm" value="false" />
    </div>
}
</section>

<!-- Payment Method Selection -->
<section>
<h2 class="font-headline-md text-headline-md text-on-surface mb-stack-md">Payment Method</h2>
<div class="space-y-stack-md" id="payment-methods-container">
<!-- Vodafone Cash -->
<label class="payment-card group flex items-start p-6 border-2 border-outline-variant/30 hover:border-primary-container/50 rounded-xl cursor-pointer bg-surface-container-lowest transition-all duration-250 relative overflow-hidden @(Model.PaymentMethod == LioraApp.Utilities.SD.PaymentMethod_VodafoneCash ? "border-primary-container" : "")">
<input class="peer sr-only" name="PaymentMethod" type="radio" value="@LioraApp.Utilities.SD.PaymentMethod_VodafoneCash" @(Model.PaymentMethod == LioraApp.Utilities.SD.PaymentMethod_VodafoneCash ? "checked" : "") onchange="toggleManualUpload(this)"/>
<div class="w-6 h-6 rounded-full border-2 border-outline-variant flex items-center justify-center mr-4 mt-1 transition-colors peer-checked:border-primary">
<div class="w-3 h-3 rounded-full bg-primary scale-0 peer-checked:scale-100 transition-transform"></div>
</div>
<div class="flex-1">
<span class="block font-body-lg text-body-lg text-on-surface mb-1">Vodafone Cash</span>
<span class="block font-body-md text-body-md text-on-surface-variant">Transfer securely to our merchant number. Ideal for quick processing.</span>
</div>
<span class="material-symbols-outlined text-primary-container opacity-20 absolute -right-4 -bottom-4 text-[100px] pointer-events-none group-hover:scale-110 transition-transform duration-500">account_balance_wallet</span>
</label>

<!-- InstaPay -->
<label class="payment-card group flex items-start p-6 border-2 border-outline-variant/30 hover:border-primary-container/50 rounded-xl cursor-pointer bg-surface-container-lowest transition-all duration-250 relative overflow-hidden @(Model.PaymentMethod == LioraApp.Utilities.SD.PaymentMethod_InstaPay ? "border-primary-container" : "")">
<input class="peer sr-only" name="PaymentMethod" type="radio" value="@LioraApp.Utilities.SD.PaymentMethod_InstaPay" @(Model.PaymentMethod == LioraApp.Utilities.SD.PaymentMethod_InstaPay ? "checked" : "") onchange="toggleManualUpload(this)"/>
<div class="w-6 h-6 rounded-full border-2 border-outline-variant flex items-center justify-center mr-4 mt-1 transition-colors peer-checked:border-primary">
<div class="w-3 h-3 rounded-full bg-primary scale-0 peer-checked:scale-100 transition-transform"></div>
</div>
<div class="flex-1">
<span class="block font-body-lg text-body-lg text-on-surface mb-1">InstaPay</span>
<span class="block font-body-md text-body-md text-on-surface-variant">Instant bank transfer. Safe and seamless.</span>
</div>
</label>

<!-- Cash on Delivery -->
<label class="payment-card group flex items-start p-6 border-2 border-outline-variant/30 hover:border-primary-container/50 rounded-xl cursor-pointer bg-surface-container-lowest transition-all duration-250 relative overflow-hidden @(Model.PaymentMethod == LioraApp.Utilities.SD.PaymentMethod_CashOnDelivery ? "border-primary-container" : "")">
<input class="peer sr-only" name="PaymentMethod" type="radio" value="@LioraApp.Utilities.SD.PaymentMethod_CashOnDelivery" @(Model.PaymentMethod == LioraApp.Utilities.SD.PaymentMethod_CashOnDelivery ? "checked" : "") onchange="toggleManualUpload(this)"/>
<div class="w-6 h-6 rounded-full border-2 border-outline-variant flex items-center justify-center mr-4 mt-1 transition-colors peer-checked:border-primary">
<div class="w-3 h-3 rounded-full bg-primary scale-0 peer-checked:scale-100 transition-transform"></div>
</div>
<div class="flex-1">
<span class="block font-body-lg text-body-lg text-on-surface mb-1">Cash on Delivery</span>
<span class="block font-body-md text-body-md text-on-surface-variant">Pay when your order arrives. Note: May incur additional handling fees.</span>
</div>
</label>
</div>

<!-- Manual Payment Conditional Upload Zone -->
<div class="mt-stack-lg transition-all duration-500 overflow-hidden @(Model.PaymentMethod == LioraApp.Utilities.SD.PaymentMethod_CashOnDelivery ? "opacity-0 max-h-0" : "opacity-100 max-h-[500px]")" id="manual-upload-zone">
<div class="bg-surface-container-low p-8 rounded-xl">
<h3 class="font-body-lg text-body-lg text-on-surface mb-2">Upload Transfer Receipt (Optional)</h3>
<p class="font-body-md text-body-md text-on-surface-variant mb-6">To complete your Vodafone Cash or InstaPay order, please upload a clear screenshot of your successful transaction.</p>
<div class="border-2 border-dashed border-primary-container/40 rounded-xl p-10 flex flex-col items-center justify-center text-center cursor-pointer hover:bg-surface-container-lowest hover:border-primary-container transition-all duration-250 group">
<div class="w-16 h-16 rounded-full bg-surface-bright flex items-center justify-center mb-4 group-hover:scale-110 shadow-sm transition-transform duration-250">
<span class="material-symbols-outlined text-3xl text-primary-container">cloud_upload</span>
</div>
<span class="font-label-caps text-label-caps text-on-surface mb-2">Click to browse or drag image here</span>
<span class="font-body-md text-body-md text-on-surface-variant text-sm">Supports JPG, PNG up to 5MB</span>
<input accept="image/png, image/jpeg" class="hidden" type="file" name="ReceiptFile"/>
</div>
</div>
</div>
</section>
</div>

<!-- Right Column: Sticky Summary -->
<div class="lg:col-span-5 xl:col-span-4 relative">
<aside class="sticky top-24 bg-on-tertiary-fixed text-on-tertiary rounded-xl p-6 lg:p-8 shadow-[0_20px_50px_rgba(26,16,37,0.15)] flex flex-col">
<h2 class="font-headline-md text-headline-md mb-stack-lg pb-4 border-b border-on-tertiary/10">Order Summary</h2>

<!-- Items List -->
<div class="space-y-6 mb-8 flex-1 max-h-[40vh] overflow-y-auto pr-2 custom-scrollbar">
    @foreach (var item in Model.Items)
    {
        var imgSrc = item.ImageUrl ?? Url.Content("~/images/product-placeholder.svg");
<div class="flex items-center space-x-4">
<div class="w-20 h-24 bg-surface rounded-lg bg-cover bg-center flex-shrink-0" style="background-image: url('@imgSrc')"></div>
<div class="flex-1 min-w-0">
<span class="block font-body-lg text-body-lg truncate text-on-tertiary mb-1">
            @if(item.IsGiftBundle)
            {
                <text>@item.GiftBundleTitle</text>
            }
            else
            {
                <text>@item.ProductName</text>
            }
</span>
<span class="block font-body-md text-body-md text-on-tertiary/60 mb-2">
            @if(!item.IsGiftBundle)
            {
                <text>Size: @item.Size | Color: @item.Color | </text>
            }
            Qty: @item.Quantity
</span>
<span class="block font-body-md text-body-md text-primary-fixed-dim">@item.LineTotal.ToString("C")</span>
</div>
</div>
    }
</div>

<!-- Costs -->
<div class="space-y-3 pt-6 border-t border-on-tertiary/10 mb-stack-lg">
<div class="flex justify-between items-center font-body-md text-body-md text-on-tertiary/80">
<span>Subtotal</span>
<span>@Model.Subtotal.ToString("C")</span>
</div>

@if (Model.DiscountAmount > 0)
{
<div class="flex justify-between items-center font-body-md text-body-md text-on-tertiary/80">
<span>Discount (@Model.CouponCode)</span>
<span class="text-primary-fixed-dim">-@Model.DiscountAmount.ToString("C")</span>
</div>
}

<div class="flex justify-between items-center font-body-md text-body-md text-on-tertiary/80">
<span>Shipping</span>
<span>Calculated at checkout</span>
</div>
<div class="flex justify-between items-center font-headline-md text-headline-md text-on-tertiary mt-6 pt-6 border-t border-on-tertiary/10">
<span>Total</span>
<span>@Model.Total.ToString("C")</span>
</div>
</div>

<!-- Coupon Section (Hidden, handled in Order processing directly if submitted from cart or here) -->
<input type="hidden" asp-for="CouponCode" />

<!-- Call to Action -->
<button type="submit" class="w-full bg-primary-container text-on-primary-container font-label-caps text-label-caps py-4 rounded-full hover:scale-[0.98] hover:shadow-[0_10px_20px_rgba(196,144,128,0.2)] transition-all duration-250 flex items-center justify-center space-x-2">
<span>PLACE YOUR ORDER</span>
<span class="material-symbols-outlined text-sm">arrow_forward</span>
</button>
<div class="mt-6 flex items-center justify-center space-x-2 text-on-tertiary/50">
<span class="material-symbols-outlined text-sm">lock</span>
<span class="font-body-md text-body-md text-xs">Secure Encrypted Checkout</span>
</div>
</aside>
</div>
</div>
</form>

<!-- Hidden forms for address toggling -->
<form id="show-new-address" method="get" asp-action="Checkout" asp-controller="Orders" style="display:none;">
    <input type="hidden" name="ShowNewAddressForm" value="true" />
    <input type="hidden" name="PaymentMethod" value="@Model.PaymentMethod" />
    <input type="hidden" name="CouponCode" value="@Model.CouponCode" />
</form>

<form id="show-saved-addresses" method="get" asp-action="Checkout" asp-controller="Orders" style="display:none;">
    <input type="hidden" name="ShowNewAddressForm" value="false" />
    <input type="hidden" name="PaymentMethod" value="@Model.PaymentMethod" />
    <input type="hidden" name="CouponCode" value="@Model.CouponCode" />
</form>

</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function toggleManualUpload(radio) {
            const uploadZone = document.getElementById('manual-upload-zone');
            
            // UI styles
            document.querySelectorAll('.payment-card').forEach(card => {
                card.classList.remove('border-primary-container');
            });
            radio.closest('.payment-card').classList.add('border-primary-container');

            if(radio.value === '@LioraApp.Utilities.SD.PaymentMethod_VodafoneCash' || radio.value === '@LioraApp.Utilities.SD.PaymentMethod_InstaPay') {
                uploadZone.classList.remove('opacity-0', 'max-h-0');
                uploadZone.classList.add('opacity-100', 'max-h-[500px]');
            } else {
                uploadZone.classList.add('opacity-0', 'max-h-0');
                uploadZone.classList.remove('opacity-100', 'max-h-[500px]');
            }
        }
    </script>
    <style>
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(255,255,255,0.05); 
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.2); 
            border-radius: 4px;
        }
    </style>
}