@model LioraApp.ViewModels.Customer.HomeIndexVM
@{
    Layout = "_CustomerLayout";
    ViewData["Title"] = "Home";
    var featured = Model?.FeaturedProducts ?? [];
    var categories = Model?.Categories ?? [];
    var placeholderImage = Url.Content("~/images/product-placeholder.svg");
    var shopUrl = Url.Action("Index", "Products", new { area = "Customer" });
    var featuredGiftBundle = Model?.FeaturedGiftBundle;
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var cartUrl = Url.Action("Index", "Cart", new { area = "Customer" });
    var addToCartUrl = Url.Action("AddToCart", "Cart", new { area = "Customer" });
}

<main class="pt-[100px] md:pt-[120px]">
<!-- Hero Section -->
<section class="px-container-padding-mobile md:px-6 mt-stack-md mb-section-gap fade-in-section">
<div class="relative w-full h-[921px] rounded-[24px] overflow-hidden flex items-center justify-center bg-surface-container" style="box-shadow: 8px 8px 40px rgba(20,10,5,0.45), -4px 4px 24px rgba(20,10,5,0.2);">
<img alt="Hero Editorial" class="absolute inset-0 w-full h-full object-cover object-top opacity-90 scale-105 transition-transform duration-[8000ms] hover:scale-100" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDO_sKYrB7nzGZQj5rsOC3bx1zu8yh0VTZ8qudI1ujF37Zu1t9U-onEzg17u5Pn_8cYfgHacwsUNxKqfXX5LNY9zB9y1AkwUuKxqrV4RrOI39caA0WzgAstb2Rk6ZXJ6c33q6veN0QkKfHvEnI9zp_bqf77Q2JM3QlKbAjovySKuWOBXNJsaQ1IfVHPXKzaHRTOfGjPmIA8uXlijy5EytHavIkwr3TBFig000JOrpw76ymvDrNOd3GRB1NU1Un7glJ2T8Nqomms5aSY"/>
<!-- Dark side vignette — no white blur -->
<div class="absolute inset-0" style="background: linear-gradient(to top, rgba(10,5,2,0.75) 0%, rgba(10,5,2,0.15) 45%, transparent 70%), linear-gradient(to right, rgba(10,5,2,0.35) 0%, transparent 40%), linear-gradient(to left, rgba(10,5,2,0.2) 0%, transparent 35%);"></div>
<div class="relative z-10 text-center flex flex-col items-center max-w-4xl px-container-padding-mobile">
<h1 class="text-hero text-on-background mb-stack-md tracking-tight">Wear Your Confidence</h1>
<p class="font-body-lg text-body-lg text-on-surface-variant mb-stack-lg max-w-2xl">Modern Egyptian craftsmanship meets intimate luxury. Designed to flow with your life, crafted for your ultimate comfort.</p>
<div class="flex justify-center mt-4">
<a href="@shopUrl" class="bg-[#1e1b18] text-white font-label-caps text-label-caps px-10 py-4 rounded-full shadow-[0_6px_20px_rgba(0,0,0,0.5)] hover:bg-black transition-colors duration-250">EXPLORE COLLECTION</a>
</div>
</div>
</div>
</section>
<!-- Ticker Strip -->
<div class="w-full bg-inverse-surface text-on-primary py-4 overflow-hidden mb-section-gap font-label-caps text-label-caps tracking-widest fade-in-section">
<div class="ticker-wrapper" style="overflow:hidden;white-space:nowrap;box-sizing:border-box;">
<div class="ticker-content" style="display:inline-block;animation:ticker 20s linear infinite;">
                    WEAR YOUR CONFIDENCE <span class="mx-8 text-primary-fixed-dim">⬦</span> CRAFTED FOR YOU <span class="mx-8 text-primary-fixed-dim">⬦</span> EGYPTIAN DESIGN <span class="mx-8 text-primary-fixed-dim">⬦</span> WEAR YOUR CONFIDENCE <span class="mx-8 text-primary-fixed-dim">⬦</span> CRAFTED FOR YOU <span class="mx-8 text-primary-fixed-dim">⬦</span> EGYPTIAN DESIGN <span class="mx-8 text-primary-fixed-dim">⬦</span>
</div>
</div>
</div>
<!-- Collections Grid (Bento Style) -->
<section class="max-w-[1280px] mx-auto px-container-padding-mobile md:px-container-padding-desktop mb-section-gap fade-in-section">
<div class="flex justify-between items-end mb-stack-lg">
<h2 class="font-display-lg text-headline-lg text-primary">
    @if (categories.Any()) { @categories.First().Name } else { <text>Curated Collections</text> }
</h2>
<a class="hidden md:flex font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors border-b border-primary pb-1" href="@shopUrl">VIEW ALL</a>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
@{
    var cat0 = categories.ElementAtOrDefault(0);
    var cat1 = categories.ElementAtOrDefault(1);
    var cat2 = categories.ElementAtOrDefault(2);
    var prod0 = featured.ElementAtOrDefault(0);
    var prod1 = featured.ElementAtOrDefault(1);
    var prod2 = featured.ElementAtOrDefault(2);
}
<!-- Large Card -->
<div class="md:col-span-2 group cursor-pointer relative h-[500px] rounded-[20px] overflow-hidden bg-surface-container" style="box-shadow: 4px 8px 32px rgba(20,10,5,0.28);">
<img alt="@(cat0?.Name ?? "Collection")" class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-110 group-hover:translate-x-1"
     src="@(prod0?.MainImageUrl ?? "https://lh3.googleusercontent.com/aida-public/AB6AXuCOa7yWJHPvZWV1olegNWp2wbF27fs0SPwgU5xZkH17xfznP9TFyAm3AuqhbT-il_-h4vpXUFdXmX4Dn18tWcm-osbdkglSHkYyb_Ivyst2a4bm22gITsnWM8MMvKpzOpEZNg1IQL9UVCV785YdrFWN5DAZOddJMU5zCBWf1Wma-AqYgRjB94QXIpsy1RmC0ZodWbu5p8Lcfaavr4KAIRqhm6SYrHlrCRmjPd1IdIBU3S2VjjilXijJRimNj_YplctVZOa8Aj9lLL31")"/>
<!-- Deep dark gradient from bottom only -->
<div class="absolute inset-0" style="background: linear-gradient(to top, rgba(10,5,2,0.80) 0%, rgba(10,5,2,0.3) 40%, transparent 70%);"></div>
<div class="absolute bottom-0 left-0 p-stack-lg">
<span class="inline-block bg-primary-container text-on-primary font-label-caps text-label-caps px-4 py-2 rounded-full mb-stack-sm shadow-sm">NEW</span>
<h3 class="font-headline-md text-headline-md text-primary mb-1">@(cat0?.Name ?? "Essential Tops")</h3>
</div>
</div>
<!-- Right Stack -->
<div class="flex flex-col gap-gutter">
<a href="@(cat1 != null ? Url.Action("Index", "Products", new { area = "Customer", categoryId = cat1.Id }) : shopUrl)" class="group cursor-pointer relative h-[238px] rounded-[20px] overflow-hidden bg-surface-container" style="box-shadow: 4px 6px 24px rgba(20,10,5,0.22);">
<img alt="@(cat1?.Name ?? "Intimates")" class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-110 group-hover:-translate-y-1"
     src="@(prod1?.MainImageUrl ?? "https://lh3.googleusercontent.com/aida-public/AB6AXuBQo5ZvscsiCnRDJoVm9FI7xF-LtkQrsi8GdR02srekII5czNip1wx8ARImB1qNU1eT-ypygS53JbiH4y1EiNmyVM7630O71f_VLDwd9ninHLa9Q1zAzpGV5blEpk1QTfMRHAMQNZA4Dfm9ImGepBwtAlM1CKPxu64pBKDPx1d7viKyHd0OfLQPkTDbDnRl_nTZBj_Xvp3pxm3ZyoIizQFjWPhYex7ISee2BTxjynhCligXRxK3cljtoinOjYxwkBzUoWxeZRsPyVO7")"/>
<div class="absolute inset-0" style="background: linear-gradient(to top, rgba(10,5,2,0.75) 0%, transparent 60%);"></div>
<div class="absolute bottom-0 left-0 p-stack-md">
<h3 class="font-headline-md text-headline-md text-primary mb-1">@(cat1?.Name ?? "Intimates")</h3>
</div>
</a>
<a href="@(cat2 != null ? Url.Action("Index", "Products", new { area = "Customer", categoryId = cat2.Id }) : shopUrl)" class="group cursor-pointer relative h-[238px] rounded-[20px] overflow-hidden bg-surface-container" style="box-shadow: 4px 6px 24px rgba(20,10,5,0.22);">
<img alt="@(cat2?.Name ?? "Bottoms")" class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-110 group-hover:translate-x-1"
     src="@(prod2?.MainImageUrl ?? "https://lh3.googleusercontent.com/aida-public/AB6AXuC5oE1zIPNvcV69SsEQuYdym3bLi94hOLqo55O186YlIwVz9446LJHFTa8nZrEj9cD3vEnwPF9GisvmiQw5TKpn7mi3KF4eDF_1X_5DBKSEztoe6BYv2-8txNhtkG7leic2lHbpk22jrjTW7OFqG-K8K-GypnskP63W1O_dLhRYhwczWpT54IgVyQGAgIOQBkui1cjbcNVPqwo4Xj31Tyt9smmS_x2XoRBIVwCE60I47dcwZyTvpx3mXdOOJqB9A4LyDHdI5AQj1Wq7")"/>
<div class="absolute inset-0" style="background: linear-gradient(to top, rgba(10,5,2,0.75) 0%, transparent 60%);"></div>
<div class="absolute bottom-0 left-0 p-stack-md">
<h3 class="font-headline-md text-headline-md text-primary mb-1">@(cat2?.Name ?? "Bottoms")</h3>
</div>
</a>
</div>
</div>
<div class="mt-stack-md text-center md:hidden">
<a class="inline-block font-label-caps text-label-caps text-primary border-b border-primary pb-1" href="@shopUrl">VIEW ALL COLLECTIONS</a>
</div>
</section>

@if (featuredGiftBundle != null)
{
<!-- Gift Bundle Section -->
<section class="max-w-[1280px] mx-auto px-container-padding-mobile md:px-container-padding-desktop mb-section-gap fade-in-section">
<div class="bg-inverse-surface rounded-[24px] p-8 md:p-16">
<div class="flex flex-col md:flex-row gap-8 items-center">
<div class="flex-1">
<span class="font-label-caps text-label-caps text-primary-fixed-dim mb-stack-sm block">FEATURED BUNDLE</span>
<h2 class="font-display-lg text-headline-lg text-surface-bright mb-stack-sm">@featuredGiftBundle.Name</h2>
<p class="font-body-md text-body-md text-surface-variant/80 mb-stack-lg">@featuredGiftBundle.Description</p>
<div class="flex items-baseline gap-4 mb-stack-lg">
<span class="font-headline-md text-headline-md text-primary-fixed-dim">@featuredGiftBundle.BundlePrice.ToString("C")</span>
@if (featuredGiftBundle.OriginalTotal > featuredGiftBundle.BundlePrice)
{
<span class="font-body-md text-body-md text-surface-variant/60 line-through">@featuredGiftBundle.OriginalTotal.ToString("C")</span>
}
</div>
@if (isAuthenticated)
{
<form asp-area="Customer" asp-controller="Cart" asp-action="AddGiftBundleToCart" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="giftBundleId" value="@featuredGiftBundle.Id"/>
    <button type="submit" class="bg-primary-container text-on-primary font-label-caps text-label-caps px-8 py-4 rounded-full hover:opacity-90 transition-opacity shadow-level-1">ADD BUNDLE TO CART</button>
</form>
}
else
{
<a href="@Url.Action("Login", "Account", new { area = "Identity", returnUrl = Url.Action("Index", "Home", new { area = "Customer" }) })" class="inline-block bg-primary-container text-on-primary font-label-caps text-label-caps px-8 py-4 rounded-full hover:opacity-90 transition-opacity shadow-level-1">SHOP THIS BUNDLE</a>
}
</div>
<div class="flex gap-4 mt-4">
@foreach (var item in featuredGiftBundle.Items.Take(3))
{
<div class="w-20 h-20 rounded-xl overflow-hidden bg-surface/10 border border-surface/20 flex-shrink-0">
    <img src="@(item.MainImageUrl ?? placeholderImage)" alt="@item.ProductName" class="w-full h-full object-cover"/>
</div>
}
</div>
</div>
</div>
</section>
}

<!-- Brand Statement -->
<section class="w-full bg-inverse-surface py-section-gap px-container-padding-mobile text-center fade-in-section">
<div class="max-w-4xl mx-auto">
<span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-stack-md block">diamond</span>
<p class="text-statement text-surface-bright mb-stack-lg leading-tight">
                    "True elegance is quiet. It is the feeling of fine Egyptian craftsmanship against your skin, empowering your every movement."
                </p>
<span class="font-label-caps text-label-caps text-tertiary-fixed-dim">— THE FOUNDERS</span>
</div>
</section>

<!-- Featured Products Strip -->
@if (featured.Any())
{
<section class="max-w-[1280px] mx-auto px-container-padding-mobile md:px-container-padding-desktop mb-section-gap mt-section-gap fade-in-section">
<div class="flex justify-between items-end mb-stack-lg">
<h2 class="font-display-lg text-headline-lg text-primary">Fresh Drops</h2>
<a class="hidden md:flex font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors border-b border-primary pb-1" href="@shopUrl">VIEW ALL</a>
</div>
<div class="flex overflow-x-auto pb-8 gap-gutter snap-x no-scrollbar" style="scrollbar-width:none;">
@foreach (var product in featured.Take(8))
{
var productUrl = Url.Action("Details", "Products", new { area = "Customer", id = product.Id });
var imgSrc = product.MainImageUrl ?? placeholderImage;
var displayPrice = product.MinVariantPrice > 0 ? product.MinVariantPrice : product.BasePrice;
<div class="min-w-[280px] w-[280px] snap-start group cursor-pointer flex-shrink-0">
<a href="@productUrl">
<div class="aspect-[3/4] bg-surface-container mb-4 overflow-hidden relative rounded-[16px] shadow-level-1">
<img alt="@product.Name" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" src="@imgSrc"/>
</div>
<div class="text-center">
<h3 class="font-body-md text-body-md mb-1 tracking-wide text-on-surface">@product.Name</h3>
<p class="font-body-md text-body-md text-primary-container">@displayPrice.ToString("C")</p>
</div>
</a>
</div>
}
</div>
</section>
}

<!-- Instagram / Social Strip -->
<section class="max-w-[1280px] mx-auto px-container-padding-mobile md:px-container-padding-desktop mb-section-gap mt-section-gap fade-in-section">
<div class="text-center mb-stack-lg">
<h2 class="font-display-lg text-headline-lg text-primary mb-2">#lioraLife</h2>
<p class="font-body-md text-body-md text-on-surface-variant">Join our community of confident women.</p>
</div>
<div class="flex overflow-x-auto pb-8 gap-gutter snap-x no-scrollbar" style="scrollbar-width: none;">
<!-- Card 1 -->
<div class="min-w-[280px] md:min-w-[320px] snap-center rounded-[12px] overflow-hidden shadow-level-1 bg-surface group">
<div class="relative w-full aspect-square">
<img alt="Instagram 1" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD6n0a9JPiEYZ5ee2sEviMUFXv1uHyWXIECB9-Fp_uhQfz2K3LY-Kuyh_GH0eXl-ms--ZZLRrKjadZZmUOXMwRtlAwOBSjLiwTNsyEb7uSetCo307rH78B4tZHN33g2taeViJ8eBOikxdFoJQdBruLXJx_2vJbzHt60nycq9sY9gvKwMqN17WjoZ4Rm9xkEloTg2Lz8pa6PofRhviSN7tgLxCj76CWKLCPcAC1613ZaXtnPjhiL9G_6pJyC9_3_7qkEZNZ49jtxa_bj"/>
</div>
</div>
<!-- Card 2 -->
<div class="min-w-[280px] md:min-w-[320px] snap-center rounded-[12px] overflow-hidden shadow-level-1 bg-surface group">
<div class="relative w-full aspect-square">
<img alt="Instagram 2" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA1K5hQTZayHz1IQkQ0E6J2OP2xHpQwpNUqK3Fks3iRdkyQLvuaNQsh74ruDPKI4tC9WUiV3xFpFxQAHWuvhtFll1vXrDcorRboRy47B_RpYKat3gn9S8LE8Tn9EAHUPu9JfJDsqV6F0zaSKD78Kv11LruWAymZjJ6OYiYPlQn78-5PUAUztuORrFvGcPJrQfHvzbrnZ_Q1YJwYtWr2RdrpW0FlPXr1n5DE8B9CX9IK155wgUEdRgrs-F3bYXcq8PzsxKcEXxYnS75y"/>
</div>
</div>
<!-- Card 3 -->
<div class="min-w-[280px] md:min-w-[320px] snap-center rounded-[12px] overflow-hidden shadow-level-1 bg-surface group">
<div class="relative w-full aspect-square">
<img alt="Instagram 3" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAaDnN_9eIDrnYmyhrGBQIhmdbgcFTzwgtD3trwZK9deJoS1P0ogyTo8TCIaYVXYKoFBdbQzX4fa5FW0SZXNIRKVF8XFSKHAmgZltkuzCwrhgOFigJ_KqRFqGbTWbHahE6oOrj6h1OHxa1a9x6WA1Ulqw5oz06ikh7ZDg-A6wpiCM1f1WM_uA8hS8JjvDYznzXGF5nxkkul4tSgESsGmg5ejJDrITe7-pNBpAFzNDUYAayQVsg8L9OgYJpNOGBAJRrBmSIjE2DVhGC2"/>
</div>
</div>
<!-- Card 4 - Quote -->
<div class="min-w-[280px] md:min-w-[320px] snap-center rounded-[12px] overflow-hidden shadow-level-1 bg-surface group">
<div class="relative w-full aspect-square bg-primary-container flex items-center justify-center p-8 text-center">
<div>
<span class="material-symbols-outlined text-4xl text-on-primary-container mb-4">format_quote</span>
<p class="font-body-md text-body-md text-on-primary-container italic mb-4">"The softest silk I've ever owned. Truly exceptional quality."</p>
<span class="font-label-caps text-label-caps text-on-primary-container opacity-80">— Sarah M.</span>
</div>
</div>
</div>
</div>
</section>

<!-- Newsletter Section -->
<section class="max-w-[1000px] mx-auto px-container-padding-mobile mb-section-gap fade-in-section">
<div class="rounded-[24px] bg-gradient-to-br from-inverse-surface to-on-background p-10 md:p-16 text-center shadow-[0px_20px_50px_rgba(26,16,37,0.08)]">
<h2 class="font-display-lg text-headline-lg text-surface-bright mb-stack-sm">The Inner Circle</h2>
<p class="font-body-md text-body-md text-surface-variant/80 mb-stack-lg max-w-md mx-auto">Subscribe to receive early access to new collections, exclusive events, and musings on modern elegance.</p>
<form class="flex flex-col sm:flex-row gap-stack-sm justify-center max-w-lg mx-auto">
<input class="flex-1 bg-surface-bright text-on-surface font-body-md text-body-md px-6 py-4 rounded-full border border-transparent focus:border-primary-container focus:ring-4 focus:ring-primary-container/20 transition-all outline-none" placeholder="Your Email Address" required="" type="email"/>
<button class="bg-primary-container text-on-primary font-label-caps text-label-caps px-8 py-4 rounded-full shadow-level-1 whitespace-nowrap hover:opacity-90 transition-opacity" type="submit">SUBSCRIBE</button>
</form>
</div>
</section>
</main>