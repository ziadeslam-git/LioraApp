@model LioraApp.ViewModels.Customer.OrderDetailsCustomerVM
@{
    Layout = "_CustomerLayout";
    ViewData["Title"] = $"Order #{Model.Id}";

    // Simple progress logic based on typical statuses
    // Statuses: Pending, Pending Verification, Confirmed, Shipped, Delivered, Cancelled
    var steps = new List<string> { "Placed", "Verified", "Processing", "Delivered" };
    int currentStepIndex = 0;
    
    if (Model.Status == LioraApp.Utilities.SD.Status_Cancelled)
    {
        currentStepIndex = -1; // Special case
    }
    else if (Model.Status == LioraApp.Utilities.SD.Status_Delivered)
    {
        currentStepIndex = 3;
    }
    else if (Model.Status == LioraApp.Utilities.SD.Status_Shipped)
    {
        currentStepIndex = 2; // Processing / Shipped
    }
    else if (Model.Status == LioraApp.Utilities.SD.Status_Confirmed)
    {
        currentStepIndex = 1;
    }
    else // Pending or Pending Verification
    {
        currentStepIndex = 0;
    }
    
    var progressPercent = currentStepIndex >= 0 ? (currentStepIndex * 33) : 0;
}

<main class="flex-grow w-full max-w-[900px] mx-auto px-container-padding-mobile md:px-0 py-stack-lg md:py-section-gap flex flex-col gap-stack-lg">

@if (TempData["Success"] != null)
{
    <div class="p-4 text-on-primary bg-primary rounded-xl font-body-md text-center">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="p-4 text-error-container bg-error rounded-xl font-body-md text-center">
        @TempData["Error"]
    </div>
}

<!-- Header -->
<header class="flex flex-col gap-stack-sm">
<a class="flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors duration-250 w-fit" href="@Url.Action("Index", "Orders", new { area = "Customer" })">
<span class="material-symbols-outlined text-[18px]">arrow_back</span>
<span class="font-label-caps text-label-caps">Back to My Orders</span>
</a>
<div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
<h1 class="font-headline-md text-headline-md md:text-[28px] text-on-surface">Order #@Model.Id</h1>

@if (Model.Status != LioraApp.Utilities.SD.Status_Cancelled)
{
<span class="bg-primary-fixed text-on-primary-fixed font-label-caps text-label-caps px-4 py-1.5 rounded-full w-fit flex items-center gap-2">
<span class="w-2 h-2 rounded-full bg-primary @(Model.Status == LioraApp.Utilities.SD.Status_Delivered ? "" : "animate-pulse")"></span> @Model.Status
</span>
}
else
{
<span class="bg-error-container text-on-error-container font-label-caps text-label-caps px-4 py-1.5 rounded-full w-fit flex items-center gap-2">
<span class="w-2 h-2 rounded-full bg-error"></span> Cancelled
</span>
}

</div>
</header>

@if (Model.Status != LioraApp.Utilities.SD.Status_Cancelled)
{
<!-- Status Timeline Card -->
<section class="bg-surface-container-lowest rounded-[16px] p-stack-lg shadow-[0_10px_30px_rgba(26,16,37,0.05)] relative overflow-hidden">
<div class="absolute inset-0 bg-on-surface/5 mix-blend-multiply opacity-50"></div>
<div class="relative z-10 flex flex-col gap-stack-md">
<h2 class="font-headline-sm text-body-lg font-medium text-on-surface">Order Status</h2>
<div class="relative w-full py-stack-sm mt-4">
<div class="absolute top-[12px] left-0 right-0 h-[2px] bg-outline-variant z-0"></div>
<div class="absolute top-[12px] left-0 h-[2px] bg-primary-container z-[1] transition-all duration-500" style="width: @(progressPercent)%"></div>
<div class="flex justify-between relative z-10">
    @for (int i = 0; i < steps.Count; i++)
    {
        var step = steps[i];
        var isCompleted = i <= currentStepIndex;
        var isCurrent = i == currentStepIndex;
        
        <div class="flex flex-col items-center gap-2 w-20">
            @if (isCompleted && !isCurrent)
            {
                <div class="w-6 h-6 rounded-full bg-primary-container text-surface-container-lowest flex items-center justify-center relative z-10">
                    <span class="material-symbols-outlined text-[14px]">check</span>
                </div>
                <span class="font-label-caps text-[10px] text-center text-on-surface">@step</span>
            }
            else if (isCurrent)
            {
                <div class="w-6 h-6 rounded-full bg-primary-container text-surface-container-lowest shadow-[0_0_0_4px_rgba(196,144,128,0.2)] flex items-center justify-center relative z-10">
                    <span class="w-2 h-2 bg-surface-container-lowest rounded-full"></span>
                </div>
                <span class="font-label-caps text-[10px] text-center text-primary font-bold">@step</span>
            }
            else
            {
                <div class="w-6 h-6 rounded-full bg-surface-container-high border-2 border-outline-variant text-transparent flex items-center justify-center relative z-10">
                    <span class="w-2 h-2 rounded-full"></span>
                </div>
                <span class="font-label-caps text-[10px] text-center text-on-surface-variant">@step</span>
            }
        </div>
    }
</div>
</div>
</div>
</section>
}

<!-- Items Card -->
<section class="bg-surface-container-lowest rounded-[16px] shadow-[0_10px_30px_rgba(26,16,37,0.05)] overflow-hidden">
<div class="p-stack-md md:p-gutter border-b border-outline-variant/20 flex justify-between items-end">
<h2 class="font-headline-sm text-body-lg font-medium text-on-surface">Order Items</h2>
<span class="font-label-caps text-label-caps text-on-surface-variant">@Model.Items.Sum(i => i.Quantity) Items</span>
</div>
<div class="flex flex-col divide-y divide-outline-variant/10">
    @foreach (var item in Model.Items)
    {
        <div class="p-stack-md md:p-gutter flex items-center gap-stack-md hover:bg-surface-container-lowest/50 transition-colors">
        <div class="flex-grow flex flex-col md:flex-row justify-between md:items-center gap-2">
        <div class="flex flex-col">
        <span class="font-headline-sm text-body-lg font-medium text-on-surface">@item.ProductName</span>
        <span class="font-body-sm text-[14px] text-on-surface-variant">
            @if(!string.IsNullOrEmpty(item.Color)) { <text>@item.Color • </text> }
            @if(!string.IsNullOrEmpty(item.Size)) { <text>Size @item.Size</text> }
        </span>
        </div>
        <div class="flex items-center gap-6 md:gap-10">
        <span class="font-body-sm text-[14px] text-on-surface-variant">Qty: @item.Quantity</span>
        <span class="font-body-lg text-body-lg text-on-surface">@item.Subtotal.ToString("C")</span>
        </div>
        </div>
        </div>
    }
</div>
<!-- Summary -->
<div class="bg-surface-container-low p-stack-md md:p-gutter flex flex-col items-end gap-2 border-t border-outline-variant/20">
<div class="flex justify-between w-full md:w-1/2 text-[14px] text-on-surface-variant">
<span>Subtotal</span>
<span>@Model.Subtotal.ToString("C")</span>
</div>
@if (Model.DiscountAmount > 0)
{
<div class="flex justify-between w-full md:w-1/2 text-[14px] text-on-surface-variant">
<span>Discount (@Model.CouponCode)</span>
<span>-@Model.DiscountAmount.ToString("C")</span>
</div>
}
<div class="flex justify-between w-full md:w-1/2 font-headline-sm text-[18px] text-on-surface pt-2 border-t border-outline-variant/10 mt-2">
<span>Total</span>
<span>@Model.TotalAmount.ToString("C")</span>
</div>
</div>
</section>

<!-- Info Cards Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-stack-lg">
<!-- Payment Info -->
<section class="bg-surface-container-lowest rounded-[16px] p-stack-md md:p-gutter shadow-[0_10px_30px_rgba(26,16,37,0.05)] flex flex-col gap-stack-md h-full">
<div class="flex items-center gap-2 text-primary pb-2 border-b border-outline-variant/10">
<span class="material-symbols-outlined text-[20px]">account_balance_wallet</span>
<h2 class="font-headline-sm text-[16px] font-medium text-on-surface">Payment Info</h2>
</div>
<div class="flex flex-col gap-4 flex-grow">
<div>
<span class="block font-label-caps text-[10px] text-on-surface-variant mb-1">STATUS</span>
    @if (Model.PaymentStatus == LioraApp.Utilities.SD.Payment_Paid)
    {
        <span class="inline-flex items-center gap-1 text-[14px] text-primary"><span class="material-symbols-outlined text-[16px]">check_circle</span> Verified</span>
    }
    else if (Model.PaymentStatus == LioraApp.Utilities.SD.Payment_Pending)
    {
        <span class="inline-flex items-center gap-1 text-[14px] text-on-surface-variant"><span class="material-symbols-outlined text-[16px]">pending</span> Pending</span>
    }
    else
    {
        <span class="inline-flex items-center gap-1 text-[14px] text-on-surface-variant"><span class="material-symbols-outlined text-[16px]">info</span> @Model.PaymentStatus</span>
    }
</div>
</div>
</section>

<!-- Shipping Info -->
<section class="bg-surface-container-lowest rounded-[16px] p-stack-md md:p-gutter shadow-[0_10px_30px_rgba(26,16,37,0.05)] flex flex-col gap-stack-md h-full">
<div class="flex items-center gap-2 text-primary pb-2 border-b border-outline-variant/10">
<span class="material-symbols-outlined text-[20px]">local_shipping</span>
<h2 class="font-headline-sm text-[16px] font-medium text-on-surface">Shipping Info</h2>
</div>
<div class="flex flex-col gap-4">
<div>
<span class="block font-label-caps text-[10px] text-on-surface-variant mb-1">DELIVERY TO</span>
<span class="font-body-md text-on-surface block mt-1">@Model.AddressLine</span>
</div>
</div>
</section>
</div>

<!-- Actions -->
<div class="flex flex-col sm:flex-row justify-end items-center gap-4 mt-stack-md pt-stack-md border-t border-outline-variant/20">
@if (Model.Status == LioraApp.Utilities.SD.Status_Pending || Model.Status == LioraApp.Utilities.SD.Status_Confirmed)
{
    <form method="post" asp-action="Cancel" asp-controller="Orders" asp-area="Customer" class="w-full sm:w-auto" onsubmit="return confirm('Are you sure you want to cancel this order?');">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <button type="submit" class="px-6 py-3 rounded-full border border-error/50 text-error hover:bg-error/5 font-label-caps text-label-caps w-full sm:w-auto transition-colors active:scale-[0.98]">
            CANCEL ORDER
        </button>
    </form>
}
<a href="#" class="px-6 py-3 rounded-full border border-primary-container text-primary hover:bg-primary-container/10 font-label-caps text-label-caps w-full sm:w-auto transition-colors active:scale-[0.98] text-center">
    NEED HELP? CONTACT US
</a>
</div>
</main>