@inject Microsoft.Extensions.Localization.IStringLocalizer<LioraApp.Resources.SharedResource> SR
@model OrderSuccessCustomerVM
@{
    ViewData["Title"] = SR["OrderPlaced"];
    var etaFrom = Model.EstimatedDeliveryFrom?.ToString("MMM dd, yyyy") ?? SR["Tbd"].Value;
    var etaTo = Model.EstimatedDeliveryTo?.ToString("MMM dd, yyyy") ?? etaFrom;
    var email = string.IsNullOrWhiteSpace(Model.CustomerEmail) ? SR["YourEmailAddress"].Value : Model.CustomerEmail;
    var statusMessage = Model.IsPaid
        ? SR["OrderPlacedStatusPaid"].Value
        : SR["OrderPlacedStatusPending"].Value;
}

<section class="relative flex min-h-[calc(100vh-10rem)] items-center justify-center overflow-hidden px-4 py-10 sm:px-6 lg:px-8">
    <div class="pointer-events-none absolute left-1/4 top-1/4 -z-10 h-80 w-80 rounded-full bg-primary/20 blur-3xl"></div>
    <div class="pointer-events-none absolute bottom-1/4 right-1/4 -z-10 h-[26rem] w-[26rem] rounded-full bg-indigo-200/30 blur-3xl"></div>

    <div class="w-full max-w-3xl rounded-[28px] border border-slate-200/70 bg-white/95 p-8 text-center shadow-[0_24px_70px_rgba(15,23,42,0.08)] backdrop-blur-xl sm:p-12">
        <div class="mx-auto mb-8 flex h-24 w-24 items-center justify-center">
            <div class="absolute h-24 w-24 rounded-full bg-primary/10 blur-md"></div>
            <div class="relative flex h-20 w-20 items-center justify-center rounded-full bg-primary text-white shadow-[0_12px_30px_rgba(70,72,212,0.28)]">
                <span class="material-symbols-outlined text-4xl" style="font-variation-settings:'FILL' 1">check</span>
            </div>
        </div>

        <div class="mx-auto mb-10 max-w-2xl space-y-4">
            <h1 class="text-3xl font-black tracking-tight text-slate-900 sm:text-4xl">@SR["OrderPlaced"]</h1>
            <p class="text-base leading-7 text-slate-500 sm:text-lg">@statusMessage</p>

            <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-4 py-2">
                <span class="text-sm font-medium text-slate-500">@SR["OrderNumber"]:</span>
                <span class="font-mono text-sm font-bold tracking-[0.18em] text-primary">#ORD-@Model.Id</span>
            </div>
        </div>

        <div class="mb-10 grid gap-5 text-left md:grid-cols-2">
            <div class="rounded-2xl border border-slate-200/80 bg-slate-50/80 p-6">
                <div class="mb-3 flex items-center gap-2 text-slate-500">
                    <span class="material-symbols-outlined text-xl">local_shipping</span>
                    <h3 class="text-sm font-semibold uppercase tracking-[0.14em]">@SR["EstimatedDelivery"]</h3>
                </div>
                <p class="text-lg font-semibold text-slate-900">@etaFrom - @etaTo</p>
                <p class="mt-2 text-sm text-slate-500">@Model.ShippingLabel</p>
            </div>

            <div class="rounded-2xl border border-slate-200/80 bg-slate-50/80 p-6">
                <div class="mb-3 flex items-center gap-2 text-slate-500">
                    <span class="material-symbols-outlined text-xl">mail</span>
                    <h3 class="text-sm font-semibold uppercase tracking-[0.14em]">@SR["ConfirmationSentTo"]</h3>
                </div>
                <p class="truncate text-base font-semibold text-slate-900">@email</p>
                <p class="mt-2 text-sm text-slate-500">@SR["ShippingAndPaymentUpdatesHere"]</p>
            </div>
        </div>

        <div class="flex flex-col justify-center gap-4 sm:flex-row">
            <a asp-area="Customer"
               asp-controller="Orders"
               asp-action="Details"
               asp-route-id="@Model.Id"
               class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-br from-primary to-indigo-500 px-8 py-3.5 text-sm font-bold text-white shadow-[0_10px_24px_rgba(70,72,212,0.22)] transition-all hover:-translate-y-0.5 hover:shadow-[0_14px_28px_rgba(70,72,212,0.28)]">
                @SR["TrackMyOrder"]
                <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>

            <a asp-area="Customer"
               asp-controller="Products"
               asp-action="Index"
               class="inline-flex items-center justify-center gap-2 rounded-xl border-2 border-slate-200 bg-white px-8 py-3.5 text-sm font-bold text-primary transition-colors hover:border-slate-300 hover:bg-slate-50">
                <span class="material-symbols-outlined text-sm">storefront</span>
                @SR["ContinueShopping"]
            </a>
        </div>
    </div>
</section>
