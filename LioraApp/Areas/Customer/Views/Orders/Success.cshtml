@model LioraApp.ViewModels.Customer.OrderSuccessCustomerVM
@{
    Layout = "_CustomerLayout";
    ViewData["Title"] = "Order Confirmed";
}

<style>
    .check-anim {
        stroke-dasharray: 100;
        stroke-dashoffset: 100;
        animation: dash 1s ease-out forwards;
        animation-delay: 0.2s;
    }
    @@keyframes dash {
        to {
            stroke-dashoffset: 0;
        }
    }
    .scale-in {
        animation: scaleIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        opacity: 0;
        transform: scale(0.8);
    }
    @@keyframes scaleIn {
        to {
            opacity: 1;
            transform: scale(1);
        }
    }
    .fade-up {
        animation: fadeUp 0.6s ease-out forwards;
        opacity: 0;
        transform: translateY(20px);
    }
    .fade-up-delay-1 { animation-delay: 0.3s; }
    .fade-up-delay-2 { animation-delay: 0.5s; }
    .fade-up-delay-3 { animation-delay: 0.7s; }
    
    @@keyframes fadeUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<main class="flex-grow flex items-center justify-center py-section-gap px-container-padding-mobile md:px-container-padding-desktop">
<div class="w-full max-w-[560px] mx-auto text-center">
<!-- Success Icon -->
<div class="scale-in mx-auto w-[100px] h-[100px] rounded-full bg-primary/15 flex items-center justify-center mb-stack-lg shadow-[0_10px_30px_rgba(26,16,37,0.05)]">
<svg class="w-12 h-12 text-primary" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewbox="0 0 24 24">
<path class="check-anim" d="M20 6L9 17l-5-5"></path>
</svg>
</div>

<!-- Headlines -->
<h1 class="fade-up fade-up-delay-1 font-headline-md text-headline-md text-primary mb-stack-sm">Your Order is Confirmed! ✨</h1>
<p class="fade-up fade-up-delay-1 font-body-lg text-body-lg text-on-surface-variant mb-stack-lg max-w-md mx-auto">
    We'll prepare your order and contact you for delivery details.
</p>

<!-- Order Summary Card -->
<div class="fade-up fade-up-delay-2 bg-surface-container-lowest rounded-xl p-6 md:p-8 mb-stack-lg shadow-[0_10px_30px_rgba(26,16,37,0.05)] text-left border border-outline-variant/20">
<div class="flex justify-between items-center mb-6 pb-6 border-b border-outline-variant/20">
<div>
<p class="font-label-caps text-label-caps text-on-surface-variant mb-1">ORDER ID</p>
<p class="font-body-md text-body-md text-on-surface">#@Model.Id</p>
</div>
<div class="text-right">
<p class="font-label-caps text-label-caps text-on-surface-variant mb-1">DATE</p>
<p class="font-body-md text-body-md text-on-surface">@Model.CreatedAt.ToString("MMM dd, yyyy")</p>
</div>
</div>
<div class="pt-2 flex justify-between items-end">
<div>
<p class="font-label-caps text-label-caps text-on-surface-variant mb-1">PAYMENT STATUS</p>
<p class="font-body-md text-body-md text-on-surface flex items-center gap-1">
    @if (Model.PaymentStatus == LioraApp.Utilities.SD.Payment_Paid)
    {
        <span class="material-symbols-outlined text-[18px] text-primary">check_circle</span>
        <text>Verified</text>
    }
    else
    {
        <span class="material-symbols-outlined text-[18px]">pending</span>
        <text>@Model.PaymentStatus</text>
    }
</p>
</div>
<div class="text-right">
<p class="font-label-caps text-label-caps text-on-surface-variant mb-1">ESTIMATED DELIVERY</p>
<p class="font-body-md text-body-md text-primary">@(Model.EstimatedDeliveryFrom?.ToString("MMM dd") ?? "") - @(Model.EstimatedDeliveryTo?.ToString("MMM dd") ?? "")</p>
</div>
</div>
</div>

<!-- CTAs -->
<div class="fade-up fade-up-delay-3 flex flex-col gap-4 mb-section-gap">
<a href="@Url.Action("Details", "Orders", new { id = Model.Id, area = "Customer" })" class="w-full bg-primary-container text-on-primary-container font-label-caps text-label-caps py-4 px-8 rounded-full hover:scale-[0.98] transition-transform duration-250 ease-out shadow-[0_10px_30px_rgba(26,16,37,0.05)] hover:shadow-[0_20px_50px_rgba(26,16,37,0.08)] inline-block">
    TRACK MY ORDER
</a>
<a href="@Url.Action("Index", "Products", new { area = "Customer" })" class="w-full bg-transparent border border-primary text-primary font-label-caps text-label-caps py-4 px-8 rounded-full hover:bg-primary/5 transition-colors duration-250 ease-out inline-block">
    CONTINUE SHOPPING
</a>
</div>

<!-- Brand Moment -->
<div class="fade-up fade-up-delay-3 font-accent-italic text-accent-italic text-primary/80 italic">
    Thank you for choosing liora. Wear it. Own it. Wear your confidence.
</div>
</div>
</main>