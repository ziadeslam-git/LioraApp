@model OrderIndexPagedVM
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> SR
@{
    ViewData["Title"] = SR["MyOrders"];
    var orders = Model?.Orders ?? [];
    string Badge(string? s) => s switch { "Pending" => "bg-amber-100 text-amber-700", "Confirmed" => "bg-blue-100 text-blue-700", "Shipped" => "bg-sky-100 text-sky-700", "Delivered" => "bg-emerald-100 text-emerald-700", "Cancelled" => "bg-rose-100 text-rose-700", _ => "bg-slate-100 text-slate-700" };
    string LocStatus(string? s) => s switch { "Pending" => SR["OrderStatus_Pending"], "Confirmed" => SR["OrderStatus_Confirmed"], "Shipped" => SR["OrderStatus_Shipped"], "Delivered" => SR["OrderStatus_Delivered"], "Cancelled" => SR["OrderStatus_Cancelled"], _ => s ?? "-" };
    string TextOrFallback(string key, string fallback)
    {
        var value = SR[key].Value;
        return string.IsNullOrWhiteSpace(value) || value == key ? fallback : value;
    }
}
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold">@SR["MyOrders"]</h1>
        <a asp-area="Customer" asp-controller="Products" asp-action="Index" class="text-sm text-primary hover:underline">@SR["Products"]</a>
    </div>

    @if (!orders.Any())
    {
        <div class="rounded-2xl border border-dashed border-slate-300 bg-white p-10 text-center">
            <p class="mb-3 text-slate-600">@SR["NoOrdersYet"]</p>
            <a asp-area="Customer" asp-controller="Products" asp-action="Index" class="inline-flex rounded-lg bg-primary px-4 py-2 text-white">@SR["StartShopping"]</a>
        </div>
    }
    else
    {
        <div class="space-y-4 md:hidden">
            @foreach (var order in orders)
            {
                <article class="rounded-[18px] border border-slate-200 bg-white p-4 shadow-sm">
                    <div class="flex items-start justify-between gap-3">
                        <div>
                            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-400">Placed on</p>
                            <h2 class="mt-1 text-lg font-bold text-slate-900">@order.CreatedAt.ToString("dd MMM yyyy")</h2>
                        </div>

                        <a asp-area="Customer"
                           asp-controller="Orders"
                           asp-action="Details"
                           asp-route-id="@order.Id"
                           class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-primary/15 bg-primary/5 text-primary transition hover:border-primary/30 hover:bg-primary/10">
                            <span class="material-symbols-outlined text-[18px]">visibility</span>
                        </a>
                    </div>

                    <div class="mt-4 grid grid-cols-2 gap-3 rounded-[16px] bg-slate-50 p-3">
                        <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-400">Date</p>
                            <p class="mt-1 text-sm font-semibold text-slate-800">@order.CreatedAt.ToString("dd MMM yyyy")</p>
                        </div>
                        <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-400">Items</p>
                            <p class="mt-1 text-sm font-semibold text-slate-800">@order.ItemCount</p>
                        </div>
                        <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-400">@SR["Total"]</p>
                            <p class="mt-1 text-sm font-bold text-slate-900">@order.TotalAmount.ToString("0.00") EGP</p>
                        </div>
                        <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-400">Payment</p>
                            <span class="mt-1 inline-flex rounded-full px-2.5 py-1 text-[11px] font-semibold @Badge(order.PaymentStatus)">
                                @order.PaymentStatus
                            </span>
                        </div>
                    </div>

                    <div class="mt-4 flex items-center justify-between gap-3">
                        <span class="inline-flex rounded-full px-2.5 py-1 text-[11px] font-semibold @Badge(order.Status)">
                            @LocStatus(order.Status)
                        </span>

                        @if (order.Status == "Pending")
                        {
                            <form asp-area="Customer" asp-controller="Orders" asp-action="Cancel" method="post" data-loading="true" class="inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@order.Id" />
                                <button type="submit"
                                        class="inline-flex items-center justify-center rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-xs font-semibold text-rose-600 transition hover:border-rose-300 hover:bg-rose-100">
                                    @TextOrFallback("CancelOrder", "Cancel")
                                </button>
                            </form>
                        }
                    </div>
                </article>
            }
        </div>

        <div class="hidden overflow-auto rounded-2xl border border-slate-200 bg-white md:block">
            <table class="w-full text-sm">
                <thead class="bg-slate-50">
                    <tr class="text-left">
                        <th class="p-3">Date</th>
                        <th class="p-3">Items</th>
                        <th class="p-3">@SR["Total"]</th>
                        <th class="p-3">Status</th>
                        <th class="p-3">Payment</th>
                        <th class="p-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var order in orders)
                {
                    <tr class="border-t border-slate-100">
                        <td class="p-3">@order.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td class="p-3">@order.ItemCount</td>
                        <td class="p-3">@order.TotalAmount.ToString("0.00") EGP</td>
                        <td class="p-3"><span class="rounded-full px-2 py-1 text-xs @Badge(order.Status)">@LocStatus(order.Status)</span></td>
                        <td class="p-3"><span class="rounded-full px-2 py-1 text-xs @Badge(order.PaymentStatus)">@order.PaymentStatus</span></td>
                        <td class="p-3">
                            <div class="flex flex-wrap items-center gap-2">
                                <a asp-area="Customer" asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id"
                                   class="inline-flex items-center gap-1.5 rounded-full border border-primary/15 bg-primary/5 px-3 py-1.5 text-xs font-semibold text-primary transition hover:border-primary/30 hover:bg-primary/10">
                                    <span class="material-symbols-outlined text-[16px]">visibility</span>
                                    @TextOrFallback("View", "View")
                                </a>
                                @if (order.Status == "Pending")
                                {
                                    <form asp-area="Customer" asp-controller="Orders" asp-action="Cancel" method="post" data-loading="true" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@order.Id" />
                                        <button type="submit"
                                                class="inline-flex items-center gap-1.5 rounded-full border border-rose-200 bg-rose-50 px-3 py-1.5 text-xs font-semibold text-rose-600 transition hover:border-rose-300 hover:bg-rose-100">
                                            <span class="material-symbols-outlined text-[16px]">close</span>
                                            @TextOrFallback("CancelOrder", "Cancel")
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        @if ((Model?.TotalPages ?? 0) > 1)
        {
            <div class="flex items-center justify-between text-sm">
                <span class="text-slate-500">Page @(Model?.CurrentPage ?? 1) of @(Model?.TotalPages ?? 1)</span>
                <div class="flex items-center gap-2">
                    @if (Model?.HasPreviousPage ?? false)
                    {
                        <a asp-area="Customer" asp-controller="Orders" asp-action="Index" asp-route-page="@((Model?.CurrentPage ?? 1) - 1)" class="rounded-lg border border-slate-300 px-3 py-2 hover:border-primary hover:text-primary">Previous</a>
                    }
                    @if (Model?.HasNextPage ?? false)
                    {
                        <a asp-area="Customer" asp-controller="Orders" asp-action="Index" asp-route-page="@((Model?.CurrentPage ?? 1) + 1)" class="rounded-lg border border-slate-300 px-3 py-2 hover:border-primary hover:text-primary">Next</a>
                    }
                </div>
            </div>
        }
    }
</section>
