@model LioraApp.ViewModels.Customer.OrderIndexPagedVM
@{
    Layout = "_CustomerLayout";
    ViewData["Title"] = "My Orders";
}

<main class="flex-grow w-full max-w-7xl mx-auto px-container-padding-mobile md:px-container-padding-desktop py-section-gap">
<!-- Page Header -->
<div class="mb-stack-lg">
<h1 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface mb-stack-md">MY ORDERS</h1>
<p class="font-body-md text-body-md text-on-surface-variant max-w-2xl">Review your past purchases and track current shipments.</p>
</div>

<!-- Filter Tabs (UI only for now, could wire up if needed) -->
<div class="flex gap-3 overflow-x-auto no-scrollbar pb-2 mb-stack-lg border-b border-outline-variant/30">
<button class="px-6 py-2 rounded-full font-label-caps text-label-caps whitespace-nowrap bg-primary-container text-on-primary-container transition-transform duration-250 ease-out hover:scale-[0.98]">All</button>
<button class="px-6 py-2 rounded-full font-label-caps text-label-caps whitespace-nowrap border border-outline-variant text-on-surface-variant hover:bg-surface-container transition-colors duration-250 ease-out">Pending</button>
<button class="px-6 py-2 rounded-full font-label-caps text-label-caps whitespace-nowrap border border-outline-variant text-on-surface-variant hover:bg-surface-container transition-colors duration-250 ease-out">Confirmed</button>
<button class="px-6 py-2 rounded-full font-label-caps text-label-caps whitespace-nowrap border border-outline-variant text-on-surface-variant hover:bg-surface-container transition-colors duration-250 ease-out">Delivered</button>
<button class="px-6 py-2 rounded-full font-label-caps text-label-caps whitespace-nowrap border border-outline-variant text-on-surface-variant hover:bg-surface-container transition-colors duration-250 ease-out">Cancelled</button>
</div>

<!-- Orders List Grid -->
@if (!Model.Orders.Any())
{
    <div class="flex flex-col items-center justify-center py-section-gap text-center">
        <div class="w-20 h-20 bg-surface-container rounded-full flex items-center justify-center mb-6">
            <span class="material-symbols-outlined text-[40px] text-tertiary">inventory_2</span>
        </div>
        <h3 class="font-headline-md text-headline-md text-on-surface mb-2">No orders yet</h3>
        <p class="font-body-md text-body-md text-on-surface-variant mb-8">When you place an order, it will appear here.</p>
        <a href="@Url.Action("Index", "Products", new { area = "Customer" })" class="px-8 py-3 rounded-full bg-primary-container text-on-primary-container font-label-caps text-label-caps hover:scale-[0.98] transition-transform duration-250 ease-out inline-block">
            Start Shopping
        </a>
    </div>
}
else
{
    <div class="grid grid-cols-1 gap-stack-lg">
        @foreach (var order in Model.Orders)
        {
            var badgeClass = order.Status == "Delivered" ? "bg-secondary-container text-on-secondary-container" :
                             order.Status == "Pending" ? "bg-surface-variant text-on-surface-variant border border-outline-variant/50" :
                             "bg-surface-variant text-on-surface-variant";
            
            var imgSrc = order.MainImageUrl ?? Url.Content("~/images/product-placeholder.svg");

            <article class="bg-surface-container-lowest rounded-[16px] shadow-[0_10px_30px_rgba(26,16,37,0.05)] hover:shadow-[0_20px_50px_rgba(26,16,37,0.08)] hover:-translate-y-0.5 transition-all duration-300 p-6 md:p-8 flex flex-col md:flex-row gap-6 md:items-center justify-between border border-outline-variant/10">
            <div class="flex flex-col gap-4 flex-grow">
            <!-- Header Info -->
            <div class="flex flex-wrap items-center gap-4">
            <span class="font-body-md text-body-md text-on-surface font-medium">Order #@order.Id</span>
            <span class="w-1 h-1 rounded-full bg-outline-variant hidden md:block"></span>
            <span class="font-body-md text-body-md text-on-surface-variant">@order.CreatedAt.ToString("MMM dd, yyyy")</span>
            <div class="px-3 py-1 rounded-full font-label-caps text-[10px] ml-auto md:ml-0 @badgeClass">@order.Status</div>
            </div>
            <!-- Thumbnails -->
            <div class="flex gap-3 mt-2">
            <img alt="Order Thumbnail" class="w-16 h-16 rounded-xl object-cover border border-outline-variant/20" src="@imgSrc"/>
            @if (order.ItemCount > 1)
            {
                <div class="w-16 h-16 rounded-xl flex items-center justify-center bg-surface-container text-on-surface-variant font-label-caps text-xs border border-outline-variant/20">
                    +@(order.ItemCount - 1)
                </div>
            }
            </div>
            </div>
            <!-- Footer / Action -->
            <div class="flex flex-row md:flex-col items-center md:items-end justify-between md:justify-center gap-4 border-t md:border-t-0 border-outline-variant/20 pt-4 md:pt-0 mt-2 md:mt-0 md:pl-8 md:border-l">
            <div class="flex flex-col md:items-end">
            <span class="font-label-caps text-label-caps text-on-surface-variant">TOTAL</span>
            <span class="font-body-lg text-body-lg text-on-surface font-medium">@order.TotalAmount.ToString("C")</span>
            </div>
            <a href="@Url.Action("Details", "Orders", new { id = order.Id, area = "Customer" })" class="px-5 py-2 rounded-full border border-primary text-primary font-label-caps text-label-caps hover:bg-primary hover:text-on-primary transition-colors duration-250 ease-out flex items-center gap-2">
                                    View Details <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
            </a>
            </div>
            </article>
        }
    </div>
    
    @if (Model.TotalPages > 1)
    {
        <div class="flex justify-center mt-stack-lg gap-2">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                var activeClass = i == Model.CurrentPage ? "bg-primary text-on-primary" : "bg-surface-container-low text-on-surface-variant border border-outline-variant hover:border-primary";
                <a href="@Url.Action("Index", "Orders", new { area = "Customer", page = i })" class="w-10 h-10 rounded-full flex items-center justify-center font-label-caps transition-colors duration-250 @activeClass">
                    @i
                </a>
            }
        </div>
    }
}
</main>