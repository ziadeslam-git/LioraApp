@model LioraApp.ViewModels.Customer.ProductController.ProductDetailsVM
@{
    Layout = "_CustomerLayout";
    ViewData["Title"] = Model.Product.Name;
    var displayPrice = Model.Product.Variants.Any(v => v.IsActive && v.Stock > 0)
        ? Model.Product.Variants.Where(v => v.IsActive && v.Stock > 0).Min(v => v.Price)
        : Model.Product.BasePrice;
    
    var allImages = Model.Product.Images.OrderByDescending(i => i.IsMain).ThenBy(i => i.DisplayOrder).ToList();
    var mainImage = allImages.FirstOrDefault()?.ImageUrl ?? Url.Content("~/images/product-placeholder.svg");
    var hasStock = Model.Product.Variants.Any(v => v.IsActive && v.Stock > 0);
    
    // Group sizes and colors
    var uniqueSizes = Model.Product.Variants.Where(v => v.IsActive).Select(v => v.Size).Distinct().OrderBy(s => s).ToList();
    var uniqueColors = Model.Product.Variants.Where(v => v.IsActive && !string.IsNullOrEmpty(v.Color)).Select(v => v.Color).Distinct().ToList();
}

<main class="max-w-[1280px] mx-auto px-container-padding-mobile md:px-container-padding-desktop py-stack-lg md:py-section-gap">
<!-- Breadcrumbs -->
<nav aria-label="Breadcrumb" class="mb-stack-lg">
<ol class="flex items-center space-x-2 font-label-caps text-label-caps text-on-surface-variant">
<li><a class="hover:text-primary transition-colors duration-250 ease-tactile" href="@Url.Action("Index", "Home", new { area = "Customer" })">HOME</a></li>
<li><span class="material-symbols-outlined text-[16px]">chevron_right</span></li>
<li><a class="hover:text-primary transition-colors duration-250 ease-tactile" href="@Url.Action("Index", "Products", new { area = "Customer" })">SHOP ALL</a></li>
<li><span class="material-symbols-outlined text-[16px]">chevron_right</span></li>
@if (Model.Product.Category != null)
{
<li><a class="hover:text-primary transition-colors duration-250 ease-tactile" href="@Url.Action("Index", "Products", new { area = "Customer", categoryId = Model.Product.CategoryId })">@Model.Product.Category.Name.ToUpper()</a></li>
<li><span class="material-symbols-outlined text-[16px]">chevron_right</span></li>
}
<li aria-current="page" class="text-primary-container truncate max-w-[200px]">@Model.Product.Name.ToUpper()</li>
</ol>
</nav>

<!-- Product Layout Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-gutter lg:gap-16">
<!-- Left: Image Gallery -->
<div class="flex flex-col-reverse md:flex-row gap-stack-sm md:gap-4 h-full">
<!-- Thumbnail Strip -->
<div class="flex md:flex-col gap-stack-sm overflow-x-auto md:overflow-visible md:w-24 shrink-0 no-scrollbar">
@foreach (var img in allImages)
{
    var isActiveClass = img.IsMain ? "border-primary-container" : "border-transparent opacity-70";
<button class="thumbnail-btn w-20 h-24 md:w-full md:h-32 shrink-0 rounded-xl overflow-hidden border-2 @isActiveClass hover:border-outline-variant transition-all duration-250 ease-tactile hover:opacity-100">
<img alt="@Model.Product.Name thumbnail" class="w-full h-full object-cover" src="@img.ImageUrl"/>
</button>
}
</div>
<!-- Main Image -->
<div class="flex-grow aspect-[3/4] rounded-xl overflow-hidden bg-surface-container-low relative shadow-ambient-lvl1">
<img id="main-product-image" alt="@Model.Product.Name" class="w-full h-full object-cover" src="@mainImage"/>
</div>
</div>

<!-- Right: Product Info -->
<div class="flex flex-col pt-4 md:pt-0">
<!-- Header & Price -->
<div class="mb-stack-lg border-b border-outline-variant/30 pb-stack-md">
<h1 class="font-headline-lg-mobile text-headline-lg-mobile md:font-headline-md md:text-headline-md text-on-surface mb-2">@Model.Product.Name</h1>
<p class="font-accent-italic text-accent-italic text-on-surface-variant mb-4">Effortless grace in every thread.</p>
<div class="font-body-lg text-body-lg font-semibold text-primary-container">
                    @displayPrice.ToString("C")
                </div>
</div>

<form method="post" asp-action="AddToCart" asp-controller="Cart" asp-area="Customer">
    @Html.AntiForgeryToken()
    <input type="hidden" name="productId" value="@Model.Product.Id" />
    <input type="hidden" name="quantity" value="1" />

<!-- Color Selection -->
@if (uniqueColors.Any())
{
<div class="mb-stack-md">
<div class="flex justify-between items-center mb-unit">
<span class="font-label-caps text-label-caps text-on-surface">COLOR</span>
</div>
<div class="flex gap-3">
    @foreach (var color in uniqueColors)
    {
<label class="cursor-pointer">
<input type="radio" name="color" value="@color" class="peer sr-only" required />
<div class="w-10 h-10 rounded-full border-2 border-background ring-2 ring-transparent peer-checked:ring-primary-container hover:ring-outline-variant transition-transform duration-250 ease-tactile hover:scale-110 flex items-center justify-center font-label-caps text-xs bg-surface-variant text-on-surface-variant">
                                @color
                            </div>
</label>
    }
</div>
</div>
}

<!-- Size Selection -->
@if (uniqueSizes.Any())
{
<div class="mb-stack-lg">
<div class="flex justify-between items-center mb-unit">
<span class="font-label-caps text-label-caps text-on-surface">SIZE</span>
</div>
<div class="flex flex-wrap gap-3">
    @foreach (var size in uniqueSizes)
    {
<label class="cursor-pointer">
<input type="radio" name="size" value="@size" class="peer sr-only" required />
<div class="w-14 h-14 rounded-xl border border-outline-variant text-on-surface-variant peer-checked:bg-primary peer-checked:text-on-primary peer-checked:border-primary font-label-caps text-label-caps flex items-center justify-center hover:border-primary hover:text-primary transition-all duration-250 ease-tactile shadow-ambient-lvl1">
                                @size
                            </div>
</label>
    }
</div>
</div>
}

<!-- Actions -->
<div class="flex flex-col gap-3 mb-stack-lg">
@if (hasStock)
{
<button type="submit" class="w-full py-4 rounded-full bg-primary-container text-surface font-label-caps text-label-caps hover:scale-[0.98] transition-transform duration-250 ease-tactile shadow-ambient-lvl1">
                        ADD TO CART
                    </button>
}
else
{
<button type="button" disabled class="w-full py-4 rounded-full bg-surface-variant text-on-surface-variant font-label-caps text-label-caps opacity-70 cursor-not-allowed">
                        SOLD OUT
                    </button>
}
</div>
</form>

<!-- Accordions -->
<div class="flex flex-col gap-2 mt-auto">
<details class="group bg-surface-container-low rounded-xl overflow-hidden" open>
<summary class="flex justify-between items-center p-4 cursor-pointer select-none">
<span class="font-label-caps text-label-caps text-on-surface">PRODUCT DETAILS</span>
<span class="material-symbols-outlined text-on-surface-variant group-open:rotate-180 transition-transform duration-250 ease-tactile">keyboard_arrow_down</span>
</summary>
<div class="px-4 pb-4 font-body-md text-body-md text-on-surface-variant pt-2">
<p>@Model.Product.Description</p>
</div>
</details>
<details class="group bg-surface-container-low rounded-xl overflow-hidden">
<summary class="flex justify-between items-center p-4 cursor-pointer select-none">
<span class="font-label-caps text-label-caps text-on-surface">DELIVERY &amp; RETURNS</span>
<span class="material-symbols-outlined text-on-surface-variant group-open:rotate-180 transition-transform duration-250 ease-tactile">keyboard_arrow_down</span>
</summary>
<div class="px-4 pb-4 font-body-md text-body-md text-on-surface-variant pt-2">
<p>Standard delivery within 3-5 business days. Express delivery available at checkout. Returns accepted within 14 days of purchase in original condition.</p>
</div>
</details>
</div>
</div>
</div>

<!-- You May Also Like Section -->
@if (Model.RelatedProducts.Any())
{
<section class="mt-section-gap">
<div class="text-center mb-stack-lg">
<h2 class="font-headline-md text-headline-md text-on-surface">You May Also Like</h2>
</div>
<div class="grid grid-cols-2 md:grid-cols-4 gap-gutter">
    @foreach (var related in Model.RelatedProducts)
    {
        var relUrl = Url.Action("Details", "Products", new { id = related.Id });
        var relImg = related.Images.OrderByDescending(i => i.IsMain).FirstOrDefault()?.ImageUrl ?? Url.Content("~/images/product-placeholder.svg");
        var relPrice = related.Variants.Any(v => v.IsActive && v.Stock > 0)
            ? related.Variants.Where(v => v.IsActive && v.Stock > 0).Min(v => v.Price)
            : related.BasePrice;

<a class="group block" href="@relUrl">
<div class="aspect-[3/4] rounded-xl overflow-hidden bg-surface-container-low mb-4 shadow-ambient-lvl1">
<img alt="@related.Name" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-tactile" src="@relImg"/>
</div>
<div class="text-center">
<h3 class="font-body-lg text-body-lg font-medium text-on-surface mb-1 group-hover:text-primary transition-colors">@related.Name</h3>
<p class="font-body-md text-body-md text-primary-container">@relPrice.ToString("C")</p>
</div>
</a>
    }
</div>
</section>
}
</main>

@section Scripts {
<script>
    // Micro-interaction for thumbnail clicks to update main image
    document.querySelectorAll('.thumbnail-btn').forEach(button => {
        button.addEventListener('click', function() {
            // Remove active state from all
            document.querySelectorAll('.thumbnail-btn').forEach(btn => {
                btn.classList.remove('border-primary-container');
                btn.classList.add('border-transparent', 'opacity-70');
            });
            // Add active state to clicked
            this.classList.remove('border-transparent', 'opacity-70');
            this.classList.add('border-primary-container');
            
            const newSrc = this.querySelector('img').src;
            document.querySelector('#main-product-image').src = newSrc;
        });
    });
</script>
}