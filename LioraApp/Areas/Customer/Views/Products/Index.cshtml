@model LioraApp.ViewModels.Customer.ProductController.ProductIndexCustomerVM
@{
    Layout = "_CustomerLayout";
    ViewData["Title"] = "Shop All";
}

<main class="max-w-7xl mx-auto px-container-padding-mobile md:px-container-padding-desktop py-stack-lg md:py-section-gap flex flex-col md:flex-row gap-gutter">
<!-- Filter Sidebar -->
<aside class="w-full md:w-[240px] flex-shrink-0 mb-stack-lg md:mb-0">
<form method="get" asp-action="Index" id="filter-form">
<div class="bg-surface-variant/40 rounded-[16px] p-6 shadow-ambient-1 sticky top-28 border border-outline-variant/20">
<div class="flex items-center justify-between mb-8 pb-4 border-b border-outline-variant/30">
<h2 class="font-headline-md text-headline-md text-on-surface">Filters</h2>
<a href="@Url.Action("Index")" class="font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors">CLEAR</a>
</div>
<!-- Category -->
<div class="mb-8">
<h3 class="font-label-caps text-label-caps text-on-surface mb-4">CATEGORY</h3>
<div class="space-y-3">
<label class="flex items-center space-x-3 cursor-pointer group">
<input type="radio" name="categoryId" value="" onchange="this.form.submit()" @(Model.SelectedCategoryId == null ? "checked" : "") class="form-radio h-4 w-4 text-primary border-outline-variant focus:ring-primary-container bg-surface transition-all duration-200"/>
<span class="font-body-md text-body-md text-on-surface-variant group-hover:text-primary transition-colors">All Clothing</span>
</label>
@foreach (var cat in Model.Categories)
{
<label class="flex items-center space-x-3 cursor-pointer group">
<input type="radio" name="categoryId" value="@cat.Value" onchange="this.form.submit()" @(Model.SelectedCategoryId?.ToString() == cat.Value ? "checked" : "") class="form-radio h-4 w-4 text-primary border-outline-variant focus:ring-primary-container bg-surface transition-all duration-200"/>
<span class="font-body-md text-body-md text-on-surface-variant group-hover:text-primary transition-colors">@cat.Text</span>
</label>
}
</div>
</div>
<!-- Sorting Dropdown for Mobile/Desktop Sync -->
<input type="hidden" name="sort" value="@Model.Sort" id="sort-hidden" />
<input type="hidden" name="search" value="@Model.SearchQuery" />
</div>
</form>
</aside>
<!-- Product Grid Area -->
<section class="flex-1 w-full flex flex-col">
<!-- Grid Header -->
<header class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-stack-lg gap-4">
<div>
<h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface">Shop All</h1>
<p class="font-body-md text-body-md text-on-surface-variant mt-2">Showing @(Model.Products.Count()) results @(string.IsNullOrEmpty(Model.SearchQuery) ? "" : $"for '{Model.SearchQuery}'")</p>
</div>
<div class="flex items-center gap-2 bg-surface-container-low rounded-full px-4 py-2 border border-outline-variant/40 shadow-sm hover:border-primary/40 transition-all">
<span class="material-symbols-outlined text-[18px] text-on-surface-variant">sort</span>
<span class="font-label-caps text-label-caps text-on-surface-variant text-[11px]">SORT:</span>
<select id="sort-select" aria-label="Sort products" class="bg-transparent border-none font-body-md text-body-md text-on-surface font-semibold focus:ring-0 cursor-pointer py-0 pr-6 pl-0" onchange="document.getElementById('sort-hidden').value = this.value; document.getElementById('filter-form').submit();">
<option value="newest">New Arrivals</option>
<option value="price_asc">Price: Low to High</option>
<option value="price_desc">Price: High to Low</option>
</select>
<script>document.getElementById('sort-select').value = '@(Model.Sort ?? "newest")';</script>
</div>
</header>
<!-- Grid -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-gutter gap-y-stack-lg mb-section-gap">
@foreach (var product in Model.Products)
{
    var productUrl = Url.Action("Details", "Products", new { id = product.Id });
    var displayPrice = product.MinVariantPrice > 0 ? product.MinVariantPrice : product.BasePrice;
    var imgSrc = product.MainImageUrl ?? Url.Content("~/images/product-placeholder.svg");

<!-- Product Card -->
<article class="group relative rounded-[16px] bg-surface-container-lowest shadow-ambient-1 hover:shadow-ambient-2 transition-all duration-300 ease-out hover:-translate-y-1 flex flex-col overflow-hidden">
<a href="@productUrl" class="block h-full flex flex-col">
<div class="relative w-full aspect-[3/4] overflow-hidden bg-surface-dim">
<img alt="@product.Name" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" src="@imgSrc"/>
@if (!product.HasStock)
{
<span class="absolute top-4 left-4 bg-error text-on-error px-3 py-1 font-label-caps text-label-caps rounded-full z-10 tracking-widest shadow-sm">SOLD OUT</span>
}
<!-- Hover Button -->
<div class="absolute bottom-6 left-0 right-0 px-6 opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300 ease-out z-20 flex justify-center">
<button class="w-full max-w-[200px] bg-primary-container text-on-primary-container px-6 py-3 rounded-full font-label-caps text-label-caps shadow-lg hover:scale-[0.98] transition-transform">
                                View Details
                            </button>
</div>
</div>
<div class="p-6 flex flex-col items-start bg-surface-container-lowest relative z-10 transition-colors group-hover:bg-surface/50 flex-grow">
<h3 class="font-body-lg text-body-lg text-on-surface mb-1 truncate w-full">@product.Name</h3>
<p class="font-body-md text-body-md text-primary-container font-medium">@displayPrice?.ToString("C")</p>
</div>
</a>
</article>
}
</div>
<!-- Pagination -->
@if (Model.TotalPages > 1)
{
<nav aria-label="Pagination" class="flex justify-center items-center space-x-2 mt-auto">
    @if (Model.CurrentPage > 1)
    {
<a href="@Url.Action("Index", new { page = Model.CurrentPage - 1, sort = Model.Sort, search = Model.SearchQuery, categoryId = Model.SelectedCategoryId })" aria-label="Previous page" class="w-10 h-10 rounded-full flex items-center justify-center text-on-surface-variant hover:bg-surface-variant hover:text-primary transition-colors">
<span class="material-symbols-outlined text-[20px]" data-icon="chevron_left">chevron_left</span>
</a>
    }

    @for (int i = 1; i <= Model.TotalPages; i++)
    {
        if (i == Model.CurrentPage)
        {
<button aria-current="page" class="w-10 h-10 rounded-full flex items-center justify-center font-label-caps text-label-caps bg-primary-container text-on-primary-container shadow-ambient-1 transition-transform hover:scale-105">@i</button>
        }
        else
        {
<a href="@Url.Action("Index", new { page = i, sort = Model.Sort, search = Model.SearchQuery, categoryId = Model.SelectedCategoryId })" class="w-10 h-10 rounded-full flex items-center justify-center font-label-caps text-label-caps text-on-surface-variant hover:bg-surface-variant hover:text-primary transition-colors">@i</a>
        }
    }

    @if (Model.CurrentPage < Model.TotalPages)
    {
<a href="@Url.Action("Index", new { page = Model.CurrentPage + 1, sort = Model.Sort, search = Model.SearchQuery, categoryId = Model.SelectedCategoryId })" aria-label="Next page" class="w-10 h-10 rounded-full flex items-center justify-center text-on-surface-variant hover:bg-surface-variant hover:text-primary transition-colors">
<span class="material-symbols-outlined text-[20px]" data-icon="chevron_right">chevron_right</span>
</a>
    }
</nav>
}
</section>
</main>